<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= plant.name %> - MY NURSERY
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
</head>

<body>
    <%- include('partials/header') %>

        <section class="py-5 bg-surface">
            <div class="container">
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/" class="text-success text-decoration-none">Home</a></li>
                        <li class="breadcrumb-item"><a href="/gallery"
                                class="text-success text-decoration-none">Gallery</a></li>
                        <li class="breadcrumb-item active" aria-current="page">
                            <%= plant.name %>
                        </li>
                    </ol>
                </nav>

                <div class="row g-5">
                    <div class="col-lg-6">
                        <div class="card border-0 shadow-sm rounded-4 overflow-hidden product-image-container">
                            <% if (plant.images && plant.images.length> 0) { %>
                                <img src="<%= plant.images[0].url %>" class="img-fluid w-100" alt="<%= plant.name %>"
                                    id="mainImage" style="object-fit: cover;">
                                <div class="p-3 bg-background-alt d-flex gap-2 overflow-auto thumbnails-scroll">
                                    <% plant.images.forEach((img, index)=> { %>
                                        <img src="<%= img.url %>" class="rounded cursor-pointer border shadow-sm flex-shrink-0"
                                            style="width: 70px; height: 70px; object-fit: cover;"
                                            onclick="document.getElementById('mainImage').src='<%= img.url %>'">
                                        <% }); %>
                                </div>
                                <% } else { %>
                                    <img src="https://placehold.co/600x600/e9ecef/6c757d?text=No+Image"
                                        class="img-fluid" alt="<%= plant.name %>">
                                    <% } %>
                        </div>
                    </div>
                    <div class="col-lg-6">
                        <div class="ps-lg-4 mt-4 mt-lg-0">
                            <span
                                class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 mb-3 fw-bold">
                                <i class="fas fa-tag me-1"></i>
                                <%= plant.category %>
                            </span>
                            <h1 class="display-4 fw-bold text-main mb-3">
                                <%= plant.name %>
                            </h1>

                            <!-- Rating Display -->
                            <div class="mb-3">
                                <% if (totalReviews> 0) { %>
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="d-flex align-items-center me-3">
                                            <span class="fs-3 fw-bold text-main me-2">
                                                <%= avgRating %>
                                            </span>
                                            <div>
                                                <div class="text-warning">
                                                    <% for(let i=1; i <=5; i++) { %>
                                                        <i
                                                            class="fas fa-star<%= i <= Math.round(avgRating) ? '' : '-o' %>"></i>
                                                        <% } %>
                                                </div>
                                                <small class="text-muted">(<%= totalReviews %>
                                                        <%= totalReviews===1 ? 'review' : 'reviews' %>)</small>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Rating Distribution -->
                                    <div class="small">
                                        <% [5, 4, 3, 2, 1].forEach(rating=> {
                                            const count = ratingDistribution[rating] || 0;
                                            const percentage = totalReviews > 0 ? (count / totalReviews * 100) : 0;
                                            %>
                                            <div class="d-flex align-items-center mb-1">
                                                <span class="text-muted" style="width: 30px;">
                                                    <%= rating %>★
                                                </span>
                                                <div class="progress flex-grow-1 me-2" style="height: 8px;">
                                                    <div class="progress-bar bg-warning" role="progressbar"
                                                        style="width: <%= percentage + '%' %>"></div>
                                                </div>
                                                <span class="text-muted small" style="width: 40px;">
                                                    <%= count %>
                                                </span>
                                            </div>
                                            <% }) %>
                                    </div>
                                    <% } else { %>
                                        <div class="text-muted">
                                            <i class="far fa-star"></i> No reviews yet. Be the first to review!
                                        </div>
                                        <% } %>
                            </div>

                            <!-- Price and Stock removed for Gallery Mode -->

                            <p class="text-muted fs-5 mb-5 leading-relaxed">
                                <%= plant.description %>
                            </p>

                            <!-- Order Section -->
                            <div class="card border-0 shadow-sm rounded-4 mb-5" style="background: var(--background-alt); border: 1px solid var(--border) !important;">
                                <div class="card-body p-4">
                                    <h5 class="fw-bold text-main mb-3"><i class="fas fa-shopping-basket me-2 text-success"></i>Place an Order</h5>
                                    <form id="directOrderForm" action="/orders/create-direct" method="POST">
                                        <input type="hidden" name="plantId" value="<%= plant._id %>">
                                        <input type="hidden" name="plantName" value="<%= plant.name %>">
                                        <input type="hidden" name="plantPrice" value="<%= plant.price || 0 %>">
                                        <input type="hidden" name="plantImage" value="<%= plant.images && plant.images[0] ? plant.images[0].url : '' %>">
                                        
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold text-muted">PACKET SIZE</label>
                                                <select name="size" class="form-select border-0 shadow-sm" required>
                                                    <option value="small">Small Packet</option>
                                                    <option value="medium" selected>Medium Packet</option>
                                                    <option value="large">Large Packet</option>
                                                    <option value="extra-large">Extra Large</option>
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label small fw-bold text-muted">QUANTITY</label>
                                                <input type="number" name="quantity" class="form-control border-0 shadow-sm" value="1" min="1" required>
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label small fw-bold text-muted">SHIPPING ADDRESS</label>
                                                <textarea name="address" class="form-control border-0 shadow-sm" rows="2" placeholder="Enter your full address" required></textarea>
                                            </div>
                                            <div class="col-12 mt-4">
                                                <% if (user) { %>
                                                    <button type="submit" class="btn btn-success btn-lg w-100 rounded-pill shadow-sm fw-bold py-3">
                                                        <i class="fas fa-check-circle me-2"></i>Confirm Order
                                                    </button>
                                                <% } else { %>
                                                    <a href="/login?redirect=/plant/<%= plant.slug || plant._id %>" class="btn btn-outline-success btn-lg w-100 rounded-pill fw-bold py-3">
                                                        <i class="fas fa-sign-in-alt me-2"></i>Login to Order
                                                    </a>
                                                <% } %>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>

                            <div class="row g-4 pt-4 border-top">
                                            <div class="col-6">
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3">
                                                        <i class="fas fa-truck text-success"></i>
                                                    </div>
                                                    <div>
                                                        <h6 class="mb-0 fw-bold">Daily Delivery</h6>
                                                        <small class="text-muted">Safe & fast shipping</small>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-6">
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3">
                                                        <i class="fas fa-shield-alt text-success"></i>
                                                    </div>
                                                    <div>
                                                        <h6 class="mb-0 fw-bold">Health Guarantee</h6>
                                                        <small class="text-muted">30 days plant support</small>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Reviews Section -->
        <section class="py-5 bg-background">
            <div class="container">
                <div class="row">
                    <div class="col-lg-8 mx-auto">
                        <h2 class="fw-bold text-success mb-4">
                            <i class="fas fa-star me-2"></i>Customer Reviews
                            <% if (totalReviews> 0) { %>
                                <span class="badge bg-success ms-2">
                                    <%= totalReviews %>
                                </span>
                                <% } %>
                        </h2>

                        <!-- Write Review Form (if user is logged in and hasn't reviewed) -->
                        <% if (user && !hasUserReviewed) { %>
                            <div class="card border-0 shadow-sm mb-5 bg-surface">
                                <div class="card-header bg-transparent border-bottom py-3">
                                    <h5 class="mb-0 text-main"><i class="fas fa-edit me-2"></i>Write a Review</h5>
                                </div>
                                <div class="card-body p-4">
                                    <form id="reviewForm">
                                        <input type="hidden" name="plantId" value="<%= plant._id %>">

                                        <div class="mb-3">
                                            <label class="form-label fw-bold text-main">Your Rating</label>
                                            <div class="rating-input mb-2">
                                                <% for(let i=1; i <=5; i++) { %>
                                                    <i class="far fa-star rating-star" data-rating="<%= i %>"
                                                        style="font-size: 2rem; color: #ffc107; cursor: pointer; margin-right: 5px;"></i>
                                                    <% } %>
                                            </div>
                                            <input type="hidden" name="rating" id="ratingValue" required>
                                            <small class="text-muted" id="ratingText">Click stars to rate</small>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-bold text-main">Review Title</label>
                                            <input type="text" class="form-control bg-background-alt border-border text-main" name="title"
                                                placeholder="Summarize your experience" maxlength="100" required>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label fw-bold text-main">Your Review</label>
                                            <textarea class="form-control bg-background-alt border-border text-main" name="comment" rows="5"
                                                placeholder="Share your experience with this plant..." maxlength="500"
                                                required></textarea>
                                            <small class="text-muted">Maximum 500 characters</small>
                                        </div>

                                        <div class="d-flex justify-content-end gap-2">
                                            <button type="button" class="btn btn-outline-secondary"
                                                onclick="document.getElementById('reviewForm').reset(); document.querySelectorAll('.rating-star').forEach(s => s.classList.replace('fas', 'far')); document.getElementById('ratingValue').value = '';">
                                                Cancel
                                            </button>
                                            <button type="submit" class="btn btn-success">
                                                <i class="fas fa-paper-plane me-2"></i>Submit Review
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                            <% } else if (user && hasUserReviewed) { %>
                                <div class="alert alert-info mb-4">
                                    <i class="fas fa-info-circle me-2"></i>You have already reviewed this product.
                                    <% if (userReview) { %>
                                        <a href="#review-<%= userReview._id %>" class="alert-link">View your review</a>
                                        <% } %>
                                </div>
                                <% } else { %>
                                    <div class="alert alert-warning mb-4">
                                        <i class="fas fa-sign-in-alt me-2"></i>
                                        <a href="/login?redirect=/plant/<%= plant.slug %>" class="alert-link">Login</a>
                                        to write a review
                                    </div>
                                    <% } %>

                                        <!-- Reviews List -->
                                        <div id="reviewsList">
                                            <% if (reviews && reviews.length> 0) { %>
                                                <% reviews.forEach((review, index)=> { %>
                                                    <div class="card border-0 shadow-sm mb-3 bg-surface"
                                                        id="review-<%= review._id %>">
                                                        <div class="card-body p-4">
                                                            <div
                                                                class="d-flex justify-content-between align-items-start mb-3">
                                                                <div>
                                                                    <h6 class="mb-1 fw-bold text-main">
                                                                        <%= review.user.firstName %>
                                                                            <%= review.user.lastName %>
                                                                                <% if (review.isVerified || hasOrdered)
                                                                                    { %>
                                                                                    <span
                                                                                        class="badge bg-success bg-opacity-10 text-success ms-2">
                                                                                        <i
                                                                                            class="fas fa-check-circle"></i>
                                                                                        Verified Purchase
                                                                                    </span>
                                                                                    <% } %>
                                                                    </h6>
                                                                    <div class="text-warning mb-2">
                                                                        <% for(let i=1; i <=5; i++) { %>
                                                                            <i
                                                                                class="fas fa-star<%= i <= review.rating ? '' : '-o' %>"></i>
                                                                            <% } %>
                                                                    </div>
                                                                    <small class="text-muted">
                                                                        <i class="far fa-calendar me-1"></i>
                                                                        <%= new
                                                                            Date(review.createdAt).toLocaleDateString('en-IN',
                                                                            { year: 'numeric' , month: 'long' ,
                                                                            day: 'numeric' }) %>
                                                                    </small>
                                                                </div>
                                                                <% if (user &&
                                                                    user._id.toString()===review.user._id.toString()) {
                                                                    %>
                                                                    <span class="badge bg-primary">Your Review</span>
                                                                    <% } %>
                                                            </div>

                                                            <h6 class="fw-bold mb-2 text-main">
                                                                <%= review.title %>
                                                            </h6>
                                                            <p class="text-muted mb-3">
                                                                <%= review.comment %>
                                                            </p>

                                                            <% if (review.images && review.images.length> 0) { %>
                                                                <div class="d-flex gap-2 mb-3">
                                                                    <% review.images.forEach(img=> { %>
                                                                        <img src="<%= img.url %>"
                                                                            alt="<%= img.alt || 'Review image' %>"
                                                                            class="rounded"
                                                                            style="width: 80px; height: 80px; object-fit: cover; cursor: pointer;"
                                                                            onclick="window.open('<%= img.url %>', '_blank')">
                                                                        <% }) %>
                                                                </div>
                                                                <% } %>

                                                                    <div class="d-flex align-items-center">
                                                                        <button
                                                                            class="btn btn-sm btn-outline-secondary me-2"
                                                                            onclick="markHelpful('<%= review._id %>')">
                                                                            <i class="fas fa-thumbs-up me-1"></i>Helpful
                                                                            (<span id="helpful-<%= review._id %>">
                                                                                <%= review.helpful.count || 0 %>
                                                                            </span>)
                                                                        </button>
                                                                    </div>
                                                        </div>
                                                    </div>
                                                    <% }) %>
                                                        <% } else { %>
                                                            <div class="card border-0 shadow-sm">
                                                                <div class="card-body text-center py-5">
                                                                    <i
                                                                        class="fas fa-comments fa-3x text-muted mb-3 opacity-50"></i>
                                                                    <h5 class="text-muted">No reviews yet</h5>
                                                                    <p class="text-muted">Be the first to review this
                                                                        product!</p>
                                                                </div>
                                                            </div>
                                                            <% } %>
                                        </div>
                    </div>
                </div>
            </div>
        </section>

        <%- include('partials/footer') %>

                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
                <script src="/js/utils.js"></script>
                <script>
                    function updateQty(change) {
                        const input = document.getElementById('quantityInput');
                        if (!input) return;
                        let value = parseInt(input.value) + change;
                        const maxStock = parseInt('<%= plant.stock %>') || 100;
                        if (value < 1) value = 1;
                        if (value > maxStock) value = maxStock;
                        input.value = value;
                    }

                    // Mark Review as Helpful
                    async function markHelpful(reviewId) {
                        try {
                            const response = await fetch(`/reviews/${reviewId}/helpful`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' }
                            });

                            const result = await response.json();

                            if (result.success) {
                                const countElement = document.getElementById(`helpful-${reviewId}`);
                                if (countElement) {
                                    countElement.textContent = result.count;
                                }
                            } else if (result.message) {
                                alert(result.message);
                            }
                        } catch (error) {
                            console.error(error);
                        }
                    }
                </script>

                <% if (user && !hasUserReviewed) { %>
                    <script>
                        // Rating Stars Interaction
                        document.querySelectorAll('.rating-star').forEach(star => {
                            star.addEventListener('click', function () {
                                const rating = parseInt(this.getAttribute('data-rating'));
                                document.getElementById('ratingValue').value = rating;

                                // Update stars display
                                document.querySelectorAll('.rating-star').forEach((s, index) => {
                                    if (index < rating) {
                                        s.classList.replace('far', 'fas');
                                    } else {
                                        s.classList.replace('fas', 'far');
                                    }
                                });

                                // Update rating text
                                const texts = ['', 'Poor', 'Fair', 'Good', 'Very Good', 'Excellent'];
                                document.getElementById('ratingText').textContent = texts[rating] || 'Click stars to rate';
                            });

                            star.addEventListener('mouseenter', function () {
                                const rating = parseInt(this.getAttribute('data-rating'));
                                document.querySelectorAll('.rating-star').forEach((s, index) => {
                                    if (index < rating) {
                                        s.classList.replace('far', 'fas');
                                    }
                                });
                            });
                        });

                        document.querySelector('.rating-input').addEventListener('mouseleave', function () {
                            const currentRating = parseInt(document.getElementById('ratingValue').value) || 0;
                            document.querySelectorAll('.rating-star').forEach((s, index) => {
                                if (index < currentRating) {
                                    s.classList.replace('far', 'fas');
                                } else {
                                    s.classList.replace('fas', 'far');
                                }
                            });
                        });

                        // Review Form Submission
                        document.getElementById('reviewForm').addEventListener('submit', async function (e) {
                            e.preventDefault();

                            const formData = new FormData(this);
                            const data = {
                                plantId: formData.get('plantId'),
                                rating: parseInt(formData.get('rating')),
                                title: formData.get('title'),
                                comment: formData.get('comment')
                            };

                            if (!data.rating) {
                                alert('Please select a rating');
                                return;
                            }

                            try {
                                const response = await fetch('/reviews/submit', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify(data)
                                });

                                const result = await response.json();

                                if (result.success) {
                                    alert('Thank you for your review! It will be displayed after approval.');
                                    window.location.reload();
                                } else {
                                    alert(result.message || 'Error submitting review');
                                }
                            } catch (error) {
                                console.error(error);
                                alert('Error submitting review. Please try again.');
                            }
                        });
                    </script>
                <% } %>
</body>

</html>