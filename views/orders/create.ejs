<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .order-card {
            background: #ffffff;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            border: 1px solid #eee;
        }
        .table-items thead th {
            background-color: #f8fafc;
            color: #64748b;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            padding: 1rem;
        }
        .btn-add-row {
            color: #10b981;
            border-color: #10b981;
        }
        .btn-add-row:hover {
            background-color: #10b981;
            color: white;
        }
        #posResults {
            z-index: 1050;
            max-height: 250px;
            overflow-y: auto;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            border-radius: 0 0 10px 10px;
        }
        .search-item:hover {
            background-color: #f0fdf4;
            cursor: pointer;
        }
    </style>
</head>

<body class="bg-light">
    <%- include('../partials/header') %>

    <div class="container py-5">
        <div class="row mb-4">
            <div class="col-12 text-center">
                <h1 class="display-5 fw-bold text-success">Create New Order</h1>
                <p class="text-muted">Add items from our gallery or specify custom plants you need.</p>
            </div>
        </div>

        <!-- Flash Messages -->
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <% if (typeof messages !== 'undefined' && messages.error_msg) { %>
                    <div class="alert alert-danger alert-dismissible fade show rounded-4 shadow-sm mb-4">
                        <i class="fas fa-exclamation-circle me-2"></i><%= messages.error_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                <% if (typeof messages !== 'undefined' && messages.success_msg) { %>
                    <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm mb-4">
                        <i class="fas fa-check-circle me-2"></i><%= messages.success_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-10">
                <form action="/orders/create" method="POST" id="orderForm">
                    <!-- Customer & Shipping Info -->
                    <div class="card order-card mb-4">
                        <div class="card-header bg-white py-3">
                            <h5 class="mb-0 text-success"><i class="fas fa-truck me-2"></i>Shipping Information</h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Full Name</label>
                                    <input type="text" name="shippingAddress[fullName]" class="form-control" 
                                        value="<%= user.firstName %> <%= user.lastName %>" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Phone Number</label>
                                    <input type="tel" name="shippingAddress[phone]" class="form-control" 
                                        value="<%= user.phone || '' %>" required>
                                </div>
                                <div class="col-12 mb-3">
                                    <label class="form-label fw-bold">Delivery Address</label>
                                    <textarea name="shippingAddress[address]" class="form-control" rows="2" required><%= user.address || '' %></textarea>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">City</label>
                                    <input type="text" name="shippingAddress[city]" class="form-control" value="N/A" required>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">State</label>
                                    <input type="text" name="shippingAddress[state]" class="form-control" value="N/A" required>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Zip Code</label>
                                    <input type="text" name="shippingAddress[zipCode]" class="form-control" value="N/A" required>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Order Items -->
                    <div class="card order-card mb-4">
                        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                            <h5 class="mb-0 text-success"><i class="fas fa-leaf me-2"></i>Order Items</h5>
                            <button type="button" class="btn btn-outline-success btn-sm" id="addRowBtn">
                                <i class="fas fa-plus me-1"></i> Add Row
                            </button>
                        </div>
                        <div class="card-body p-0">
                            <!-- Search Bar -->
                            <div class="p-3 border-bottom bg-light">
                                <div class="position-relative">
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0">
                                            <i class="fas fa-search text-muted"></i>
                                        </span>
                                        <input id="plantSearch" type="text" class="form-control border-start-0" 
                                            placeholder="Search plants from gallery or type custom name..." autocomplete="off">
                                    </div>
                                    <ul id="posResults" class="list-group position-absolute w-100 bg-white shadow-lg" style="display: none;">
                                    </ul>
                                </div>
                            </div>

                            <div class="table-responsive">
                                <table class="table table-hover mb-0" id="itemsTable">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 5%">#</th>
                                            <th style="width: 50%">Plant Name</th>
                                            <th style="width: 25%">Size/Packet</th>
                                            <th style="width: 15%" class="text-center">Quantity</th>
                                            <th style="width: 5%"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="itemsBody">
                                        <!-- Rows will be added here -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Additional Notes</label>
                        <textarea name="notes" class="form-control" rows="3" placeholder="Any special instructions for your order?"></textarea>
                    </div>

                    <input type="hidden" name="items" id="itemsJson">

                    <div class="text-center mb-5">
                        <button type="submit" class="btn btn-success btn-lg px-5 py-3 rounded-pill shadow">
                            <i class="fas fa-paper-plane me-2"></i> Place Order
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <!-- Size & Quantity Modal -->
    <div class="modal fade" id="itemConfigModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header bg-success text-white rounded-top-4 py-3">
                    <h5 class="modal-title fw-bold" id="modalPlantName">Configure Item</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" id="modalPlantId">
                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark">Select Size</label>
                        <select id="modalSize" class="form-select form-select-lg border-2">
                            <option value="" disabled selected>-- Select Size --</option>
                            <option value="5/6 (Small Pot)">5/6 (Small Pot)</option>
                            <option value="6/7 (Standard)">6/7 (Standard)</option>
                            <option value="8/10 (Medium)">8/10 (Medium)</option>
                            <option value="9/10">9/10</option>
                            <option value="12/12 (Large)">12/12 (Large)</option>
                            <option value="13/13">13/13</option>
                            <option value="14/15">14/15</option>
                            <option value="15/16 (XL)">15/16 (XL)</option>
                            <option value="18/18">18/18</option>
                            <option value="21/21">21/21</option>
                            <option value="25/25">25/25</option>
                            <option value="30/30 (XXL)">30/30 (XXL)</option>
                            <option value="40/50 (Jumbo)">40/50 (Jumbo)</option>
                            <option value="Packet of Seeds (10g)">Packet of Seeds (10g)</option>
                            <option value="Packet of Seeds (50g)">Packet of Seeds (50g)</option>
                            <option value="Packet of Seeds (100g)">Packet of Seeds (100g)</option>
                            <option value="Single Plant (Graft)">Single Plant (Graft)</option>
                            <option value="Single Plant (Seedling)">Single Plant (Seedling)</option>
                            <option value="Bundle (10 Plants)">Bundle (10 Plants)</option>
                            <option value="Wholesale (100+ Plants)">Wholesale (100+ Plants)</option>
                            <option value="Other (Custom)">Other (Custom)</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-bold text-dark">Quantity Required</label>
                        <div class="input-group input-group-lg">
                            <button class="btn btn-outline-secondary border-2" type="button" onclick="adjustQty(-1)">
                                <i class="fas fa-minus"></i>
                            </button>
                            <input type="number" id="modalQty" class="form-control text-center border-2 fw-bold" value="1" min="1">
                            <button class="btn btn-outline-secondary border-2" type="button" onclick="adjustQty(1)">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light btn-lg px-4 rounded-pill fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success btn-lg px-5 rounded-pill fw-bold shadow" onclick="confirmAddItem()">
                        Add to List
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const itemsBody = document.getElementById('itemsBody');
        const addRowBtn = document.getElementById('addRowBtn');
        const plantSearch = document.getElementById('plantSearch');
        const posResults = document.getElementById('posResults');
        const orderForm = document.getElementById('orderForm');
        const itemsJson = document.getElementById('itemsJson');
        
        // Modal elements
        const itemConfigModal = new bootstrap.Modal(document.getElementById('itemConfigModal'));
        const modalPlantName = document.getElementById('modalPlantName');
        const modalPlantId = document.getElementById('modalPlantId');
        const modalSize = document.getElementById('modalSize');
        const modalQty = document.getElementById('modalQty');

        let rowCount = 0;

        function addRow(data = {}) {
            rowCount++;
            const row = document.createElement('tr');
            row.innerHTML = `
                <td class="align-middle text-muted small">${rowCount}</td>
                <td>
                    <input type="hidden" class="item-plant-id" value="${data.id || ''}">
                    <input type="text" class="form-control item-name" value="${data.name || ''}" placeholder="Plant Name" required>
                </td>
                <td>
                    <input type="text" class="form-control item-packet" value="${data.packet || ''}" placeholder="Select size..." readonly onclick="openModalForExistingRow(this)">
                </td>
                <td>
                    <input type="number" class="form-control text-center item-qty" value="${data.qty || 1}" min="1" required>
                </td>
                <td class="text-center">
                    <button type="button" class="btn btn-link text-danger p-0" onclick="removeRow(this)">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            `;
            itemsBody.appendChild(row);
            return row;
        }

        function removeRow(btn) {
            btn.closest('tr').remove();
            updateRowNumbers();
        }

        function updateRowNumbers() {
            const rows = itemsBody.querySelectorAll('tr');
            rowCount = 0;
            rows.forEach((row, index) => {
                rowCount++;
                row.cells[0].textContent = rowCount;
            });
        }

        // Search functionality
        let searchTimeout;
        plantSearch.addEventListener('input', (e) => {
            const query = e.target.value.trim();
            clearTimeout(searchTimeout);
            
            if (query.length < 2) {
                posResults.style.display = 'none';
                return;
            }

            searchTimeout = setTimeout(async () => {
                try {
                    const res = await fetch(`/api/billing/catalog/search?q=${encodeURIComponent(query)}`);
                    const data = await res.json();
                    
                    if (data.success && data.results.length > 0) {
                        posResults.innerHTML = '';
                        data.results.forEach(plant => {
                            const li = document.createElement('li');
                            li.className = 'list-group-item search-item d-flex justify-content-between align-items-center';
                            li.innerHTML = `
                                <div>
                                    <div class="fw-bold">${plant.name}</div>
                                    <small class="text-muted">${plant.category || 'General'}</small>
                                </div>
                                <span class="badge bg-success rounded-pill">₹${plant.price}</span>
                            `;
                            li.onclick = () => {
                                showConfigModal(plant.name, plant._id);
                                plantSearch.value = '';
                                posResults.style.display = 'none';
                            };
                            posResults.appendChild(li);
                        });
                        posResults.style.display = 'block';
                    } else {
                        posResults.style.display = 'none';
                    }
                } catch (err) {
                    console.error('Search error:', err);
                }
            }, 300);
        });

        function showConfigModal(name, id = '') {
            modalPlantName.textContent = name;
            modalPlantId.value = id;
            modalSize.value = "";
            modalQty.value = 1;
            delete document.getElementById('itemConfigModal').dataset.editingRow;
            itemConfigModal.show();
        }

        function adjustQty(amount) {
            let current = parseInt(modalQty.value) || 1;
            modalQty.value = Math.max(1, current + amount);
        }

        function openModalForExistingRow(input) {
            const row = input.closest('tr');
            const name = row.querySelector('.item-name').value;
            const id = row.querySelector('.item-plant-id').value;
            const packet = row.querySelector('.item-packet').value;
            const qty = row.querySelector('.item-qty').value;

            modalPlantName.textContent = name;
            modalPlantId.value = id;
            modalSize.value = packet;
            modalQty.value = qty;
            
            // Store the row reference to update it later
            document.getElementById('itemConfigModal').dataset.editingRow = rowCount_of_this_row(row);
            
            itemConfigModal.show();
        }

        function rowCount_of_this_row(row) {
            const rows = Array.from(itemsBody.querySelectorAll('tr'));
            return rows.indexOf(row);
        }

        function confirmAddItem() {
            const name = modalPlantName.textContent;
            const id = modalPlantId.value;
            const size = modalSize.value;
            const qty = modalQty.value;

            if (!size) {
                alert('Please select a size');
                return;
            }

            const editingRowIndex = document.getElementById('itemConfigModal').dataset.editingRow;
            if (editingRowIndex !== undefined && editingRowIndex !== "") {
                const rows = itemsBody.querySelectorAll('tr');
                const row = rows[editingRowIndex];
                if (row) {
                    row.querySelector('.item-name').value = name;
                    row.querySelector('.item-plant-id').value = id;
                    row.querySelector('.item-packet').value = size;
                    row.querySelector('.item-qty').value = qty;
                    delete document.getElementById('itemConfigModal').dataset.editingRow;
                    itemConfigModal.hide();
                    return;
                }
            }

            addRow({
                id: id,
                name: name,
                packet: size,
                qty: qty
            });

            itemConfigModal.hide();
        }

        // Add Row button now triggers modal for custom item if search is empty
        addRowBtn.addEventListener('click', () => {
            const customName = prompt("Enter Custom Plant Name:");
            if (customName) {
                showConfigModal(customName);
            }
        });

        // Add custom item on Enter in search bar
        plantSearch.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                const name = plantSearch.value.trim();
                if (name) {
                    showConfigModal(name);
                    plantSearch.value = '';
                    posResults.style.display = 'none';
                }
            }
        });

        // Close search results on click outside
        document.addEventListener('click', (e) => {
            if (!plantSearch.contains(e.target) && !posResults.contains(e.target)) {
                posResults.style.display = 'none';
            }
        });

        // Form submission
        orderForm.addEventListener('submit', (e) => {
            const items = [];
            const rows = itemsBody.querySelectorAll('tr');
            
            rows.forEach(row => {
                const name = row.querySelector('.item-name').value.trim();
                if (name) {
                    items.push({
                        plantId: row.querySelector('.item-plant-id').value,
                        name: name,
                        packetSize: row.querySelector('.item-packet').value.trim(),
                        quantity: row.querySelector('.item-qty').value
                    });
                }
            });

            if (items.length === 0) {
                e.preventDefault();
                alert('Please add at least one item to your order.');
                return;
            }

            itemsJson.value = JSON.stringify(items);
        });
    </script>
</body>

</html>