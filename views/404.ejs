<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Page Not Found - SRI LALITAMBA NURSERY</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .error-overlay {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('/images/background.jpg');
            background-size: cover;
            background-position: center;
        }

        .error-container {
            text-align: center;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            padding: 3rem;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            max-width: 500px;
            animation: fadeIn 0.8s ease-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .error-code {
            font-size: 8rem;
            font-weight: 900;
            color: #2e7d32;
            margin-bottom: 0;
            line-height: 1;
        }

        .plant-icon {
            font-size: 4rem;
            color: #2e7d32;
            margin-bottom: 1rem;
        }
    </style>
</head>

<body class="auth-body">
    <div class="error-overlay">
        <div class="error-container">
            <div class="plant-icon">
                <i class="fas fa-leaf"></i>
            </div>
            <h1 class="error-code">404</h1>
            <h2 class="mb-3 fw-bold">Oops! Page Lost in the Woods</h2>
            <p class="text-muted mb-4">The page you are looking for might have been pruned or moved to a different
                garden
                branch.</p>
            <div class="d-grid gap-2">
                <a href="/" class="btn btn-success btn-lg rounded-pill">
                    <i class="fas fa-home me-2"></i>Back to Home
                </a>
                <a href="/gallery" class="btn btn-outline-success btn-lg rounded-pill">
                    <i class="fas fa-search me-2"></i>Browse Gallery
                </a>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/utils.js"></script>
</body>

</html>