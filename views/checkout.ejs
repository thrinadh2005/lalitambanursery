<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
    <style>
        .checkout-header {
            background: linear-gradient(135deg, #1b5e2f 0%, #2d8a4e 100%);
            padding: 4rem 0;
            color: white;
            margin-bottom: 3rem;
            text-align: center;
        }
        .checkout-header h1 {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
        }
        .checkout-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            background: #ffffff;
            overflow: hidden;
            transition: all 0.3s;
        }
        .checkout-card-header {
            background: #f4f9f5;
            border-bottom: 2px solid #e8f5ec;
            padding: 1.5rem;
            font-weight: 700;
            color: #0d2b13;
            font-family: 'Playfair Display', serif;
            font-size: 1.25rem;
        }
        .form-control, .form-select {
            padding: 0.8rem 1rem;
            border-radius: 12px;
            border: 1px solid #cce8d6;
            background: #fdfdfd;
        }
        .form-control:focus, .form-select:focus {
            border-color: #2d8a4e;
            box-shadow: 0 0 0 4px rgba(45,138,78,0.1);
        }
        .form-label {
            font-weight: 600;
            color: #2e4033;
            font-size: 0.9rem;
            margin-bottom: 0.4rem;
        }
        .payment-option {
            border: 2px solid #e8f5ec;
            border-radius: 12px;
            padding: 1.2rem;
            margin-bottom: 1rem;
            transition: all 0.3s;
            cursor: pointer;
        }
        .payment-option:hover {
            border-color: #2d8a4e;
            background: #f4f9f5;
        }
        .payment-option input:checked + label {
            color: #0d2b13;
            font-weight: 700;
        }
        .order-item-img {
            width: 65px;
            height: 65px;
            object-fit: cover;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        }
        .btn-checkout {
            background: #2d8a4e;
            color: white;
            padding: 1rem;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1.1rem;
            transition: all 0.3s;
            border: none;
            width: 100%;
        }
        .btn-checkout:hover {
            background: #1b5e2f;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(45,138,78,0.2);
        }
        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.8rem;
            color: #2e4033;
        }
        .summary-total {
            font-size: 1.25rem;
            font-weight: 800;
            color: #0d2b13;
            border-top: 2px solid #e8f5ec;
            padding-top: 1rem;
            margin-top: 1rem;
        }
    </style>
</head>

<body>
    <%- include('partials/header') %>

    <div class="checkout-header" data-aos="fade-down">
        <div class="container">
            <h1>Secure Checkout</h1>
            <p class="text-white-50 mb-0">Complete your order details below</p>
        </div>
    </div>

    <div class="container pb-5 mb-5">
        <div class="row g-5">
            <!-- Checkout Form -->
            <div class="col-lg-8" data-aos="fade-right" data-aos-delay="100">
                <div class="checkout-card mb-4">
                    <div class="checkout-card-header d-flex align-items-center gap-2">
                        <i class="fas fa-map-marker-alt text-success"></i> Shipping Details
                    </div>
                    <div class="card-body p-4">
                        <form id="checkoutForm" action="/checkout" method="POST">
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label">Full Name</label>
                                    <input type="text" name="fullName" class="form-control" required value="<%= user.firstName %> <%= user.lastName %>" placeholder="Enter your full name">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Phone Number</label>
                                    <input type="text" name="phone" class="form-control" required placeholder="+91 xxxxx xxxxx">
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label">Address</label>
                                <textarea name="address" class="form-control" rows="3" required placeholder="House number, Street name, Landmark..."></textarea>
                            </div>
                            <div class="row g-3 mb-5">
                                <div class="col-md-4">
                                    <label class="form-label">City</label>
                                    <input type="text" name="city" class="form-control" required placeholder="City">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">State</label>
                                    <input type="text" name="state" class="form-control" required placeholder="State">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Zip Code</label>
                                    <input type="text" name="zipCode" class="form-control" required placeholder="Zip Code">
                                </div>
                            </div>

                             <h5 class="mb-3" style="font-family: 'Playfair Display', serif; font-weight: 700; color: #0d2b13;">Order Method</h5>
                            
                            <div class="payment-option d-flex align-items-center gap-3 mb-3" style="border-color: #2d8a4e; background: #f4f9f5;">
                                <input class="form-check-input mt-0 fs-5" type="radio" name="paymentMethod" value="cod" id="paymentCod" checked>
                                <label class="form-check-label w-100 d-flex justify-content-between align-items-center m-0" for="paymentCod" style="cursor: pointer;">
                                    <div>
                                        <span class="d-block fw-bold">Cash on Delivery / Pickup</span>
                                        <small class="text-muted">Pay when you receive your plants</small>
                                    </div>
                                    <i class="fas fa-money-bill-wave text-success fs-4"></i>
                                </label>
                            </div>

                            <div class="alert alert-info border-0 rounded-4 p-3 mb-4">
                                <div class="d-flex gap-3">
                                    <i class="fas fa-phone-alt fs-4 mt-1"></i>
                                    <div>
                                        <h6 class="alert-heading fw-bold mb-1">Want to pay via UPI or Bank Transfer?</h6>
                                        <p class="small mb-0">Please call us at <strong>+91 99633 72123</strong> after placing your order to get our payment details.</p>
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="btn-checkout mt-3">
                                Place Order <i class="fas fa-arrow-right ms-2"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="col-lg-4" data-aos="fade-left" data-aos-delay="200">
                <div class="checkout-card sticky-top" style="top: 100px;">
                    <div class="checkout-card-header d-flex align-items-center gap-2">
                        <i class="fas fa-shopping-bag text-success"></i> Order Summary
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-4" style="max-height: 350px; overflow-y: auto;">
                            <% cart.items.forEach(item => { %>
                                <div class="d-flex align-items-center mb-3 pb-3 border-bottom">
                                    <div class="position-relative me-3">
                                        <img src="<%= item.image || '/images/placeholder-plant.jpg' %>" alt="<%= item.name %>" class="order-item-img">
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1 text-truncate" style="max-width: 150px; font-weight: 600;"><%= item.name %></h6>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                        <div class="summary-row">
                            <span>Total Items</span>
                            <span class="font-weight-bold"><%= cart.items.length %></span>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 p-4 pt-0 text-center">
                        <a href="/cart" class="text-muted text-decoration-none hover-success transition" style="font-size: 0.9rem;">
                            <i class="fas fa-arrow-left me-1"></i> Return to Cart
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });
        
        // Add interactive highlighting to payment options
        document.querySelectorAll('.payment-option').forEach(option => {
            option.addEventListener('click', function() {
                document.querySelectorAll('.payment-option').forEach(opt => opt.style.borderColor = '#e8f5ec');
                this.style.borderColor = '#2d8a4e';
                const radio = this.querySelector('input[type="radio"]');
                radio.checked = true;
            });
        });
    </script>
</body>

</html>