<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - SRI LALITAMBA NURSERY</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .error-overlay {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('/images/background.jpg');
            background-size: cover;
            background-position: center;
        }

        .error-container {
            text-align: center;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            padding: 3rem;
            border-radius: var(--radius-2xl);
            box-shadow: var(--shadow-2xl);
            max-width: 600px;
        }

        .error-code {
            font-size: 6rem;
            font-weight: 800;
            color: var(--accent);
            margin-bottom: 0;
            line-height: 1;
            font-family: 'Merriweather', Georgia, serif;
        }

        .error-title {
            font-family: 'Merriweather', Georgia, serif;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 1rem;
        }

        .error-message {
            color: var(--text-body);
            margin-bottom: 2rem;
            line-height: 1.6;
        }

        .db-status {
            background: var(--accent-light);
            color: var(--accent);
            padding: 0.75rem 1.5rem;
            border-radius: var(--radius-full);
            font-weight: 600;
            margin-bottom: 1.5rem;
            display: inline-block;
        }

        .db-status.disconnected {
            background: #fee2e2;
            color: #991b1b;
        }

        .help-section {
            background: var(--background-alt);
            padding: 1.5rem;
            border-radius: var(--radius-lg);
            margin-top: 2rem;
            text-align: left;
        }

        .help-title {
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 1rem;
            font-family: 'Merriweather', Georgia, serif;
        }

        .help-steps {
            list-style: none;
            padding: 0;
        }

        .help-steps li {
            padding: 0.5rem 0;
            color: var(--text-body);
        }

        .help-steps li i {
            color: var(--accent);
            margin-right: 0.5rem;
        }
    </style>
</head>

<body>
    <div class="error-overlay">
        <div class="error-container">
            <div class="text-danger mb-3">
                <i class="fas fa-exclamation-triangle fa-4x"></i>
            </div>
            <h1 class="error-code">500</h1>
            <h2 class="error-title"><%= title %></h2>
            
            <% if (typeof dbConnected !== 'undefined' && !dbConnected) { %>
                <div class="db-status disconnected">
                    <i class="fas fa-database me-2"></i>Database Disconnected
                </div>
            <% } else if (typeof dbConnected !== 'undefined' && dbConnected) { %>
                <div class="db-status">
                    <i class="fas fa-database me-2"></i>Database Connected
                </div>
            <% } %>
            
            <p class="error-message">
                <%= message || 'Our gardeners are working hard to fix a glitch in the system. Please try again in a few minutes.' %>
            </p>
            
            <% if (typeof dbConnected !== 'undefined' && !dbConnected) { %>
                <div class="help-section">
                    <h3 class="help-title">
                        <i class="fas fa-cloud me-2"></i>How to Fix Database Connection
                    </h3>
                    <ul class="help-steps">
                        <li><i class="fas fa-wifi"></i>Check your internet connection</li>
                        <li><i class="fas fa-key"></i>Verify MongoDB Atlas credentials in .env file</li>
                        <li><i class="fas fa-globe"></i>Check MongoDB Atlas cluster status</li>
                        <li><i class="fas fa-sync-alt"></i>Refresh this page to retry connection</li>
                        <li><i class="fas fa-terminal"></i>Check server console for detailed error messages</li>
                        <li><i class="fas fa-phone"></i>Contact support if the problem persists</li>
                    </ul>
                </div>
            <% } %>
            
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a href="/" class="btn btn-primary">
                    <i class="fas fa-home me-2"></i>Go Home
                </a>
                <a href="javascript:location.reload()" class="btn btn-outline-primary">
                    <i class="fas fa-redo me-2"></i>Retry
                </a>
                <% if (typeof dbConnected !== 'undefined' && !dbConnected) { %>
                    <a href="/admin/login" class="btn btn-outline-secondary">
                        <i class="fas fa-cog me-2"></i>Admin Panel
                    </a>
                <% } %>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/utils.js"></script>
</body>

</html>