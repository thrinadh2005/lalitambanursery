<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !=='undefined' ? title : 'Bill Management' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .admin-page-header {
            background: linear-gradient(135deg, #2e7d32, #1b5e20);
            color: white;
            padding: 4rem 0;
            margin-bottom: 2rem;
            border-radius: 0 0 var(--radius-3xl) var(--radius-3xl);
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

        .admin-page-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M40 0l40 40-40 40L0 40z' fill='%23ffffff' fill-opacity='0.03'/%3E%3C/svg%3E");
            opacity: 0.1;
        }

        .form-glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-2xl);
            padding: 2.5rem;
            box-shadow: var(--shadow-2xl);
        }

        .input-glass-group {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .input-glass-group:focus-within {
            border-color: #2e7d32;
            box-shadow: 0 0 0 4px rgba(46, 125, 50, 0.1);
            background: rgba(255, 255, 255, 0.1);
        }

        .input-glass-group .form-control, 
        .input-glass-group .form-select,
        .input-glass-group .input-group-text {
            background: transparent !important;
            border: none !important;
            color: var(--text-main) !important;
            box-shadow: none !important;
        }

        .pos-table thead th {
            background: rgba(0, 0, 0, 0.02);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.1em;
            font-weight: 800;
            color: var(--text-muted);
            padding: 1rem;
            border-bottom: 2px solid var(--border-light);
        }

        .pos-table tbody td {
            padding: 0.75rem;
            vertical-align: middle;
            border-bottom: 1px solid var(--border-light);
        }

        .summary-pill {
            background: rgba(46, 125, 50, 0.05);
            border-radius: var(--radius-xl);
            padding: 1.5rem;
            border: 1px solid rgba(46, 125, 50, 0.1);
        }

        .total-hero {
            font-size: 2.5rem;
            font-weight: 900;
            color: #2e7d32;
        }

        .search-results-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-2xl);
            z-index: 1100;
        }

        .active-result {
            background: rgba(46, 125, 50, 0.1) !important;
            border-left: 4px solid #2e7d32 !important;
        }

        .row-active {
            background: rgba(46, 125, 50, 0.02);
        }
    </style>
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <div class="admin-page-header">
        <div class="container px-5">
            <div class="row align-items-center">
                <div class="col-md-7" data-aos="fade-right">
                    <h1 class="display-5 fw-900 mb-2"><%= (typeof bill !=='undefined' && bill) ? 'Modify Fiscal Record' : 'Generate New Invoice' %></h1>
                    <p class="mb-0 opacity-75 fs-5">Point of Sale & Inventory Accounting Module</p>
                </div>
                <div class="col-md-5 text-md-end mt-4 mt-md-0" data-aos="fade-left">
                    <div class="d-flex gap-3 justify-content-md-end">
                        <a href="/admin/bills" class="btn btn-light rounded-pill px-4 py-2 fw-bold shadow-sm">
                            <i class="fas fa-arrow-left me-2"></i>Back to Ledger
                        </a>
                        <button type="button" class="btn btn-glass-success rounded-pill px-4 fw-bold" onclick="submitBillForm()">
                            <i class="fas fa-check-circle me-2"></i>Finalize Bill
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-5 py-4">
        <div class="row g-4">
            <main class="col-12">
                <form action="<%= (typeof bill !== 'undefined' && bill) ? '/admin/bills/edit/' + bill._id : '/admin/bills/create' %>" method="POST" id="billForm">
                    <div class="row g-4">
                        <div class="col-xl-8">
                            <!-- Customer & Items Section -->
                            <div class="form-glass-card mb-4" data-aos="fade-up">
                                <div class="section-title mb-4 d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5 class="fw-bold mb-0 text-success">Client Identification</h5>
                                        <div class="text-muted small">Primary billing entity and contact details</div>
                                    </div>
                                    <div class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 fw-bold">
                                        <%= (typeof bill !=='undefined' && bill) ? 'Ref: #' + bill.billNumber : 'New Manifest' %>
                                    </div>
                                </div>

                                <div class="row g-4 mb-2">
                                    <div class="col-md-7">
                                        <label class="form-label fw-bold small text-uppercase">Full Identity / Name</label>
                                        <div class="input-glass-group d-flex align-items-center">
                                            <span class="px-3 text-success"><i class="fas fa-user-tie"></i></span>
                                            <input type="text" name="customerName" id="customerName" class="form-control form-control-lg" 
                                                required autofocus placeholder="Customer Name"
                                                value="<%= (typeof bill !== 'undefined' && bill) ? bill.customerName : '' %>">
                                        </div>
                                    </div>
                                    <div class="col-md-5">
                                        <label class="form-label fw-bold small text-uppercase">Contact Frequency (Phone)</label>
                                        <div class="input-glass-group d-flex align-items-center">
                                            <span class="px-3 text-success"><i class="fas fa-phone"></i></span>
                                            <input type="tel" name="customerPhone" id="customerPhone" class="form-control form-control-lg" 
                                                pattern="^[0-9]{10}$" inputmode="numeric" maxlength="10" placeholder="10-digit number"
                                                value="<%= (typeof bill !== 'undefined' && bill) ? bill.customerPhone : '' %>">
                                        </div>
                                    </div>
                                </div>

                                <div class="row g-4 mt-1 mb-2">
                                    <div class="col-12">
                                        <div class="form-check form-switch custom-switch">
                                            <input class="form-check-input" type="checkbox" name="isFarmerBill" id="isFarmerBill" value="true"
                                                <%= (typeof bill !== 'undefined' && bill && bill.isFarmerBill) ? 'checked' : '' %>>
                                            <label class="form-check-label fw-bold text-success" for="isFarmerBill">
                                                <i class="fas fa-tractor me-2"></i>MARK AS FARMER ACCOUNT
                                            </label>
                                        </div>
                                    </div>
                                </div>

                                <div class="row g-4 mt-1">
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold small text-uppercase">Fiscal Date</label>
                                        <div class="input-glass-group d-flex align-items-center">
                                            <span class="px-3 text-success"><i class="fas fa-calendar-day"></i></span>
                                            <input type="date" name="billDate" id="billDate" class="form-control" readonly
                                                value="<%= (typeof bill !== 'undefined' && bill && bill.billDate) ? bill.billDate.toISOString().split('T')[0] : new Date().toISOString().split('T')[0] %>">
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold small text-uppercase">Due Deadline</label>
                                        <div class="input-glass-group d-flex align-items-center">
                                            <span class="px-3 text-success"><i class="fas fa-hourglass-half"></i></span>
                                            <input type="date" name="dueDate" id="dueDate" class="form-control"
                                                value="<%= (typeof bill !== 'undefined' && bill && bill.dueDate) ? bill.dueDate.toISOString().split('T')[0] : '' %>">
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold small text-uppercase">Settlement Medium</label>
                                        <div class="input-glass-group d-flex align-items-center">
                                            <span class="px-3 text-success"><i class="fas fa-wallet"></i></span>
                                            <select name="paymentMethod" id="paymentMethod" class="form-select">
                                                <% ['cash', 'card' , 'upi' , 'bank_transfer' , 'other'].forEach(opt=> { %>
                                                    <option value="<%= opt %>" <%=(typeof bill !=='undefined' && bill && bill.paymentMethod===opt) ? 'selected' : '' %>>
                                                        <%= opt.replace('_',' ').toUpperCase() %>
                                                    </option>
                                                <% }) %>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- POS Items Section -->
                            <div class="form-glass-card" data-aos="fade-up" data-aos-delay="100">
                                <div class="section-title mb-4 d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5 class="fw-bold mb-0 text-success">Itemized Catalog</h5>
                                        <div class="text-muted small">Add items from inventory or custom entries</div>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3" id="clearItemsBtn">
                                            <i class="fas fa-trash-alt me-1"></i>Reset List
                                        </button>
                                        <button type="button" class="btn btn-success btn-sm rounded-pill px-3" id="addEmptyItemBtn">
                                            <i class="fas fa-plus me-1"></i>New Entry
                                        </button>
                                    </div>
                                </div>

                                <!-- Search Interface -->
                                <div class="mb-4 position-relative">
                                    <div class="input-glass-group d-flex align-items-center p-1">
                                        <span class="px-3 text-success"><i class="fas fa-search"></i></span>
                                        <input id="posSearch" type="text" class="form-control form-control-lg" 
                                            placeholder="Scan catalog or type botanical variety name..." autocomplete="off">
                                    </div>
                                    <ul id="posResults" class="list-group position-absolute w-100 search-results-glass mt-1" style="display: none;"></ul>
                                </div>

                                <div class="table-responsive">
                                    <table class="table pos-table mb-0" id="itemsTable">
                                        <thead>
                                            <tr>
                                                <th style="width:40px">#</th>
                                                <th style="width:120px">Spec (Size)</th>
                                                <th>Botanical Identity</th>
                                                <th style="width:100px" class="text-center">Qty</th>
                                                <th style="width:140px" class="text-end">Unit Rate</th>
                                                <th style="width:140px" class="text-end">Line Total</th>
                                                <th style="width:50px"></th>
                                            </tr>
                                        </thead>
                                        <tbody id="itemsTbody">
                                            <!-- Rows dynamic -->
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="col-xl-4">
                            <!-- Summary & Finalization -->
                            <div class="form-glass-card sticky-top" style="top: 100px; z-index: 100;" data-aos="fade-left">
                                <div class="section-title mb-4">
                                    <h5 class="fw-bold mb-0 text-success">Fiscal Consolidation</h5>
                                    <div class="text-muted small">Summary of transactions and adjustments</div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-uppercase">Manifest Status</label>
                                    <div class="input-glass-group d-flex align-items-center">
                                        <span class="px-3 text-success"><i class="fas fa-flag"></i></span>
                                        <select name="status" id="statusSelect" class="form-select fw-bold">
                                            <option value="pending" <%=(typeof bill !=='undefined' && bill && bill.status==='pending' ) ? 'selected' : '' %>>PENDING REVIEW</option>
                                            <option value="paid" <%=(typeof bill !=='undefined' && bill && bill.status==='paid' ) ? 'selected' : '' %>>AUTHORIZED / PAID</option>
                                            <option value="overdue" <%=(typeof bill !=='undefined' && bill && bill.status==='overdue' ) ? 'selected' : '' %>>OVERDUE / DEBT</option>
                                            <option value="cancelled" <%=(typeof bill !=='undefined' && bill && bill.status==='cancelled' ) ? 'selected' : '' %>>VOIDED</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="summary-pill mb-4">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="text-muted small fw-bold">TOTAL UNITS</span>
                                        <span id="totalQtyDisplay" class="badge bg-success rounded-pill px-3 py-2 fw-bold fs-6">0</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="text-muted small">SUBTOTAL</span>
                                        <span id="subTotalDisplay" class="fw-bold">₹0.00</span>
                                        <input type="hidden" name="subTotal" id="subTotalInput" value="0">
                                    </div>
                                    
                                    <div class="row g-2 mb-3">
                                        <div class="col-6">
                                            <label class="form-label small fw-bold text-muted">SURCHARGE / TAX (Optional) (₹)</label>
                                            <div class="input-glass-group">
                                                <input type="number" name="tax" id="taxInput" class="form-control text-end" 
                                                    value="<%= (typeof bill !== 'undefined' && bill) ? bill.tax : 0 %>"
                                                    step="0.01" min="0" oninput="calculateTotals()">
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label small fw-bold text-muted">CONCESSION (₹)</label>
                                            <div class="input-glass-group">
                                                <input type="number" name="discount" id="discountInput" class="form-control text-end" 
                                                    value="<%= (typeof bill !== 'undefined' && bill) ? bill.discount : 0 %>"
                                                    step="0.01" min="0" oninput="calculateTotals()">
                                            </div>
                                        </div>
                                    </div>

                                    <div class="pt-3 border-top border-light mt-3">
                                        <div class="d-flex justify-content-between align-items-end">
                                            <div class="text-muted small fw-bold">GRAND TOTAL</div>
                                            <div class="total-hero" id="totalAmountDisplay">₹0.00</div>
                                            <input type="hidden" name="totalAmount" id="totalAmountInput" value="0">
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-uppercase">Internal Annotations</label>
                                    <div class="input-glass-group">
                                        <textarea name="notes" id="notesInput" class="form-control" rows="3" 
                                            placeholder="Enter terms, special instructions, or audit notes..."><%= (typeof bill !== 'undefined' && bill) ? bill.notes : '' %></textarea>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-success w-100 btn-lg rounded-pill py-3 fw-900 shadow-lg" onclick="submitBillForm()">
                                    <i class="fas fa-file-invoice me-2"></i><%= (typeof bill !=='undefined' && bill) ? 'UPDATE INVOICE' : 'COMMIT MANIFEST' %>
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </main>
        </div>
    </div>

    <!-- Hidden Datalists -->
    <datalist id="sizeCatalogList">
        <option value="5/6"><option value="6/7"><option value="8/10"><option value="9/10"><option value="12/12">
        <option value="13/13"><option value="14/15"><option value="15/16"><option value="18/18"><option value="21/21">
        <option value="25/25"><option value="30/30"><option value="40/40"><option value="50/50"><option value="1 unit">
    </datalist>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>

    <script>
        // Seed data from server
        window.availablePlants = <%- JSON.stringify(typeof plants !== 'undefined' ? plants : []) %>;
        window.serverItems = <%- JSON.stringify((typeof bill !== 'undefined' && bill && bill.items) ? bill.items : []) %>;
        window.isNewBill = <%- JSON.stringify(Boolean(typeof bill === 'undefined' || !bill)) %>;

        if (typeof AOS !== 'undefined') {
            AOS.init({ duration: 800, once: true });
        }

        // ============================================================
        // POS LOGIC ENGINE
        // ============================================================
        const availablePlants = window.availablePlants;
        let items = window.serverItems.map(item => ({
            packetSize: item.packetSize || '',
            plantName: item.plantName || item.description || '',
            quantity: Number(item.quantity) || 1,
            unitPrice: Number(item.unitPrice) || Number(item.price) || 0,
            lineTotal: (Number(item.quantity) || 1) * (Number(item.unitPrice) || Number(item.price) || 0),
            plantId: item.plantId || null
        }));

        if (window.isNewBill && items.length === 0) {
            items.push({ packetSize: '', plantName: '', quantity: 1, unitPrice: 0, lineTotal: 0, plantId: null });
        }

        function renderItems() {
            const tbody = document.getElementById('itemsTbody');
            if (!tbody) return;

            if (items.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="text-center py-5 text-muted">
                    <i class="fas fa-shopping-basket fa-2x mb-3 opacity-25 d-block"></i>
                    No items selected. Use the search bar above to build the manifest.
                </td></tr>`;
                calculateTotals();
                return;
            }

            tbody.innerHTML = '';
            items.forEach((item, idx) => {
                const tr = document.createElement('tr');
                tr.id = `row-${idx}`;
                tr.innerHTML = `
                    <td class="text-muted small fw-bold">${idx + 1}</td>
                    <td>
                        <input type="text" id="size-${idx}" class="form-control form-control-sm"
                            placeholder="Size" value="${escHtml(item.packetSize)}"
                            list="sizeCatalogList" onchange="fieldChanged(${idx},'packetSize',this.value)" onfocus="rowFocus(${idx})">
                    </td>
                    <td>
                        <input type="text" id="desc-${idx}" class="form-control form-control-sm fw-bold"
                            placeholder="Plant Name" value="${escHtml(item.plantName)}"
                            onchange="fieldChanged(${idx},'plantName',this.value)" onfocus="rowFocus(${idx})">
                    </td>
                    <td>
                        <input type="number" id="qty-${idx}" class="form-control form-control-sm text-center fw-bold text-success"
                            value="${item.quantity}" min="1"
                            oninput="fieldChanged(${idx},'quantity',this.value)" onfocus="this.select(); rowFocus(${idx})">
                    </td>
                    <td>
                        <input type="number" id="rate-${idx}" class="form-control form-control-sm text-end fw-bold"
                            value="${item.unitPrice}" step="0.01" min="0"
                            oninput="fieldChanged(${idx},'unitPrice',this.value)" onfocus="this.select(); rowFocus(${idx})">
                    </td>
                    <td class="text-end fw-900 text-success" id="total-${idx}">
                        ₹${fmtNum(item.lineTotal)}
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-link text-danger p-0" onclick="removeItem(${idx})">
                            <i class="fas fa-times-circle"></i>
                        </button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
            calculateTotals();
        }

        function escHtml(str) {
            return String(str || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }
        function fmtNum(n) {
            return (Number(n) || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function rowFocus(idx) {
            document.querySelectorAll('#itemsTable tr').forEach(r => r.classList.remove('row-active'));
            document.getElementById(`row-${idx}`)?.classList.add('row-active');
        }

        function fieldChanged(idx, field, value) {
            if (!items[idx]) return;
            if (field === 'quantity' || field === 'unitPrice') {
                items[idx][field] = parseFloat(value) || 0;
            } else {
                items[idx][field] = value;
            }
            items[idx].lineTotal = items[idx].quantity * items[idx].unitPrice;
            const totalEl = document.getElementById(`total-${idx}`);
            if (totalEl) totalEl.textContent = '₹' + fmtNum(items[idx].lineTotal);
            calculateTotals();
        }

        window.removeItem = function(idx) {
            items.splice(idx, 1);
            renderItems();
        };

        document.getElementById('addEmptyItemBtn').addEventListener('click', () => {
            items.push({ packetSize: '', plantName: '', quantity: 1, unitPrice: 0, lineTotal: 0, plantId: null });
            renderItems();
            setTimeout(() => {
                const lastIdx = items.length - 1;
                document.getElementById(`size-${lastIdx}`)?.focus();
            }, 50);
        });

        document.getElementById('clearItemsBtn').addEventListener('click', () => {
            if (confirm('Discard all items from this manifest?')) {
                items = [];
                renderItems();
            }
        });

        window.calculateTotals = function() {
            const subTotal = items.reduce((s, item) => s + (item.lineTotal || 0), 0);
            const totalQty = items.reduce((s, item) => s + (parseFloat(item.quantity) || 0), 0);
            const tax = parseFloat(document.getElementById('taxInput')?.value) || 0;
            const discount = parseFloat(document.getElementById('discountInput')?.value) || 0;
            const total = subTotal + tax - discount;

            document.getElementById('subTotalDisplay').textContent = '₹' + fmtNum(subTotal);
            document.getElementById('subTotalInput').value = subTotal.toFixed(2);
            document.getElementById('totalAmountDisplay').textContent = '₹' + fmtNum(total);
            document.getElementById('totalAmountInput').value = total.toFixed(2);
            document.getElementById('totalQtyDisplay').textContent = totalQty;
        };

        // Search Interface
        const posSearch = document.getElementById('posSearch');
        const posResults = document.getElementById('posResults');
        let searchTimer = null;
        let activeResultIdx = -1;

        posSearch.addEventListener('input', function() {
            clearTimeout(searchTimer);
            const q = this.value.trim();
            if (!q) { posResults.style.display = 'none'; return; }

            searchTimer = setTimeout(async () => {
                try {
                    const resp = await fetch('/api/billing/catalog/search?q=' + encodeURIComponent(q));
                    const data = await resp.json();
                    posResults.innerHTML = '';
                    if (data.results && data.results.length > 0) {
                        data.results.forEach((plant, i) => {
                            const li = document.createElement('li');
                            li.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 py-3';
                            li.innerHTML = `
                                <div>
                                    <div class="fw-900 text-dark">${escHtml(plant.name)}</div>
                                    <div class="small text-muted">${escHtml(plant.category || 'General')} · Stock: ${plant.stock}</div>
                                </div>
                                <span class="fw-bold text-success fs-5">₹${fmtNum(plant.price)}</span>
                            `;
                            li.onclick = () => addCatalogItem(plant);
                            posResults.appendChild(li);
                        });
                        posResults.style.display = 'block';
                    } else {
                        posResults.innerHTML = `<li class="list-group-item text-muted small py-3 border-0">No matches found. Press Enter to add custom item.</li>`;
                        posResults.style.display = 'block';
                    }
                } catch (err) { console.error(err); }
            }, 300);
        });

        function addCatalogItem(plant) {
            items.push({
                packetSize: '',
                plantName: plant.name,
                quantity: 1,
                unitPrice: plant.price || 0,
                lineTotal: plant.price || 0,
                plantId: plant._id
            });
            posSearch.value = '';
            posResults.style.display = 'none';
            renderItems();
        }

        posSearch.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                const q = posSearch.value.trim();
                if (q) {
                    items.push({ packetSize: '', plantName: q, quantity: 1, unitPrice: 0, lineTotal: 0, plantId: null });
                    posSearch.value = '';
                    posResults.style.display = 'none';
                    renderItems();
                }
            }
        });

        window.submitBillForm = function() {
            // Logic to prepare hidden inputs for items if needed, or AJAX
            // The current form will just send what's in the visible inputs
            // But we need to ensure all dynamic items are sent.
            // Let's inject hidden inputs for items array before submit.
            const form = document.getElementById('billForm');
            
            // Remove any existing hidden item inputs
            form.querySelectorAll('input[name^="items"]').forEach(el => el.remove());

            items.forEach((item, idx) => {
                if (!item.plantName) return;
                const base = `items[${idx}]`;
                const createHidden = (name, val) => {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = `${base}[${name}]`;
                    input.value = val;
                    form.appendChild(input);
                };
                createHidden('packetSize', item.packetSize);
                createHidden('plantName', item.plantName);
                createHidden('quantity', item.quantity);
                createHidden('unitPrice', item.unitPrice);
                if (item.plantId) createHidden('plantId', item.plantId);
            });
            
            form.submit();
        };

        document.addEventListener('DOMContentLoaded', renderItems);
    </script>

        <!-- Hidden datalist for sizes -->
        <datalist id="sizeCatalogList">
            <option value="5/6">
            <option value="6/7">
            <option value="8/10">
            <option value="9/10">
            <option value="12/12">
            <option value="13/13">
            <option value="14/15">
            <option value="15/16">
            <option value="18/18">
            <option value="21/21">
            <option value="25/25">
            <option value="30/30">
            <option value="40/40">
            <option value="50/50">
            <option value="1 unit">
        </datalist>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
        <script src="/js/utils.js"></script>

        <script>
            // Seed data from server (Global variables)
            window.availablePlants = <%- JSON.stringify(typeof plants !== 'undefined' ? plants : []) %>;
            window.serverItems = <%- JSON.stringify((typeof bill !== 'undefined' && bill && bill.items) ? bill.items : []) %>;
            window.isNewBill = <%- JSON.stringify(Boolean(typeof bill === 'undefined' || !bill)) %>;
        </script>

        <script>
            if (typeof AOS !== 'undefined') {
                AOS.init({ duration: 800, once: true });
            }
            // ============================================================
            // BILL FORM — DATA ENTRY ENGINE
            // ============================================================

            const availablePlants = window.availablePlants;
            let items = window.serverItems;
            const isNewBill = window.isNewBill;

            // Normalize items for display
            items = items.map(item => ({
                packetSize: item.packetSize || '',
                plantName: item.plantName || item.description || '',
                quantity: Number(item.quantity) || 1,
                unitPrice: Number(item.unitPrice) || Number(item.price) || 0,
                lineTotal: 0,
                plantId: item.plantId || null
            }));
            items.forEach(item => { item.lineTotal = item.quantity * item.unitPrice; });


            // Start with one empty row for new bills
            if (isNewBill && items.length === 0) {
                items.push({ packetSize: '', plantName: '', quantity: 1, unitPrice: 0, lineTotal: 0, plantId: null });
            }

            // ---- RENDER ----
            function renderItems() {
                const tbody = document.getElementById('itemsTbody');
                if (!tbody) return;

                if (items.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="7" class="text-center py-5 text-muted">
                <i class="fas fa-shopping-basket fa-2x mb-2 text-light d-block"></i>
                No items yet. Search the catalog above or click <strong>Add Row</strong>.
            </td></tr>`;
                    calculateTotals();
                    return;
                }

                tbody.innerHTML = '';
                items.forEach((item, idx) => {
                    const tr = document.createElement('tr');
                    tr.id = `row-${idx}`;
                    tr.innerHTML = `
                <td class="text-muted small ps-3 fw-bold">${idx + 1}</td>
                <td>
                    <input type="text" id="size-${idx}" class="form-control form-control-sm"
                        placeholder="Size" value="${escHtml(item.packetSize)}"
                        list="sizeCatalogList"
                        data-idx="${idx}" data-field="size"
                        onchange="fieldChanged(${idx},'packetSize',this.value)" onfocus="rowFocus(${idx})" onfocusout="syncRow(${idx})">
                </td>
                <td>
                    <input type="text" id="desc-${idx}" class="form-control form-control-sm fw-bold"
                        placeholder="Plant Name" value="${escHtml(item.plantName)}"
                        data-idx="${idx}" data-field="desc"
                        onchange="fieldChanged(${idx},'plantName',this.value)" onfocus="rowFocus(${idx})" onfocusout="syncRow(${idx})">
                </td>
                <td>
                    <input type="number" id="qty-${idx}" class="form-control form-control-sm text-center fw-bold text-primary"
                        value="${item.quantity}" min="1"
                        data-idx="${idx}" data-field="qty"
                        oninput="fieldChanged(${idx},'quantity',this.value)"
                        onchange="fieldChanged(${idx},'quantity',this.value)"
                        onfocus="this.select(); rowFocus(${idx})" onfocusout="syncRow(${idx})">
                </td>
                <td>
                    <input type="number" id="rate-${idx}" class="form-control form-control-sm text-end fw-bold"
                        value="${item.unitPrice}" step="0.01" min="0"
                        data-idx="${idx}" data-field="rate"
                        oninput="fieldChanged(${idx},'unitPrice',this.value)"
                        onchange="fieldChanged(${idx},'unitPrice',this.value)"
                        onfocus="this.select(); rowFocus(${idx})" onfocusout="syncRow(${idx})">
                </td>
                <td class="text-end fw-bold text-success" id="total-${idx}">
                    ₹${fmtNum(item.lineTotal)}
                </td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-light text-danger"
                        onclick="removeItem(${idx})" title="Remove">
                        <i class="fas fa-times"></i>
                    </button>
                </td>
            `;
                    tbody.appendChild(tr);
                });

                calculateTotals();
            }

            function escHtml(str) {
                return String(str || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            }
            function fmtNum(n) {
                return (Number(n) || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }

            function rowFocus(idx) {
                document.querySelectorAll('#itemsTable tr').forEach(r => r.classList.remove('row-active'));
                const row = document.getElementById(`row-${idx}`);
                if (row) row.classList.add('row-active');
            }

            // ---- FIELD CHANGES ----
            function fieldChanged(idx, field, value) {
                if (!items[idx]) return;
                if (field === 'quantity' || field === 'unitPrice') {
                    items[idx][field] = parseFloat(value) || 0;
                } else {
                    items[idx][field] = value;
                }
                items[idx].lineTotal = (items[idx].quantity || 0) * (items[idx].unitPrice || 0);
                const totalEl = document.getElementById(`total-${idx}`);
                if (totalEl) totalEl.textContent = '₹' + fmtNum(items[idx].lineTotal);
                calculateTotals();
            }

            // Sync a row from DOM → items[] (called on focusout)
            function syncRow(idx) {
                if (!items[idx]) return;
                const sizeEl = document.getElementById(`size-${idx}`);
                const descEl = document.getElementById(`desc-${idx}`);
                const qtyEl = document.getElementById(`qty-${idx}`);
                const rateEl = document.getElementById(`rate-${idx}`);
                if (sizeEl) items[idx].packetSize = sizeEl.value;
                if (descEl) items[idx].plantName = descEl.value;
                if (qtyEl) items[idx].quantity = parseFloat(qtyEl.value) || 1;
                if (rateEl) items[idx].unitPrice = parseFloat(rateEl.value) || 0;
                items[idx].lineTotal = items[idx].quantity * items[idx].unitPrice;
            }

            // Sync all rows before submission or count operations
            function syncAll() {
                items.forEach((_, idx) => syncRow(idx));
            }

            // ---- ADD / REMOVE ----
            window.removeItem = function (idx) {
                syncAll();
                if (items.length === 1) {
                    if (!confirm('Remove the only item? The bill will have no items.')) return;
                }
                items.splice(idx, 1);
                renderItems();
            };

            function addEmptyItem() {
                syncAll();
                items.push({ packetSize: '', plantName: '', quantity: 1, unitPrice: 0, lineTotal: 0, plantId: null });
                renderItems();
                // Focus Size of new row
                focusSizeOfLastItem();
            }

            // Add a catalog item (from search dropdown click or Enter)
            function addCatalogItem(plant) {
                syncAll();
                items.push({
                    packetSize: '',
                    plantName: plant.name || '',
                    quantity: 1,
                    unitPrice: plant.price || 0,
                    lineTotal: plant.price || 0,
                    plantId: plant._id || null
                });
                renderItems();
                focusSizeOfLastItem();
            }

            // Add a custom item (typed text from search bar → Enter)
            function addCustomItem(name) {
                syncAll();
                items.push({
                    packetSize: '',
                    plantName: name || '',
                    quantity: 1,
                    unitPrice: 0,
                    lineTotal: 0,
                    plantId: null
                });
                renderItems();
                focusSizeOfLastItem();
            }

            // Helper: focus the Size field of the last item row
            function focusSizeOfLastItem() {
                const newIdx = items.length - 1;
                setTimeout(() => {
                    const sizeEl = document.getElementById(`size-${newIdx}`);
                    if (sizeEl) { sizeEl.focus(); sizeEl.select(); }
                }, 30);
            }

            // ---- TOTALS ----
            window.calculateTotals = function () {
                const subTotal = items.reduce((s, item) => s + ((item.quantity || 0) * (item.unitPrice || 0)), 0);
                const totalQty = items.reduce((s, item) => s + (parseFloat(item.quantity) || 0), 0);
                const tax = parseFloat(document.getElementById('taxInput')?.value) || 0;
                const discount = parseFloat(document.getElementById('discountInput')?.value) || 0;
                const total = subTotal + tax - discount;

                const sd = document.getElementById('subTotalDisplay');
                const si = document.getElementById('subTotalInput');
                const tad = document.getElementById('totalAmountDisplay');
                const tai = document.getElementById('totalAmountInput');
                const tqd = document.getElementById('totalQtyDisplay');

                if (sd) sd.textContent = '₹' + fmtNum(subTotal);
                if (si) si.value = subTotal.toFixed(2);
                if (tad) tad.textContent = '₹' + fmtNum(total);
                if (tai) tai.value = total.toFixed(2);
                if (tqd) tqd.textContent = totalQty;
            };

            // ---- CATALOG SEARCH elements (must be declared before keydown handler) ----
            let searchTimer = null;
            let activeResultIdx = -1;
            const posSearch = document.getElementById('posSearch');
            const posResults = document.getElementById('posResults');

            function hideResults() {
                if (!posResults) return;
                posResults.style.display = 'none';
                posResults.innerHTML = '';
                activeResultIdx = -1;
            }

            // ---- KEYBOARD NAVIGATION (Enter key flow) ----
            document.addEventListener('keydown', function (e) {
                if (e.key !== 'Enter') return;

                const el = e.target;
                const id = el.id || '';
                const field = el.getAttribute('data-field');
                const idx = parseInt(el.getAttribute('data-idx'));

                // Allow textarea and real buttons to behave normally
                if (el.tagName === 'TEXTAREA' || el.tagName === 'BUTTON') return;

                // Stop the form from submitting immediately on any other Enter!
                e.preventDefault();
                e.stopImmediatePropagation();

                console.log('POS KB DISPATCH:', { id, field, idx, tagName: el.tagName });

                // 1. Grid Rows (Size -> Desc -> Qty -> Rate)
                if (field && !isNaN(idx)) {
                    syncRow(idx);
                    if (field === 'size') {
                        document.getElementById(`desc-${idx}`)?.focus();
                    } else if (field === 'desc') {
                        document.getElementById(`qty-${idx}`)?.focus();
                    } else if (field === 'qty') {
                        const r = document.getElementById(`rate-${idx}`);
                        if (r) { r.focus(); r.select(); }
                    } else if (field === 'rate') {
                        const s = document.getElementById('posSearch');
                        if (s) { s.value = ''; s.focus(); }
                    }
                    return;
                }

                // 2. Top-level form fields explicit flow
                switch (id) {
                    case 'customerName':
                        document.getElementById('customerPhone')?.focus();
                        break;
                    case 'customerPhone':
                        document.getElementById('dueDate')?.focus();
                        break;
                    case 'dueDate':
                        document.getElementById('paymentMethod')?.focus();
                        break;
                    case 'paymentMethod':
                        document.getElementById('posSearch')?.focus();
                        break;
                    case 'posSearch': {
                        hideResults();
                        if (!posResults) break;
                        // 1. Highlighted
                        const highlighted = posResults.querySelector('.list-group-item.active-result');
                        if (highlighted) {
                            highlighted.dispatchEvent(new MouseEvent('mousedown', { bubbles: true }));
                            el.value = '';
                            return;
                        }
                        // 2. First result
                        const firstResult = posResults.querySelector('li.list-group-item-action');
                        if (firstResult) {
                            firstResult.dispatchEvent(new MouseEvent('mousedown', { bubbles: true }));
                            el.value = '';
                            return;
                        }
                        // 3. Custom item
                        const text = el.value.trim();
                        if (text) {
                            addCustomItem(text);
                            el.value = '';
                            return;
                        }
                        // 4. Empty -> move to tax
                        if (items.length === 0) {
                            el.focus(); // must add item
                            return;
                        }
                        const tax = document.getElementById('taxInput');
                        if (tax) { tax.focus(); tax.select(); }
                        break;
                    }
                    case 'taxInput': {
                        const disc = document.getElementById('discountInput');
                        if (disc) { disc.focus(); disc.select(); }
                        break;
                    }
                    case 'discountInput':
                        document.getElementById('notesInput')?.focus();
                        break;
                    case 'notesInput':
                        // Let it be
                        break;
                    default:
                        console.log('Unhandeld KB ID:', id);
                        break;
                }
            }, true); // Use capture mode to absolutely hijack the Enter key first


            // (posSearch, posResults, hideResults already declared above keydown handler)

            if (posSearch) {
                posSearch.addEventListener('input', function () {
                    clearTimeout(searchTimer);
                    const q = this.value.trim();
                    activeResultIdx = -1;

                    if (!q) { hideResults(); return; }

                    searchTimer = setTimeout(async () => {
                        try {
                            const resp = await fetch('/api/billing/catalog/search?q=' + encodeURIComponent(q));
                            const data = await resp.json();
                            activeResultIdx = -1;
                            posResults.innerHTML = '';

                            if (data.results && data.results.length > 0) {
                                data.results.forEach((plant, i) => {
                                    const li = document.createElement('li');
                                    li.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center';
                                    li.dataset.pidx = i;
                                    li.innerHTML = `
                                <div>
                                    <div class="fw-bold text-dark">${escHtml(plant.name)}</div>
                                    <div class="small text-muted">${escHtml(plant.category || '')} &nbsp;·&nbsp; Stock: ${plant.stock}</div>
                                </div>
                                <span class="fw-bold text-success">₹${fmtNum(plant.price)}</span>
                            `;
                                    li.addEventListener('mousedown', function (ev) {
                                        ev.preventDefault(); // prevent blur before click
                                        addCatalogItem(plant);
                                        posSearch.value = '';
                                        hideResults();
                                        posSearch.focus();
                                    });
                                    posResults.appendChild(li);
                                });
                                posResults.style.display = 'block';
                            } else {
                                posResults.innerHTML = `<li class="list-group-item text-muted small fst-italic">
                            No matches found. Press <kbd>Enter</kbd> to add "<em>${escHtml(q)}</em>" as custom item.
                        </li>`;
                                posResults.style.display = 'block';
                            }
                        } catch (err) {
                            console.error('Catalog search error:', err);
                            hideResults();
                        }
                    }, 200);
                });

                // Arrow key navigation in search results
                posSearch.addEventListener('keydown', function (ev) {
                    const lis = posResults.querySelectorAll('li.list-group-item-action');
                    if (!lis.length) return;

                    if (ev.key === 'ArrowDown') {
                        ev.preventDefault();
                        activeResultIdx = Math.min(activeResultIdx + 1, lis.length - 1);
                        lis.forEach((l, i) => l.classList.toggle('active-result', i === activeResultIdx));
                    } else if (ev.key === 'ArrowUp') {
                        ev.preventDefault();
                        activeResultIdx = Math.max(activeResultIdx - 1, 0);
                        lis.forEach((l, i) => l.classList.toggle('active-result', i === activeResultIdx));
                    }
                });

                // Hide results when clicking outside
                document.addEventListener('click', function (ev) {
                    if (!posSearch.contains(ev.target) && !posResults.contains(ev.target)) {
                        hideResults();
                    }
                });

                posSearch.addEventListener('blur', function () {
                    // Delay so mousedown on result fires first
                    setTimeout(() => { hideResults(); }, 200);
                });
            }

            // ---- FORM SUBMIT ----
            window.submitBillForm = function () {
                syncAll();

                // Filter to meaningful items only (has name or price)
                const meaningful = items.filter(item =>
                    (item.plantName && item.plantName.trim()) || item.unitPrice > 0
                );

                if (meaningful.length === 0) {
                    alert('Please add at least one item (with a plant name or price) before saving the bill.');
                    posSearch?.focus();
                    return;
                }

                const form = document.getElementById('billForm');
                // Remove any old hidden items input
                document.querySelectorAll('input[name="items"]').forEach(el => el.remove());

                // Inject items as JSON
                const inp = document.createElement('input');
                inp.type = 'hidden';
                inp.name = 'items';
                inp.value = JSON.stringify(meaningful);
                form.appendChild(inp);

                form.submit();
            };

            document.getElementById('billForm')?.addEventListener('submit', function (e) {
                e.preventDefault(); // Stop default submit
                submitBillForm();
            });

            // ---- BUTTON WIRING ----
            document.getElementById('addEmptyItemBtn')?.addEventListener('click', function (e) {
                e.preventDefault();
                addEmptyItem();
            });

            document.getElementById('clearItemsBtn')?.addEventListener('click', function (e) {
                e.preventDefault();
                if (items.length === 0 || confirm('Remove all items from this bill?')) {
                    items = [];
                    renderItems();
                    posSearch?.focus();
                }
            });

            // ---- INIT ----
            renderItems();
            calculateTotals();
        </script>
</body>

</html>
