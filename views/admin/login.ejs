<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        body {
            background: linear-gradient(rgba(15, 23, 42, 0.7), rgba(15, 23, 42, 0.7)), url('/images/admin_bg.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;
        }

        .admin-login-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 28px;
            padding: 48px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            color: white;
            width: 100%;
        }

        .admin-form-control {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 14px;
            color: white !important;
            padding: 14px 20px;
            transition: all 0.3s;
        }

        .admin-form-control:focus {
            background: rgba(255, 255, 255, 0.15);
            border-color: var(--primary-color);
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.25);
        }

        .admin-form-control::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        .brand-icon {
            width: 64px;
            height: 64px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin: 0 auto 20px;
        }

        /* Mobile Responsiveness */
        @media (max-width: 576px) {
            .admin-login-card {
                padding: 32px 24px;
                border-radius: 20px;
            }
            .brand-icon {
                width: 56px;
                height: 56px;
                font-size: 1.5rem;
                margin-bottom: 16px;
            }
            .admin-form-control {
                padding: 12px 16px;
            }
            .btn-lg {
                padding: 12px;
                font-size: 1rem;
            }
            .container {
                padding-left: 15px;
                padding-right: 15px;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-4">
                <div class="admin-login-card hover-zoom">
                    <div class="text-center mb-5">
                        <div class="brand-icon">🌱</div>
                        <h2 class="fw-800 mb-1">Nursery Admin</h2>
                        <p class="text-white-50">Portal Access Management</p>
                    </div>

                    <% if (typeof error_msg !=='undefined' && error_msg.length> 0) { %>
                        <div class="alert bg-danger text-white border-0 bg-opacity-50 rounded-4 px-4 py-3 mb-4 small">
                            <i class="fas fa-shield-alt me-2"></i>
                            <%= error_msg %>
                        </div>
                        <% } %>

                            <form method="POST" action="/admin/login">
                                <div class="mb-3">
                                    <label class="form-label text-white-50 small fw-600">USERNAME</label>
                                    <input type="text" class="admin-form-control w-100" name="username"
                                        placeholder="Enter credentials" required autofocus>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label text-white-50 small fw-600">PASSWORD</label>
                                    <input type="password" class="admin-form-control w-100" name="password"
                                        placeholder="••••••••" required>
                                </div>
                                <button type="submit" class="btn btn-primary w-100 btn-lg rounded-4 fw-bold">
                                    Login secure <i class="fas fa-lock ms-2 small"></i>
                                </button>
                            </form>

                            <div class="text-center mt-4">
                                <a href="/" class="text-white-50 text-decoration-none small hover-opacity">
                                    <i class="fas fa-arrow-left me-1"></i> Back to Public Site
                                </a>
                            </div>
                </div>
                <div class="text-center mt-4 text-white-50 small opacity-50">
                    &copy; <%= new Date().getFullYear() %> SRI LALITAMBA NURSERY
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/utils.js"></script>
</body>

</html>