<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Image Management - Sri Lalitamba Nursery</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .image-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }
        
        .image-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: all var(--transition-base);
            box-shadow: var(--shadow-sm);
        }
        
        .image-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }
        
        .image-preview {
            width: 100%;
            height: 200px;
            object-fit: cover;
            background: var(--background-alt);
        }
        
        .image-preview.svg {
            object-fit: contain;
            padding: 1rem;
        }
        
        .format-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(0, 0, 0, 0.8);
            color: white;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
        }
        
        .image-wrapper {
            position: relative;
        }
        
        .image-info {
            padding: 1rem;
        }
        
        .image-name {
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
        }
        
        .image-details {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.8rem;
            color: var(--text-muted);
        }
        
        .upload-area {
            border: 2px dashed var(--border);
            border-radius: var(--radius-lg);
            padding: 3rem;
            text-align: center;
            transition: all var(--transition-base);
            background: var(--background-alt);
        }
        
        .upload-area:hover {
            border-color: var(--accent);
            background: var(--accent-light);
        }
        
        .upload-area.dragover {
            border-color: var(--accent);
            background: var(--accent-light);
            transform: scale(1.02);
        }
        
        .stats-card {
            background: var(--gradient-primary);
            color: white;
            padding: 2rem;
            border-radius: var(--radius-lg);
            margin-bottom: 2rem;
        }
        
        .btn-delete {
            background: var(--accent);
            color: white;
            border: none;
            padding: 0.25rem 0.5rem;
            border-radius: var(--radius-sm);
            font-size: 0.8rem;
        }
        
        .btn-delete:hover {
            background: var(--accent-hover);
        }
    </style>
</head>
<body class="bg-light">
    <div class="container py-5">
        <div class="row mb-4">
            <div class="col-12">
                <h1 class="display-5 fw-bold mb-4">
                    <i class="fas fa-images me-3"></i>Image Management
                </h1>
                <p class="lead text-muted">Manage your website images stored in MongoDB Atlas</p>
            </div>
        </div>

        <!-- Statistics -->
        <div class="stats-card" id="statsCard">
            <div class="row text-center">
                <div class="col-md-3">
                    <h3 class="fw-bold mb-0" id="totalImages">0</h3>
                    <p class="mb-0">Total Images</p>
                </div>
                <div class="col-md-3">
                    <h3 class="fw-bold mb-0" id="totalSize">0 MB</h3>
                    <p class="mb-0">Total Size</p>
                </div>
                <div class="col-md-3">
                    <h3 class="fw-bold mb-0" id="avgSize">0 KB</h3>
                    <p class="mb-0">Average Size</p>
                </div>
                <div class="col-md-3">
                    <h3 class="fw-bold mb-0" id="lastUpload">-</h3>
                    <p class="mb-0">Last Upload</p>
                </div>
            </div>
        </div>

        <!-- Upload Section -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="upload-area" id="uploadArea">
                    <i class="fas fa-cloud-upload-alt fa-3x mb-3 text-muted"></i>
                    <h4 class="mb-3">Upload New Images</h4>
                    <p class="text-muted mb-2">Drag and drop images here or click to select</p>
                    <p class="text-muted small mb-3">
                        <strong>Supported formats:</strong> JPEG, PNG, GIF, WebP, SVG, BMP, TIFF, ICO, AVIF, HEIC, HEIF<br>
                        <strong>Maximum file size:</strong> 10MB per image
                    </p>
                    <input type="file" id="fileInput" multiple accept=".jpg,.jpeg,.png,.gif,.webp,.svg,.bmp,.tiff,.tif,.ico,.avif,.heic,.heif,image/*" style="display: none;">
                    <button class="btn btn-primary" onclick="document.getElementById('fileInput').click()">
                        <i class="fas fa-folder-open me-2"></i>Choose Files
                    </button>
                </div>
            </div>
        </div>

        <!-- Images Grid -->
        <div class="image-grid" id="imageGrid">
            <!-- Images will be loaded here -->
        </div>

        <!-- Loading -->
        <div id="loading" class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Loading images...</p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        let images = [];
        
        // Load images from API
        async function loadImages() {
            try {
                const response = await fetch('/api/images');
                const data = await response.json();
                
                if (data.success) {
                    images = data.images;
                    displayImages();
                    updateStats();
                } else {
                    console.error('Failed to load images:', data.error);
                }
            } catch (error) {
                console.error('Error loading images:', error);
            } finally {
                document.getElementById('loading').style.display = 'none';
            }
        }
        
        // Display images
        function displayImages() {
            const grid = document.getElementById('imageGrid');
            grid.innerHTML = '';
            
            images.forEach(image => {
                const card = document.createElement('div');
                card.className = 'image-card';
                
                // Get image format
                const format = image.name.split('.').pop().toLowerCase();
                const formatClass = format === 'jpg' || format === 'jpeg' ? 'format-jpg' : 
                                  format === 'png' ? 'format-png' : 
                                  format === 'gif' ? 'format-gif' : 
                                  format === 'webp' ? 'format-webp' : 
                                  format === 'svg' ? 'format-svg' : 
                                  format === 'bmp' ? 'format-bmp' : 
                                  format === 'tiff' || format === 'tif' ? 'format-tiff' : 
                                  format === 'ico' ? 'format-ico' : 
                                  format === 'avif' ? 'format-avif' : 
                                  format === 'heic' || format === 'heif' ? 'format-heic' : '';
                const imgClass = format === 'svg' ? 'image-preview svg' : 'image-preview';
                
                card.innerHTML = `
                    <div class="image-wrapper">
                        <span class="format-badge ${formatClass}">${format}</span>
                        <img src="/images/${image.name}" alt="${image.name}" class="${imgClass}">
                    </div>
                    <div class="image-info">
                        <div class="image-name">${image.name}</div>
                        <div class="image-details">
                            <span>${formatFileSize(image.size)}</span>
                            <span class="text-muted">${format.toUpperCase()}</span>
                            <button class="btn-delete" onclick="deleteImage('${image.name}')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                `;
                grid.appendChild(card);
            });
        }
        
        // Update statistics
        function updateStats() {
            const totalImages = images.length;
            const totalSize = images.reduce((sum, img) => sum + img.size, 0);
            const avgSize = totalImages > 0 ? totalSize / totalImages : 0;
            const lastUpload = images.length > 0 ? 
                new Date(images[images.length - 1].uploadedAt).toLocaleDateString() : '-';
            
            document.getElementById('totalImages').textContent = totalImages;
            document.getElementById('totalSize').textContent = formatFileSize(totalSize);
            document.getElementById('avgSize').textContent = formatFileSize(avgSize);
            document.getElementById('lastUpload').textContent = lastUpload;
        }
        
        // Format file size
        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }
        
        // Delete image
        async function deleteImage(name) {
            if (!confirm(`Are you sure you want to delete "${name}"?`)) {
                return;
            }
            
            try {
                const response = await fetch(`/api/images/${name}`, {
                    method: 'DELETE'
                });
                
                if (response.ok) {
                    images = images.filter(img => img.name !== name);
                    displayImages();
                    updateStats();
                    alert('Image deleted successfully!');
                } else {
                    alert('Failed to delete image');
                }
            } catch (error) {
                console.error('Error deleting image:', error);
                alert('Error deleting image');
            }
        }
        
        // File upload handling
        const uploadArea = document.getElementById('uploadArea');
        const fileInput = document.getElementById('fileInput');
        
        // Drag and drop
        uploadArea.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadArea.classList.add('dragover');
        });
        
        uploadArea.addEventListener('dragleave', () => {
            uploadArea.classList.remove('dragover');
        });
        
        uploadArea.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadArea.classList.remove('dragover');
            handleFiles(e.dataTransfer.files);
        });
        
        // File selection
        fileInput.addEventListener('change', (e) => {
            handleFiles(e.target.files);
        });
        
        // Handle file upload
        async function handleFiles(files) {
            const formData = new FormData();
            
            for (let file of files) {
                if (!file.type.startsWith('image/')) {
                    alert(`${file.name} is not an image file`);
                    continue;
                }
                
                if (file.size > 5 * 1024 * 1024) {
                    alert(`${file.name} is too large (max 5MB)`);
                    continue;
                }
                
                formData.append('images', file);
            }
            
            if (formData.has('images')) {
                try {
                    const response = await fetch('/api/upload', {
                        method: 'POST',
                        body: formData
                    });
                    
                    if (response.ok) {
                        alert('Images uploaded successfully!');
                        loadImages(); // Reload images
                    } else {
                        alert('Failed to upload images');
                    }
                } catch (error) {
                    console.error('Error uploading images:', error);
                    alert('Error uploading images');
                }
            }
        }
        
        // Load images on page load
        document.addEventListener('DOMContentLoaded', loadImages);
    </script>
</body>
</html>
