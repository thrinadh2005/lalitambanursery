<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Image Assets - Sri Lalitamba Nursery</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .admin-page-header {
            background: var(--gradient-primary);
            color: white;
            padding: 4rem 0;
            margin-bottom: 2rem;
            border-radius: 0 0 var(--radius-3xl) var(--radius-3xl);
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

        .admin-page-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43-7c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM12 86c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm66-3c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm-40-39c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm43 38c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2z' fill='%23ffffff' fill-opacity='0.05'/%3E%3C/svg%3E");
            opacity: 0.1;
        }

        .stats-glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-2xl);
            padding: 2rem;
            box-shadow: var(--shadow-xl);
            transition: all 0.3s ease;
        }

        .stats-glass-card:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.15);
        }

        .upload-glass-zone {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            border: 2px dashed var(--glass-border);
            border-radius: var(--radius-2xl);
            padding: 4rem;
            text-align: center;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .upload-glass-zone:hover, .upload-glass-zone.dragover {
            border-color: var(--primary);
            background: rgba(var(--primary-rgb), 0.05);
            transform: scale(1.01);
        }

        .image-glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-xl);
            overflow: hidden;
            transition: all 0.3s ease;
            height: 100%;
        }

        .image-glass-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-2xl);
            border-color: var(--primary);
        }

        .image-glass-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            transition: all 0.5s ease;
        }

        .image-glass-card:hover img {
            transform: scale(1.05);
        }

        .format-pill {
            position: absolute;
            top: 15px;
            right: 15px;
            background: var(--primary);
            color: white;
            padding: 0.25rem 0.75rem;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            box-shadow: var(--shadow-md);
            z-index: 10;
        }

        .asset-actions {
            background: rgba(255, 255, 255, 0.05);
            border-top: 1px solid var(--glass-border);
            padding: 1rem;
        }
    </style>
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <div class="admin-page-header">
        <div class="container px-5">
            <div class="row align-items-center">
                <div class="col-md-7" data-aos="fade-right">
                    <h1 class="display-5 fw-900 mb-2">Visual Asset Control</h1>
                    <p class="mb-0 opacity-75 fs-5">Manage high-resolution botanical imagery and media artifacts</p>
                </div>
                <div class="col-md-5 text-md-end mt-4 mt-md-0" data-aos="fade-left">
                    <div class="d-flex gap-3 justify-content-md-end">
                        <button class="btn btn-light rounded-pill px-4 py-2 fw-bold shadow-sm" onclick="document.getElementById('fileInput').click()">
                            <i class="fas fa-plus-circle me-2"></i>Inject Assets
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-5 py-4">
        <div class="row g-4">
            <main class="col-12">
                <!-- Statistics Dashboard -->
                <div class="row g-4 mb-5" data-aos="fade-up">
                    <div class="col-md-3">
                        <div class="stats-glass-card text-center">
                            <div class="text-primary mb-2"><i class="fas fa-images fa-2x"></i></div>
                            <h3 class="fw-900 mb-0" id="totalImages">0</h3>
                            <div class="text-muted small fw-bold">TOTAL ASSETS</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stats-glass-card text-center">
                            <div class="text-success mb-2"><i class="fas fa-database fa-2x"></i></div>
                            <h3 class="fw-900 mb-0" id="totalSize">0 MB</h3>
                            <div class="text-muted small fw-bold">VAULT SIZE</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stats-glass-card text-center">
                            <div class="text-info mb-2"><i class="fas fa-weight fa-2x"></i></div>
                            <h3 class="fw-900 mb-0" id="avgSize">0 KB</h3>
                            <div class="text-muted small fw-bold">AVG WEIGHT</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stats-glass-card text-center">
                            <div class="text-warning mb-2"><i class="fas fa-history fa-2x"></i></div>
                            <h3 class="fw-900 mb-0 text-truncate px-2" id="lastUpload">-</h3>
                            <div class="text-muted small fw-bold">LAST SYNC</div>
                        </div>
                    </div>
                </div>

                <!-- Injection Zone -->
                <div class="upload-glass-zone mb-5" id="uploadArea" data-aos="fade-up" data-aos-delay="100">
                    <div class="mb-3 text-primary"><i class="fas fa-cloud-upload-alt fa-4x"></i></div>
                    <h3 class="fw-900">Media Injection Gateway</h3>
                    <p class="text-muted fs-5 mb-4">Drag & drop high-res files or click to initialize manual selection</p>
                    <div class="d-flex justify-content-center gap-4 text-muted small fw-bold mb-4">
                        <span><i class="fas fa-check-circle me-1 text-success"></i> WEBP / AVIF / PNG</span>
                        <span><i class="fas fa-check-circle me-1 text-success"></i> MAX 10MB / UNIT</span>
                    </div>
                    <input type="file" id="fileInput" multiple accept="image/*" style="display: none;">
                    <button class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow-lg" onclick="document.getElementById('fileInput').click()">
                        <i class="fas fa-folder-open me-2"></i>EXPLORE SYSTEM STORAGE
                    </button>
                </div>

                <!-- Assets Catalog -->
                <div class="section-title mb-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="fw-bold mb-0 text-primary">Media Repository</h4>
                        <div class="text-muted small">Synchronized with MongoDB Atlas Storage</div>
                    </div>
                    <div class="d-flex gap-2">
                        <div class="input-group">
                            <span class="input-group-text bg-white border-0 shadow-sm"><i class="fas fa-search text-muted"></i></span>
                            <input type="text" class="form-control border-0 shadow-sm rounded-end" placeholder="Filter assets..." id="assetFilter">
                        </div>
                    </div>
                </div>

                <div id="loading" class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-3 text-muted fw-bold">Synchronizing with Vault...</p>
                </div>

                <div class="row g-4" id="imageGrid">
                    <!-- Dynamic Assets -->
                </div>
            </main>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });
        
        let images = [];
        
        async function loadImages() {
            try {
                const response = await fetch('/api/images');
                const data = await response.json();
                
                if (data.success) {
                    images = data.images;
                    displayImages();
                    updateStats();
                }
            } catch (error) {
                console.error('Failed to load assets:', error);
            } finally {
                document.getElementById('loading').style.display = 'none';
            }
        }
        
        function displayImages(filter = '') {
            const grid = document.getElementById('imageGrid');
            grid.innerHTML = '';
            
            const filtered = images.filter(img => img.name.toLowerCase().includes(filter.toLowerCase()));
            
            if (filtered.length === 0) {
                grid.innerHTML = '<div class="col-12 text-center py-5 opacity-50"><i class="fas fa-folder-open fa-3x mb-3"></i><h5>No matches found in the repository</h5></div>';
                return;
            }

            filtered.forEach(image => {
                const col = document.createElement('div');
                col.className = 'col-md-4 col-xl-3';
                col.setAttribute('data-aos', 'zoom-in');
                
                const format = image.name.split('.').pop().toLowerCase();
                
                col.innerHTML = `
                    <div class="image-glass-card">
                        <div class="position-relative">
                            <span class="format-pill">${format}</span>
                            <img src="/images/${image.name}" alt="${image.name}">
                        </div>
                        <div class="p-3">
                            <div class="fw-bold text-dark text-truncate mb-1" title="${image.name}">${image.name}</div>
                            <div class="d-flex justify-content-between align-items-center small text-muted">
                                <span>${formatFileSize(image.size)}</span>
                                <span class="fw-bold">${format.toUpperCase()}</span>
                            </div>
                        </div>
                        <div class="asset-actions d-flex justify-content-between gap-2">
                            <button class="btn btn-sm btn-light border flex-grow-1 rounded-pill" onclick="copyUrl('${image.name}')">
                                <i class="fas fa-link me-1"></i>URL
                            </button>
                            <button class="btn btn-sm btn-outline-danger border flex-grow-1 rounded-pill" onclick="deleteImage('${image.name}')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                `;
                grid.appendChild(col);
            });
        }
        
        function updateStats() {
            const totalImages = images.length;
            const totalSize = images.reduce((sum, img) => sum + img.size, 0);
            const avgSize = totalImages > 0 ? totalSize / totalImages : 0;
            const lastUpload = images.length > 0 ? 
                new Date(images[images.length - 1].uploadedAt).toLocaleDateString() : '-';
            
            document.getElementById('totalImages').textContent = totalImages;
            document.getElementById('totalSize').textContent = formatFileSize(totalSize);
            document.getElementById('avgSize').textContent = formatFileSize(avgSize);
            document.getElementById('lastUpload').textContent = lastUpload;
        }
        
        function formatFileSize(bytes) {
            if (bytes === 0) return '0 B';
            const k = 1024;
            const sizes = ['B', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
        }

        function copyUrl(name) {
            const url = window.location.origin + '/images/' + name;
            navigator.clipboard.writeText(url).then(() => {
                alert('Asset endpoint copied to clipboard');
            });
        }
        
        async function deleteImage(name) {
            if (!confirm(`Authorize permanent deletion of "${name}"?`)) return;
            
            try {
                const response = await fetch(`/api/images/${name}`, { method: 'DELETE' });
                if (response.ok) {
                    images = images.filter(img => img.name !== name);
                    displayImages();
                    updateStats();
                }
            } catch (error) {
                alert('Deauthorization failed');
            }
        }
        
        const uploadArea = document.getElementById('uploadArea');
        const fileInput = document.getElementById('fileInput');
        const assetFilter = document.getElementById('assetFilter');

        assetFilter.addEventListener('input', (e) => displayImages(e.target.value));
        
        uploadArea.addEventListener('dragover', (e) => { e.preventDefault(); uploadArea.classList.add('dragover'); });
        uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('dragover'));
        uploadArea.addEventListener('drop', (e) => { e.preventDefault(); uploadArea.classList.remove('dragover'); handleFiles(e.dataTransfer.files); });
        fileInput.addEventListener('change', (e) => handleFiles(e.target.files));
        
        async function handleFiles(files) {
            const formData = new FormData();
            for (let file of files) {
                if (file.type.startsWith('image/')) formData.append('images', file);
            }
            
            if (formData.has('images')) {
                document.getElementById('loading').style.display = 'block';
                try {
                    const response = await fetch('/api/upload', { method: 'POST', body: formData });
                    if (response.ok) loadImages();
                } catch (error) {
                    alert('Injection sequence failed');
                }
            }
        }
        
        document.addEventListener('DOMContentLoaded', loadImages);
    </script>
</body>

</html>
