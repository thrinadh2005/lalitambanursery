<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .admin-page-header {
            background: var(--gradient-primary);
            color: white;
            padding: 4rem 0;
            margin-bottom: 2rem;
            border-radius: 0 0 var(--radius-3xl) var(--radius-3xl);
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

        .admin-page-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43-7c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM12 86c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm66-3c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm-40-39c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm43 38c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2z' fill='%23ffffff' fill-opacity='0.05'/%3E%3C/svg%3E");
            opacity: 0.1;
        }

        .form-glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-2xl);
            padding: 3rem;
            box-shadow: var(--shadow-2xl);
        }

        .input-glass-group {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .input-glass-group:focus-within {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(var(--primary-rgb), 0.1);
            background: rgba(255, 255, 255, 0.1);
        }

        .input-glass-group .form-control, 
        .input-glass-group .form-select {
            background: transparent !important;
            border: none !important;
            color: var(--text-main) !important;
            box-shadow: none !important;
        }

        .transaction-badge {
            padding: 0.5rem 1.5rem;
            border-radius: 50px;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
        }
    </style>
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <div class="admin-page-header">
        <div class="container px-5">
            <div class="row align-items-center">
                <div class="col-md-7" data-aos="fade-right">
                    <h1 class="display-5 fw-900 mb-2">New Logistics Bridge</h1>
                    <p class="mb-0 opacity-75 fs-5">Initiate a cross-border or wholesale botanical transaction</p>
                </div>
                <div class="col-md-5 text-md-end mt-4 mt-md-0" data-aos="fade-left">
                    <a href="/admin/imports-exports" class="btn btn-light rounded-pill px-4 py-2 fw-bold shadow-sm">
                        <i class="fas fa-arrow-left me-2"></i>Back to Ledger
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-5 py-4">
        <div class="row g-4">
            <main class="col-12">
                <div class="row justify-content-center">
                    <div class="col-xl-9">
                        <div class="form-glass-card" data-aos="fade-up">
                            <form action="/admin/imports-exports/add" method="POST" class="needs-validation" novalidate>
                                
                                <div class="section-title mb-4">
                                    <h5 class="fw-bold mb-0 text-primary">Core Transaction Logistics</h5>
                                    <div class="text-muted small">Define the scope and identification of the manifest</div>
                                </div>

                                <div class="row g-4 mb-5">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-uppercase">Trade Vector</label>
                                        <div class="input-glass-group d-flex align-items-center p-1">
                                            <span class="px-3 text-primary"><i class="fas fa-exchange-alt"></i></span>
                                            <select class="form-select form-select-lg" name="type" required>
                                                <option value="import">Import (Botanical Acquisition)</option>
                                                <option value="export">Export (Wholesale Distribution)</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-uppercase">Manifest ID / Reference</label>
                                        <div class="input-glass-group d-flex align-items-center p-1">
                                            <span class="px-3 text-primary"><i class="fas fa-fingerprint"></i></span>
                                            <input type="text" class="form-control form-control-lg" name="referenceNumber" 
                                                required placeholder="e.g. IE-2026-XQ-42">
                                        </div>
                                        <div class="text-muted extra-small mt-2 px-2">External invoice or bill reference from partner.</div>
                                    </div>
                                </div>

                                <div class="section-title mb-4">
                                    <h5 class="fw-bold mb-0 text-primary">Strategic Partner Identity</h5>
                                    <div class="text-muted small">Collaborating entity for this transaction</div>
                                </div>

                                <div class="mb-5">
                                    <div class="input-glass-group d-flex align-items-center p-1">
                                        <span class="px-3 text-primary"><i class="fas fa-handshake"></i></span>
                                        <input type="text" class="form-control form-control-lg" name="partnerName" 
                                            required placeholder="Legal name of Supplier or Buyer entity">
                                    </div>
                                </div>

                                <div class="section-title mb-4">
                                    <h5 class="fw-bold mb-0 text-primary">Financial Consolidation</h5>
                                    <div class="text-muted small">Valuation and temporal parameters</div>
                                </div>

                                <div class="row g-4 mb-5">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-uppercase">Gross Valuation (INR)</label>
                                        <div class="input-glass-group d-flex align-items-center p-1">
                                            <span class="px-3 text-success fw-bold">₹</span>
                                            <input type="number" class="form-control form-control-lg" name="totalAmount" 
                                                required step="0.01" placeholder="0.00">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-uppercase">Execution Date</label>
                                        <div class="input-glass-group d-flex align-items-center p-1">
                                            <span class="px-3 text-primary"><i class="fas fa-calendar-check"></i></span>
                                            <input type="date" class="form-control form-control-lg" name="transactionDate" 
                                                value="<%= new Date().toISOString().split('T')[0] %>" required>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-end gap-3 mt-5 pt-5 border-top border-light">
                                    <a href="/admin/imports-exports" class="btn btn-light rounded-pill px-5 py-3 fw-bold">Discard</a>
                                    <button type="submit" class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow-lg">
                                        <i class="fas fa-shield-check me-2"></i>Authorize Transaction
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });
    </script>
</body>

</html>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>