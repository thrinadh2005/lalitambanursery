<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">
    <!-- Admin Navigation -->
    <%- include('partials/navbar') %>

        <div class="container-fluid py-4">
            <div class="row">
                <!-- Sidebar -->
                <%- include('partials/sidebar') %>

                    <!-- Main Content -->
                    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                                <li class="breadcrumb-item"><a href="/admin/imports-exports">Import/Export</a></li>
                                <li class="breadcrumb-item active">New Transaction</li>
                            </ol>
                        </nav>

                        <div class="row justify-content-center">
                            <div class="col-lg-10">
                                <div class="card shadow border-0">
                                    <div class="card-header bg-primary text-white py-3">
                                        <h4 class="mb-0">
                                            <i class="fas fa-truck me-2"></i>New Import/Export Transaction
                                        </h4>
                                    </div>
                                    <div class="card-body p-4">
                                        <form action="/admin/imports-exports/add" method="POST">
                                            <div class="row">
                                                <div class="col-md-6 mb-4">
                                                    <label class="form-label fw-bold">Transaction Type</label>
                                                    <select class="form-select" name="type">
                                                        <option value="import">Import (Purchase)</option>
                                                        <option value="export">Export (Wholesale Sale)</option>
                                                    </select>
                                                </div>
                                                <div class="col-md-6 mb-4">
                                                    <label class="form-label fw-bold">Reference Number</label>
                                                    <input type="text" class="form-control" name="referenceNumber"
                                                        required placeholder="e.g. IE-2026-001">
                                                    <small class="text-muted">Bill or invoice number from
                                                        partner.</small>
                                                </div>
                                            </div>

                                            <div class="card bg-light border-0 mb-4">
                                                <div class="card-body">
                                                    <h5 class="card-title text-primary mb-3">Partner Information</h5>
                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold">Partner Name
                                                            (Supplier/Buyer)</label>
                                                        <input type="text" class="form-control" name="partnerName"
                                                            required placeholder="e.g. Southern Green Supplies">
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="card bg-light border-0 mb-4">
                                                <div class="card-body">
                                                    <h5 class="card-title text-primary mb-3">Financial Details</h5>
                                                    <div class="row">
                                                        <div class="col-md-6 mb-3">
                                                            <label class="form-label fw-bold">Total Amount (₹)</label>
                                                            <div class="input-group">
                                                                <span class="input-group-text">₹</span>
                                                                <input type="number" class="form-control"
                                                                    name="totalAmount" required step="0.01">
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6 mb-3">
                                                            <label class="form-label fw-bold">Transaction Date</label>
                                                            <input type="date" class="form-control"
                                                                name="transactionDate"
                                                                value="<%= new Date().toISOString().split('T')[0] %>"
                                                                required>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="d-flex justify-content-end gap-2 border-top pt-4">
                                                <a href="/admin/imports-exports"
                                                    class="btn btn-outline-secondary px-4">Cancel</a>
                                                <button type="submit" class="btn btn-primary px-5">
                                                    <i class="fas fa-save me-2"></i>Save Transaction
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </main>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>