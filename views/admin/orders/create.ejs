<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .admin-order-card {
            border-radius: 15px;
            border: none;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
        .table-items thead th {
            background-color: #f8fafc;
            color: #64748b;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            padding: 1rem;
        }
        #posResults {
            z-index: 1050;
            max-height: 300px;
            overflow-y: auto;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }
        .search-item:hover {
            background-color: #f0fdf4;
            cursor: pointer;
        }
    </style>
</head>
<body class="bg-light">
    <!-- Navigation -->
    <%- include('../partials/navbar') %>

    <div class="container-fluid px-md-5 px-3 py-4">
        <div class="row">
            <main class="col-12 px-md-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1 class="h2"><i class="fas fa-shopping-cart me-2"></i><%= typeof order !== 'undefined' ? 'Edit Order #' + order._id.toString().slice(-8).toUpperCase() : 'Create New Order' %></h1>
                </div>

                <!-- Flash Messages -->
                <% if (typeof messages !== 'undefined' && messages.error_msg && messages.error_msg.length > 0) { %>
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="fas fa-exclamation-circle me-2"></i><%= messages.error_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <form action="<%= typeof order !== 'undefined' ? '/admin/orders/edit/' + order._id : '/admin/orders/create' %>" method="POST" id="adminOrderForm">
                    <div class="row">
                        <div class="col-lg-8">
                            <!-- Customer Selection -->
                            <div class="card admin-order-card mb-4">
                                <div class="card-header bg-white py-3">
                                    <h5 class="mb-0 text-primary"><i class="fas fa-user me-2"></i>Customer Details</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold">Customer Type</label>
                                            <select id="customerType" class="form-select" onchange="toggleCustomerType()" <%= typeof order !== 'undefined' ? 'disabled' : '' %>>
                                                <option value="existing" <%= (typeof order !== 'undefined' && order.user) ? 'selected' : '' %>>Existing Registered User</option>
                                                <option value="new" <%= (typeof order !== 'undefined' && !order.user) ? 'selected' : '' %>>New / Guest Customer</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label fw-bold">Payment Method</label>
                                            <select name="paymentMethod" class="form-select">
                                                <option value="cod" <%= (typeof order !== 'undefined' && order.paymentMethod === 'cod') ? 'selected' : '' %>>Cash on Delivery</option>
                                                <option value="online" <%= (typeof order !== 'undefined' && order.paymentMethod === 'online') ? 'selected' : '' %>>Online Payment</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div id="existingCustomerSection" class="<%= (typeof order !== 'undefined' && !order.user) ? 'd-none' : '' %>">
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Select Registered User</label>
                                            <select name="userId" id="userIdSelect" class="form-select" <%= typeof order !== 'undefined' ? 'disabled' : '' %>>
                                                <option value="">Choose a user...</option>
                                                <% if (typeof users !== 'undefined') { %>
                                                    <% users.forEach(u => { %>
                                                        <option value="<%= u._id %>" 
                                                            data-name="<%= u.firstName %> <%= u.lastName %>"
                                                            data-phone="<%= u.phone %>"
                                                            data-address="<%= u.address %>"
                                                            <%= (typeof order !== 'undefined' && order.user && order.user._id.toString() === u._id.toString()) ? 'selected' : '' %>>
                                                            <%= u.firstName %> <%= u.lastName %> (<%= u.email %>)
                                                        </option>
                                                    <% }); %>
                                                <% } %>
                                            </select>
                                            <% if (typeof order !== 'undefined' && order.user) { %>
                                                <input type="hidden" name="userId" value="<%= order.user._id %>">
                                            <% } %>
                                        </div>
                                    </div>

                                    <div id="newCustomerSection" class="<%= (typeof order !== 'undefined' && order.user) ? 'd-none' : (typeof order === 'undefined' ? 'd-none' : '') %>">
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label fw-bold">Customer Name</label>
                                                <input type="text" name="customerName" id="customerName" class="form-control" placeholder="Enter name" value="<%= typeof order !== 'undefined' && !order.user ? order.shippingAddress.fullName : '' %>">
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label fw-bold">Customer Phone</label>
                                                <input type="tel" name="customerPhone" id="customerPhone" class="form-control" placeholder="Enter phone" value="<%= typeof order !== 'undefined' && !order.user ? order.shippingAddress.phone : '' %>">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Items Section -->
                            <div class="card admin-order-card mb-4">
                                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0 text-success"><i class="fas fa-leaf me-2"></i>Order Items</h5>
                                    <button type="button" class="btn btn-outline-success btn-sm" id="addRowBtn">
                                        <i class="fas fa-plus me-1"></i> Add Row
                                    </button>
                                </div>
                                <div class="card-body p-0">
                                    <!-- Search Bar -->
                                    <div class="p-3 border-bottom bg-light">
                                        <div class="position-relative">
                                            <div class="input-group">
                                                <span class="input-group-text bg-white border-end-0">
                                                    <i class="fas fa-search text-muted"></i>
                                                </span>
                                                <input id="plantSearch" type="text" class="form-control border-start-0" 
                                                    placeholder="Search catalog or type custom plant name..." autocomplete="off">
                                            </div>
                                            <ul id="posResults" class="list-group position-absolute w-100 bg-white shadow-lg" style="display: none;">
                                            </ul>
                                        </div>
                                    </div>

                                    <div class="table-responsive">
                                        <table class="table table-hover mb-0" id="itemsTable">
                                            <thead class="table-light">
                                                <tr>
                                                    <th style="width: 5%">#</th>
                                                    <th style="width: 45%">Plant Name</th>
                                                    <th style="width: 25%">Packet/Size</th>
                                                    <th style="width: 15%" class="text-center">Quantity</th>
                                                    <th style="width: 10%"></th>
                                                </tr>
                                            </thead>
                                            <tbody id="itemsBody">
                                                <!-- Dynamic Rows -->
                                                <% if (typeof order !== 'undefined' && order.items) { %>
                                                    <% order.items.forEach((item, index) => { %>
                                                        <tr>
                                                            <td class="align-middle text-muted small"><%= index + 1 %></td>
                                                            <td>
                                                                <input type="hidden" class="item-plant-id" value="<%= item.plant || '' %>">
                                                                <input type="text" class="form-control item-name" value="<%= item.name %>" placeholder="Plant Name" required>
                                                            </td>
                                                            <td>
                                                                <input type="text" class="form-control item-packet" value="<%= item.packetSize || item.size %>" placeholder="Select size..." readonly onclick="openModalForExistingRow(this)">
                                                            </td>
                                                            <td>
                                                                <input type="number" class="form-control text-center item-qty" value="<%= item.quantity %>" min="1" required>
                                                            </td>
                                                            <td class="text-center">
                                                                <button type="button" class="btn btn-link text-danger p-0" onclick="this.closest('tr').remove(); updateRowNumbers();">
                                                                    <i class="fas fa-trash"></i>
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4">
                            <!-- Shipping Info -->
                            <div class="card admin-order-card mb-4">
                                <div class="card-header bg-info text-white py-3">
                                    <h5 class="mb-0"><i class="fas fa-truck me-2"></i>Shipping Address</h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Full Name</label>
                                        <input type="text" name="shippingAddress[fullName]" id="shipName" class="form-control" required value="<%= typeof order !== 'undefined' ? order.shippingAddress.fullName : '' %>">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Phone</label>
                                        <input type="tel" name="shippingAddress[phone]" id="shipPhone" class="form-control" required value="<%= typeof order !== 'undefined' ? order.shippingAddress.phone : '' %>">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Address</label>
                                        <textarea name="shippingAddress[address]" id="shipAddress" class="form-control" rows="3" required><%= typeof order !== 'undefined' ? order.shippingAddress.address : '' %></textarea>
                                    </div>
                                    <div class="row">
                                        <div class="col-6 mb-3">
                                            <label class="form-label fw-bold">City</label>
                                            <input type="text" name="shippingAddress[city]" class="form-control" required value="<%= typeof order !== 'undefined' ? order.shippingAddress.city : 'N/A' %>">
                                        </div>
                                        <div class="col-6 mb-3">
                                            <label class="form-label fw-bold">Zip Code</label>
                                            <input type="text" name="shippingAddress[zipCode]" class="form-control" required value="<%= typeof order !== 'undefined' ? order.shippingAddress.zipCode : 'N/A' %>">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Fulfillment Info -->
                            <div class="card admin-order-card mb-4">
                                <div class="card-header bg-warning py-3">
                                    <h5 class="mb-0"><i class="fas fa-clock me-2"></i>Fulfillment</h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Delivery Deadline</label>
                                        <input type="date" name="deliveryDeadline" class="form-control" required
                                            value="<%= typeof order !== 'undefined' ? new Date(order.deliveryDeadline).toISOString().split('T')[0] : new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString().split('T')[0] %>">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Status</label>
                                        <select name="status" class="form-select">
                                            <option value="pending" <%= (typeof order !== 'undefined' && order.status === 'pending') ? 'selected' : '' %>>Pending</option>
                                            <option value="processing" <%= (typeof order !== 'undefined' && order.status === 'processing') ? 'selected' : '' %>>Processing</option>
                                            <option value="shipped" <%= (typeof order !== 'undefined' && order.status === 'shipped') ? 'selected' : '' %>>Shipped</option>
                                            <option value="delivered" <%= (typeof order !== 'undefined' && order.status === 'delivered') ? 'selected' : '' %>>Delivered</option>
                                            <option value="cancelled" <%= (typeof order !== 'undefined' && order.status === 'cancelled') ? 'selected' : '' %>>Cancelled</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Order Notes</label>
                                <textarea name="notes" class="form-control" rows="3" placeholder="Any special instructions for this order?"><%= typeof order !== 'undefined' ? order.notes : '' %></textarea>
                            </div>

                            <input type="hidden" name="items" id="itemsJson">
                            
                            <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm py-3 mb-4">
                                <i class="fas fa-check-circle me-2"></i> <%= typeof order !== 'undefined' ? 'Update Order' : 'Create Order' %>
                            </button>
                        </div>
                    </div>
                </form>
            </main>
        </div>
    </div>

    <div class="modal fade" id="itemConfigModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header bg-success text-white rounded-top-4 py-3">
                    <h5 class="modal-title fw-bold" id="modalPlantName">Configure Item</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" id="modalPlantId">
                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark">Select Size</label>
                        <select id="modalSize" class="form-select form-select-lg border-2">
                            <option value="" disabled selected>-- Select Size --</option>
                            <option value="5/6 (Small Pot)">5/6 (Small Pot)</option>
                            <option value="6/7 (Standard)">6/7 (Standard)</option>
                            <option value="8/10 (Medium)">8/10 (Medium)</option>
                            <option value="9/10">9/10</option>
                            <option value="12/12 (Large)">12/12 (Large)</option>
                            <option value="13/13">13/13</option>
                            <option value="14/15">14/15</option>
                            <option value="15/16 (XL)">15/16 (XL)</option>
                            <option value="18/18">18/18</option>
                            <option value="21/21">21/21</option>
                            <option value="25/25">25/25</option>
                            <option value="30/30 (XXL)">30/30 (XXL)</option>
                            <option value="40/50 (Jumbo)">40/50 (Jumbo)</option>
                            <option value="Packet of Seeds (10g)">Packet of Seeds (10g)</option>
                            <option value="Packet of Seeds (50g)">Packet of Seeds (50g)</option>
                            <option value="Packet of Seeds (100g)">Packet of Seeds (100g)</option>
                            <option value="Single Plant (Graft)">Single Plant (Graft)</option>
                            <option value="Single Plant (Seedling)">Single Plant (Seedling)</option>
                            <option value="Bundle (10 Plants)">Bundle (10 Plants)</option>
                            <option value="Wholesale (100+ Plants)">Wholesale (100+ Plants)</option>
                            <option value="Other (Custom)">Other (Custom)</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-bold text-dark">Quantity Required</label>
                        <div class="input-group input-group-lg">
                            <button class="btn btn-outline-secondary border-2" type="button" onclick="adjustQty(-1)">
                                <i class="fas fa-minus"></i>
                            </button>
                            <input type="number" id="modalQty" class="form-control text-center border-2 fw-bold" value="1" min="1">
                            <button class="btn btn-outline-secondary border-2" type="button" onclick="adjustQty(1)">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light btn-lg px-4 rounded-pill fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success btn-lg px-5 rounded-pill fw-bold shadow" onclick="confirmAddItem()">
                        Add to List
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        const itemsBody = document.getElementById('itemsBody');
        const addRowBtn = document.getElementById('addRowBtn');
        const plantSearch = document.getElementById('plantSearch');
        const posResults = document.getElementById('posResults');
        const itemsJson = document.getElementById('itemsJson');
        const adminOrderForm = document.getElementById('adminOrderForm');
        
        // Modal elements
        const itemConfigModal = new bootstrap.Modal(document.getElementById('itemConfigModal'));
        const modalPlantName = document.getElementById('modalPlantName');
        const modalPlantId = document.getElementById('modalPlantId');
        const modalSize = document.getElementById('modalSize');
        const modalQty = document.getElementById('modalQty');

        let rowCount = 0;

        function addRow(data = {}) {
            rowCount++;
            const row = document.createElement('tr');
            row.innerHTML = `
                <td class="align-middle text-muted small">${rowCount}</td>
                <td>
                    <input type="hidden" class="item-plant-id" value="${data.id || ''}">
                    <input type="text" class="form-control item-name" value="${data.name || ''}" placeholder="Plant Name" required>
                </td>
                <td>
                    <input type="text" class="form-control item-packet" value="${data.packet || ''}" placeholder="Select size..." readonly onclick="openModalForExistingRow(this)">
                </td>
                <td>
                    <input type="number" class="form-control text-center item-qty" value="${data.qty || 1}" min="1" required>
                </td>
                <td class="text-center">
                    <button type="button" class="btn btn-link text-danger p-0" onclick="this.closest('tr').remove(); updateRowNumbers();">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            `;
            itemsBody.appendChild(row);
            return row;
        }

        function updateRowNumbers() {
            const rows = itemsBody.querySelectorAll('tr');
            rowCount = 0;
            rows.forEach((row) => {
                rowCount++;
                row.cells[0].textContent = rowCount;
            });
        }

        // Customer Selection Logic
        function toggleCustomerType() {
            const type = document.getElementById('customerType').value;
            document.getElementById('existingCustomerSection').style.display = type === 'existing' ? 'block' : 'none';
            document.getElementById('newCustomerSection').style.display = type === 'new' ? 'block' : 'none';
            
            if (type === 'new') {
                document.getElementById('shipName').value = '';
                document.getElementById('shipPhone').value = '';
                document.getElementById('shipAddress').value = '';
            }
        }

        document.getElementById('userIdSelect').addEventListener('change', function() {
            const option = this.options[this.selectedIndex];
            if (option.value) {
                document.getElementById('shipName').value = option.dataset.name;
                document.getElementById('shipPhone').value = option.dataset.phone || '';
                document.getElementById('shipAddress').value = option.dataset.address || '';
            }
        });

        // Search Logic
        let searchTimeout;
        plantSearch.addEventListener('input', (e) => {
            const query = e.target.value.trim();
            clearTimeout(searchTimeout);
            if (query.length < 2) {
                posResults.style.display = 'none';
                return;
            }
            searchTimeout = setTimeout(async () => {
                try {
                    const res = await fetch(`/api/billing/catalog/search?q=${encodeURIComponent(query)}`);
                    const data = await res.json();
                    if (data.success && data.results.length > 0) {
                        posResults.innerHTML = '';
                        data.results.forEach(plant => {
                            const li = document.createElement('li');
                            li.className = 'list-group-item search-item d-flex justify-content-between align-items-center';
                            li.innerHTML = `<div><div class="fw-bold">${plant.name}</div><small class="text-muted">${plant.category}</small></div>`;
                            li.onclick = () => {
                                showConfigModal(plant.name, plant._id);
                                plantSearch.value = '';
                                posResults.style.display = 'none';
                            };
                            posResults.appendChild(li);
                        });
                        posResults.style.display = 'block';
                    } else {
                        posResults.style.display = 'none';
                    }
                } catch (err) { console.error(err); }
            }, 300);
        });

        function openModalForExistingRow(input) {
            const row = input.closest('tr');
            const name = row.querySelector('.item-name').value;
            const id = row.querySelector('.item-plant-id').value;
            const packet = row.querySelector('.item-packet').value;
            const qty = row.querySelector('.item-qty').value;

            modalPlantName.textContent = name;
            modalPlantId.value = id;
            modalSize.value = packet;
            modalQty.value = qty;
            
            // Store the row reference index to update it later
            document.getElementById('itemConfigModal').dataset.editingRow = Array.from(itemsBody.querySelectorAll('tr')).indexOf(row);
            
            itemConfigModal.show();
        }

        function showConfigModal(name, id = '') {
            modalPlantName.textContent = name;
            modalPlantId.value = id;
            modalSize.value = "";
            modalQty.value = 1;
            delete document.getElementById('itemConfigModal').dataset.editingRow;
            itemConfigModal.show();
        }

        function adjustQty(amount) {
            let current = parseInt(modalQty.value) || 1;
            modalQty.value = Math.max(1, current + amount);
        }

        function confirmAddItem() {
            const name = modalPlantName.textContent;
            const id = modalPlantId.value;
            const size = modalSize.value;
            const qty = modalQty.value;

            if (!size) {
                alert('Please select a size');
                return;
            }

            const editingRowIndex = document.getElementById('itemConfigModal').dataset.editingRow;
            if (editingRowIndex !== undefined && editingRowIndex !== "") {
                const rows = itemsBody.querySelectorAll('tr');
                const row = rows[editingRowIndex];
                if (row) {
                    row.querySelector('.item-name').value = name;
                    row.querySelector('.item-plant-id').value = id;
                    row.querySelector('.item-packet').value = size;
                    row.querySelector('.item-qty').value = qty;
                    delete document.getElementById('itemConfigModal').dataset.editingRow;
                    itemConfigModal.hide();
                    return;
                }
            }

            addRow({
                id: id,
                name: name,
                packet: size,
                qty: qty
            });

            itemConfigModal.hide();
        }

        // Add Row button now triggers modal for custom item
        addRowBtn.addEventListener('click', () => {
            const customName = prompt("Enter Custom Plant Name:");
            if (customName) {
                showConfigModal(customName);
            }
        });

        // Add custom on Enter
        plantSearch.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                const name = plantSearch.value.trim();
                if (name) { 
                    showConfigModal(name);
                    plantSearch.value = ''; 
                    posResults.style.display = 'none'; 
                }
            }
        });

        // Form Submit
        adminOrderForm.addEventListener('submit', (e) => {
            const items = [];
            itemsBody.querySelectorAll('tr').forEach(row => {
                const name = row.querySelector('.item-name').value.trim();
                if (name) {
                    items.push({
                        plantId: row.querySelector('.item-plant-id').value,
                        name: name,
                        packetSize: row.querySelector('.item-packet').value.trim(),
                        quantity: row.querySelector('.item-qty').value
                    });
                }
            });
            if (items.length === 0) {
                e.preventDefault();
                alert('Please add at least one item');
                return;
            }
            itemsJson.value = JSON.stringify(items);
        });
    </script>
</body>
</html>