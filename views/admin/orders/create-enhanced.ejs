<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !=='undefined' ? title : 'Order Management' %> - SRI LALITAMBA NURSERY</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .admin-page-header {
            background: linear-gradient(135deg, #059669, #10b981);
            color: white;
            padding: 4rem 0;
            margin-bottom: 2rem;
            border-radius: 0 0 var(--radius-3xl) var(--radius-3xl);
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

        .admin-page-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M40 0l40 40-40 40L0 40z' fill='%23ffffff' fill-opacity='0.03'/%3E%3C/svg%3E");
            opacity: 0.1;
        }

        .form-glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-2xl);
            padding: 2.5rem;
            box-shadow: var(--shadow-2xl);
        }

        .input-glass-group {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .input-glass-group:focus-within {
            border-color: #10b981;
            box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
            background: rgba(255, 255, 255, 0.1);
        }

        .input-glass-group .form-control, 
        .input-glass-group .form-select,
        .input-glass-group .input-group-text {
            background: transparent !important;
            border: none !important;
            color: var(--text-main) !important;
            box-shadow: none !important;
        }

        .pos-table thead th {
            background: rgba(0, 0, 0, 0.02);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.1em;
            font-weight: 800;
            color: var(--text-muted);
            padding: 1rem;
            border-bottom: 2px solid var(--border-light);
        }

        .pos-table tbody td {
            padding: 0.75rem;
            vertical-align: middle;
            border-bottom: 1px solid var(--border-light);
        }

        .summary-pill {
            background: rgba(16, 185, 129, 0.05);
            border-radius: var(--radius-xl);
            padding: 1.5rem;
            border: 1px solid rgba(16, 185, 129, 0.1);
        }

        .total-hero {
            font-size: 2.5rem;
            font-weight: 900;
            color: #10b981;
        }

        .search-results-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-2xl);
            z-index: 1100;
        }

        .active-result {
            background: rgba(16, 185, 129, 0.1) !important;
            border-left: 4px solid #10b981 !important;
        }

        .row-active {
            background: rgba(16, 185, 129, 0.02);
        }

        .item-image-preview {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            object-fit: cover;
            background: #f1f5f9;
        }
    </style>
</head>

<body class="bg-light">
    <%- include('../partials/navbar') %>

    <div class="admin-page-header">
        <div class="container px-5">
            <div class="row align-items-center">
                <div class="col-md-7" data-aos="fade-right">
                    <h1 class="display-5 fw-900 mb-2"><%= (typeof order !=='undefined' && order) ? 'Modify Logistics Manifest' : 'Initialize New Order' %></h1>
                    <p class="mb-0 opacity-75 fs-5">Administrative fulfillment and order lifecycle management</p>
                </div>
                <div class="col-md-5 text-md-end mt-4 mt-md-0" data-aos="fade-left">
                    <div class="d-flex gap-3 justify-content-md-end">
                        <a href="/admin/orders" class="btn btn-light rounded-pill px-4 py-2 fw-bold shadow-sm">
                            <i class="fas fa-arrow-left me-2"></i>Back to Orders
                        </a>
                        <button type="button" class="btn btn-glass-success rounded-pill px-4 fw-bold" onclick="submitOrderForm()">
                            <i class="fas fa-check-circle me-2"></i>Finalize Order
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-5 py-4">
        <form action="<%= (typeof order !== 'undefined' && order) ? '/admin/orders/edit/' + order._id : '/admin/orders/create' %>" method="POST" id="orderForm">
            <div class="row g-4">
                <div class="col-xl-8">
                    <!-- Customer & Shipping Section -->
                    <div class="form-glass-card mb-4" data-aos="fade-up">
                        <div class="section-title mb-4">
                            <h5 class="fw-bold mb-0 text-success">Client & Destination Coordinates</h5>
                            <div class="text-muted small">Account holder and physical fulfillment parameters</div>
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-7">
                                <label class="form-label fw-bold small text-uppercase">Account Holder / User</label>
                                <div class="input-glass-group d-flex align-items-center">
                                    <span class="px-3 text-success"><i class="fas fa-user-circle"></i></span>
                                    <select name="userId" class="form-select form-select-lg" required>
                                        <option value="">-- Identify Registered User --</option>
                                        <% users.forEach(u => { %>
                                            <option value="<%= u._id %>" <%= (typeof order !== 'undefined' && order && order.user && order.user.toString() === u._id.toString()) ? 'selected' : '' %>>
                                                <%= u.firstName %> <%= u.lastName %> (<%= u.email %>)
                                            </option>
                                        <% }) %>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-5">
                                <label class="form-label fw-bold small text-uppercase">Settlement Medium</label>
                                <div class="input-glass-group d-flex align-items-center">
                                    <span class="px-3 text-success"><i class="fas fa-wallet"></i></span>
                                    <select name="paymentMethod" class="form-select form-select-lg">
                                        <option value="cod" <%= (typeof order !== 'undefined' && order && order.paymentMethod === 'cod') ? 'selected' : '' %>>Cash on Delivery (COD)</option>
                                        <option value="online" <%= (typeof order !== 'undefined' && order && order.paymentMethod === 'online') ? 'selected' : '' %>>Electronic / Online Transfer</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5">
                            <h6 class="fw-800 text-muted small text-uppercase mb-3"><i class="fas fa-truck-loading me-2"></i>Shipping Parameters</h6>
                            <div class="row g-3">
                                <div class="col-md-8">
                                    <label class="form-label small text-muted">Consignee Name</label>
                                    <div class="input-glass-group">
                                        <input type="text" class="form-control" name="shippingAddress[fullName]" placeholder="Full Name" 
                                            value="<%= (typeof order !== 'undefined' && order && order.shippingAddress) ? order.shippingAddress.fullName : '' %>" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small text-muted">Contact Frequency</label>
                                    <div class="input-glass-group">
                                        <input type="tel" class="form-control" name="shippingAddress[phone]" placeholder="Phone Number" 
                                            value="<%= (typeof order !== 'undefined' && order && order.shippingAddress) ? order.shippingAddress.phone : '' %>" required>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <label class="form-label small text-muted">Destination Address</label>
                                    <div class="input-glass-group">
                                        <input type="text" class="form-control" name="shippingAddress[address]" placeholder="Street, Building, Area..." 
                                            value="<%= (typeof order !== 'undefined' && order && order.shippingAddress) ? order.shippingAddress.address : '' %>" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small text-muted">City</label>
                                    <div class="input-glass-group">
                                        <input type="text" class="form-control" name="shippingAddress[city]" placeholder="City" 
                                            value="<%= (typeof order !== 'undefined' && order && order.shippingAddress) ? order.shippingAddress.city : '' %>" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small text-muted">State</label>
                                    <div class="input-glass-group">
                                        <input type="text" class="form-control" name="shippingAddress[state]" placeholder="State" 
                                            value="<%= (typeof order !== 'undefined' && order && order.shippingAddress) ? order.shippingAddress.state : '' %>" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small text-muted">Pincode</label>
                                    <div class="input-glass-group">
                                        <input type="text" class="form-control" name="shippingAddress[zipCode]" placeholder="ZIP Code" 
                                            value="<%= (typeof order !== 'undefined' && order && order.shippingAddress) ? order.shippingAddress.zipCode : '' %>" required>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Items Manifest Section -->
                    <div class="form-glass-card" data-aos="fade-up" data-aos-delay="100">
                        <div class="section-title mb-4 d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="fw-bold mb-0 text-success">Consignment Manifest</h5>
                                <div class="text-muted small">Botanical specimens included in this shipment</div>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3" id="clearItemsBtn">
                                    <i class="fas fa-trash-alt me-1"></i>Reset List
                                </button>
                                <button type="button" class="btn btn-success btn-sm rounded-pill px-3" id="addEmptyItemBtn">
                                    <i class="fas fa-plus me-1"></i>New Entry
                                </button>
                            </div>
                        </div>

                        <!-- Search Interface -->
                        <div class="mb-4 position-relative">
                            <div class="input-glass-group d-flex align-items-center p-1">
                                <span class="px-3 text-success"><i class="fas fa-search"></i></span>
                                <input id="posSearch" type="text" class="form-control form-control-lg" 
                                    placeholder="Scan catalog or type botanical variety name..." autocomplete="off">
                            </div>
                            <ul id="posResults" class="list-group position-absolute w-100 search-results-glass mt-1" style="display: none;"></ul>
                        </div>

                        <div class="table-responsive">
                            <table class="table pos-table mb-0" id="itemsTable">
                                <thead>
                                    <tr>
                                        <th style="width:40px">#</th>
                                        <th style="width:120px">Spec (Size)</th>
                                        <th>Botanical Identity</th>
                                        <th style="width:100px" class="text-center">Qty</th>
                                        <th style="width:140px" class="text-end">Unit Rate</th>
                                        <th style="width:140px" class="text-end">Line Total</th>
                                        <th style="width:50px"></th>
                                    </tr>
                                </thead>
                                <tbody id="itemsTbody">
                                    <!-- Rows dynamic -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-xl-4">
                    <!-- Fulfillment Control & Summary -->
                    <div class="form-glass-card sticky-top" style="top: 100px; z-index: 100;" data-aos="fade-left">
                        <div class="section-title mb-4">
                            <h5 class="fw-bold mb-0 text-success">Fulfillment Control</h5>
                            <div class="text-muted small">Current status and financial consolidation</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-uppercase">Workflow Status</label>
                            <div class="input-glass-group d-flex align-items-center">
                                <span class="px-3 text-success"><i class="fas fa-stream"></i></span>
                                <select name="status" id="statusSelect" class="form-select fw-bold">
                                    <option value="pending" <%= (typeof order !== 'undefined' && order && order.status === 'pending') ? 'selected' : '' %>>PENDING APPROVAL</option>
                                    <option value="processing" <%= (typeof order !== 'undefined' && order && order.status === 'processing') ? 'selected' : '' %>>IN PROCESSING</option>
                                    <option value="shipped" <%= (typeof order !== 'undefined' && order && order.status === 'shipped') ? 'selected' : '' %>>SHIPPED / IN TRANSIT</option>
                                    <option value="delivered" <%= (typeof order !== 'undefined' && order && order.status === 'delivered') ? 'selected' : '' %>>FULFILLED / DELIVERED</option>
                                    <option value="cancelled" <%= (typeof order !== 'undefined' && order && order.status === 'cancelled') ? 'selected' : '' %>>VOIDED / CANCELLED</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-uppercase">Projected Delivery</label>
                            <div class="input-glass-group d-flex align-items-center">
                                <span class="px-3 text-success"><i class="fas fa-calendar-alt"></i></span>
                                <input type="date" class="form-control" name="deliveryDeadline" 
                                    value="<%= (typeof order !== 'undefined' && order && order.deliveryDeadline) ? order.deliveryDeadline.toISOString().split('T')[0] : '' %>" required>
                            </div>
                        </div>

                        <div class="summary-pill mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted small fw-bold">TOTAL LINE ITEMS</span>
                                <span id="totalQtyDisplay" class="badge bg-success rounded-pill px-3 py-2 fw-bold fs-6">0</span>
                            </div>
                            
                            <div class="pt-3 border-top border-light mt-3">
                                <div class="d-flex justify-content-between align-items-end">
                                    <div class="text-muted small fw-bold">CUMULATIVE VALUE</div>
                                    <div class="total-hero" id="totalAmountDisplay">₹0.00</div>
                                    <input type="hidden" name="totalAmount" id="totalAmountInput" value="0">
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-success w-100 btn-lg rounded-pill py-3 fw-900 shadow-lg" onclick="submitOrderForm()">
                            <i class="fas fa-check-circle me-2"></i><%= (typeof order !=='undefined' && order) ? 'AUTHORIZE CHANGES' : 'GENERATE ORDER' %>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <!-- Hidden Datalists -->
    <datalist id="sizeCatalogList">
        <option value="small"><option value="medium"><option value="large"><option value="extra-large">
        <option value="5/6"><option value="6/7"><option value="8/10"><option value="9/10"><option value="12/12">
        <option value="13/13"><option value="14/15"><option value="15/16"><option value="18/18"><option value="21/21">
    </datalist>

    <%- include('../../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>

    <script>
        // Seed data
        window.availablePlants = <%- JSON.stringify(typeof plants !== 'undefined' ? plants : []) %>;
        window.serverItems = <%- JSON.stringify((typeof order !== 'undefined' && order && order.items) ? order.items : []) %>;

        if (typeof AOS !== 'undefined') {
            AOS.init({ duration: 800, once: true });
        }

        // ============================================================
        // ORDER FORM LOGIC
        // ============================================================
        let items = window.serverItems.map(item => ({
            plant: item.plant || null,
            name: item.name || '',
            size: item.size || 'medium',
            quantity: Number(item.quantity) || 1,
            price: Number(item.price) || 0,
            image: item.image || '/images/placeholder-plant.jpg'
        }));

        if (items.length === 0) {
            items.push({ plant: null, name: '', size: 'medium', quantity: 1, price: 0, image: '/images/placeholder-plant.jpg' });
        }

        function renderItems() {
            const tbody = document.getElementById('itemsTbody');
            if (!tbody) return;

            if (items.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="text-center py-5 text-muted">
                    <i class="fas fa-box-open fa-2x mb-3 opacity-25 d-block"></i>
                    No specimens selected. Use the search bar above to build the manifest.
                </td></tr>`;
                calculateTotals();
                return;
            }

            tbody.innerHTML = '';
            items.forEach((item, idx) => {
                const tr = document.createElement('tr');
                tr.id = `row-${idx}`;
                const itemTotal = item.quantity * item.price;
                tr.innerHTML = `
                    <td class="text-muted small fw-bold">${idx + 1}</td>
                    <td>
                        <input type="text" id="size-${idx}" class="form-control form-control-sm"
                            placeholder="Size" value="${escHtml(item.size)}"
                            list="sizeCatalogList" onchange="fieldChanged(${idx},'size',this.value)" onfocus="rowFocus(${idx})">
                    </td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <img src="${item.image}" class="item-image-preview shadow-sm">
                            <input type="text" id="name-${idx}" class="form-control form-control-sm fw-bold"
                                placeholder="Botanical Name" value="${escHtml(item.name)}"
                                onchange="fieldChanged(${idx},'name',this.value)" onfocus="rowFocus(${idx})">
                        </div>
                    </td>
                    <td>
                        <input type="number" id="qty-${idx}" class="form-control form-control-sm text-center fw-bold text-success"
                            value="${item.quantity}" min="1"
                            oninput="fieldChanged(${idx},'quantity',this.value)" onfocus="this.select(); rowFocus(${idx})">
                    </td>
                    <td>
                        <input type="number" id="rate-${idx}" class="form-control form-control-sm text-end fw-bold"
                            value="${item.price}" step="0.01" min="0"
                            oninput="fieldChanged(${idx},'price',this.value)" onfocus="this.select(); rowFocus(${idx})">
                    </td>
                    <td class="text-end fw-900 text-success" id="total-${idx}">
                        ₹${fmtNum(itemTotal)}
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-sm btn-link text-danger p-0" onclick="removeItem(${idx})">
                            <i class="fas fa-times-circle"></i>
                        </button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
            calculateTotals();
        }

        function escHtml(str) {
            return String(str || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }
        function fmtNum(n) {
            return (Number(n) || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function rowFocus(idx) {
            document.querySelectorAll('#itemsTable tr').forEach(r => r.classList.remove('row-active'));
            document.getElementById(`row-${idx}`)?.classList.add('row-active');
        }

        function fieldChanged(idx, field, value) {
            if (!items[idx]) return;
            if (field === 'quantity' || field === 'price') {
                items[idx][field] = parseFloat(value) || 0;
            } else {
                items[idx][field] = value;
            }
            const totalEl = document.getElementById(`total-${idx}`);
            if (totalEl) totalEl.textContent = '₹' + fmtNum(items[idx].quantity * items[idx].price);
            calculateTotals();
        }

        window.removeItem = function(idx) {
            items.splice(idx, 1);
            renderItems();
        };

        document.getElementById('addEmptyItemBtn').addEventListener('click', () => {
            items.push({ plant: null, name: '', size: 'medium', quantity: 1, price: 0, image: '/images/placeholder-plant.jpg' });
            renderItems();
            setTimeout(() => {
                const lastIdx = items.length - 1;
                document.getElementById(`size-${lastIdx}`)?.focus();
            }, 50);
        });

        document.getElementById('clearItemsBtn').addEventListener('click', () => {
            if (confirm('Discard all items from this manifest?')) {
                items = [];
                renderItems();
            }
        });

        window.calculateTotals = function() {
            const total = items.reduce((s, item) => s + (item.quantity * item.price), 0);
            const totalQty = items.length;

            document.getElementById('totalAmountDisplay').textContent = '₹' + fmtNum(total);
            document.getElementById('totalAmountInput').value = total.toFixed(2);
            document.getElementById('totalQtyDisplay').textContent = totalQty;
        };

        // Search Interface
        const posSearch = document.getElementById('posSearch');
        const posResults = document.getElementById('posResults');
        let searchTimer = null;

        posSearch.addEventListener('input', function() {
            clearTimeout(searchTimer);
            const q = this.value.trim();
            if (!q) { posResults.style.display = 'none'; return; }

            searchTimer = setTimeout(async () => {
                try {
                    const resp = await fetch('/api/billing/catalog/search?q=' + encodeURIComponent(q));
                    const data = await resp.json();
                    posResults.innerHTML = '';
                    if (data.results && data.results.length > 0) {
                        data.results.forEach((plant, i) => {
                            const li = document.createElement('li');
                            li.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 py-3';
                            li.innerHTML = `
                                <div class="d-flex align-items-center">
                                    <img src="${plant.image || '/images/placeholder-plant.jpg'}" class="item-image-preview me-3 shadow-sm">
                                    <div>
                                        <div class="fw-900 text-dark">${escHtml(plant.name)}</div>
                                        <div class="small text-muted">${escHtml(plant.category || 'Flora')} · Stock: ${plant.stock}</div>
                                    </div>
                                </div>
                                <span class="fw-bold text-success fs-5">₹${fmtNum(plant.price)}</span>
                            `;
                            li.onclick = () => addCatalogItem(plant);
                            posResults.appendChild(li);
                        });
                        posResults.style.display = 'block';
                    } else {
                        posResults.innerHTML = `<li class="list-group-item text-muted small py-3 border-0">No matches found. Press Enter to add custom item.</li>`;
                        posResults.style.display = 'block';
                    }
                } catch (err) { console.error(err); }
            }, 300);
        });

        function addCatalogItem(plant) {
            items.push({
                plant: plant._id,
                name: plant.name,
                size: 'medium',
                quantity: 1,
                price: plant.price || 0,
                image: plant.image || '/images/placeholder-plant.jpg'
            });
            posSearch.value = '';
            posResults.style.display = 'none';
            renderItems();
        }

        posSearch.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                const q = posSearch.value.trim();
                if (q) {
                    items.push({ plant: null, name: q, size: 'medium', quantity: 1, price: 0, image: '/images/placeholder-plant.jpg' });
                    posSearch.value = '';
                    posResults.style.display = 'none';
                    renderItems();
                }
            }
        });

        window.submitOrderForm = function() {
            const form = document.getElementById('orderForm');
            form.querySelectorAll('input[name^="items"]').forEach(el => el.remove());

            items.forEach((item, idx) => {
                if (!item.name) return;
                const base = `items[${idx}]`;
                const createHidden = (name, val) => {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = `${base}[${name}]`;
                    input.value = val;
                    form.appendChild(input);
                };
                if (item.plant) createHidden('plant', item.plant);
                createHidden('name', item.name);
                createHidden('size', item.size);
                createHidden('quantity', item.quantity);
                createHidden('price', item.price);
                createHidden('image', item.image);
            });
            
            form.submit();
        };

        document.addEventListener('DOMContentLoaded', renderItems);
    </script>
</body>
</html>
