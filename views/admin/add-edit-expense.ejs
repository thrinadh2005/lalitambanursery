<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">
    <!-- Admin Navigation -->
    <%- include('partials/navbar') %>

        <div class="container-fluid py-4">
            <div class="row">
                <!-- Sidebar -->
                <%- include('partials/sidebar') %>

                    <!-- Main Content -->
                    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                                <li class="breadcrumb-item"><a href="/admin/expenses">Expenses</a></li>
                                <li class="breadcrumb-item active">
                                    <%= expense ? 'Edit Expense' : 'Add New Expense' %>
                                </li>
                            </ol>
                        </nav>

                        <div class="row justify-content-center">
                            <div class="col-lg-10">
                                <div class="card shadow-sm border-0 rounded-3">
                                    <div class="card-header bg-danger text-white py-3">
                                        <h4 class="mb-0">
                                            <i class="<%= expense ? 'fas fa-edit' : 'fas fa-plus-circle' %> me-2"></i>
                                            <%= expense ? 'Edit Expense Details' : 'Record New Expense' %>
                                        </h4>
                                    </div>
                                    <div class="card-body p-4">
                                        <form action="<%= expense ? '/admin/expenses/edit/' + expense._id : '/admin/expenses/add' %>" method="POST">
                                            
                                            <div class="row g-4">
                                                <!-- Left Column: Core Details -->
                                                <div class="col-md-8">
                                                    <div class="mb-4">
                                                        <label class="form-label fw-bold text-muted text-uppercase small">Expense Title</label>
                                                        <input type="text" class="form-control form-control-lg" name="title"
                                                            value="<%= expense ? expense.title : '' %>" required
                                                            placeholder="e.g. Monthly Electricity Bill">
                                                    </div>

                                                    <div class="row">
                                                        <div class="col-md-6 mb-4">
                                                            <label class="form-label fw-bold text-muted text-uppercase small">Category</label>
                                                            <div class="input-group">
                                                                <span class="input-group-text bg-light"><i class="fas fa-tag text-muted"></i></span>
                                                                <select class="form-select" name="category" required>
                                                                    <option value="" disabled <%= !expense ? 'selected' : '' %>>Select Category</option>
                                                                    <% ['labor', 'utilities', 'maintenance', 'supplies', 'transportation', 'marketing', 'insurance', 'taxes', 'equipment', 'pest_control', 'fertilizers', 'seeds', 'packaging', 'other'].forEach(cat => { %>
                                                                        <option value="<%= cat %>" <%= expense && expense.category === cat ? 'selected' : '' %>>
                                                                            <%= cat.split('_').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ') %>
                                                                        </option>
                                                                    <% }); %>
                                                                </select>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6 mb-4">
                                                            <label class="form-label fw-bold text-muted text-uppercase small">Expense Date</label>
                                                            <div class="input-group">
                                                                <span class="input-group-text bg-light"><i class="fas fa-calendar text-muted"></i></span>
                                                                <input type="date" class="form-control" name="expenseDate"
                                                                    value="<%= expense && expense.expenseDate ? new Date(expense.expenseDate).toISOString().split('T')[0] : new Date().toISOString().split('T')[0] %>"
                                                                    required>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="mb-4">
                                                        <label class="form-label fw-bold text-muted text-uppercase small">Description / Notes</label>
                                                        <textarea class="form-control" name="description" rows="5"
                                                            placeholder="Add details about the expense, vendor info, invoice numbers, etc."><%= expense ? expense.description : '' %></textarea>
                                                    </div>
                                                </div>

                                                <!-- Right Column: Amount & Status -->
                                                <div class="col-md-4">
                                                    <div class="card bg-light border-0 mb-4">
                                                        <div class="card-body">
                                                            <div class="mb-3">
                                                                <label class="form-label fw-bold text-muted text-uppercase small">Amount</label>
                                                                <div class="input-group input-group-lg">
                                                                    <span class="input-group-text bg-white border-end-0 text-success fw-bold">&#8377;</span>
                                                                    <input type="number" class="form-control border-start-0 ps-0 fw-bold text-success" name="amount"
                                                                        value="<%= expense ? expense.amount : '' %>" required
                                                                        step="0.01" min="0" placeholder="0.00">
                                                                </div>
                                                            </div>

                                                            <div class="mb-3">
                                                                <label class="form-label fw-bold text-muted text-uppercase small">Payment Status</label>
                                                                <select class="form-select" name="status">
                                                                    <option value="pending" <%= expense && expense.status === 'pending' ? 'selected' : '' %>>Pending Approval</option>
                                                                    <option value="approved" <%= expense && expense.status === 'approved' ? 'selected' : '' %>>Approved</option>
                                                                    <option value="paid" <%= expense && expense.status === 'paid' ? 'selected' : '' %>>Paid</option>
                                                                    <option value="rejected" <%= expense && expense.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <!-- Helper Text or Instructions -->
                                                    <div class="alert alert-info border-0 d-flex align-items-start small">
                                                        <i class="fas fa-info-circle me-2 mt-1"></i>
                                                        <div>
                                                            <strong>Note:</strong>
                                                            Ensure accurate categorization for better financial reporting. Attach physical receipts to your daily log if required.
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="d-flex justify-content-end gap-2 border-top pt-4 mt-2">
                                                <a href="/admin/expenses" class="btn btn-outline-secondary px-4 rounded-pill">Cancel</a>
                                                <button type="submit" class="btn btn-danger px-5 rounded-pill shadow-sm">
                                                    <i class="fas fa-save me-2"></i>
                                                    <%= expense ? 'Update Expense' : 'Save Expense' %>
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </main>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>