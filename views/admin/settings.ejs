<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .settings-section {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: var(--shadow-sm);
        }
        
        .settings-title {
            font-family: 'Merriweather', Georgia, serif;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .form-section {
            background: var(--background-alt);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            margin-bottom: 1rem;
        }
        
        .form-label {
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 0.5rem;
        }
        
        .form-control:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }
        
        .btn-primary {
            background: var(--gradient-primary);
            border: none;
        }
        
        .btn-primary:hover {
            background: var(--primary);
            transform: translateY(-1px);
        }
        
        .alert {
            border-radius: var(--radius-lg);
            border: none;
        }
        
        .alert-success {
            background: var(--accent-light);
            color: var(--accent);
        }
        
        .alert-danger {
            background: #fee2e2;
            color: #991b1b;
        }
    </style>
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>
    <div class="container-fluid py-4">
        <div class="row">
            <div class="col-md-3">
                <%- include('partials/sidebar') %>
            </div>
            <div class="col-md-9">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h1 class="h3 mb-0">Settings</h1>
                    <div class="text-muted">
                        <i class="fas fa-cog me-2"></i>System Configuration
                    </div>
                </div>

                <% if (messages.success) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i><%= messages.success %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <% if (messages.error) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-triangle me-2"></i><%= messages.error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <!-- General Settings -->
                <div class="settings-section">
                    <h2 class="settings-title">
                        <i class="fas fa-cog"></i>
                        General Settings
                    </h2>
                    
                    <form action="/admin/settings/update" method="POST">
                        <div class="form-section">
                            <h5 class="mb-3">Application Information</h5>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="appName" class="form-label">Application Name</label>
                                    <input type="text" class="form-control" id="appName" name="appName" 
                                           value="<%= settings.appName || 'SRI LALITAMBA NURSERY & GARDENS' %>" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="appUrl" class="form-label">Application URL</label>
                                    <input type="url" class="form-control" id="appUrl" name="appUrl" 
                                           value="<%= settings.appUrl || 'http://localhost:3000' %>" required>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="adminEmail" class="form-label">Admin Email</label>
                                    <input type="email" class="form-control" id="adminEmail" name="adminEmail" 
                                           value="<%= settings.adminEmail || 'lalitambanursery@gmail.com' %>" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="supportPhone" class="form-label">Support Phone</label>
                                    <input type="tel" class="form-control" id="supportPhone" name="supportPhone" 
                                           value="<%= settings.supportPhone || '+91 99633 72123' %>" required>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label for="businessDescription" class="form-label">Business Description</label>
                                <textarea class="form-control" id="businessDescription" name="businessDescription" rows="4"><%= settings.businessDescription || '' %></textarea>
                            </div>
                        </div>

                        <div class="form-section">
                            <h5 class="mb-3">Contact Information</h5>
                            
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label for="contactPhone" class="form-label">Contact Phone</label>
                                    <input type="tel" class="form-control" id="contactPhone" name="contactPhone" 
                                           value="<%= settings.contactPhone || '+91 99633 72123' %>" required>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label for="contactMobile" class="form-label">Contact Mobile</label>
                                    <input type="tel" class="form-control" id="contactMobile" name="contactMobile" 
                                           value="<%= settings.contactMobile || '+91 96633 55000' %>" required>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label for="contactEmail" class="form-label">Contact Email</label>
                                    <input type="email" class="form-control" id="contactEmail" name="contactEmail" 
                                           value="<%= settings.contactEmail || 'lalitambanursery@gmail.com' %>" required>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label for="address" class="form-label">Business Address</label>
                                <textarea class="form-control" id="address" name="address" rows="3"><%= settings.address || 'Gandhinagaram, Near Kadiypulanka, Chemudulanka - 533 234, East Godavari District, Andhra Pradesh' %></textarea>
                            </div>
                        </div>

                        <div class="form-section">
                            <h5 class="mb-3">Business Hours</h5>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="weekdaysHours" class="form-label">Weekday Hours</label>
                                    <input type="text" class="form-control" id="weekdaysHours" name="weekdaysHours" 
                                           value="<%= settings.weekdaysHours || '6:00 AM - 6:00 PM' %>" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="weekendHours" class="form-label">Weekend Hours</label>
                                    <input type="text" class="form-control" id="weekendHours" name="weekendHours" 
                                           value="<%= settings.weekendHours || '7:00 AM - 1:00 PM' %>" required>
                                </div>
                            </div>
                        </div>

                        <div class="text-end">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Save Settings
                            </button>
                        </div>
                    </form>
                </div>

                <!-- System Status -->
                <div class="settings-section">
                    <h2 class="settings-title">
                        <i class="fas fa-server"></i>
                        System Status
                    </h2>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-section">
                                <h5 class="mb-3">Database Status</h5>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>Connection Status:</span>
                                    <span class="badge <%= dbConnected ? 'bg-success' : 'bg-danger' %>">
                                        <%= dbConnected ? 'Connected' : 'Disconnected' %>
                                    </span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>Database Type:</span>
                                    <span class="badge bg-info">MongoDB Atlas</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>Environment:</span>
                                    <span class="badge bg-secondary"><%= nodeEnv %></span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="form-section">
                                <h5 class="mb-3">Server Information</h5>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>Server Status:</span>
                                    <span class="badge bg-success">Running</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div>
                                        <h6 class="mb-0">Port Number</h6>
                                        <small class="text-muted">The port your server is running on</small>
                                    </div>
                                    <span class="badge bg-info"><%= port %></span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>Node.js Version:</span>
                                    <span class="badge bg-secondary"><%= nodeVersion %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Image Management -->
                <div class="settings-section">
                    <h2 class="settings-title">
                        <i class="fas fa-images"></i>
                        Image Management
                    </h2>
                    
                    <div class="form-section">
                        <h5 class="mb-3">Image Storage</h5>
                        <p class="text-muted mb-3">Images are stored in MongoDB Atlas cloud database for reliability and performance.</p>
                        
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span>Storage Type:</span>
                            <span class="badge bg-primary">MongoDB Atlas</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span>Cache Duration:</span>
                            <span class="badge bg-info">1 Year</span>
                        </div>
                        
                        <div class="text-center">
                            <a href="/admin/image-management" class="btn btn-outline-primary">
                                <i class="fas fa-images me-2"></i>Manage Images
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Backup & Maintenance -->
                <div class="settings-section">
                    <h2 class="settings-title">
                        <i class="fas fa-database"></i>
                        Backup & Maintenance
                    </h2>
                    
                    <div class="form-section">
                        <h5 class="mb-3">Database Backup</h5>
                        <p class="text-muted mb-3">MongoDB Atlas provides automatic backups and point-in-time recovery.</p>
                        
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span>Backup Status:</span>
                            <span class="badge bg-success">Automatic</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span>Retention Period:</span>
                            <span class="badge bg-info">30 Days</span>
                        </div>
                        
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            <strong>Note:</strong> MongoDB Atlas automatically handles database backups and maintenance.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        // Auto-save draft functionality
        let autoSaveTimer;
        const inputs = document.querySelectorAll('input, textarea, select');
        
        inputs.forEach(input => {
            input.addEventListener('input', () => {
                clearTimeout(autoSaveTimer);
                autoSaveTimer = setTimeout(() => {
                    console.log('Settings draft saved');
                }, 30000); // Save after 30 seconds of inactivity
            });
        });
        
        // Form validation
        const form = document.querySelector('form');
        if (form) {
            form.addEventListener('submit', (e) => {
                const requiredFields = form.querySelectorAll('[required]');
                let isValid = true;
                
                requiredFields.forEach(field => {
                    if (!field.value.trim()) {
                        field.classList.add('is-invalid');
                        isValid = false;
                    } else {
                        field.classList.remove('is-invalid');
                    }
                });
                
                if (!isValid) {
                    e.preventDefault();
                    alert('Please fill in all required fields');
                }
            });
        }
    </script>
</body>

</html>