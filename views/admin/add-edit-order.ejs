<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !=='undefined' ? title : 'Order Management' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .admin-page-header {
            background: var(--gradient-secondary);
            color: white;
            padding: 4rem 0;
            margin-bottom: 2rem;
            border-radius: 0 0 var(--radius-3xl) var(--radius-3xl);
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

        .admin-page-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0L60 30L30 60L0 30Z' fill='%23ffffff' fill-opacity='0.03'/%3E%3C/svg%3E");
            opacity: 0.1;
        }

        .form-glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-2xl);
            padding: 2.5rem;
            box-shadow: var(--shadow-2xl);
        }

        .input-glass-group {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .input-glass-group:focus-within {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(var(--primary-rgb), 0.1);
            background: rgba(255, 255, 255, 0.1);
        }

        .input-glass-group .form-control, 
        .input-glass-group .form-select {
            background: transparent !important;
            border: none !important;
            color: var(--text-main) !important;
            box-shadow: none !important;
        }

        .item-row {
            transition: all 0.3s ease;
            border-radius: var(--radius-lg);
        }

        .item-row:hover {
            background: rgba(var(--primary-rgb), 0.02);
        }

        .search-results-glass {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-2xl);
            z-index: 1100;
            max-height: 300px;
            overflow-y: auto;
        }

        .search-item {
            padding: 1rem;
            cursor: pointer;
            transition: all 0.2s;
            border-bottom: 1px solid var(--border-light);
        }

        .search-item:last-child {
            border-bottom: none;
        }

        .search-item:hover {
            background: rgba(var(--primary-rgb), 0.05);
        }

        .summary-pill {
            background: rgba(var(--primary-rgb), 0.05);
            border-radius: var(--radius-xl);
            padding: 1.5rem;
            border: 1px solid rgba(var(--primary-rgb), 0.1);
        }

        .total-hero {
            font-size: 2.5rem;
            font-weight: 900;
            color: var(--primary);
        }
    </style>
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <div class="admin-page-header">
        <div class="container px-5">
            <div class="row align-items-center">
                <div class="col-md-7" data-aos="fade-right">
                    <h1 class="display-5 fw-900 mb-2"><%= order ? 'Modify Logistics Manifest' : 'Initialize New Order' %></h1>
                    <p class="mb-0 opacity-75 fs-5">Administrative fulfillment and order lifecycle management</p>
                </div>
                <div class="col-md-5 text-md-end mt-4 mt-md-0" data-aos="fade-left">
                    <div class="d-flex gap-3 justify-content-md-end">
                        <a href="/admin/orders" class="btn btn-light rounded-pill px-4 py-2 fw-bold shadow-sm">
                            <i class="fas fa-arrow-left me-2"></i>Back to Orders
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-5 py-4">
        <form id="orderForm" action="<%= order ? '/admin/orders/edit/' + order._id : '/admin/orders/create' %>" method="POST">
            <div class="row g-4">
                <div class="col-xl-8">
                    <!-- Client & Logistics Info -->
                    <div class="form-glass-card mb-4" data-aos="fade-up">
                        <div class="section-title mb-4">
                            <h5 class="fw-bold mb-0 text-primary">Client & Logistics Information</h5>
                            <div class="text-muted small">Customer identification and fulfillment parameters</div>
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-uppercase">Account Holder</label>
                                <div class="input-glass-group d-flex align-items-center p-1">
                                    <span class="px-3 text-primary"><i class="fas fa-user"></i></span>
                                    <select class="form-select" name="userId" required>
                                        <option value="">-- Identify Registered User --</option>
                                        <% users.forEach(u=> { %>
                                            <option value="<%= u._id %>" <%=(order && order.user && order.user.toString()===u._id.toString()) ? 'selected' : '' %>>
                                                <%= u.firstName %> <%= u.lastName %> (<%= u.email %>)
                                            </option>
                                        <% }) %>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-uppercase">Financial Instrument</label>
                                <div class="input-glass-group d-flex align-items-center p-1">
                                    <span class="px-3 text-primary"><i class="fas fa-credit-card"></i></span>
                                    <select class="form-select" name="paymentMethod">
                                        <option value="cod" <%=(order && order.paymentMethod==='cod' ) ? 'selected' : '' %>>Cash on Delivery (COD)</option>
                                        <option value="online" <%=(order && order.paymentMethod==='online' ) ? 'selected' : '' %>>Electronic / Online Transfer</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-uppercase">Projected Delivery</label>
                                <div class="input-glass-group d-flex align-items-center p-1">
                                    <span class="px-3 text-primary"><i class="fas fa-calendar-alt"></i></span>
                                    <input type="date" class="form-control" name="deliveryDeadline" 
                                        value="<%= order && order.deliveryDeadline ? order.deliveryDeadline.toISOString().split('T')[0] : '' %>" required>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5">
                            <h6 class="fw-800 text-muted small text-uppercase mb-3"><i class="fas fa-map-marker-alt me-2"></i>Destination Coordinates</h6>
                            <div class="row g-3">
                                <div class="col-md-8">
                                    <div class="input-glass-group">
                                        <input type="text" class="form-control" name="shippingAddress[fullName]" placeholder="Consignee Name" 
                                            value="<%= order && order.shippingAddress ? order.shippingAddress.fullName : '' %>" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="input-glass-group">
                                        <input type="tel" class="form-control" name="shippingAddress[phone]" placeholder="Contact Number" 
                                            value="<%= order && order.shippingAddress ? order.shippingAddress.phone : '' %>" required>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="input-glass-group">
                                        <input type="text" class="form-control" name="shippingAddress[address]" placeholder="Detailed Residence/Office Address" 
                                            value="<%= order && order.shippingAddress ? order.shippingAddress.address : '' %>" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="input-glass-group">
                                        <input type="text" class="form-control" name="shippingAddress[city]" placeholder="City" 
                                            value="<%= order && order.shippingAddress ? order.shippingAddress.city : '' %>" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="input-glass-group">
                                        <input type="text" class="form-control" name="shippingAddress[state]" placeholder="State" 
                                            value="<%= order && order.shippingAddress ? order.shippingAddress.state : '' %>" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="input-glass-group">
                                        <input type="text" class="form-control" name="shippingAddress[zipCode]" placeholder="Pincode" 
                                            value="<%= order && order.shippingAddress ? order.shippingAddress.zipCode : '' %>" required>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Items Manifest -->
                    <div class="form-glass-card" data-aos="fade-up" data-aos-delay="100">
                        <div class="section-title mb-4 d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="fw-bold mb-0 text-primary">Consignment Manifest</h5>
                                <div class="text-muted small">Botanical specimens included in this shipment</div>
                            </div>
                            <div class="position-relative" style="width: 300px;">
                                <div class="input-glass-group d-flex align-items-center p-1">
                                    <span class="px-3 text-primary small"><i class="fas fa-search"></i></span>
                                    <input type="text" id="plantSearch" class="form-control form-control-sm" placeholder="Scan inventory...">
                                </div>
                                <div id="searchResults" class="search-results-glass d-none position-absolute w-100 mt-1"></div>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead class="bg-light bg-opacity-50">
                                    <tr>
                                        <th class="ps-4 border-0 small fw-800 text-muted">IDENTITY</th>
                                        <th class="border-0 small fw-800 text-muted">SPECIFICATION</th>
                                        <th class="border-0 small fw-800 text-muted text-center">QTY</th>
                                        <th class="border-0 small fw-800 text-muted text-end">UNIT RATE</th>
                                        <th class="border-0 small fw-800 text-muted text-end">VALUATION</th>
                                        <th class="border-0 text-end pe-4"></th>
                                    </tr>
                                </thead>
                                <tbody id="orderItemsContainer">
                                    <!-- Dynamic Content -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-xl-4">
                    <!-- Order Status & Summary -->
                    <div class="form-glass-card sticky-top" style="top: 100px; z-index: 100;" data-aos="fade-left">
                        <div class="section-title mb-4">
                            <h5 class="fw-bold mb-0 text-primary">Fulfillment Control</h5>
                            <div class="text-muted small">Current status and financial consolidation</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-uppercase">Workflow Status</label>
                            <div class="input-glass-group d-flex align-items-center p-1">
                                <span class="px-3 text-primary"><i class="fas fa-stream"></i></span>
                                <select class="form-select fw-bold" name="status">
                                    <option value="pending" <%=(order && order.status==='pending' ) ? 'selected' : '' %>>PENDING APPROVAL</option>
                                    <option value="processing" <%=(order && order.status==='processing' ) ? 'selected' : '' %>>IN PROCESSING</option>
                                    <option value="shipped" <%=(order && order.status==='shipped' ) ? 'selected' : '' %>>SHIPPED / IN TRANSIT</option>
                                    <option value="delivered" <%=(order && order.status==='delivered' ) ? 'selected' : '' %>>FULFILLED / DELIVERED</option>
                                    <option value="cancelled" <%=(order && order.status==='cancelled' ) ? 'selected' : '' %>>VOIDED / CANCELLED</option>
                                </select>
                            </div>
                        </div>

                        <div class="summary-pill mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted small fw-bold">TOTAL LINE ITEMS</span>
                                <span class="badge bg-primary rounded-pill px-3 py-2 fw-bold" id="itemCount">0</span>
                            </div>
                            <div class="pt-3 border-top border-primary border-opacity-10 mt-3">
                                <div class="d-flex justify-content-between align-items-end">
                                    <div class="text-muted small fw-bold">CUMULATIVE VALUE</div>
                                    <div class="total-hero">₹<span id="totalDisplay">0.00</span></div>
                                    <input type="hidden" name="totalAmount" id="totalAmountInput" value="0">
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-primary rounded-pill py-3 fw-900 shadow-lg">
                                <i class="fas fa-check-circle me-2"></i>
                                <%= order ? 'AUTHORIZE CHANGES' : 'GENERATE ORDER' %>
                            </button>
                            <a href="/admin/orders" class="btn btn-outline-secondary rounded-pill py-2">Discard Adjustments</a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <%- include('../partials/footer') %>    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });

        const plants = <%- JSON.stringify(plants) %>;
        let selectedItems = <%- JSON.stringify(order ? order.items : []) %>;

        const searchInput = document.getElementById('plantSearch');
        const searchResults = document.getElementById('searchResults');
        const container = document.getElementById('orderItemsContainer');
        const totalDisplay = document.getElementById('totalDisplay');
        const totalAmountInput = document.getElementById('totalAmountInput');
        const itemCountDisplay = document.getElementById('itemCount');

        function renderItems() {
            container.innerHTML = '';
            let total = 0;
            let count = 0;

            if (selectedItems.length === 0) {
                container.innerHTML = '<tr><td colspan="6" class="text-center py-5 text-muted"><i class="fas fa-box-open fa-2x mb-3 opacity-25 d-block"></i>Inventory manifest is empty. Use the search tool to add botanical specimens.</td></tr>';
            } else {
                selectedItems.forEach((item, index) => {
                    const itemTotal = (item.price || 0) * (item.quantity || 1);
                    total += itemTotal;
                    count += 1;

                    const tr = document.createElement('tr');
                    tr.className = 'item-row';
                    tr.innerHTML = `
                        <td class="ps-4">
                            <input type="hidden" name="items[${index}][plant]" value="${item.plant}">
                            <input type="hidden" name="items[${index}][name]" value="${item.name}">
                            <input type="hidden" name="items[${index}][image]" value="${item.image || ''}">
                            <div class="d-flex align-items-center">
                                <div class="bg-light rounded overflow-hidden me-3 shadow-sm" style="width: 48px; height: 48px;">
                                    <img src="${item.image || '/images/placeholder-plant.jpg'}" class="w-100 h-100 object-fit-cover">
                                </div>
                                <div>
                                    <div class="fw-bold text-dark">${item.name}</div>
                                    <div class="extra-small text-muted">ID: ${item.plant.slice(-6).toUpperCase()}</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="input-glass-group">
                                <select name="items[${index}][size]" class="form-select form-select-sm border-0 bg-transparent" onchange="updateItem(${index}, 'size', this.value)">
                                    <option value="small" ${item.size === 'small' ? 'selected' : ''}>Small Pkt</option>
                                    <option value="medium" ${item.size === 'medium' ? 'selected' : ''}>Medium Pkt</option>
                                    <option value="large" ${item.size === 'large' ? 'selected' : ''}>Large Pkt</option>
                                    <option value="extra-large" ${item.size === 'extra-large' ? 'selected' : ''}>XL / Nursery</option>
                                </select>
                            </div>
                        </td>
                        <td>
                            <div class="input-glass-group" style="width: 80px; margin: auto;">
                                <input type="number" name="items[${index}][quantity]" class="form-control form-control-sm text-center border-0 bg-transparent fw-bold" 
                                    value="${item.quantity}" min="1" onchange="updateItem(${index}, 'quantity', this.value)">
                            </div>
                        </td>
                        <td class="text-end">
                            <div class="input-glass-group" style="width: 120px; margin-left: auto;">
                                <input type="number" name="items[${index}][price]" class="form-control form-control-sm text-end border-0 bg-transparent fw-bold" 
                                    value="${item.price}" min="0" step="0.01" onchange="updateItem(${index}, 'price', this.value)">
                            </div>
                        </td>
                        <td class="text-end fw-900 text-primary fs-5">₹${itemTotal.toLocaleString('en-IN')}</td>
                        <td class="text-end pe-4">
                            <button type="button" class="btn btn-link text-danger p-0" onclick="removeItem(${index})"><i class="fas fa-times-circle"></i></button>
                        </td>
                    `;
                    container.appendChild(tr);
                });
            }

            totalDisplay.innerText = total.toLocaleString('en-IN', { minimumFractionDigits: 2 });
            totalAmountInput.value = total;
            itemCountDisplay.innerText = count;
        }

        function updateItem(index, field, val) {
            if (field === 'quantity') selectedItems[index].quantity = parseInt(val) || 1;
            if (field === 'price') selectedItems[index].price = parseFloat(val) || 0;
            if (field === 'size') selectedItems[index].size = val;
            renderItems();
        }

        function removeItem(index) {
            selectedItems.splice(index, 1);
            renderItems();
        }

        searchInput.addEventListener('input', (e) => {
            const val = e.target.value.toLowerCase();
            if (!val) {
                searchResults.classList.add('d-none');
                return;
            }

            const filtered = plants.filter(p => p.name.toLowerCase().includes(val)).slice(0, 5);
            if (filtered.length > 0) {
                searchResults.innerHTML = filtered.map(p => `
                    <div class="search-item d-flex align-items-center" onclick="addItem('${p._id}', '${p.name.replace(/'/g, "\\'")}', 0, '${p.image || (p.images && p.images[0] ? p.images[0].url : '')}')">
                        <div class="bg-light rounded me-3" style="width: 40px; height: 40px; overflow: hidden;">
                            <img src="${p.image || (p.images && p.images[0] ? p.images[0].url : '/images/placeholder-plant.jpg')}" class="w-100 h-100 object-fit-cover">
                        </div>
                        <div>
                            <div class="fw-bold text-dark">${p.name}</div>
                            <div class="extra-small text-muted">${p.category || 'Flora'}</div>
                        </div>
                    </div>
                `).join('');
                searchResults.classList.remove('d-none');
            } else {
                searchResults.classList.add('d-none');
            }
        });

        function addItem(id, name, price, image) {
            const existing = selectedItems.find(i => i.plant === id);
            if (existing) {
                existing.quantity++;
            } else {
                selectedItems.push({ plant: id, name, quantity: 1, price, size: 'medium', image });
            }
            searchInput.value = '';
            searchResults.classList.add('d-none');
            renderItems();
        }

        document.addEventListener('click', (e) => {
            if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
                searchResults.classList.add('d-none');
            }
        });

        renderItems();
    </script>
</body>

</html>
/html>