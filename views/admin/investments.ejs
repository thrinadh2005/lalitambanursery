<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .admin-page-header {
            background: var(--gradient-primary);
            color: white;
            padding: 4rem 0;
            margin-bottom: 2rem;
            border-radius: 0 0 var(--radius-3xl) var(--radius-3xl);
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

        .admin-page-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43-7c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM12 86c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm66-3c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm-40-39c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm43 38c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2z' fill='%23ffffff' fill-opacity='0.05'/%3E%3C/svg%3E");
            opacity: 0.1;
        }

        .table-glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-2xl);
            overflow: hidden;
            box-shadow: var(--shadow-xl);
        }

        .investment-tag {
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 0.35rem 0.75rem;
            border-radius: 12px;
        }

        .btn-action-icon {
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text-muted);
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .btn-action-icon:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
            transform: translateY(-2px);
        }
    </style>
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <div class="admin-page-header">
        <div class="container px-md-5 px-3">
            <div class="row align-items-center">
                <div class="col-md-7" data-aos="fade-right">
                    <h1 class="display-5 fw-900 mb-2">Capital & Assets</h1>
                    <p class="mb-0 opacity-75 fs-5">Track institutional investments and strategic growth capital</p>
                </div>
                <div class="col-md-5 text-md-end mt-4 mt-md-0" data-aos="fade-left">
                    <div class="d-flex gap-3 justify-content-md-end">
                        <div class="dropdown">
                            <button class="btn btn-light rounded-pill px-4 dropdown-toggle fw-bold" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-filter me-2"></i>Status
                            </button>
                            <ul class="dropdown-menu border-0 shadow-lg rounded-4">
                                <li><a class="dropdown-item" href="/admin/investments?status=all">All Records</a></li>
                                <li><a class="dropdown-item" href="/admin/investments?status=active">Active</a></li>
                                <li><a class="dropdown-item" href="/admin/investments?status=completed">Completed</a></li>
                            </ul>
                        </div>
                        <a href="/admin/investments/add" class="btn btn-warning rounded-pill px-4 py-2 fw-bold shadow-sm">
                            <i class="fas fa-plus-circle me-2"></i>New Injection
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-md-5 px-3 py-4">
        <div class="row g-4">
            <main class="col-12">
                <!-- Portoflio Summary -->
                <% if (typeof investments !== 'undefined' && investments.length > 0) { %>
                    <div class="row g-4 mb-5" data-aos="fade-up">
                        <div class="col-md-3">
                            <div class="glass p-4 rounded-4 shadow-sm border-bottom border-4 border-success">
                                <div class="text-muted small fw-bold text-uppercase mb-1">Total Deployed</div>
                                <h3 class="fw-900 mb-0">₹<%= investments.reduce((sum, inv) => sum + inv.amount, 0).toLocaleString() %></h3>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="glass p-4 rounded-4 shadow-sm border-bottom border-4 border-primary">
                                <div class="text-muted small fw-bold text-uppercase mb-1">Projected Return</div>
                                <h3 class="fw-900 mb-0">₹<%= investments.reduce((sum, inv) => sum + (inv.expectedReturn || 0), 0).toLocaleString() %></h3>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="glass p-4 rounded-4 shadow-sm border-bottom border-4 border-warning">
                                <div class="text-muted small fw-bold text-uppercase mb-1">Realized Yield</div>
                                <h3 class="fw-900 mb-0">₹<%= investments.reduce((sum, inv) => sum + (inv.actualReturn || 0), 0).toLocaleString() %></h3>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="glass p-4 rounded-4 shadow-sm border-bottom border-4 border-info">
                                <div class="text-muted small fw-bold text-uppercase mb-1">Active Projects</div>
                                <h3 class="fw-900 mb-0"><%= investments.filter(i => i.status === 'active').length %></h3>
                            </div>
                        </div>
                    </div>
                <% } %>

                <div class="table-glass-card" data-aos="fade-up">
                    <div class="p-4 border-bottom bg-white bg-opacity-50 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold"><i class="fas fa-briefcase me-2 text-primary"></i>Asset Portfolio</h5>
                        <div class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2">FY 2026</div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">Investment Detail</th>
                                    <th>Classification</th>
                                    <th>Valuation</th>
                                    <th>Status</th>
                                    <th>Performance</th>
                                    <th class="text-end pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof investments !== 'undefined' && investments.length > 0) { %>
                                    <% investments.forEach(investment => { %>
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold text-dark"><%= investment.title %></div>
                                                <div class="text-muted extra-small"><%= investment.description ? investment.description.substring(0, 40) + '...' : 'No description' %></div>
                                            </td>
                                            <td>
                                                <span class="investment-tag bg-info bg-opacity-10 text-info border border-info border-opacity-25">
                                                    <%= investment.category %>
                                                </span>
                                            </td>
                                            <td class="fw-800 text-dark">₹<%= investment.amount.toLocaleString() %></td>
                                            <td>
                                                <% 
                                                    let statCol = 'warning';
                                                    if (investment.status === 'active') statCol = 'success';
                                                    else if (investment.status === 'completed') statCol = 'primary';
                                                %>
                                                <span class="badge bg-<%= statCol %> rounded-pill px-3 py-2 text-uppercase extra-small">
                                                    <%= investment.status %>
                                                </span>
                                            </td>
                                            <td>
                                                <% if (investment.expectedReturn) { %>
                                                    <div class="extra-small text-muted">Expected: <span class="fw-bold text-dark">₹<%= investment.expectedReturn.toLocaleString() %></span></div>
                                                    <% if (investment.actualReturn) { %>
                                                        <div class="extra-small text-success">Actual: <span class="fw-bold">₹<%= investment.actualReturn.toLocaleString() %></span></div>
                                                    <% } %>
                                                <% } else { %>
                                                    <span class="text-muted opacity-50">-</span>
                                                <% } %>
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="d-flex justify-content-end gap-2">
                                                    <a href="/admin/investments/<%= investment._id %>" class="btn-action-icon">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a href="/admin/investments/<%= investment._id %>/edit" class="btn-action-icon">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form method="POST" action="/admin/investments/delete/<%= investment._id %>" class="d-inline" onsubmit="return confirm('Liquify this investment record?')">
                                                        <button type="submit" class="btn-action-icon">
                                                            <i class="fas fa-trash-alt text-danger"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <div class="text-muted py-5">
                                                <i class="fas fa-chart-pie fa-4x mb-3 opacity-25"></i>
                                                <h5 class="fw-bold">Empty Portfolio</h5>
                                                <p>Log your first capital injection to track business growth.</p>
                                                <a href="/admin/investments/add" class="btn btn-primary rounded-pill px-4">Add Investment</a>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });
    </script>
</body>

</html>