<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .admin-page-header {
            background: var(--gradient-primary);
            color: white;
            padding: 4rem 0;
            margin-bottom: 2rem;
            border-radius: 0 0 var(--radius-3xl) var(--radius-3xl);
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

        .admin-page-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M54.626 10.5H47.43l-4.5-4.5H17.07l-4.5 4.5H5.374c-2.485 0-4.5 2.015-4.5 4.5v30c0 2.485 2.015 4.5 4.5 4.5h49.252c2.485 0 4.5-2.015 4.5-4.5v-30c0-2.485-2.015-4.5-4.5-4.5zM30 40.5c-6.627 0-12-5.373-12-12s5.373-12 12-12 12 5.373 12 12-5.373 12-12 12z' fill='%23ffffff' fill-opacity='0.05'/%3E%3C/svg%3E");
            opacity: 0.1;
        }

        .table-glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-2xl);
            overflow: hidden;
            box-shadow: var(--shadow-xl);
        }

        .plant-preview-wrap {
            width: 64px;
            height: 64px;
            border-radius: var(--radius-lg);
            overflow: hidden;
            border: 2px solid var(--glass-border);
            box-shadow: var(--shadow-sm);
        }

        .plant-preview-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .table thead th {
            background: rgba(0, 0, 0, 0.02);
            border-bottom: 2px solid var(--border-light);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.1em;
            font-weight: 800;
            color: var(--text-muted);
            padding: 1.5rem 1rem;
        }

        .table tbody td {
            padding: 1.25rem 1rem;
            vertical-align: middle;
            border-bottom: 1px solid var(--border-light);
        }

        .btn-action-icon {
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text-muted);
            transition: all 0.2s ease;
        }

        .btn-action-icon:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
            transform: translateY(-2px);
        }

        .btn-action-icon.delete:hover {
            background: var(--danger);
            border-color: var(--danger);
        }
    </style>
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <div class="admin-page-header">
        <div class="container px-5">
            <div class="row align-items-center">
                <div class="col-md-7" data-aos="fade-right">
                    <h1 class="display-5 fw-900 mb-2">Plant Collections</h1>
                    <p class="mb-0 opacity-75 fs-5">Curate and manage your nursery's digital botanical gallery</p>
                </div>
                <div class="col-md-5 text-md-end mt-4 mt-md-0" data-aos="fade-left">
                    <div class="d-flex gap-3 justify-content-md-end">
                        <button id="deleteSelectedBtn" class="btn btn-glass-danger rounded-pill px-4 d-none" onclick="submitBulkDelete()">
                            <i class="fas fa-trash-alt me-2"></i>Remove Selected
                        </button>
                        <a href="/admin/plants/add" class="btn btn-light rounded-pill px-4 py-2 fw-bold shadow-sm">
                            <i class="fas fa-plus-circle me-2 text-primary"></i>Add New Variety
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-5 py-4">
        <div class="row g-4">
            <main class="col-12">
                <div class="table-glass-card" data-aos="fade-up">
                    <div class="p-4 border-bottom bg-white bg-opacity-50 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold"><i class="fas fa-leaf me-2 text-primary"></i>Inventory Database</h5>
                        <div class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2"><%= plants.length %> Items Tracked</div>
                    </div>
                    
                    <div class="table-responsive">
                        <form id="bulkDeleteForm" action="/admin/plants/delete-multiple" method="POST" class="d-none"></form>
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4" style="width: 50px;">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" id="selectAll">
                                        </div>
                                    </th>
                                    <th>Gallery Preview</th>
                                    <th>Identification</th>
                                    <th>Botanical Category</th>
                                    <th>Publication Status</th>
                                    <th class="text-end pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (plants && plants.length > 0) { %>
                                    <% plants.forEach(plant => { %>
                                        <tr>
                                            <td class="ps-4">
                                                <div class="form-check">
                                                    <input type="checkbox" class="form-check-input item-checkbox" value="<%= plant._id %>">
                                                </div>
                                            </td>
                                            <td>
                                                <div class="plant-preview-wrap">
                                                    <img src="<%= (plant.images && plant.images[0]) ? plant.images[0].url : 'https://placehold.co/80x80?text=No+Image' %>" alt="<%= plant.name %>">
                                                </div>
                                            </td>
                                            <td>
                                                <div class="fw-bold text-dark fs-6"><%= plant.name %></div>
                                                <code class="text-muted small">UID: <%= plant._id.toString().slice(-8).toUpperCase() %></code>
                                            </td>
                                            <td>
                                                <span class="badge bg-primary bg-opacity-10 text-primary border-0 py-2 px-3 fw-700">
                                                    <i class="fas fa-tag me-1 small"></i><%= plant.category %>
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge rounded-pill px-3 py-2 fw-bold bg-<%= plant.isActive ? 'success' : 'secondary' %> bg-opacity-10 text-<%= plant.isActive ? 'success' : 'secondary' %>">
                                                    <i class="fas fa-<%= plant.isActive ? 'check-circle' : 'eye-slash' %> me-1"></i>
                                                    <%= plant.isActive ? 'LIVE' : 'DRAFT' %>
                                                </span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="d-flex gap-2 justify-content-end">
                                                    <a href="/admin/plants/edit/<%= plant._id %>" class="btn-action-icon" title="Edit Metadata">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form action="/admin/plants/delete/<%= plant._id %>" method="POST" class="d-inline" onsubmit="return confirm('Permanently decommission this plant record?');">
                                                        <button type="submit" class="btn-action-icon delete" title="Decommission">
                                                            <i class="fas fa-trash-alt"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <div class="text-muted py-5">
                                                <i class="fas fa-seedling fa-4x mb-3 opacity-25"></i>
                                                <h5 class="fw-bold">No Botanical Records</h5>
                                                <p>Start building your nursery database by adding your first plant.</p>
                                                <a href="/admin/plants/add" class="btn btn-primary rounded-pill px-4">Add First Item</a>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });
        
        document.addEventListener('DOMContentLoaded', function() {
            const selectAllCheckbox = document.getElementById('selectAll');
            const itemCheckboxes = document.querySelectorAll('.item-checkbox');
            const deleteSelectedBtn = document.getElementById('deleteSelectedBtn');

            function updateDeleteButton() {
                const checkedCount = Array.from(itemCheckboxes).filter(cb => cb.checked).length;
                if (checkedCount > 0) {
                    deleteSelectedBtn.classList.remove('d-none');
                    deleteSelectedBtn.innerHTML = `<i class="fas fa-trash-alt me-2"></i>Remove (${checkedCount}) Selected`;
                } else {
                    deleteSelectedBtn.classList.add('d-none');
                }
            }

            if (selectAllCheckbox) {
                selectAllCheckbox.addEventListener('change', function() {
                    itemCheckboxes.forEach(cb => {
                        cb.checked = this.checked;
                    });
                    updateDeleteButton();
                });
            }

            itemCheckboxes.forEach(cb => {
                cb.addEventListener('change', function() {
                    updateDeleteButton();
                    const allChecked = Array.from(itemCheckboxes).every(c => c.checked);
                    if (selectAllCheckbox) selectAllCheckbox.checked = allChecked;
                });
            });
        });

        function submitBulkDelete() {
            const selectedCheckboxes = document.querySelectorAll('.item-checkbox:checked');
            if (selectedCheckboxes.length === 0) return;

            if (confirm(`Are you sure you want to permanently delete ${selectedCheckboxes.length} selected item(s)? This action cannot be undone.`)) {
                const form = document.getElementById('bulkDeleteForm');
                form.innerHTML = '';
                selectedCheckboxes.forEach(cb => {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'selectedIds';
                    input.value = cb.value;
                    form.appendChild(input);
                });
                form.submit();
            }
        }
    </script>
</body>

</html>