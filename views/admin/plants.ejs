<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .admin-page-header {
            background: var(--gradient-primary);
            color: white;
            padding: 4rem 0;
            margin-bottom: 2rem;
            border-radius: 0 0 var(--radius-3xl) var(--radius-3xl);
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

        .admin-page-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M54.626 10.5H47.43l-4.5-4.5H17.07l-4.5 4.5H5.374c-2.485 0-4.5 2.015-4.5 4.5v30c0 2.485 2.015 4.5 4.5 4.5h49.252c2.485 0 4.5-2.015 4.5-4.5v-30c0-2.485-2.015-4.5-4.5-4.5zM30 40.5c-6.627 0-12-5.373-12-12s5.373-12 12-12 12 5.373 12 12-5.373 12-12 12z' fill='%23ffffff' fill-opacity='0.05'/%3E%3C/svg%3E");
            opacity: 0.1;
        }

        .table-glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-2xl);
            overflow: hidden;
            box-shadow: var(--shadow-xl);
        }

        .plant-preview-wrap {
            width: 64px;
            height: 64px;
            border-radius: var(--radius-lg);
            overflow: hidden;
            border: 2px solid var(--glass-border);
            box-shadow: var(--shadow-sm);
        }

        .plant-preview-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .table thead th {
            background: rgba(0, 0, 0, 0.02);
            border-bottom: 2px solid var(--border-light);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.1em;
            font-weight: 800;
            color: var(--text-muted);
            padding: 1.5rem 1rem;
        }

        .table tbody td {
            padding: 1.25rem 1rem;
            vertical-align: middle;
            border-bottom: 1px solid var(--border-light);
        }

        .btn-action-icon {
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text-muted);
            transition: all 0.2s ease;
        }

        .btn-action-icon:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
            transform: translateY(-2px);
        }

        .btn-action-icon.delete:hover {
            background: var(--danger);
            border-color: var(--danger);
        }
    </style>
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <div class="admin-page-header">
        <div class="container px-md-5 px-3">
            <div class="row align-items-center">
                <div class="col-md-7" data-aos="fade-right">
                    <h1 class="display-5 fw-900 mb-2">Plant Collections</h1>
                    <p class="mb-0 opacity-75 fs-5">Curate and manage your nursery's digital botanical gallery</p>
                </div>
                <div class="col-md-5 text-md-end mt-4 mt-md-0" data-aos="fade-left">
                    <div class="d-flex gap-2 justify-content-md-end flex-wrap">
                        <button id="deleteSelectedBtn" class="btn btn-glass-danger rounded-pill px-4 d-none" onclick="submitBulkDelete()">
                            <i class="fas fa-trash-alt me-2"></i>Remove Selected
                        </button>
                        <button type="button" class="btn btn-glass-info rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#importCsvModal">
                            <i class="fas fa-file-import me-2"></i>Bulk Import
                        </button>
                        <a href="/admin/plants/export-csv" class="btn btn-glass-success rounded-pill px-4">
                            <i class="fas fa-file-export me-2"></i>Export CSV
                        </a>
                        <a href="/admin/plants/add" class="btn btn-light rounded-pill px-4 py-2 fw-bold shadow-sm">
                            <i class="fas fa-plus-circle me-2 text-primary"></i>Add New Variety
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-md-5 px-3 py-4">
        <div class="row g-4">
            <main class="col-12">
                <div class="table-glass-card" data-aos="fade-up">
                    <div class="p-4 border-bottom bg-white bg-opacity-50 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold"><i class="fas fa-leaf me-2 text-primary"></i>Inventory Database</h5>
                        <div class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2"><%= plants.length %> Items Tracked</div>
                    </div>
                    
                    <div class="table-responsive">
                        <form id="bulkDeleteForm" action="/admin/plants/delete-multiple" method="POST" class="d-none"></form>
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4" style="width: 50px;">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" id="selectAll">
                                        </div>
                                    </th>
                                    <th>Gallery Preview</th>
                                    <th>Identification</th>
                                    <th>Botanical Category</th>
                                    <th>Publication Status</th>
                                    <th class="text-end pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (plants && plants.length > 0) { %>
                                    <% plants.forEach(plant => { %>
                                        <tr>
                                            <td class="ps-4">
                                                <div class="form-check">
                                                    <input type="checkbox" class="form-check-input item-checkbox" value="<%= plant._id %>">
                                                </div>
                                            </td>
                                            <td>
                                                <div class="plant-preview-wrap">
                                                    <img src="<%= (plant.images && plant.images[0]) ? plant.images[0].url : 'https://placehold.co/80x80?text=No+Image' %>" alt="<%= plant.name %>">
                                                </div>
                                            </td>
                                            <td>
                                                <div class="fw-bold text-dark fs-6"><%= plant.name %></div>
                                                <code class="text-muted small">UID: <%= plant._id.toString().slice(-8).toUpperCase() %></code>
                                            </td>
                                            <td>
                                                <span class="badge bg-primary bg-opacity-10 text-primary border-0 py-2 px-3 fw-700">
                                                    <i class="fas fa-tag me-1 small"></i><%= plant.category %>
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge rounded-pill px-3 py-2 fw-bold bg-<%= plant.isActive ? 'success' : 'secondary' %> bg-opacity-10 text-<%= plant.isActive ? 'success' : 'secondary' %>">
                                                    <i class="fas fa-<%= plant.isActive ? 'check-circle' : 'eye-slash' %> me-1"></i>
                                                    <%= plant.isActive ? 'LIVE' : 'DRAFT' %>
                                                </span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="d-flex gap-2 justify-content-end">
                                                    <a href="/admin/plants/edit/<%= plant._id %>" class="btn-action-icon" title="Edit Metadata">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form action="/admin/plants/delete/<%= plant._id %>" method="POST" class="d-inline" onsubmit="return confirm('Permanently decommission this plant record?');">
                                                        <button type="submit" class="btn-action-icon delete" title="Decommission">
                                                            <i class="fas fa-trash-alt"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <div class="text-muted py-5">
                                                <i class="fas fa-seedling fa-4x mb-3 opacity-25"></i>
                                                <h5 class="fw-bold">No Botanical Records</h5>
                                                <p>Start building your nursery database by adding your first plant.</p>
                                                <a href="/admin/plants/add" class="btn btn-primary rounded-pill px-4">Add First Item</a>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Import CSV Modal -->
    <div class="modal fade" id="importCsvModal" tabindex="-1" aria-labelledby="importCsvModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-2xl rounded-4 overflow-hidden" style="background: var(--surface);">
                <div class="modal-header border-bottom py-3 px-4" style="background: linear-gradient(135deg, #10b981, #059669);">
                    <h5 class="modal-title fw-bold text-white" id="importCsvModalLabel">
                        <i class="fas fa-file-csv me-2"></i>Bulk Botanical Import
                    </h5>
                    <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="/admin/plants/import-csv" method="POST" enctype="multipart/form-data">
                    <div class="modal-body p-4">
                        <div class="mb-4">
                            <label class="form-label fw-800 extra-small text-uppercase tracking-wider text-muted mb-3">Select CSV File</label>
                            
                            <div class="upload-premium-zone p-5 rounded-4 text-center" id="dropZone">
                                <div class="upload-icon-wrap mb-3 mx-auto">
                                    <i class="fas fa-cloud-arrow-up text-primary"></i>
                                </div>
                                <h6 class="fw-bold mb-1">Drag and drop your file here</h6>
                                <p class="text-muted small mb-3">or</p>
                                
                                <input type="file" name="csvFile" id="csvFileInput" class="d-none" accept=".csv" required>
                                <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" onclick="document.getElementById('csvFileInput').click()">
                                    Browse Files
                                </button>
                                
                                <div id="fileInfo" class="mt-3 d-none">
                                    <div class="badge bg-success bg-opacity-10 text-success py-2 px-3 rounded-pill border border-success border-opacity-25">
                                        <i class="fas fa-check-circle me-1"></i> <span id="fileNameDisplay">file.csv</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="format-guide-card p-3 rounded-3 mb-0">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="fas fa-lightbulb text-warning"></i>
                                <span class="fw-800 extra-small text-uppercase tracking-wider">Format Guide</span>
                            </div>
                            <p class="small text-muted mb-2">Ensure your CSV contains these exact headers:</p>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="header-tag">name</span>
                                <span class="header-tag">category</span>
                                <span class="header-tag">price</span>
                                <span class="header-tag">description</span>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-top bg-light bg-opacity-50 p-3">
                        <button type="button" class="btn btn-outline-secondary border-0 rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-lg">
                            <i class="fas fa-upload me-2"></i>Initialize Import
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <style>
        .upload-premium-zone {
            border: 2px dashed var(--border);
            background: var(--background-alt);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .upload-premium-zone.active {
            border-color: #10b981;
            background: rgba(16, 185, 129, 0.03);
            transform: scale(0.98);
        }

        .upload-icon-wrap {
            width: 60px;
            height: 60px;
            background: white;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.75rem;
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
        }

        .upload-premium-zone.active .upload-icon-wrap {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(16, 185, 129, 0.2);
            color: #10b981;
        }

        .header-tag {
            background: var(--surface);
            border: 1px solid var(--border);
            padding: 0.25rem 0.6rem;
            border-radius: 6px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            color: var(--primary);
            font-weight: 700;
        }

        .format-guide-card {
            background: var(--background-alt);
            border: 1px solid var(--border);
        }

        .shadow-2xl {
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        }

        [data-theme="dark"] .upload-icon-wrap {
            background: var(--surface);
            color: #10b981;
        }
    </style>

    <script>
        // Drop zone interaction
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('csvFileInput');
        const fileInfo = document.getElementById('fileInfo');
        const fileNameDisplay = document.getElementById('fileNameDisplay');

        if (dropZone) {
            dropZone.addEventListener('dragover', (e) => {
                e.preventDefault();
                dropZone.classList.add('active');
            });

            dropZone.addEventListener('dragleave', () => {
                dropZone.classList.remove('active');
            });

            dropZone.addEventListener('drop', (e) => {
                e.preventDefault();
                dropZone.classList.remove('active');
                if (e.dataTransfer.files.length) {
                    fileInput.files = e.dataTransfer.files;
                    updateFileInfo();
                }
            });
        }

        if (fileInput) {
            fileInput.addEventListener('change', updateFileInfo);
        }

        function updateFileInfo() {
            if (fileInput.files.length) {
                fileNameDisplay.textContent = fileInput.files[0].name;
                fileInfo.classList.remove('d-none');
            }
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });
        
        document.addEventListener('DOMContentLoaded', function() {
            const selectAllCheckbox = document.getElementById('selectAll');
            const itemCheckboxes = document.querySelectorAll('.item-checkbox');
            const deleteSelectedBtn = document.getElementById('deleteSelectedBtn');

            function updateDeleteButton() {
                const checkedCount = Array.from(itemCheckboxes).filter(cb => cb.checked).length;
                if (checkedCount > 0) {
                    deleteSelectedBtn.classList.remove('d-none');
                    deleteSelectedBtn.innerHTML = `<i class="fas fa-trash-alt me-2"></i>Remove (${checkedCount}) Selected`;
                } else {
                    deleteSelectedBtn.classList.add('d-none');
                }
            }

            if (selectAllCheckbox) {
                selectAllCheckbox.addEventListener('change', function() {
                    itemCheckboxes.forEach(cb => {
                        cb.checked = this.checked;
                    });
                    updateDeleteButton();
                });
            }

            itemCheckboxes.forEach(cb => {
                cb.addEventListener('change', function() {
                    updateDeleteButton();
                    const allChecked = Array.from(itemCheckboxes).every(c => c.checked);
                    if (selectAllCheckbox) selectAllCheckbox.checked = allChecked;
                });
            });
        });

        function submitBulkDelete() {
            const selectedCheckboxes = document.querySelectorAll('.item-checkbox:checked');
            if (selectedCheckboxes.length === 0) return;

            if (confirm(`Are you sure you want to permanently delete ${selectedCheckboxes.length} selected item(s)? This action cannot be undone.`)) {
                const form = document.getElementById('bulkDeleteForm');
                form.innerHTML = '';
                selectedCheckboxes.forEach(cb => {
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'selectedIds';
                    input.value = cb.value;
                    form.appendChild(input);
                });
                form.submit();
            }
        }
    </script>
</body>

</html>