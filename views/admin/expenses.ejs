<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .admin-page-header {
            background: var(--gradient-primary);
            color: white;
            padding: 4rem 0;
            margin-bottom: 2rem;
            border-radius: 0 0 var(--radius-3xl) var(--radius-3xl);
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

        .admin-page-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43-7c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM12 86c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm66-3c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm-40-39c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm43 38c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2z' fill='%23ffffff' fill-opacity='0.05'/%3E%3C/svg%3E");
            opacity: 0.1;
        }

        .table-glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-2xl);
            overflow: hidden;
            box-shadow: var(--shadow-xl);
        }

        .expense-category-tag {
            font-size: 0.65rem;
            font-weight: 800;
            text-transform: uppercase;
            padding: 0.25rem 0.6rem;
            border-radius: 8px;
            background: var(--primary-light);
            color: var(--primary);
        }

        .status-pill {
            font-size: 0.7rem;
            font-weight: 700;
            padding: 0.4rem 1rem;
            border-radius: 20px;
        }

        .btn-action-icon {
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text-muted);
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .btn-action-icon:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
            transform: translateY(-2px);
        }
    </style>
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <div class="admin-page-header">
        <div class="container px-5">
            <div class="row align-items-center">
                <div class="col-md-7" data-aos="fade-right">
                    <h1 class="display-5 fw-900 mb-2">Operational Costs</h1>
                    <p class="mb-0 opacity-75 fs-5">Audit and manage the nursery's fiscal outflows and overheads</p>
                </div>
                <div class="col-md-5 text-md-end mt-4 mt-md-0" data-aos="fade-left">
                    <a href="/admin/expenses/add" class="btn btn-danger rounded-pill px-4 py-2 fw-bold shadow-sm">
                        <i class="fas fa-plus-circle me-2"></i>New Expenditure
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-5 py-4">
        <div class="row g-4">
            <main class="col-12">
                <!-- Overview Stats -->
                <div class="row g-4 mb-5" data-aos="fade-up">
                    <div class="col-md-4">
                        <div class="glass p-4 rounded-4 shadow-sm border-start border-4 border-danger">
                            <div class="text-muted small fw-bold text-uppercase mb-1">Total Outflow</div>
                            <h3 class="fw-900 text-danger mb-0">₹<%= (expenseStats.totalAmount || 0).toLocaleString('en-IN') %></h3>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="glass p-4 rounded-4 shadow-sm border-start border-4 border-warning">
                            <div class="text-muted small fw-bold text-uppercase mb-1">Pending Audit</div>
                            <h3 class="fw-900 text-warning mb-0"><%= expenseStats.pendingCount || 0 %> Items</h3>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="glass p-4 rounded-4 shadow-sm border-start border-4 border-success">
                            <div class="text-muted small fw-bold text-uppercase mb-1">Cleared Ledger</div>
                            <h3 class="fw-900 text-success mb-0"><%= expenseStats.approvedCount || 0 %> Paid</h3>
                        </div>
                    </div>
                </div>

                <!-- Filters -->
                <div class="glass p-4 rounded-4 shadow-sm mb-4 border-0" data-aos="fade-up">
                    <form action="/admin/expenses" method="GET" class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted">Business Category</label>
                            <select name="category" class="form-select border-0 bg-light rounded-3">
                                <option value="all">All Expenditures</option>
                                <% ['labor', 'utilities', 'maintenance', 'supplies', 'transportation', 'marketing', 'insurance', 'taxes', 'equipment', 'pest_control', 'fertilizers', 'seeds', 'packaging', 'other'].forEach(cat => { %>
                                    <option value="<%= cat %>" <%= filters.category === cat ? 'selected' : '' %>>
                                        <%= cat.split('_').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ') %>
                                    </option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted">Audit Status</label>
                            <select name="status" class="form-select border-0 bg-light rounded-3">
                                <option value="all">All States</option>
                                <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending Approval</option>
                                <option value="approved" <%= filters.status === 'approved' ? 'selected' : '' %>>Approved</option>
                                <option value="paid" <%= filters.status === 'paid' ? 'selected' : '' %>>Paid / Settled</option>
                                <option value="rejected" <%= filters.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary flex-grow-1 rounded-pill fw-bold">
                                    <i class="fas fa-search me-2"></i>Apply Filters
                                </button>
                                <a href="/admin/expenses" class="btn btn-light rounded-pill px-4">
                                    <i class="fas fa-undo"></i>
                                </a>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="table-glass-card" data-aos="fade-up">
                    <div class="p-4 border-bottom bg-white bg-opacity-50 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold"><i class="fas fa-file-invoice-dollar me-2 text-danger"></i>Expense Ledger</h5>
                        <div class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-2">Fiscal Audit</div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">Posting Date</th>
                                    <th>Expenditure Title</th>
                                    <th>Classification</th>
                                    <th>Amount</th>
                                    <th>Audit State</th>
                                    <th class="text-end pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (expenses && expenses.length > 0) { %>
                                    <% expenses.forEach(expense=> { %>
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold text-dark"><%= new Date(expense.expenseDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></div>
                                                <div class="text-muted extra-small"><%= new Date(expense.expenseDate).toLocaleDateString('en-IN', { weekday: 'long' }) %></div>
                                            </td>
                                            <td>
                                                <div class="fw-bold text-dark"><%= expense.title || 'Internal Voucher' %></div>
                                                <div class="text-muted extra-small text-truncate" style="max-width: 180px;"><%= expense.description || 'No detailed log provided' %></div>
                                            </td>
                                            <td>
                                                <span class="expense-category-tag">
                                                    <%= expense.category.split('_').join(' ') %>
                                                </span>
                                            </td>
                                            <td class="fw-800 text-danger">
                                                ₹<%= expense.amount.toLocaleString('en-IN') %>
                                            </td>
                                            <td>
                                                <% 
                                                    let badgeCol = 'secondary';
                                                    if (expense.status === 'paid') badgeCol = 'success';
                                                    else if (expense.status === 'approved') badgeCol = 'primary';
                                                    else if (expense.status === 'pending') badgeCol = 'warning';
                                                    else if (expense.status === 'rejected') badgeCol = 'danger';
                                                %>
                                                <span class="status-pill bg-<%= badgeCol %> bg-opacity-10 text-<%= badgeCol %> border border-<%= badgeCol %> border-opacity-25">
                                                    <%= expense.status.toUpperCase() %>
                                                </span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="d-flex justify-content-end gap-2">
                                                    <a href="/admin/expenses/edit/<%= expense._id %>" class="btn-action-icon" title="Modify Record">
                                                        <i class="fas fa-edit text-primary"></i>
                                                    </a>
                                                    <form action="/admin/expenses/delete/<%= expense._id %>" method="POST" class="d-inline" onsubmit="return confirm('Permanently remove this expenditure from the ledger?');">
                                                        <button type="submit" class="btn-action-icon" title="Void Entry">
                                                            <i class="fas fa-trash-alt text-danger"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <div class="text-muted py-5">
                                                <i class="fas fa-receipt fa-4x mb-3 opacity-25"></i>
                                                <h5 class="fw-bold">No Records Logged</h5>
                                                <p>All fiscal outflows will appear here once registered.</p>
                                                <a href="/admin/expenses/add" class="btn btn-outline-danger rounded-pill px-4 mt-2">Log Expense</a>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>

                    <% if (totalPages > 1) { %>
                        <div class="p-4 border-top bg-light bg-opacity-50">
                            <nav aria-label="Page navigation">
                                <ul class="pagination justify-content-center mb-0">
                                    <li class="page-item <%= currentPage == 1 ? 'disabled' : '' %>">
                                        <a class="page-link rounded-pill px-3 border-0 shadow-sm mx-1" href="/admin/expenses?page=<%= currentPage - 1 %><%= filters.category !== 'all' ? '&category=' + filters.category : '' %><%= filters.status !== 'all' ? '&status=' + filters.status : '' %>">Previous</a>
                                    </li>
                                    <% for(let i = 1; i <= totalPages; i++) { %>
                                        <li class="page-item <%= currentPage == i ? 'active' : '' %>">
                                            <a class="page-link rounded-pill border-0 shadow-sm mx-1 <%= currentPage == i ? 'bg-primary text-white' : 'bg-white' %>" href="/admin/expenses?page=<%= i %><%= filters.category !== 'all' ? '&category=' + filters.category : '' %><%= filters.status !== 'all' ? '&status=' + filters.status : '' %>"><%= i %></a>
                                        </li>
                                    <% } %>
                                    <li class="page-item <%= currentPage == totalPages ? 'disabled' : '' %>">
                                        <a class="page-link rounded-pill px-3 border-0 shadow-sm mx-1" href="/admin/expenses?page=<%= currentPage + 1 %><%= filters.category !== 'all' ? '&category=' + filters.category : '' %><%= filters.status !== 'all' ? '&status=' + filters.status : '' %>">Next</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    <% } %>
                </div>
            </main>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });
    </script>
</body>

</html>