<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        :root {
            --admin-green: #10b981;
            --admin-bg: var(--background);
            --surface-admin: var(--surface);
            --text-main-admin: var(--text-main);
            --text-muted-admin: var(--text-muted);
            --border-admin: var(--border);
            --radius-xl: 16px;
        }

        .admin-dashboard {
            background: var(--admin-bg);
            min-height: 100vh;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            color: var(--text-main-admin);
        }

        .admin-header {
            background: linear-gradient(135deg, #059669 0%, #10b981 100%);
            color: white;
            padding: 2.5rem 2rem;
            margin-bottom: 2rem;
            position: relative;
            overflow: hidden;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .card-form {
            border-radius: var(--radius-xl);
            border: 1px solid var(--border-admin);
            background: var(--surface-admin);
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
            overflow: hidden;
        }

        .form-label {
            font-weight: 600;
            color: var(--text-main-admin);
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
        }

        .form-control, .form-select {
            border-radius: 10px;
            padding: 0.75rem 1rem;
            border-color: #e2e8f0;
            transition: all 0.2s;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--admin-green);
            box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
        }

        .image-preview-container {
            width: 100%;
            height: 200px;
            border-radius: 12px;
            border: 2px dashed #cbd5e1;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: #f8fafc;
            position: relative;
        }

        .image-preview-container img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .nav-tabs-custom {
            border-bottom: 2px solid #f1f5f9;
            gap: 1.5rem;
        }

        .nav-tabs-custom .nav-link {
            border: none;
            padding: 0.75rem 0;
            color: var(--text-muted);
            font-weight: 600;
            position: relative;
            background: transparent;
        }

        .nav-tabs-custom .nav-link.active {
            color: var(--admin-green);
        }

        .nav-tabs-custom .nav-link.active::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            right: 0;
            height: 2px;
            background: var(--admin-green);
        }
    </style>
</head>

<body class="admin-dashboard">
    <%- include('partials/navbar') %>

        <div class="container-fluid">
            <div class="row">
                <%- include('partials/sidebar') %>

                    <!-- Main Content -->
                    <main class="col-md-9 ms-sm-auto col-lg-10 px-0">
                        <header class="admin-header">
                            <div class="container-fluid px-md-4">
                                <nav aria-label="breadcrumb" class="mb-3">
                                    <ol class="breadcrumb mb-0">
                                        <li class="breadcrumb-item"><a href="/admin/dashboard" class="text-white opacity-75 text-decoration-none">Dashboard</a></li>
                                        <li class="breadcrumb-item"><a href="/admin/plants" class="text-white opacity-75 text-decoration-none">Gallery</a></li>
                                        <li class="breadcrumb-item active text-white" aria-current="page"><%= plant ? 'Edit Item' : 'New Item' %></li>
                                    </ol>
                                </nav>
                                <h1 class="display-6 fw-800 mb-0"><%= plant ? 'Edit Gallery Item' : 'Add to Gallery' %></h1>
                            </div>
                        </header>

                        <div class="px-md-4 pb-5">
                            <div class="row justify-content-center">
                                <div class="col-lg-10">
                                    <div class="card card-form border-0 shadow-lg" data-aos="fade-up">
                                        <div class="card-body p-4 p-md-5">
                                            <form action="<%= plant ? '/admin/plants/edit/' + plant._id : '/admin/plants/add' %>"
                                                method="POST" enctype="multipart/form-data" class="needs-validation" novalidate>
                                                
                                                <div class="row g-4">
                                                    <!-- Basic Info Section -->
                                                    <div class="col-md-7">
                                                        <div class="mb-4">
                                                            <label class="form-label">Plant / Item Name</label>
                                                            <input type="text" class="form-control" name="name"
                                                                value="<%= plant ? plant.name : '' %>" required
                                                                placeholder="e.g. Rare Red Rose Hybrid">
                                                        </div>

                                                        <div class="row mb-4">
                                                            <div class="col-md-6">
                                                                <label class="form-label">Category</label>
                                                                <select class="form-select" name="category" required>
                                                                    <option value="" disabled <%=!plant ? 'selected' : '' %>>Select Category</option>
                                                                    <% ['Flower', 'Fruit' , 'Ornamental' , 'Indoor' , 'Outdoor' , 'Avenue' ].forEach(cat=> { %>
                                                                        <option value="<%= cat %>" <%=plant && plant.category===cat ? 'selected' : '' %>><%= cat %></option>
                                                                    <% }) %>
                                                                </select>
                                                            </div>
                                                            <div class="col-md-6">
                                                                <label class="form-label d-block">Visibility</label>
                                                                <div class="form-check form-switch mt-2">
                                                                    <input class="form-check-input" type="checkbox" name="isActive" id="isActive" <%=(plant===null || plant.isActive) ? 'checked' : '' %>>
                                                                    <label class="form-check-label text-muted" for="isActive">Show in Public Gallery</label>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div class="mb-0">
                                                            <label class="form-label">Detailed Description</label>
                                                            <textarea class="form-control" name="description" rows="6" required
                                                                placeholder="Describe features, care tips, origin..."><%= plant ? plant.description : '' %></textarea>
                                                        </div>
                                                    </div>

                                                    <!-- Media Section -->
                                                    <div class="col-md-5">
                                                        <label class="form-label">Item Media / Images</label>
                                                        
                                                        <div class="nav nav-tabs nav-tabs-custom mb-3" id="imageTabs" role="tablist">
                                                            <button class="nav-link active" id="file-tab" data-bs-toggle="tab" data-bs-target="#file-upload" type="button">Local Upload</button>
                                                            <button class="nav-link" id="url-tab" data-bs-toggle="tab" data-bs-target="#url-input" type="button">Image URL</button>
                                                        </div>

                                                        <div class="tab-content">
                                                            <div class="tab-pane fade show active" id="file-upload">
                                                                <div class="image-preview-container mb-3" id="filePreview">
                                                                    <% if (plant && plant.images && plant.images.length > 0) { %>
                                                                        <img src="<%= plant.images[0].url %>" alt="Current" id="currentImg">
                                                                    <% } else { %>
                                                                        <div class="text-center text-muted">
                                                                            <i class="fas fa-cloud-upload-alt fa-3x mb-2"></i>
                                                                            <p class="small mb-0">Click to upload image</p>
                                                                        </div>
                                                                    <% } %>
                                                                </div>
                                                                <input type="file" class="form-control" name="imageFiles" accept="image/*" id="imageInput">
                                                            </div>
                                                            
                                                            <div class="tab-pane fade" id="url-input">
                                                                <div class="image-preview-container mb-3" id="urlPreview">
                                                                    <div class="text-center text-muted">
                                                                        <i class="fas fa-link fa-3x mb-2"></i>
                                                                        <p class="small mb-0">Image preview will appear here</p>
                                                                    </div>
                                                                </div>
                                                                <input type="text" class="form-control" name="imageUrl" id="imageUrlInput"
                                                                    value="<%= plant && plant.images[0] ? plant.images[0].url : '' %>"
                                                                    placeholder="https://example.com/image.jpg">
                                                                <div class="form-text mt-2 small">Paste a direct link to the image (JPG, PNG, WebP).</div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top">
                                                    <a href="/admin/plants" class="btn btn-light rounded-pill px-4">Cancel</a>
                                                    <button type="submit" class="btn btn-success rounded-pill px-5 fw-bold shadow-sm">
                                                        <i class="fas fa-save me-2"></i>
                                                        <%= plant ? 'Save Changes' : 'Publish to Gallery' %>
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </main>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="/js/utils.js"></script>
        <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
        <script>
            AOS.init({ duration: 800, once: true });

            document.addEventListener('DOMContentLoaded', function() {
                const imageInput = document.getElementById('imageInput');
                const filePreview = document.getElementById('filePreview');
                const imageUrlInput = document.getElementById('imageUrlInput');
                const urlPreview = document.getElementById('urlPreview');

                // File Preview logic
                imageInput.addEventListener('change', function() {
                    if (this.files && this.files[0]) {
                        const reader = new FileReader();
                        reader.onload = function(e) {
                            filePreview.innerHTML = `<img src="${e.target.result}" alt="Preview">`;
                        }
                        reader.readAsDataURL(this.files[0]);
                        imageUrlInput.value = ''; // Clear URL if file selected
                    }
                });

                // URL Preview logic
                imageUrlInput.addEventListener('input', function() {
                    if (this.value.trim() !== '') {
                        urlPreview.innerHTML = `<img src="${this.value}" alt="Preview" onerror="this.parentElement.innerHTML='<div class=\"text-danger small\">Invalid Image URL</div>'">`;
                        imageInput.value = ''; // Clear file selection if URL entered
                    }
                });
            });
        </script>
</body>

</html>
