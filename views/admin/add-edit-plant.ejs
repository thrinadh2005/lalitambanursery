<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .admin-page-header {
            background: var(--gradient-primary);
            color: white;
            padding: 4rem 0;
            margin-bottom: 2rem;
            border-radius: 0 0 var(--radius-3xl) var(--radius-3xl);
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

        .admin-page-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43-7c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM12 86c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm66-3c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm-40-39c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm43 38c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2z' fill='%23ffffff' fill-opacity='0.05'/%3E%3C/svg%3E");
            opacity: 0.1;
        }

        .form-glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-2xl);
            padding: 3rem;
            box-shadow: var(--shadow-2xl);
        }

        .image-preview-glass {
            width: 100%;
            height: 300px;
            border-radius: var(--radius-xl);
            border: 2px dashed var(--border);
            background: rgba(255, 255, 255, 0.05);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
            transition: all 0.3s ease;
        }

        .image-preview-glass:hover {
            border-color: var(--primary);
            background: rgba(var(--primary-rgb), 0.05);
        }

        .image-preview-glass img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .nav-pills-glass .nav-link {
            border-radius: 12px;
            padding: 0.6rem 1.5rem;
            font-weight: 700;
            color: var(--text-muted);
            transition: all 0.3s ease;
            border: 1px solid transparent;
        }

        .nav-pills-glass .nav-link.active {
            background: var(--primary);
            color: white;
            box-shadow: var(--shadow-md);
        }

        .nav-pills-glass .nav-link:not(.active):hover {
            background: rgba(0, 0, 0, 0.05);
            border-color: var(--border);
        }
    </style>
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <div class="admin-page-header">
        <div class="container px-5">
            <div class="row align-items-center">
                <div class="col-md-7" data-aos="fade-right">
                    <h1 class="display-5 fw-900 mb-2"><%= plant ? 'Refine Specimen' : 'Add New specimen' %></h1>
                    <p class="mb-0 opacity-75 fs-5">Update details or introduce new flora to the master collection</p>
                </div>
                <div class="col-md-5 text-md-end mt-4 mt-md-0" data-aos="fade-left">
                    <a href="/admin/plants" class="btn btn-light rounded-pill px-4 py-2 fw-bold shadow-sm">
                        <i class="fas fa-arrow-left me-2"></i>Back to Gallery
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-5 py-4">
        <div class="row g-4">
            <main class="col-12">
                <div class="row justify-content-center">
                    <div class="col-xl-10">
                        <div class="form-glass-card" data-aos="fade-up">
                            <form action="<%= plant ? '/admin/plants/edit/' + plant._id : '/admin/plants/add' %>"
                                method="POST" enctype="multipart/form-data" class="needs-validation" novalidate>
                                
                                <div class="row g-5">
                                    <!-- Specimen Details -->
                                    <div class="col-lg-7">
                                        <div class="section-title mb-4">
                                            <h5 class="fw-bold mb-0 text-primary">Core Information</h5>
                                            <div class="text-muted small">Scientific and common nomenclature</div>
                                        </div>

                                        <div class="mb-4">
                                            <label class="form-label fw-bold">Plant / Item Name</label>
                                            <input type="text" class="form-control form-control-lg border-0 bg-light rounded-4 shadow-sm" 
                                                name="name" value="<%= plant ? plant.name : '' %>" required
                                                placeholder="Specimen name...">
                                        </div>

                                        <div class="row g-4 mb-4">
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold">Taxonomy / Category</label>
                                                <select class="form-select border-0 bg-light rounded-4 shadow-sm" name="category" required>
                                                    <option value="" disabled <%=!plant ? 'selected' : '' %>>Select Classification</option>
                                                    <% ['Flower', 'Fruit' , 'Ornamental' , 'Indoor' , 'Outdoor' , 'Avenue' ].forEach(cat=> { %>
                                                        <option value="<%= cat %>" <%=plant && plant.category===cat ? 'selected' : '' %>><%= cat %></option>
                                                    <% }) %>
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label fw-bold">Status</label>
                                                <div class="p-3 bg-light rounded-4 shadow-sm d-flex align-items-center justify-content-between">
                                                    <span class="small fw-bold text-muted">Public Visibility</span>
                                                    <div class="form-check form-switch m-0">
                                                        <input class="form-check-input" type="checkbox" name="isActive" id="isActive" <%=(plant===null || plant.isActive) ? 'checked' : '' %>>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="mb-0">
                                            <label class="form-label fw-bold">Botanical Description</label>
                                            <textarea class="form-control border-0 bg-light rounded-4 shadow-sm" name="description" rows="8" required
                                                placeholder="Provide detailed care instructions, characteristics..."><%= plant ? plant.description : '' %></textarea>
                                        </div>
                                    </div>

                                    <!-- Media Gallery -->
                                    <div class="col-lg-5">
                                        <div class="section-title mb-4">
                                            <h5 class="fw-bold mb-0 text-primary">Visual Identity</h5>
                                            <div class="text-muted small">High-resolution imagery</div>
                                        </div>

                                        <ul class="nav nav-pills nav-pills-glass mb-4 gap-2" id="mediaTabs" role="tablist">
                                            <li class="nav-item">
                                                <button class="nav-link active" id="local-tab" data-bs-toggle="pill" data-bs-target="#local-upload" type="button">
                                                    <i class="fas fa-upload me-2"></i>Upload
                                                </button>
                                            </li>
                                            <li class="nav-item">
                                                <button class="nav-link" id="cloud-tab" data-bs-toggle="pill" data-bs-target="#cloud-url" type="button">
                                                    <i class="fas fa-link me-2"></i>URL
                                                </button>
                                            </li>
                                        </ul>

                                        <div class="tab-content">
                                            <div class="tab-pane fade show active" id="local-upload">
                                                <div class="image-preview-glass mb-4" id="filePreview">
                                                    <% if (plant && plant.images && plant.images.length > 0) { %>
                                                        <img src="<%= plant.images[0].url %>" alt="Current specimen">
                                                    <% } else { %>
                                                        <div class="text-center opacity-50">
                                                            <i class="fas fa-image fa-4x mb-3"></i>
                                                            <div class="fw-bold">No Image Selected</div>
                                                        </div>
                                                    <% } %>
                                                </div>
                                                <input type="file" class="form-control border-0 bg-light rounded-4 p-3" name="imageFiles" accept="image/*" id="imageInput">
                                            </div>
                                            
                                            <div class="tab-pane fade" id="cloud-url">
                                                <div class="image-preview-glass mb-4" id="urlPreview">
                                                    <div class="text-center opacity-50">
                                                        <i class="fas fa-cloud-upload-alt fa-4x mb-3"></i>
                                                        <div class="fw-bold">URL Preview Area</div>
                                                    </div>
                                                </div>
                                                <input type="text" class="form-control border-0 bg-light rounded-4 p-3 shadow-sm" name="imageUrl" id="imageUrlInput"
                                                    value="<%= plant && plant.images[0] ? plant.images[0].url : '' %>"
                                                    placeholder="https://images.unsplash.com/...">
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-end gap-3 mt-5 pt-5 border-top border-light">
                                    <a href="/admin/plants" class="btn btn-light rounded-pill px-5 py-3 fw-bold">Discard</a>
                                    <button type="submit" class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow-lg">
                                        <i class="fas fa-check-circle me-2"></i>
                                        <%= plant ? 'Commit Changes' : 'Initialize Specimen' %>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });

        document.addEventListener('DOMContentLoaded', function() {
            const imageInput = document.getElementById('imageInput');
            const filePreview = document.getElementById('filePreview');
            const imageUrlInput = document.getElementById('imageUrlInput');
            const urlPreview = document.getElementById('urlPreview');

            imageInput.addEventListener('change', function() {
                if (this.files && this.files[0]) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        filePreview.innerHTML = `<img src="${e.target.result}" alt="Preview" class="w-100 h-100 object-fit-cover">`;
                    }
                    reader.readAsDataURL(this.files[0]);
                    imageUrlInput.value = '';
                }
            });

            imageUrlInput.addEventListener('input', function() {
                if (this.value.trim() !== '') {
                    urlPreview.innerHTML = `<img src="${this.value}" alt="Preview" class="w-100 h-100 object-fit-cover" onerror="this.parentElement.innerHTML='<div class=\"text-danger fw-bold\">Invalid Asset URL</div>'">`;
                    imageInput.value = '';
                }
            });
        });
    </script>
</body>

</html>
