<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--background);
            color: var(--text-body);
        }

        .invoice-card {
            background: var(--surface);
            border-radius: 16px;
            box-shadow: var(--shadow-sm);
            padding: 40px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            color: var(--text-body);
        }

        .invoice-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-xl) !important;
        }

        .invoice-header {
            border-bottom: 2px solid var(--border-light);
            padding-bottom: 25px;
            margin-bottom: 30px;
        }

        .table thead th {
            background-color: var(--background-alt);
            color: var(--text-muted);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            padding: 16px;
            border-bottom: 2px solid var(--border);
        }

        .table tbody td {
            vertical-align: middle;
            padding: 16px;
        }

        .badge {
            padding: 0.5em 0.8em;
            font-weight: 600;
            border-radius: 6px;
        }

        .btn {
            border-radius: 8px;
            font-weight: 500;
            padding: 8px 16px;
            transition: all 0.2s;
        }

        .btn:hover {
            transform: translateY(-1px);
        }
    </style>
</head>

<body class="bg-light">
    <!-- Admin Navigation -->
    <%- include('partials/navbar') %>

        <div class="container-fluid py-4">
            <div class="row">
                <!-- Sidebar -->
                <%- include('partials/sidebar') %>

                    <!-- Main Content -->
                    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">

                        <div class="container py-5">
                            <div class="row justify-content-center">
                                <div class="col-lg-10">
                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                        <a href="/admin/bills" class="btn btn-outline-secondary">
                                            <i class="fas fa-arrow-left me-1"></i> Back to Bills
                                        </a>
                                        <div>
                                            <a href="/admin/bills/<%= bill._id %>/pdf" class="btn btn-danger me-2">
                                                <i class="fas fa-file-pdf me-1"></i> Generate PDF
                                            </a>
                                            <a href="/admin/bills/<%= bill._id %>/print" target="_blank"
                                                class="btn btn-primary me-2">
                                                <i class="fas fa-print me-1"></i> Print Invoice
                                            </a>
                                            <a href="/admin/bills/<%= bill._id %>/edit"
                                                class="btn btn-outline-info me-2">
                                                <i class="fas fa-edit me-1"></i> Edit
                                            </a>
                                            <form method="POST" action="/admin/bills/delete/<%= bill._id %>"
                                                class="d-inline"
                                                onsubmit="return confirm('Are you sure you want to delete this bill? This action cannot be undone.')">
                                                <button type="submit" class="btn btn-outline-danger">
                                                    <i class="fas fa-trash me-1"></i> Delete
                                                </button>
                                            </form>
                                        </div>
                                    </div>

                                    <div class="invoice-card">
                                        <div class="invoice-header d-flex justify-content-between align-items-center">
                                            <div>
                                                <h1 class="text-success fw-bold">SRI LALITAMBA NURSERY & GARDENS</h1>
                                                <p class="text-muted small mb-0">Suppliers of Flowers, Fruits &
                                                    Ornamental Plants</p>
                                            </div>
                                            <div class="text-end">
                                                <h2 class="mb-0">INVOICE</h2>
                                                <p class="text-muted fw-bold">#<%= bill.billNumber %>
                                                </p>
                                            </div>
                                        </div>

                                        <div class="row mb-5">
                                            <div class="col-md-6">
                                                <h6 class="text-muted text-uppercase mb-3">Billed To:</h6>
                                                <h4 class="mb-1">
                                                    <%= bill.customerName %>
                                                </h4>
                                                <% if (bill.customerPhone) { %>
                                                    <p class="mb-0 text-muted"><i class="fas fa-phone me-2"></i>
                                                        <%= bill.customerPhone %>
                                                    </p>
                                                    <% } %>
                                            </div>
                                            <div class="col-md-6 text-md-end">
                                                <div class="mb-2">
                                                    <span class="text-muted">Invoice Date:</span>
                                                    <span class="fw-bold">
                                                        <%= new Date(bill.billDate).toLocaleDateString('en-IN') %>
                                                    </span>
                                                </div>
                                                <% if (bill.dueDate) { %>
                                                    <div class="mb-2">
                                                        <span class="text-muted">Due Date:</span>
                                                        <span class="fw-bold text-danger">
                                                            <%= new Date(bill.dueDate).toLocaleDateString('en-IN') %>
                                                        </span>
                                                    </div>
                                                    <% } %>
                                                        <div>
                                                            <span class="text-muted">Status:</span>
                                                            <span
                                                                class="badge bg-<%= bill.status === 'paid' ? 'success' : bill.status === 'pending' ? 'warning' : 'danger' %> ms-2">
                                                                <%= bill.status.toUpperCase() %>
                                                            </span>
                                                        </div>
                                            </div>
                                        </div>

                                        <div class="table-responsive mb-5">
                                            <table class="table table-borderless">
                                                <thead class="bg-light">
                                                    <tr>
                                                        <th>Size of Packet</th>
                                                        <th>Plant Name</th>
                                                        <th class="text-center">Quantity</th>
                                                        <th class="text-end">Cost / Plant</th>
                                                        <th class="text-end">Total for Item</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% bill.items.forEach(item=> {
                                                        const packetSize = item.packetSize || '1 unit';
                                                        const plantName = item.plantName || item.description || '';
                                                        const quantity = item.quantity || 1;
                                                        const unitPrice = item.unitPrice || item.price || 0;
                                                        const lineTotal = item.lineTotal || (quantity * unitPrice);
                                                        %>
                                                        <tr>
                                                            <td class="py-3">
                                                                <%= packetSize %>
                                                            </td>
                                                            <td class="py-3">
                                                                <%= plantName %>
                                                            </td>
                                                            <td class="py-3 text-center">
                                                                <%= quantity %>
                                                            </td>
                                                            <td class="py-3 text-end">₹<%=
                                                                    unitPrice.toLocaleString('en-IN', {
                                                                    minimumFractionDigits: 2 }) %>
                                                            </td>
                                                            <td class="py-3 text-end fw-bold">₹<%=
                                                                    lineTotal.toLocaleString('en-IN', {
                                                                    minimumFractionDigits: 2 }) %>
                                                            </td>
                                                        </tr>
                                                        <% }) %>
                                                </tbody>
                                            </table>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6">
                                                <% if (bill.notes) { %>
                                                    <h6 class="text-muted text-uppercase mb-2">Notes:</h6>
                                                    <p class="small text-muted mb-4">
                                                        <%= bill.notes %>
                                                    </p>
                                                <% } %>

                                                <% if (bill.payments && bill.payments.length > 0) { %>
                                                    <h6 class="text-muted text-uppercase mb-3">Payment History:</h6>
                                                    <div class="table-responsive">
                                                        <table class="table table-sm table-borderless small">
                                                            <thead>
                                                                <tr class="border-bottom">
                                                                    <th class="py-2">Date</th>
                                                                    <th class="py-2">Mode</th>
                                                                    <th class="py-2 text-end">Amount</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <% bill.payments.forEach(payment => { %>
                                                                    <tr class="border-bottom-0">
                                                                        <td class="py-2"><%= new Date(payment.date).toLocaleDateString('en-IN') %></td>
                                                                        <td class="py-2 text-capitalize"><%= payment.mode.replace('_', ' ') %></td>
                                                                        <td class="py-2 text-end fw-bold">₹<%= payment.amount.toLocaleString('en-IN') %></td>
                                                                    </tr>
                                                                <% }) %>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                <% } %>
                                            </div>
                                            <div class="col-md-5 ms-auto">
                                                <div class="d-flex justify-content-between mb-2">
                                                    <span class="text-muted">Subtotal:</span>
                                                    <span>₹<%= bill.subTotal.toLocaleString() %></span>
                                                </div>
                                                <div class="d-flex justify-content-between mb-2">
                                                    <span class="text-muted">Tax:</span>
                                                    <span>₹<%= bill.tax.toLocaleString() %></span>
                                                </div>
                                                <div class="d-flex justify-content-between mb-3 pb-3 border-bottom">
                                                    <span class="text-muted">Discount:</span>
                                                    <span class="text-danger">-₹<%= bill.discount.toLocaleString() %></span>
                                                </div>
                                                <div class="d-flex justify-content-between mb-2">
                                                    <span class="text-muted fw-bold">Total:</span>
                                                    <span class="fw-bold">₹<%= bill.totalAmount.toLocaleString() %></span>
                                                </div>
                                                <div class="d-flex justify-content-between mb-2">
                                                    <span class="text-muted">Paid Amount:</span>
                                                    <span class="text-success fw-bold">₹<%= (bill.paidAmount || 0).toLocaleString() %></span>
                                                </div>
                                                <div class="d-flex justify-content-between mb-3 pb-3 border-bottom">
                                                    <span class="text-muted">Balance:</span>
                                                    <span class="text-danger fw-bold">₹<%= (bill.balanceAmount || (bill.totalAmount - (bill.paidAmount || 0))).toLocaleString() %></span>
                                                </div>
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <h3 class="fw-bold text-success mb-0">Grand Total:</h3>
                                                    <h3 class="fw-bold text-success mb-0">₹<%= bill.totalAmount.toLocaleString() %></h3>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="mt-5 pt-4 text-center border-top text-muted small">
                                            <p>Thank you for your business! If you have any questions, please contact us
                                                at
                                                lalitambanursery@gmail.com</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <script
                            src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
                        <script src="/js/utils.js"></script>
                    </main>
            </div>
        </div>
</body>

</html>