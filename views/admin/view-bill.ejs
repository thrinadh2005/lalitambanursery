<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .admin-page-header {
            background: var(--gradient-primary);
            color: white;
            padding: 3rem 0;
            margin-bottom: 2rem;
            border-radius: 0 0 var(--radius-3xl) var(--radius-3xl);
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

        .admin-page-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43-7c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM12 86c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm66-3c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm-40-39c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm43 38c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2z' fill='%23ffffff' fill-opacity='0.05'/%3E%3C/svg%3E");
            opacity: 0.1;
        }

        .bill-glass-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-2xl);
            padding: 4rem;
            box-shadow: var(--shadow-premium);
            position: relative;
            overflow: hidden;
        }

        .bill-glass-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 10px;
            background: var(--gradient-primary);
            border-radius: var(--radius-3xl) var(--radius-3xl) 0 0;
        }

        .bill-header {
            border-bottom: 2px dashed var(--border);
            padding-bottom: 2rem;
            margin-bottom: 3rem;
        }

        .bill-info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2rem;
            margin-bottom: 3rem;
        }

        .info-block h6 {
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 0.75rem;
        }

        .info-block p {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 0;
        }

        .bill-table thead th {
            background: rgba(var(--primary-rgb), 0.05);
            color: var(--primary);
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
            padding: 1.25rem 1rem;
            border: none;
        }

        .bill-table tbody td {
            padding: 1.5rem 1rem;
            border-bottom: 1px solid var(--border-light);
            color: var(--text-main);
            font-weight: 600;
        }

        .summary-block {
            background: rgba(var(--primary-rgb), 0.03);
            border-radius: var(--radius-xl);
            padding: 2rem;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }

        .summary-row:last-child {
            margin-bottom: 0;
            padding-top: 1rem;
            border-top: 2px solid var(--border-light);
        }

        .grand-total-hero {
            font-size: 2rem;
            font-weight: 900;
            color: var(--primary);
        }

        .status-pill {
            padding: 0.5rem 1.5rem;
            border-radius: 50px;
            font-weight: 800;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .watermark {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-30deg);
            font-size: 8rem;
            font-weight: 900;
            opacity: 0.03;
            pointer-events: none;
            white-space: nowrap;
            z-index: 0;
        }

        @media (max-width: 768px) {
            .bill-glass-card {
                padding: 2rem 1.5rem;
                border-radius: var(--radius-xl);
            }
            .bill-header {
                flex-direction: column;
                gap: 1.5rem;
                text-align: center;
            }
            .grand-total-hero {
                font-size: 1.5rem;
            }
            .bill-info-grid {
                grid-template-columns: 1fr;
                gap: 1.5rem;
            }
            .summary-block {
                padding: 1.5rem;
            }
            .admin-page-header {
                padding: 2rem 0;
            }
        }

        @media print {
            .navbar, .sidebar, .admin-page-header, .btn-group-actions, .footer {
                display: none !important;
            }
            .container-fluid {
                padding: 0 !important;
            }
            .bill-glass-card {
                box-shadow: none;
                border: 1px solid #eee;
                padding: 2rem;
            }
        }
    </style>
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <div class="admin-page-header">
        <div class="container px-md-5 px-3">
            <div class="row align-items-center">
                <div class="col-md-7" data-aos="fade-right">
                    <h1 class="display-5 fw-900 mb-2">Invoice Audit</h1>
                    <p class="mb-0 opacity-75 fs-5">Detailed review of financial transaction #<%= bill.billNumber %></p>
                </div>
                <div class="col-md-5 text-md-end mt-4 mt-md-0" data-aos="fade-left">
                    <div class="d-flex gap-2 justify-content-md-end btn-group-actions">
                        <a href="/admin/bills" class="btn btn-light rounded-pill px-4 fw-bold">
                            <i class="fas fa-arrow-left me-2"></i>Back
                        </a>
                        <div class="dropdown">
                            <button class="btn btn-primary rounded-pill px-4 fw-bold dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-download me-2"></i>Export
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end rounded-4 shadow-lg border-0 p-2">
                                <li><a class="dropdown-item rounded-3 py-2" href="/admin/bills/<%= bill._id %>/print" target="_blank"><i class="fas fa-print me-2 text-primary"></i>Print Official Copy</a></li>
                                <li><a class="dropdown-item rounded-3 py-2" href="/admin/bills/<%= bill._id %>/pdf"><i class="fas fa-file-pdf me-2 text-danger"></i>Generate PDF Document</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item rounded-3 py-2" href="/admin/bills/<%= bill._id %>/edit"><i class="fas fa-edit me-2 text-info"></i>Modify Record</a></li>
                                <% if (bill.status !== 'cancelled') { %>
                                <li>
                                    <form action="/admin/bills/update-status/<%= bill._id %>" method="POST" onsubmit="return confirm('Void this invoice? This will mark it as cancelled.');">
                                        <input type="hidden" name="status" value="cancelled">
                                        <button type="submit" class="dropdown-item rounded-3 py-2 text-warning">
                                            <i class="fas fa-ban me-2"></i>Void Invoice
                                        </button>
                                    </form>
                                </li>
                                <% } %>
                                <li>
                                    <form action="/admin/bills/delete/<%= bill._id %>" method="POST" onsubmit="return confirm('Delete this record permanently? This cannot be undone.');">
                                        <button type="submit" class="dropdown-item rounded-3 py-2 text-danger">
                                            <i class="fas fa-trash-alt me-2"></i>Delete Record
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-md-5 px-3 py-4">
        <div class="row g-4">
            <main class="col-12">
                <div class="bill-glass-card" data-aos="fade-up">
                    <div class="watermark"><%= bill.status.toUpperCase() %></div>
                    
                    <div class="bill-header d-flex justify-content-between align-items-start">
                        <div>
                            <h2 class="fw-900 text-primary mb-1">SRI LALITAMBA NURSERY AND GARDENS</h2>
                            <p class="text-muted small fw-bold mb-0">BOTANICAL EXCELLENCE SINCE INCEPTION</p>
                            <div class="mt-3 small text-muted fw-600">
                                <i class="fas fa-map-marker-alt me-2"></i>Kadiypulanka, East Godavari, AP<br>
                                <i class="fas fa-phone me-2"></i>+91 99633 72123
                            </div>
                        </div>
                        <div class="text-end">
                            <h1 class="fw-900 mb-0">INVOICE</h1>
                            <div class="badge status-pill bg-<%= bill.status === 'paid' ? 'success' : bill.status === 'pending' ? 'warning' : 'danger' %> mt-2">
                                <%= bill.status.toUpperCase() %>
                            </div>
                            <div class="mt-3">
                                <h5 class="fw-900 mb-0">#<%= bill.billNumber %></h5>
                                <p class="text-muted small fw-bold">GEN-<%= new Date(bill.billDate).getFullYear() %></p>
                            </div>
                        </div>
                    </div>

                    <div class="bill-info-grid">
                        <div class="info-block">
                            <h6>RECIPIENT ENTITY</h6>
                            <p><%= bill.customerName %></p>
                            <% if (bill.customerPhone) { %>
                                <div class="small text-muted mt-1 fw-bold"><i class="fas fa-phone-alt me-2"></i><%= bill.customerPhone %></div>
                            <% } %>
                        </div>
                        <div>
                            <h1 class="display-6 fw-900 mb-1 glistening-text">Invoice #<%= bill.billNumber %></h1>
                            <p class="mb-0 opacity-75 fw-semibold">Generated on <%= new Date(bill.billDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
                        </div>
                        <div class="info-block">
                            <h6>MATURITY DATE</h6>
                            <p><%= bill.dueDate ? new Date(bill.dueDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) : 'N/A' %></p>
                        </div>
                        <div class="info-block">
                            <h6>PAYMENT INSTRUMENT</h6>
                            <p class="text-uppercase"><%= bill.paymentMode || 'Standard' %></p>
                        </div>
                    </div>

                    <div class="table-responsive mb-5">
                        <table class="table bill-table align-middle">
                            <thead>
                                <tr>
                                    <th style="width: 15%">SPECIFICATION</th>
                                    <th>BOTANICAL SPECIMEN</th>
                                    <th class="text-center" style="width: 10%">QTY</th>
                                    <th class="text-end" style="width: 15%">UNIT RATE</th>
                                    <th class="text-end" style="width: 15%">VALUATION</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% bill.items.forEach(item => { %>
                                    <tr>
                                        <td><span class="badge bg-light text-dark border px-3 py-2 rounded-pill"><%= item.packetSize || 'Standard' %></span></td>
                                        <td class="fw-bold"><%= item.plantName || item.description %></td>
                                        <td class="text-center fw-900"><%= item.quantity %></td>
                                        <td class="text-end fw-bold text-muted">₹<%= item.unitPrice.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                                        <td class="text-end fw-900 text-primary">₹<%= item.lineTotal.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <div class="row g-5">
                        <div class="col-md-6">
                            <% if (bill.notes) { %>
                                <div class="p-4 rounded-4 bg-light bg-opacity-50 border border-dashed mb-4">
                                    <h6 class="fw-bold small text-uppercase text-muted mb-2">Administrative Notes</h6>
                                    <p class="small text-muted mb-0"><%= bill.notes %></p>
                                </div>
                            <% } %>
                            
                            <% if (bill.payments && bill.payments.length > 0) { %>
                                <h6 class="fw-bold small text-uppercase text-muted mb-3">Transaction Log</h6>
                                <div class="table-responsive">
                                    <table class="table table-sm table-borderless small">
                                        <tbody>
                                            <% bill.payments.forEach(payment => { %>
                                                <tr class="border-bottom border-light">
                                                    <td class="py-2"><%= new Date(payment.date).toLocaleDateString('en-IN') %></td>
                                                    <td class="py-2 text-muted fw-bold"><%= payment.mode.toUpperCase() %></td>
                                                    <td class="py-2 text-end fw-900 text-success">₹<%= payment.amount.toLocaleString('en-IN') %></td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>
                        </div>
                        <div class="col-md-6">
                            <div class="summary-block">
                                <div class="summary-row">
                                    <span class="text-muted fw-bold">Subtotal Consolidation</span>
                                    <span class="fw-bold text-dark">₹<%= bill.subTotal.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
                                </div>
                                <div class="summary-row">
                                    <span class="text-muted fw-bold">Tax Assessment</span>
                                    <span class="fw-bold text-dark">₹<%= bill.tax.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
                                </div>
                                <div class="summary-row text-danger">
                                    <span class="fw-bold">Trade Discount</span>
                                    <span class="fw-bold">-₹<%= bill.discount.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
                                </div>
                                <div class="summary-row">
                                    <span class="fw-900 text-primary">GRAND VALUATION</span>
                                    <span class="grand-total-hero">₹<%= bill.totalAmount.toLocaleString('en-IN', { minimumFractionDigits: 2 }) %></span>
                                </div>
                            </div>
                            
                            <div class="mt-4 px-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="small fw-bold text-muted">LIQUIDATED AMOUNT</span>
                                    <span class="small fw-900 text-success">₹<%= (bill.paidAmount || 0).toLocaleString('en-IN') %></span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="small fw-bold text-muted">OUTSTANDING BALANCE</span>
                                    <span class="small fw-900 text-danger">₹<%= (bill.balanceAmount || (bill.totalAmount - (bill.paidAmount || 0))).toLocaleString('en-IN') %></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 pt-5 border-top text-center text-muted small d-print-none">
                        <p class="mb-0">This is a system-generated audit manifest. Unauthorized duplication is strictly prohibited.</p>
                        <p class="fw-bold text-primary mt-2">© SRI LALITAMBA NURSERY & GARDENS</p>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });
    </script>
</body>
</html>