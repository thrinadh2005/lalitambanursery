<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .admin-page-header {
            background: var(--gradient-primary);
            color: white;
            padding: 4rem 0;
            margin-bottom: 2rem;
            border-radius: 0 0 var(--radius-3xl) var(--radius-3xl);
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

        .admin-page-header::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11 18c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm48 25c3.866 0 7-3.134 7-7s-3.134-7-7-7-7 3.134-7 7 3.134 7 7 7zm-43-7c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm63 31c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zM34 90c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3zm56-76c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zM12 86c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm66-3c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm-40-39c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2zm43 38c1.105 0 2-.895 2-2s-.895-2-2-2-2 .895-2 2 .895 2 2 2z' fill='%23ffffff' fill-opacity='0.05'/%3E%3C/svg%3E");
            opacity: 0.1;
        }

        .glass-report-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-2xl);
            overflow: hidden;
            box-shadow: var(--shadow-xl);
            transition: transform 0.3s ease;
        }

        .glass-report-card:hover {
            transform: translateY(-5px);
        }

        .table-glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-2xl);
            overflow: hidden;
            box-shadow: var(--shadow-xl);
        }
    </style>
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <div class="admin-page-header">
        <div class="container px-5">
            <div class="row align-items-center">
                <div class="col-md-7" data-aos="fade-right">
                    <h1 class="display-5 fw-900 mb-2">Business Insights</h1>
                    <p class="mb-0 opacity-75 fs-5">Comprehensive analytics and performance metrics for your nursery</p>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-5 py-4">
        <div class="row g-4">
            <main class="col-12">
                <!-- Analytics Summary -->
                <div class="row g-4 mb-5" data-aos="fade-up">
                    <div class="col-md-6">
                        <div class="glass-report-card p-4 border-start border-4 border-success">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="text-muted small fw-bold text-uppercase mb-1">Gross Revenue</div>
                                    <h2 class="fw-900 text-dark mb-0">₹<%= stats.revenue.toLocaleString('en-IN') %></h2>
                                </div>
                                <div class="bg-success bg-opacity-10 p-3 rounded-4">
                                    <i class="fas fa-indian-rupee-sign fa-2x text-success"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="glass-report-card p-4 border-start border-4 border-primary">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="text-muted small fw-bold text-uppercase mb-1">Fulfillment Rate</div>
                                    <h2 class="fw-900 text-dark mb-0"><%= stats.orders %> Shipments</h2>
                                </div>
                                <div class="bg-primary bg-opacity-10 p-3 rounded-4">
                                    <i class="fas fa-truck-fast fa-2x text-primary"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Product Performance -->
                <div class="table-glass-card" data-aos="fade-up">
                    <div class="p-4 border-bottom bg-white bg-opacity-50 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold"><i class="fas fa-chart-line me-2 text-primary"></i>Top Performing Species</h5>
                        <div class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2">Sales Volume</div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">Product Name</th>
                                    <th class="text-center">Units Distributed</th>
                                    <th class="text-end pe-4">Market Share</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(stats.topProducts && stats.topProducts.length > 0) { %>
                                    <% 
                                        const totalCount = stats.topProducts.reduce((sum, p) => sum + p.count, 0);
                                        stats.topProducts.forEach(product => { 
                                            const share = ((product.count / totalCount) * 100).toFixed(1);
                                    %>
                                        <tr>
                                            <td class="ps-4 fw-bold text-dark"><%= product._id %></td>
                                            <td class="text-center">
                                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-1">
                                                    <%= product.count %> units
                                                </span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="d-flex align-items-center justify-content-end gap-2">
                                                    <div class="progress flex-grow-1" style="height: 6px; width: 100px; max-width: 100px;">
                                                        <div class="progress-bar bg-success" style="width: <%= share %>%"></div>
                                                    </div>
                                                    <span class="small fw-bold text-muted"><%= share %>%</span>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="3" class="text-center py-5">
                                            <div class="text-muted py-5">
                                                <i class="fas fa-box-open fa-4x mb-3 opacity-25"></i>
                                                <h5 class="fw-bold">No Transaction Data</h5>
                                                <p>Market insights will populate as orders are processed.</p>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        AOS.init({ duration: 800, once: true });
    </script>
</body>

</html>