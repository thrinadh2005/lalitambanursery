<style>
    .admin-main-nav {
        background: var(--glass-bg);
        backdrop-filter: blur(12px) saturate(180%);
        -webkit-backdrop-filter: blur(12px) saturate(180%);
        border-bottom: 1px solid var(--glass-border);
        padding: 0.5rem 0;
        z-index: 1040;
    }
    
    .nav-link-admin {
        font-weight: 800;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-main) !important;
        padding: 0.6rem 0.9rem !important;
        border-radius: 10px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.35rem;
        border: 1px solid transparent;
        white-space: nowrap;
    }
    
    .nav-link-admin i {
        font-size: 1rem;
        transition: transform 0.3s ease;
    }
    
    .nav-link-admin:hover {
        background: rgba(16, 185, 129, 0.05);
        color: var(--accent) !important;
        transform: translateY(-2px);
    }
    
    .nav-link-admin:hover i {
        transform: scale(1.2);
    }
    
    .nav-link-admin.active {
        background: rgba(16, 185, 129, 0.1) !important;
        color: var(--accent) !important;
        border: 1px solid rgba(16, 185, 129, 0.2);
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.1);
    }
    
    .brand-text {
        font-family: 'Playfair Display', serif;
        font-weight: 900;
        font-size: 1.25rem;
        letter-spacing: -0.02em;
    }

    /* Fix for wrapping Audit Logs */
    .nav-link-admin {
        min-width: 80px;
        justify-content: center;
    }

    @media (max-width: 1199px) {
        .admin-main-nav {
            padding: 0.75rem 0;
        }
        .navbar-collapse {
            background: var(--surface);
            padding: 1.5rem;
            border-radius: 20px;
            margin-top: 1rem;
            box-shadow: var(--shadow-premium);
            border: 1px solid var(--border);
        }
        .nav-link-admin {
            flex-direction: row;
            font-size: 0.85rem;
            padding: 0.8rem 1.2rem !important;
            margin-bottom: 0.5rem;
            justify-content: flex-start;
            gap: 1rem;
        }
        .nav-link-admin i {
            font-size: 1.1rem;
        }
    }
</style>

<nav class="navbar navbar-expand-xl sticky-top shadow-sm admin-main-nav navbar-light">
    <div class="container-fluid px-md-5 px-3">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/admin/dashboard">
            <div class="brand-icon bg-primary rounded-3 d-flex align-items-center justify-content-center text-white" style="width: 38px; height: 38px;">
                <i class="fas fa-leaf"></i>
            </div>
            <span class="brand-text">Admin <span class="text-primary">Panel</span></span>
        </a>

        <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbarCollapse">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="adminNavbarCollapse">
            <ul class="navbar-nav me-auto mb-2 mb-xl-0 gap-1 mt-3 mt-xl-0">
                <li class="nav-item">
                    <a class="nav-link-admin <%= typeof page !== 'undefined' && page === 'dashboard' ? 'active' : '' %>" href="/admin/dashboard">
                        <i class="fas fa-chart-pie"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link-admin <%= typeof page !== 'undefined' && page === 'plants' ? 'active' : '' %>" href="/admin/plants">
                        <i class="fas fa-leaf"></i> Gallery
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link-admin <%= typeof page !== 'undefined' && page === 'orders' ? 'active' : '' %>" href="/admin/orders">
                        <i class="fas fa-shopping-cart"></i> Orders
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link-admin <%= typeof page !== 'undefined' && page === 'expenses' ? 'active' : '' %>" href="/admin/expenses">
                        <i class="fas fa-wallet"></i> Expenses
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link-admin <%= typeof page !== 'undefined' && page === 'investments' ? 'active' : '' %>" href="/admin/investments">
                        <i class="fas fa-trending-up"></i> Investments
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link-admin <%= typeof page !== 'undefined' && page === 'imports-exports' ? 'active' : '' %>" href="/admin/imports-exports">
                        <i class="fas fa-exchange-alt"></i> Logistics
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link-admin <%= typeof page !== 'undefined' && page === 'bills' ? 'active' : '' %>" href="/admin/bills">
                        <i class="fas fa-file-invoice"></i> Bills
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link-admin <%= typeof page !== 'undefined' && page === 'users' ? 'active' : '' %>" href="/admin/users">
                        <i class="fas fa-users"></i> Users
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link-admin <%= typeof page !== 'undefined' && page === 'audit-logs' ? 'active' : '' %>" href="/admin/audit-logs">
                        <i class="fas fa-history"></i> Audit Logs
                    </a>
                </li>
            </ul>

            <div class="d-flex flex-row align-items-center mt-3 mt-xl-0 gap-3 ms-xl-2 border-top border-xl-0 pt-3 pt-xl-0 w-100 w-xl-auto">
                <!-- Theme Toggle (Icon Only) -->
                <button class="btn btn-outline-primary theme-toggle-btn shadow-none d-flex justify-content-center align-items-center rounded-circle flex-shrink-0" id="themeToggle" title="Toggle Theme" style="width: 40px; height: 40px;">
                    <i class="fas fa-moon theme-icon-dark fa-lg"></i>
                    <i class="fas fa-sun theme-icon-light d-none fa-lg"></i>
                </button>

                <div class="dropdown flex-grow-1 w-xl-auto">
                    <a class="btn btn-light dropdown-toggle d-flex align-items-center justify-content-center gap-2 rounded-pill px-4 w-100 border" href="#" id="adminProfileDropdown" data-bs-toggle="dropdown">
                        <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center text-white" style="width: 24px; height: 24px; font-size: 0.7rem;">
                            <%= user && user.firstName ? user.firstName.charAt(0) : 'A' %>
                        </div>
                        <span class="fw-bold small"><%= (user && user.firstName) || 'Admin' %></span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 mt-2 w-100">
                        <li><a class="dropdown-item py-2 px-3" href="/profile"><i class="fas fa-user-circle me-2 text-primary"></i>My Profile</a></li>
                        <li><a class="dropdown-item py-2 px-3" href="/" target="_blank"><i class="fas fa-external-link-alt me-2 text-info"></i>View Website</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2 px-3 text-danger" href="/admin/logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</nav>

<!-- Flash Messages -->
<div class="container-fluid mt-3">
    <% if (typeof success_msg !=='undefined' && success_msg && success_msg.length> 0) { %>
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            <%= success_msg %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>
            <% if (typeof error_msg !=='undefined' && error_msg && error_msg.length> 0) { %>
                <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    <%= error_msg %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                <% } %>
</div>