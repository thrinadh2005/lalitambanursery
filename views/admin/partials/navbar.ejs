                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link-admin <%= typeof page !== 'undefined' && page === 'expenses' ? 'active' : '' %>" href="/admin/expenses">
                        <i class="fas fa-wallet"></i> Expenses
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link-admin <%= typeof page !== 'undefined' && page === 'investments' ? 'active' : '' %>" href="/admin/investments">
                        <i class="fas fa-trending-up"></i> Invests
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link-admin <%= typeof page !== 'undefined' && page === 'imports-exports' ? 'active' : '' %>" href="/admin/imports-exports">
                        <i class="fas fa-exchange-alt"></i> Logistics
                    </a>
                </li>
                <li class="nav-item">
