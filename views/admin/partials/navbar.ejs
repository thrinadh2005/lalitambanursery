            </a>
            <a href="/admin/expenses" class="list-group-item list-group-item-action <%= typeof page !== 'undefined' && page === 'expenses' ? 'active-item' : '' %>">
                <i class="fas fa-wallet me-3 opacity-50" style="width:20px;text-align:center;"></i> Expenses
            </a>
            <a href="/admin/investments" class="list-group-item list-group-item-action <%= typeof page !== 'undefined' && page === 'investments' ? 'active-item' : '' %>">
                <i class="fas fa-trending-up me-3 opacity-50" style="width:20px;text-align:center;"></i> Investments
            </a>
            <a href="/admin/imports-exports" class="list-group-item list-group-item-action <%= typeof page !== 'undefined' && page === 'imports-exports' ? 'active-item' : '' %>">
                <i class="fas fa-exchange-alt me-3 opacity-50" style="width:20px;text-align:center;"></i> Logistics
            </a>
            <a href="/admin/bills" class="list-group-item list-group-item-action <%= typeof page !== 'undefined' && page === 'bills' ? 'active-item' : '' %>">
                <i class="fas fa-file-invoice me-3 opacity-50" style="width:20px;text-align:center;"></i> Bills
            </a>
            <a href="/admin/users" class="list-group-item list-group-item-action <%= typeof page !== 'undefined' && page === 'users' ? 'active-item' : '' %>">
                <i class="fas fa-users me-3 opacity-50" style="width:20px;text-align:center;"></i> Users
            </a>
            <a href="/admin/audit-logs" class="list-group-item list-group-item-action <%= typeof page !== 'undefined' && page === 'audit-logs' ? 'active-item' : '' %>">
