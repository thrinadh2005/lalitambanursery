<!-- Clock Script -->
<script>
    function updateAdminClocks() {
        const now = new Date();
        const options = { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true };
        const timeString = now.toLocaleTimeString('en-US', options);
        
        const deskClock = document.querySelector('#adminClockDesktop span');
        const veryMobClock = document.querySelector('#adminClockVeryMobile span');
        
        if (deskClock) deskClock.textContent = timeString;
        if (veryMobClock) veryMobClock.textContent = timeString;
    }
    setInterval(updateAdminClocks, 1000);
    updateAdminClocks();

    // Navbar Scroll Effect
    window.addEventListener('scroll', () => {
        const nav = document.querySelector('.admin-main-nav');
        if (window.scrollY > 30) {
            nav.classList.add('scrolled');
        } else {
            nav.classList.remove('scrolled');
        }
    });
</script>

<!-- Flash Messages -->
<div class="container-fluid mt-3">
    <% if (typeof success_msg !== 'undefined' && success_msg) { %>
        <% const successes = Array.isArray(success_msg) ? success_msg : [success_msg]; %>
        <% successes.filter(m => m && m.length > 0).forEach(msg => { %>
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-lg rounded-4 mb-3 p-3" role="alert" style="border-left: 5px solid #10b981 !important; background: var(--surface);">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; min-width: 40px;">
                        <i class="fas fa-check-circle fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-success small text-uppercase">Success</div>
                        <div class="text-main small"><%= msg %></div>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% }) %>
    <% } %>
    
    <% if (typeof error_msg !== 'undefined' && error_msg) { %>
        <% const errors = Array.isArray(error_msg) ? error_msg : [error_msg]; %>
        <% errors.filter(m => m && m.length > 0).forEach(msg => { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 shadow-lg rounded-4 mb-3 p-3" role="alert" style="border-left: 5px solid #ef4444 !important; background: var(--surface);">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; min-width: 40px;">
                        <i class="fas fa-circle-exclamation fs-5"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-danger small text-uppercase">Error</div>
                        <div class="text-main small"><%= msg %></div>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% }) %>
    <% } %>
</div>