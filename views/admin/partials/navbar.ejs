<style>
    :root {
        --nav-height: 70px;
        --nav-gap: 0.5rem;
    }

    .admin-main-nav {
        background: var(--glass-bg);
        backdrop-filter: blur(25px);
        -webkit-backdrop-filter: blur(25px);
        border-bottom: 1px solid var(--glass-border);
        padding: 0;
        height: var(--nav-height);
        z-index: 1040;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .admin-main-nav.scrolled {
        height: 60px;
        background: var(--surface);
        box-shadow: var(--shadow-lg);
    }
    
    .nav-link-admin {
        font-weight: 600;
        font-size: 0.82rem;
        color: var(--text-main) !important;
        padding: 0.6rem 0.9rem !important;
        border-radius: 12px;
        transition: all 0.25s ease;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        white-space: nowrap;
        position: relative;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .nav-link-admin i {
        font-size: 1rem;
        opacity: 0.7;
        transition: all 0.25s ease;
    }

    .nav-link-admin:hover {
        background: rgba(16, 185, 129, 0.08);
        color: #10b981 !important;
        transform: translateY(-1px);
    }

    .nav-link-admin:hover i {
        opacity: 1;
        transform: scale(1.1);
    }

    .nav-link-admin.active {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white !important;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
    }

    .nav-link-admin.active i {
        opacity: 1;
    }
    
    /* Active indicator dot */
    .nav-link-admin.active::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 50%;
        transform: translateX(-50%);
        width: 4px;
        height: 4px;
        background: #10b981;
        border-radius: 50%;
        display: none; /* Optional: use dot instead of full background */
    }
    
    .navbar-nav {
        display: flex;
        align-items: center;
        gap: var(--nav-gap);
    }

    .navbar-brand {
        transition: transform 0.3s ease;
    }

    .navbar-brand:hover {
        transform: scale(1.05);
    }

    .brand-icon {
        background: linear-gradient(135deg, #10b981, #059669);
        box-shadow: 0 4px 10px rgba(16, 185, 129, 0.2);
    }

    .brand-text {
        font-family: 'Outfit', sans-serif;
        font-size: 1.25rem;
        letter-spacing: -0.5px;
    }

    .clock-display {
        font-family: 'JetBrains Mono', 'Inter', monospace;
        font-weight: 700;
        font-size: 0.8rem;
        color: var(--text-main);
        background: rgba(0, 0, 0, 0.03);
        padding: 0.5rem 1rem;
        border-radius: 12px;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 0.6rem;
        box-shadow: var(--shadow-sm);
    }

    [data-theme="dark"] .clock-display {
        background: rgba(255, 255, 255, 0.03);
    }

    .user-pill {
        background: var(--background-alt);
        border: 1px solid var(--border);
        padding: 0.35rem 1rem 0.35rem 0.35rem;
        border-radius: 50px;
        transition: all 0.3s ease;
    }

    .user-pill:hover {
        background: var(--surface);
        border-color: #10b981;
        box-shadow: var(--shadow-md);
    }

    [data-theme="dark"] .admin-main-nav {
        background: rgba(15, 23, 42, 0.8);
        border-bottom-color: rgba(255, 255, 255, 0.05);
    }

    /* Offcanvas Styling */
    .offcanvas-admin {
        background: var(--surface) !important;
        border-left: 1px solid var(--border);
    }

    .offcanvas-admin .list-group-item {
        margin: 0.25rem 1rem;
        border-radius: 12px;
        font-weight: 600;
        padding: 0.8rem 1.2rem;
        border: none;
        transition: all 0.2s ease;
    }

    .offcanvas-admin .list-group-item:hover {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
        transform: translateX(5px);
    }

    .offcanvas-admin .list-group-item.active-item {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
    }
</style>

