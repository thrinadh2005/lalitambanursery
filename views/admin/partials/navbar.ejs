            <a href="/admin/plants" class="list-group-item list-group-item-action <%= typeof page !== 'undefined' && page === 'plants' ? 'active-item' : '' %>">
                <i class="fas fa-leaf me-3 opacity-50" style="width:20px;text-align:center;"></i> Gallery
            </a>
            <a href="/admin/orders" class="list-group-item list-group-item-action <%= typeof page !== 'undefined' && page === 'orders' ? 'active-item' : '' %>">
