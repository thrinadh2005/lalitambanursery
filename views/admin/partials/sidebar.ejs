<style>
    #sidebar {
        background: var(--surface) !important;
        border-right: 1px solid var(--border-light);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        height: auto;
    }

    #sidebar .nav-link {
        color: var(--text-body) !important;
        font-weight: 600;
        padding: 12px 20px !important;
        border-radius: 12px;
        margin: 4px 16px;
        display: flex;
        align-items: center;
        transition: all 0.2s ease;
        font-size: 0.95rem;
        border: 2px solid transparent;
    }

    #sidebar .nav-link i {
        font-size: 1.25rem;
        width: 32px;
        margin-right: 12px;
        color: var(--text-muted);
        transition: all 0.2s ease;
    }

    #sidebar .nav-link:hover {
        background-color: var(--background-alt);
        color: var(--text-main) !important;
    }

    #sidebar .nav-link:hover i {
        color: var(--text-main);
    }

    #sidebar .nav-link.active {
        background-color: var(--accent-light) !important;
        color: var(--accent) !important;
        position: relative;
    }

    #sidebar .nav-link.active i {
        color: var(--accent) !important;
    }

    #sidebar .nav-link.active::after {
        content: '';
        position: absolute;
        bottom: 4px;
        left: 50%;
        transform: translateX(-50%);
        width: 24px;
        height: 3px;
        background-color: var(--accent);
        border-radius: 10px;
    }

    #sidebar .sidebar-heading {
        color: var(--text-muted);
        font-size: 1rem;
        font-weight: 800;
        padding: 32px 32px 16px;
        letter-spacing: -0.01em;
    }

    #sidebar .nav-link.text-danger {
        color: var(--text-muted) !important;
    }

    #sidebar .nav-link.text-danger:hover {
        background-color: rgba(220, 38, 38, 0.1) !important;
        color: #dc2626 !important;
    }

    #sidebar .nav-link.text-danger:hover i {
        color: #dc2626;
    }

    @media (max-width: 767.98px) {
        #sidebar {
            position: fixed !important;
            top: 56px; /* Below navbar */
            left: 0;
            width: 250px;
            max-width: 80%;
            height: calc(100vh - 56px);
            z-index: 1050 !important;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5) !important;
            background: var(--surface) !important;
            overflow-y: auto;
            transform: translateX(-100%);
            transition: transform 0.3s ease-in-out;
            display: block !important;
        }

        #sidebar.show {
            transform: translateX(0);
        }
    }
</style>

<nav id="sidebar" class="sidebar collapse d-md-block shadow-sm">
    <div class="pt-3">
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link <%= typeof page !== 'undefined' && page === 'dashboard' ? 'active' : '' %>"
                    href="/admin/dashboard">
                    <i class="fas fa-gauge-high"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link <%= typeof page !== 'undefined' && page === 'plants' ? 'active' : '' %>"
                    href="/admin/plants">
                    <i class="fas fa-image"></i> Gallery
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link <%= typeof page !== 'undefined' && page === 'orders' ? 'active' : '' %>"
                    href="/admin/orders">
                    <i class="fas fa-shopping-bag"></i> Orders
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link <%= typeof page !== 'undefined' && page === 'expenses' ? 'active' : '' %>"
                    href="/admin/expenses">
                    <i class="fas fa-money-bill"></i> Expenses
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link <%= typeof page !== 'undefined' && page === 'investments' ? 'active' : '' %>"
                    href="/admin/investments">
                    <i class="fas fa-chart-line"></i> Investments
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link <%= typeof page !== 'undefined' && page === 'imports-exports' ? 'active' : '' %>"
                    href="/admin/imports-exports">
                    <i class="fas fa-right-left"></i> Import/Export
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link <%= typeof page !== 'undefined' && page === 'bills' ? 'active' : '' %>"
                    href="/admin/bills">
                    <i class="fas fa-file-invoice-dollar"></i> Bills
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link <%= typeof page !== 'undefined' && page === 'users' ? 'active' : '' %>"
                    href="/admin/users">
                    <i class="fas fa-user-group"></i> Users
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link <%= typeof page !== 'undefined' && page === 'reports' ? 'active' : '' %>"
                    href="/admin/reports">
                    <i class="fas fa-chart-bar"></i> Reports
                </a>
            </li>
        </ul>

        <h6 class="sidebar-heading d-flex justify-content-between align-items-center px-4 mt-4 mb-1">
            <span>Quick Links</span>
        </h6>
        <ul class="nav flex-column mb-2 px-3">
            <li class="nav-item">
                <a class="nav-link" href="/" target="_blank">
                    <i class="fas fa-arrow-up-right-from-square"></i> View Website
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-danger" href="/admin/logout">
                    <i class="fas fa-arrow-right-from-bracket"></i> Logout
                </a>
            </li>
        </ul>
    </div>
</nav>