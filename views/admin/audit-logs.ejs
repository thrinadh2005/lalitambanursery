<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        .admin-page-header {
            background: var(--gradient-primary);
            color: white;
            padding: 3.5rem 0 !important;
            margin-bottom: 2rem;
            border-radius: 0 0 var(--radius-2xl) var(--radius-2xl);
            box-shadow: var(--shadow-lg);
        }

        .audit-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
        }

        .severity-badge {
            font-size: 0.65rem;
            font-weight: 900;
            padding: 0.35rem 0.75rem;
            border-radius: 6px;
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .severity-low { background: rgba(16, 185, 129, 0.15); color: #10b981; }
        .severity-medium { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
        .severity-high { background: rgba(239, 68, 68, 0.15); color: #ef4444; }
        .severity-critical { background: #ef4444; color: #ffffff; }

        .log-timestamp {
            font-family: 'Inter', sans-serif;
            font-size: 0.8rem;
            color: var(--text-main);
            font-weight: 600;
            line-height: 1.3;
        }

        .log-action {
            font-weight: 800;
            color: var(--text-main);
            font-size: 0.9rem;
        }

        .log-module {
            background: var(--background-alt);
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--primary);
        }

        .table thead th {
            background: var(--background-alt);
            border-bottom: 2px solid var(--accent);
            text-transform: uppercase;
            font-size: 0.7rem;
            font-weight: 900;
            padding: 1rem !important;
            color: var(--text-main);
            letter-spacing: 0.05em;
        }

        .table tbody td {
            padding: 1rem !important;
            vertical-align: middle;
            border-bottom: 1px solid var(--border-light);
            font-size: 0.9rem;
            color: var(--text-main);
        }
    </style>
</head>

<body class="bg-light">
    <%- include('partials/navbar') %>

    <div class="admin-page-header">
        <div class="container px-md-5 px-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-5 fw-900 mb-2">System Audit Logs</h1>
                    <p class="mb-0 opacity-75">Tracking administrative actions and system security events</p>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-md-5 px-3 pb-5">
        <div class="audit-card" data-aos="fade-up">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>Action</th>
                            <th>Module</th>
                            <th>Details</th>
                            <th>Admin</th>
                            <th>Severity</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (logs && logs.length > 0) { %>
                            <% logs.forEach(log => { %>
                                <tr>
                                    <td>
                                        <div class="log-timestamp">
                                            <%= new Date(log.timestamp).toLocaleDateString('en-IN') %><br>
                                            <small><%= new Date(log.timestamp).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) %></small>
                                        </div>
                                    </td>
                                    <td><span class="log-action"><%= log.action %></span></td>
                                    <td><span class="log-module"><%= log.module %></span></td>
                                    <td>
                                        <div class="text-wrap" style="max-width: 300px;">
                                            <%= log.details %>
                                        </div>
                                    </td>
                                    <td>
                                        <% if (log.performedBy) { %>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="bg-primary-light text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 24px; height: 24px; font-size: 0.7rem;">
                                                    <%= log.performedBy.firstName ? log.performedBy.firstName.charAt(0) : 'A' %>
                                                </div>
                                                <small><%= log.performedBy.email %></small>
                                            </div>
                                        <% } else { %>
                                            <span class="text-muted small">System</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <span class="severity-badge severity-<%= log.severity %>">
                                            <%= log.severity %>
                                        </span>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="fas fa-history fa-3x mb-3 opacity-25"></i>
                                        <p>No audit logs recorded yet</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
            
            <% if (totalPages > 1) { %>
                <div class="p-4 border-top">
                    <nav aria-label="Audit log pagination">
                        <ul class="pagination justify-content-center mb-0">
                            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                <a class="page-link rounded-start-pill px-3" href="?page=<%= currentPage - 1 %>">Previous</a>
                            </li>
                            <% for(let i = 1; i <= totalPages; i++) { %>
                                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                    <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                                </li>
                            <% } %>
                            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                <a class="page-link rounded-end-pill px-3" href="?page=<%= currentPage + 1 %>">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            <% } %>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script>
        AOS.init({
            duration: 800,
            once: true
        });
    </script>
</body>

</html>
