<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        :root {
            --admin-green: #10b981;
            --admin-bg: var(--background);
            --surface-admin: var(--surface);
            --text-main-admin: var(--text-main);
            --text-muted-admin: var(--text-muted);
            --border-admin: var(--border);
            --radius-xl: 16px;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
            --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1);
            --transition-base: 0.2s ease;
        }

        .admin-dashboard {
            background: var(--admin-bg);
            min-height: 100vh;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            color: var(--text-main-admin);
        }

        .admin-header {
            background: linear-gradient(135deg, #059669 0%, #10b981 100%);
            color: white;
            padding: 3rem 2rem;
            margin-bottom: 2rem;
            position: relative;
            overflow: hidden;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .admin-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="adminPattern" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse"><circle cx="10" cy="10" r="2" fill="rgba(255,255,255,0.1)"/></pattern></defs><rect width="100" height="100" fill="url(%23adminPattern)"/></svg>');
            opacity: 0.3;
        }

        .table-card {
            background: var(--surface-admin);
            border: 1px solid var(--border-admin);
            border-radius: var(--radius-xl);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
        }

        .table {
            margin-bottom: 0;
            color: var(--text-main-admin);
        }

        .sidebar {
            background: var(--primary-light);
            border-right: 1px solid var(--border-admin);
            min-height: 100vh;
        }

        .chart-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            padding: 2rem;
            box-shadow: var(--shadow-sm);
            margin-bottom: 2rem;
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }

        .chart-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--text-main);
            margin: 0;
        }

        .period-btn {
            padding: 0.5rem 1rem;
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text-main);
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .period-btn.active {
            background: var(--admin-green);
            color: white;
            border-color: var(--admin-green);
        }

        .quick-actions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .action-link {
            background: var(--surface);
            border: 1px solid var(--border);
            padding: 1.5rem;
            border-radius: 16px;
            text-decoration: none;
            color: var(--text-main);
            transition: all 0.2s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }

        .action-link:hover {
            border-color: var(--admin-green);
            background: var(--background-alt);
            color: var(--admin-green);
            transform: translateY(-3px);
        }

        .action-link i {
            font-size: 1.5rem;
        }

        .recent-activity {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 2rem;
        }

        .activity-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem 0;
            border-bottom: 1px solid var(--border-light);
        }

        .activity-item:last-child {
            border-bottom: none;
        }

        .activity-dot {
            width: 10px;
            height: 10px;
            background: var(--admin-green);
            border-radius: 50%;
        }

        @media (max-width: 991.98px) {
            .admin-header {
                padding: 2rem 1.5rem;
            }
        }
    </style>
</head>

<body class="admin-dashboard">
    <%- include('partials/navbar') %>

        <div class="container-fluid">
            <div class="row">
                <%- include('partials/sidebar') %>

                    <main class="col-md-9 ms-sm-auto col-lg-10 px-0">
                        <!-- Admin Header -->
                        <header class="admin-header">
                            <div class="container-fluid px-md-4">
                                <div class="row align-items-center">
                                    <div class="col-md-7" data-aos="fade-right">
                                        <h1 class="display-6 fw-800 mb-2">Admin Dashboard</h1>
                                        <p class="mb-0 opacity-90">Welcome back, <%= user.firstName %>! Monitor your
                                                nursery operations.</p>
                                    </div>
                                    <div class="col-md-5 text-md-end mt-3 mt-md-0" data-aos="fade-left">
                                        <div
                                            class="d-inline-flex align-items-center bg-white bg-opacity-10 rounded-pill p-2 px-3">
                                            <span class="small me-3 text-white-50">Last updated: <span id="lastUpdate"></span></span>
                                            <div class="btn-group">
                                                <button class="btn btn-light btn-sm rounded-pill" onclick="refreshData()">
                                                    <i class="fas fa-sync-alt me-1"></i> Refresh
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </header>

                        <div class="px-md-4 pb-5">
                            <!-- Quick Stats Row -->
                            <div class="row g-3 g-md-4 mb-5" data-aos="fade-up">
                                <div class="col-xl-3 col-sm-6">
                                    <div class="stat-card">
                                        <div class="stat-icon"><i class="fas fa-indian-rupee-sign"></i></div>
                                        <% const todayRev = stats.totalRevenue || 0; %>
                                        <div class="stat-number" title="₹<%= todayRev.toLocaleString('en-IN') %>">
                                            ₹<%= todayRev.toLocaleString('en-IN') %>
                                        </div>
                                        <div class="stat-label">Today's Revenue</div>
                                    </div>
                                </div>
                                <div class="col-xl-3 col-sm-6">
                                    <div class="stat-card">
                                        <div class="stat-icon" style="background: #eff6ff; color: #3b82f6;"><i
                                                class="fas fa-truck-fast"></i></div>
                                        <div class="stat-number">
                                            <%= stats.todayOrders || 0 %>
                                        </div>
                                        <div class="stat-label">Today's Orders</div>
                                    </div>
                                </div>
                                <div class="col-xl-3 col-sm-6">
                                    <div class="stat-card">
                                        <div class="stat-icon" style="background: #fff7ed; color: #f59e0b;"><i
                                                class="fas fa-users-viewfinder"></i></div>
                                        <div class="stat-number">
                                            <%= stats.activeUsers || 0 %>
                                        </div>
                                        <div class="stat-label">Active Users</div>
                                    </div>
                                </div>
                                <div class="col-xl-3 col-sm-6">
                                    <div class="stat-card">
                                        <div class="stat-icon" style="background: #fef2f2; color: #ef4444;"><i
                                                class="fas fa-triangle-exclamation"></i></div>
                                        <div class="stat-number">
                                            <%= stats.stockAlerts || 0 %>
                                        </div>
                                        <div class="stat-label">Stock Alerts</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Charts Section -->
                            <div class="row g-4 mb-5">
                                <div class="col-lg-8" data-aos="fade-right">
                                    <div class="chart-card">
                                        <div class="chart-header">
                                            <h3 class="chart-title">Sales Analytics</h3>
                                            <div class="btn-group">
                                                <button class="period-btn active"
                                                    onclick="updateChart('week')">Week</button>
                                                <button class="period-btn" onclick="updateChart('month')">Month</button>
                                            </div>
                                        </div>
                                        <canvas id="revenueChart" style="max-height: 350px;"></canvas>
                                    </div>
                                </div>
                                <div class="col-lg-4" data-aos="fade-left">
                                    <div class="chart-card">
                                        <div class="chart-header">
                                            <h3 class="chart-title">Popular Categories</h3>
                                        </div>
                                        <canvas id="categoryChart" style="max-height: 350px;"></canvas>
                                    </div>
                                </div>
                            </div>

                            <!-- Quick Actions -->
                            <h5 class="fw-700 mb-4" data-aos="fade-up">Quick Management</h5>
                            <div class="quick-actions-grid mb-5" data-aos="fade-up">
                                <a href="/admin/plants/add" class="action-link">
                                    <i class="fas fa-seedling"></i>
                                    <span>Add New Plant</span>
                                </a>
                                <a href="/admin/bills/create" class="action-link">
                                    <i class="fas fa-file-circle-plus"></i>
                                    <span>Generate Bill</span>
                                </a>
                                <a href="/admin/expenses/add" class="action-link">
                                    <i class="fas fa-receipt"></i>
                                    <span>Add Expense</span>
                                </a>
                                <a href="/admin/users" class="action-link">
                                    <i class="fas fa-user-gear"></i>
                                    <span>User Settings</span>
                                </a>
                            </div>

                            <!-- Footer activity and status -->
                            <div class="row g-4">
                                <div class="col-lg-6" data-aos="fade-up">
                                    <div class="recent-activity h-100">
                                        <h5 class="fw-700 mb-4">Recent Activity</h5>
                                        <% if (recentOrders && recentOrders.length > 0) { %>
                                            <% recentOrders.forEach(order => { %>
                                                <div class="activity-item">
                                                    <div class="activity-dot"></div>
                                                    <div class="flex-grow-1">
                                                        <div class="fw-600">New Order #<%= order._id.toString().slice(-6).toUpperCase() %></div>
                                                        <div class="text-muted small">Customer: <%= order.user ? order.user.firstName : 'Guest' %> · <%= new Date(order.createdAt).toLocaleTimeString() %></div>
                                                    </div>
                                                    <div class="fw-bold text-success">₹<%= order.totalAmount.toLocaleString('en-IN') %></div>
                                                </div>
                                            <% }); %>
                                        <% } else { %>
                                            <div class="text-center py-4 text-muted">No recent activity</div>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="col-lg-6" data-aos="fade-up">
                                    <div class="chart-card h-100">
                                        <h5 class="fw-700 mb-4">Stock Health</h5>
                                        <canvas id="stockChart" style="max-height: 250px;"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </main>
            </div>
        </div>

        <!-- Scripts -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
        <script src="/js/utils.js"></script>
        <script>
            AOS.init({ duration: 800, once: true });

            function updateLastUpdateTime() {
                document.getElementById('lastUpdate').textContent = new Date().toLocaleTimeString();
            }
            updateLastUpdateTime();

            // Revenue Chart
            const revenueChart = new Chart(document.getElementById('revenueChart'), {
                type: 'line',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        label: 'Revenue',
                        data: [12000, 19000, 15000, 25000, 22000, 30000, 28000],
                        borderColor: '#10b981',
                        backgroundColor: 'rgba(16, 185, 129, 0.1)',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } }
                }
            });

            // Category Chart
            const categoryData = <%- JSON.stringify(categoryStats || []) %>;
            const categoryChart = new Chart(document.getElementById('categoryChart'), {
                type: 'doughnut',
                data: {
                    labels: categoryData.map(c => c._id || 'Unknown'),
                    datasets: [{
                        data: categoryData.map(c => c.count),
                        backgroundColor: ['#10b981', '#3b82f6', '#f59e0b', '#ef4444', '#8b5cf6'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'bottom' } }
                }
            });

            // Stock Chart
            const stockData = <%- JSON.stringify(stockStats || []) %>;
            new Chart(document.getElementById('stockChart'), {
                type: 'bar',
                data: {
                    labels: stockData.map(s => s._id || 'Unknown'),
                    datasets: [{
                        label: 'Total Stock',
                        data: stockData.map(s => s.totalStock),
                        backgroundColor: '#10b981',
                        borderRadius: 6
                    }]
                },
                options: { 
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true }
                    }
                }
            });

            function refreshData() {
                const icon = event.currentTarget.querySelector('i');
                icon.classList.add('fa-spin');
                setTimeout(() => {
                    icon.classList.remove('fa-spin');
                    updateLastUpdateTime();
                }, 800);
            }
        </script>
</body>

</html>