<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
</head>

<body>
    <%- include('partials/header') %>

        <section class="profile-header">
            <div class="container text-center">
                <h1 class="display-4 fw-bold">My Orders</h1>
            </div>
        </section>

        <div class="container py-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold text-dark mb-0">Order History</h2>
                <a href="/orders/create" class="btn btn-success rounded-pill px-4 shadow-sm">
                    <i class="fas fa-plus-circle me-2"></i> Create New Order
                </a>
            </div>

            <% if (orders && orders.length> 0) { %>
                <div class="row">
                    <% orders.forEach(order=> { %>
                        <div class="col-12 mb-4">
                            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center flex-wrap gap-3">
                                    <div class="d-flex gap-4 flex-wrap">
                                        <div>
                                            <span class="text-muted small fw-bold">ORDER PLACED</span><br>
                                            <strong class="text-dark">
                                                <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                            </strong>
                                        </div>

                                        <div>
                                            <span class="text-muted small fw-bold">ORDER #</span><br>
                                            <span class="text-uppercase text-muted font-monospace small">
                                                <%= order._id.toString().substring(order._id.toString().length - 8) %>
                                            </span>
                                        </div>
                                    </div>
                                    <div>
                                        <span class="badge rounded-pill bg-<%= 
                                            order.status === 'delivered' ? 'success' : 
                                            order.status === 'pending' ? 'warning' : 
                                            order.status === 'processing' ? 'info' : 
                                            order.status === 'shipped' ? 'primary' : 'secondary' 
                                        %> px-3 py-2">
                                            <i class="fas fa-<%= 
                                                order.status === 'delivered' ? 'check-circle' : 
                                                order.status === 'pending' ? 'clock' : 
                                                order.status === 'processing' ? 'sync' : 
                                                order.status === 'shipped' ? 'truck' : 'info-circle' 
                                            %> me-1"></i>
                                            <%= order.status.toUpperCase() %>
                                        </span>
                                    </div>
                                </div>
                                <div class="card-body p-4">
                                    <div class="row">
                                        <div class="col-md-8">
                                            <% order.items.forEach((item, index)=> { %>
                                                <div class="d-flex align-items-center mb-<%= index === order.items.length - 1 ? '0' : '3' %>">
                                                    <div class="bg-light rounded-3 d-flex align-items-center justify-content-center overflow-hidden" style="width: 70px; height: 70px; flex-shrink: 0;">
                                                        <img src="<%= item.image || '/images/placeholder-plant.jpg' %>"
                                                            alt="<%= item.name %>" class="img-fluid"
                                                            style="width: 100%; height: 100%; object-fit: cover;">
                                                    </div>
                                                    <div class="ms-3">
                                                        <h6 class="mb-1 fw-bold text-dark">
                                                            <%= item.name %>
                                                        </h6>
                                                        <div class="text-muted small">
                                                            <% if (item.packetSize) { %>
                                                                <span class="me-3">Size: <strong><%= item.packetSize %></strong></span>
                                                            <% } else if (item.size) { %>
                                                                <span class="me-3">Size: <strong><%= item.size %></strong></span>
                                                            <% } %>
                                                        </div>
                                                    </div>
                                                </div>
                                            <% }) %>
                                        </div>
                                        <div class="col-md-4 mt-4 mt-md-0 border-start-md ps-md-4">
                                            <h6 class="small fw-bold text-muted mb-2">SHIPPING ADDRESS</h6>
                                            <p class="small text-dark mb-0">
                                                <strong><%= order.shippingAddress.fullName %></strong><br>
                                                <%= order.shippingAddress.address %><br>
                                                <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> <%= order.shippingAddress.zipCode %><br>
                                                <i class="fas fa-phone-alt me-1 text-muted"></i> <%= order.shippingAddress.phone %>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                                <% if (order.notes) { %>
                                    <div class="card-footer bg-light border-top-0 py-2 px-4">
                                        <small class="text-muted italic"><i class="fas fa-sticky-note me-1"></i> Note: <%= order.notes %></small>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
                <% } else { %>
                    <div class="text-center py-5 order-card bg-white">
                        <div class="mb-4">
                            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                                <i class="fas fa-shopping-bag fa-3x text-muted opacity-50"></i>
                            </div>
                        </div>
                        <h4 class="fw-bold">No orders found</h4>
                        <p class="text-muted">You haven't placed any orders yet. Start your green journey today!</p>
                        <div class="d-flex justify-content-center gap-3 mt-4">
                            <a href="/gallery" class="btn btn-outline-success rounded-pill px-4">Browse Gallery</a>
                            <a href="/orders/create" class="btn btn-success rounded-pill px-4">Create Custom Order</a>
                        </div>
                    </div>
                <% } %>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="/js/utils.js"></script>
</body>

</html>