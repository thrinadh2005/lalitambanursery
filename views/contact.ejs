<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        /* ── BASE ─────────────────────────────────────────────── */
        body {
            font-family: 'Inter', sans-serif;
            color: #2e4033;
            background: #fff;
            overflow-x: hidden;
        }

        h1,
        h2,
        h3,
        h4,
        h5,
        h6 {
            font-family: 'Playfair Display', serif;
        }

        .contact-hero {
            min-height: 50vh;
            background-image: 
                linear-gradient(170deg, rgba(5, 18, 8, 0.25) 0%, rgba(5, 18, 8, 0.55) 55%, rgba(5, 18, 8, 0.80) 100%),
                url('/images/hero-nursery.jpg');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
            overflow: hidden;
            padding: 5rem 0;
        }
        
        .contact-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="leaves" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse"><path d="M10 5 Q15 10 10 15 Q5 10 10 5" fill="rgba(255,255,255,0.05)"/></pattern></defs><rect width="100" height="100" fill="url(%23leaves)"/></svg>');
            opacity: 0.3;
        }
        
        .contact-hero-content {
            position: relative;
            z-index: 2;
            color: #fff;
            padding: 0 1.5rem;
            max-width: 820px;
        }

        .hero-tag {
            display: inline-block;
            background: rgba(255, 255, 255, 0.12);
            border: 1.5px solid rgba(255, 255, 255, 0.40);
            backdrop-filter: blur(10px);
            color: #e8fff0;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            padding: 0.42rem 1.4rem;
            border-radius: 50px;
            margin-bottom: 1.5rem;
        }

        .contact-hero h1 {
            font-size: clamp(2.6rem, 6vw, 4.8rem);
            font-weight: 900;
            line-height: 1.08;
            color: #fff;
            text-shadow: 0 3px 24px rgba(0, 0, 0, 0.5);
            margin-bottom: 1.25rem;
        }

        .contact-hero p.lead {
            font-size: clamp(1rem, 2vw, 1.18rem);
            color: rgba(255, 255, 255, 0.90);
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.75;
            text-shadow: 0 1px 8px rgba(0, 0, 0, 0.35);
        }

        .contact-info-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            padding: 2rem;
            text-align: center;
            transition: all var(--transition-base);
            height: 100%;
            position: relative;
            overflow: hidden;
        }
        
        .contact-info-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--gradient-accent);
            transform: scaleX(0);
            transition: transform var(--transition-base);
        }
        
        .contact-info-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-xl);
        }
        
        .contact-info-card:hover::before {
            transform: scaleX(1);
        }
        
        .contact-icon {
            width: 80px;
            height: 80px;
            background: var(--gradient-accent);
            border-radius: var(--radius-2xl);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2rem;
            color: white;
            transition: all var(--transition-base);
        }
        
        .contact-info-card:hover .contact-icon {
            transform: scale(1.1) rotate(5deg);
            box-shadow: var(--shadow-lg);
        }
        
        .contact-form-container {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-2xl);
            padding: 3rem;
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }
        
        .contact-form-container::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(16, 185, 129, 0.05) 0%, transparent 70%);
            animation: float 6s ease-in-out infinite;
        }
        
        .form-floating {
            margin-bottom: 1.5rem;
        }
        
        .form-floating label {
            color: var(--text-muted);
        }
        
        .form-floating input:focus,
        .form-floating textarea:focus {
            border-color: var(--accent);
        }
        
        .contact-form-container .form-control {
            background: var(--surface);
            border: 2px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 1rem;
            font-size: 1rem;
            transition: all var(--transition-base);
        }
        
        .contact-form-container .form-control:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
        }
        
        .map-container {
            background: #f0f0f0;
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            overflow: hidden;
            box-shadow: var(--shadow-lg);
            height: 500px;
            position: relative;
            background-image: url('/images/map-location.png');
            background-size: contain;
            background-position: center;
            background-repeat: no-repeat;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        .map-container:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }

        .map-container::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.2), transparent);
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .map-container:hover::after {
            opacity: 1;
        }

        .map-container a.map-link {
            position: absolute;
            inset: 0;
            z-index: 5;
        }

        .map-btn-wrap {
            position: absolute;
            bottom: 2rem;
            right: 2rem;
            z-index: 10;
            transition: transform 0.3s ease;
        }

        .map-container:hover .map-btn-wrap {
            transform: scale(1.05);
        }

        .btn-view-maps {
            background: #1e293b;
            color: #ffffff;
            border: none;
            padding: 1rem 1.8rem;
            border-radius: 12px;
            font-weight: 700;
            font-size: 0.95rem;
            letter-spacing: 0.5px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            display: inline-flex;
            align-items: center;
            gap: 0.8rem;
            text-transform: uppercase;
            transition: all 0.3s ease;
        }

        .btn-view-maps:hover {
            background: #0f172a;
            color: #ffffff;
            box-shadow: 0 15px 30px rgba(0,0,0,0.3);
        }

        /* Review Section Styling */
        .star-rating {
            display: flex;
            flex-direction: row-reverse;
            justify-content: flex-end;
        }

        .star-rating input {
            display: none;
        }

        .star-rating label {
            color: #e2e8f0;
            cursor: pointer;
            transition: color 0.2s ease;
        }

        .star-rating input:checked ~ label,
        .star-rating label:hover,
        .star-rating label:hover ~ label {
            color: #fbbf24;
        }

        .hover-lift {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .hover-lift:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
        }

        .text-dark {
            color: #0f172a !important;
        }

        .text-secondary {
            color: #475569 !important;
        }

        .bg-light {
            background-color: #f8fafc !important;
        }

        .fw-800 { font-weight: 800; }
        .fw-700 { font-weight: 700; }
        .fw-600 { font-weight: 600; }
        .fw-500 { font-weight: 500; }

        /* Ensure form controls have good contrast */
        .form-control {
            border-color: #cbd5e1;
            color: #0f172a;
        }

        .form-control:focus {
            border-color: #10b981;
            box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
        }

        .form-label {
            margin-bottom: 0.5rem;
            display: block;
        }

        /* Prevent overlapping in reviews */
        .review-item {
            overflow: hidden;
            word-wrap: break-word;
        }

        @media (max-width: 768px) {
            .star-rating {
                font-size: 2rem !important;
            }
        }
        
        .map-overlay {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 0.75rem 1rem;
            box-shadow: var(--shadow-md);
            z-index: 10;
        }
        
        .business-hours {
            background: var(--gradient-surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            padding: 2rem;
            margin-top: 3rem;
        }
        
        .hours-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-top: 1.5rem;
        }
        
        .hours-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.75rem;
            background: var(--surface);
            border-radius: var(--radius-md);
            border: 1px solid var(--border-light);
        }
        
        .hours-item.today {
            background: var(--accent-light);
            border-color: var(--accent);
        }
        
        .social-links-section {
            text-align: center;
            padding: 3rem 0;
        }
        
        .social-links-large {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            margin-top: 2rem;
        }
        
        .social-link-large {
            width: 60px;
            height: 60px;
            background: var(--gradient-accent);
            border-radius: var(--radius-2xl);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-decoration: none;
            font-size: 1.5rem;
            transition: all var(--transition-base);
        }
        
        .social-link-large:hover {
            transform: translateY(-8px) scale(1.1);
            box-shadow: var(--shadow-xl);
        }
        
        @media (max-width: 768px) {
            .contact-hero {
                padding: 3rem 0;
            }
            
            .contact-form-container {
                padding: 2rem;
            }
            
            .map-container {
                height: 300px;
            }
            
            .hours-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <!-- Navigation -->
    <%- include('partials/header') %>

    <!-- Contact Hero Section -->
    <section class="contact-hero">
        <div class="container">
            <div class="contact-hero-content mx-auto" data-aos="fade-up">
                <span class="hero-tag">Reach Out to Us</span>
                <h1 class="display-3 fw-800 mb-3">Get in Touch</h1>
                <p class="lead opacity-90 mb-0">We'd love to hear from you! Let's grow something beautiful together.</p>
            </div>
        </div>
    </section>

    <!-- Contact Information Cards -->
    <section class="py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="contact-info-card">
                        <div class="contact-icon">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <h3 class="fw-700 mb-3">Visit Our Nursery</h3>
                        <p class="text-muted mb-4">
                            <strong>Gandhinagaram, Near Kadiypulanka</strong><br>
                            Chemudulanka - 533 234<br>
                            East Godavari District, Andhra Pradesh
                        </p>
                        <a href="https://maps.app.goo.gl/KK2vsCpQWM6Ud5GZ7?g_st=awb"
                           target="_blank" class="btn btn-success">
                            <i class="fas fa-directions me-2"></i>Get Directions
                        </a>
                    </div>
                </div>
                
                <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="contact-info-card">
                        <div class="contact-icon">
                            <i class="fas fa-phone-alt"></i>
                        </div>
                        <h3 class="fw-700 mb-3">Call Us</h3>
                        <p class="text-muted mb-4">
                            <strong>Phone:</strong> +91 99633 72123<br>
                            <strong>Mobile:</strong> +91 96633 55000<br>
                            <strong>WhatsApp:</strong> +91 96633 55000
                        </p>
                        <a href="tel:+919963372123" class="btn btn-success">
                            <i class="fas fa-phone me-2"></i>Call Now
                        </a>
                    </div>
                </div>
                
                <div class="col-lg-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="contact-info-card">
                        <div class="contact-icon">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <h3 class="fw-700 mb-3">Email Us</h3>
                        <p class="text-muted mb-4">
                            <strong>General:</strong> lalitambanursery@gmail.com<br>
                            <strong>Orders:</strong> lalitambanursery@gmail.com<br>
                            <strong>Support:</strong> lalitambanursery@gmail.com
                        </p>
                        <a href="mailto:lalitambanursery@gmail.com" class="btn btn-success">
                            <i class="fas fa-envelope me-2"></i>Send Email
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Form and Map -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-6" data-aos="fade-right">
                    <div class="contact-form-container">
                        <h2 class="fw-800 mb-4">Send Us a Message</h2>
                        <form action="/contact" method="POST" class="contact-form">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="firstName" name="firstName" placeholder="First Name" required>
                                        <label for="firstName">First Name</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="text" class="form-control" id="lastName" name="lastName" placeholder="Last Name" required>
                                        <label for="lastName">Last Name</label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-floating">
                                        <input type="email" class="form-control" id="email" name="email" placeholder="Email Address" required>
                                        <label for="email">Email Address</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <input type="tel" class="form-control" id="phone" name="phone" placeholder="Phone Number">
                                        <label for="phone">Phone Number</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating">
                                        <select class="form-control" id="subject" name="subject" required>
                                            <option value="">Select Subject</option>
                                            <option value="general">General Inquiry</option>
                                            <option value="orders">Order Related</option>
                                            <option value="plants">Plant Information</option>
                                            <option value="complaint">Complaint</option>
                                            <option value="feedback">Feedback</option>
                                        </select>
                                        <label for="subject">Subject</label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-floating">
                                        <textarea class="form-control" id="message" name="message" placeholder="Your Message" style="height: 120px" required></textarea>
                                        <label for="message">Your Message</label>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-success btn-lg">
                                        <i class="fas fa-paper-plane me-2"></i>Send Message
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
                
                <div class="col-lg-6" data-aos="fade-left">
                    <div class="map-container">
                        <a href="https://maps.app.goo.gl/KK2vsCpQWM6Ud5GZ7?g_st=awb" target="_blank" class="map-link"></a>
                        <div class="map-overlay">
                            <small class="text-muted"><i class="fas fa-map-marker-alt me-1"></i> OUR NURSERY LOCATION</small>
                        </div>
                        <div class="map-btn-wrap">
                            <a href="https://maps.app.goo.gl/KK2vsCpQWM6Ud5GZ7?g_st=awb" 
                               target="_blank" 
                               class="btn btn-view-maps text-decoration-none">
                                <i class="fas fa-external-link-alt"></i>VIEW IN MAPS
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Reviews Section -->
    <section id="reviews" class="py-5 bg-white">
        <div class="container">
            <div class="text-center mb-5" data-aos="fade-up">
                <h2 class="display-4 fw-800 text-dark">Customer Reviews</h2>
                <p class="lead text-muted">What our valued customers say about Sri Lalitamba Nursery</p>
            </div>

            <div class="row g-5">
                <!-- Review Form -->
                <div class="col-lg-5" data-aos="fade-right">
                    <div class="review-form-card shadow-sm border p-4 rounded-4 bg-light">
                        <h3 class="fw-700 mb-4 text-dark border-bottom pb-2">Write a Review</h3>
                        <% if (user) { %>
                            <form action="/reviews/nursery" method="POST">
                                <div class="mb-4">
                                    <label class="form-label fw-600 text-dark">Rating</label>
                                    <div class="star-rating d-flex gap-2 fs-3">
                                        <input type="radio" name="rating" value="5" id="star5" required><label for="star5" class="fa fa-star"></label>
                                        <input type="radio" name="rating" value="4" id="star4"><label for="star4" class="fa fa-star"></label>
                                        <input type="radio" name="rating" value="3" id="star3"><label for="star3" class="fa fa-star"></label>
                                        <input type="radio" name="rating" value="2" id="star2"><label for="star2" class="fa fa-star"></label>
                                        <input type="radio" name="rating" value="1" id="star1"><label for="star1" class="fa fa-star"></label>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label for="reviewTitle" class="form-label fw-600 text-dark">Title</label>
                                    <input type="text" class="form-control border-2" id="reviewTitle" name="title" placeholder="Summary of your experience" required>
                                </div>
                                <div class="mb-4">
                                    <label for="reviewComment" class="form-label fw-600 text-dark">Comment</label>
                                    <textarea class="form-control border-2" id="reviewComment" name="comment" rows="4" placeholder="Share your feedback..." required></textarea>
                                </div>
                                <button type="submit" class="btn btn-dark btn-lg w-100 fw-700 shadow-sm py-3">Submit Review</button>
                            </form>
                        <% } else { %>
                            <div class="text-center py-4">
                                <p class="text-muted mb-4 fs-5">Please login to share your experience with us.</p>
                                <a href="/login?redirect=/contact#reviews" class="btn btn-success btn-lg px-5 fw-700">Login to Review</a>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Reviews Display -->
                <div class="col-lg-7" data-aos="fade-left">
                    <div class="reviews-list">
                        <% if (reviews && reviews.length > 0) { %>
                            <% reviews.forEach(review => { %>
                                <div class="review-item mb-4 p-4 rounded-4 border bg-white shadow-sm hover-lift">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div class="user-info">
                                            <h5 class="mb-0 fw-700 text-dark text-capitalize"><%= review.user.firstName %> <%= review.user.lastName %></h5>
                                            <small class="text-muted fw-500"><i class="far fa-calendar-alt me-1"></i> <%= new Date(review.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></small>
                                        </div>
                                        <div class="rating-badge">
                                            <% for(let i=1; i<=5; i++) { %>
                                                <i class="fa fa-star <%= i <= review.rating ? 'text-warning' : 'text-light' %>"></i>
                                            <% } %>
                                        </div>
                                    </div>
                                    <h6 class="fw-800 text-dark mb-2"><%= review.title %></h6>
                                    <p class="text-secondary mb-0 lh-base fs-6"><%= review.comment %></p>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="text-center py-5 bg-light rounded-4 border">
                                <i class="far fa-comments fa-4x text-muted mb-3"></i>
                                <p class="text-muted fs-5">No reviews yet. Be the first to share your experience!</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Business Hours -->
    <section class="py-5">
        <div class="container">
            <div class="business-hours" data-aos="fade-up">
                <div class="text-center mb-4">
                    <h2 class="fw-800 mb-3">Business Hours</h2>
                    <p class="text-muted">Visit us during our working hours for the best service</p>
                </div>
                <div class="hours-grid">
                    <div class="hours-item">
                        <span><i class="fas fa-calendar-day me-2"></i>Monday</span>
                        <span class="fw-600">6:00 AM - 6:00 PM</span>
                    </div>
                    <div class="hours-item">
                        <span><i class="fas fa-calendar-day me-2"></i>Tuesday</span>
                        <span class="fw-600">6:00 AM - 6:00 PM</span>
                    </div>
                    <div class="hours-item">
                        <span><i class="fas fa-calendar-day me-2"></i>Wednesday</span>
                        <span class="fw-600">6:00 AM - 6:00 PM</span>
                    </div>
                    <div class="hours-item">
                        <span><i class="fas fa-calendar-day me-2"></i>Thursday</span>
