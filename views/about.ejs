<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Discover the heritage of Sri Lalitamba Nursery & Gardens. From our humble beginnings in 2007 to becoming a botanical landmark in Chemudulanka, explore our journey of green excellence.">
    <title><%= title %></title>

    <!-- External Assets -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        :root {
            /* Professional Green Palette */
            --primary-accent: #155e2f;
            --primary-glow: rgba(21, 94, 47, 0.08);
            --secondary-accent: #10b981;
            --hero-bg: #051208;
            --text-heading: #111827;
            --text-body: #4b5563;
            --text-muted: #6b7280;
            --surface: #ffffff;
            --surface-alt: #f9fafb;
            --border: #e5e7eb;
            --font-main: 'Plus Jakarta Sans', sans-serif;
            --font-heading: 'Playfair Display', serif;
            --font-accent: 'Outfit', sans-serif;
            --shadow-premium: 0 20px 40px -10px rgba(0, 0, 0, 0.05);
        }

        [data-theme="dark"] {
            --surface: #111827;
            --surface-alt: #1f2937;
            --text-heading: #f9fafb;
            --text-body: #d1d5db;
            --text-muted: #9ca3af;
            --border: #374151;
            --shadow-premium: 0 20px 40px -10px rgba(0, 0, 0, 0.3);
        }

        body {
            font-family: var(--font-main);
            color: var(--text-body);
            background: var(--surface);
            overflow-x: hidden;
            line-height: 1.8;
            -webkit-font-smoothing: antialiased;
        }

        /* ── UTILITIES ────────────────────────────────────────── */
        .section-label {
            font-family: var(--font-accent);
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.25em;
            color: var(--secondary-accent);
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.5rem;
            padding: 0.6rem 1.25rem;
            background: var(--primary-glow);
            border-radius: 100px;
        }

        .heading-xl {
            font-family: var(--font-heading);
            color: var(--text-heading);
            font-weight: 900;
            line-height: 1.1;
        }

        /* ── HERO SECTION ─────────────────────────────────────── */
        .about-hero {
            position: relative;
            min-height: 85vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: var(--hero-bg);
            padding: 100px 0;
        }

        .hero-bg-img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.6;
            filter: saturate(1.2) brightness(0.8);
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, var(--hero-bg) 100%);
            z-index: 1;
        }

        .about-hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            color: #fff;
            max-width: 900px;
            padding: 0 1.5rem;
        }

        .about-hero h1 {
            font-size: clamp(3rem, 8vw, 5.5rem);
            margin-bottom: 1.5rem;
            text-shadow: 0 10px 30px rgba(0,0,0,0.4);
        }

        .about-hero p {
            font-size: clamp(1.1rem, 2vw, 1.25rem);
            opacity: 0.9;
            max-width: 650px;
            margin: 0 auto 3rem;
            font-weight: 400;
        }

        /* ── STORY SECTION ────────────────────────────────────── */
        .story-section {
            padding: 10rem 0;
            background: var(--surface);
        }

        .story-img-container {
            position: relative;
            padding: 2rem;
        }

        .img-main {
            width: 100%;
            height: auto;
            border-radius: 30px;
            box-shadow: var(--shadow-premium);
        }

        .img-accent {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 50%;
            border-radius: 20px;
            border: 8px solid var(--surface);
            box-shadow: var(--shadow-premium);
        }

        .exp-badge {
            position: absolute;
            top: 0;
            left: 0;
            background: var(--primary-accent);
            color: #fff;
            padding: 1.5rem 2rem;
            border-radius: 20px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(21, 94, 47, 0.3);
            z-index: 5;
        }

        .exp-badge .num { font-size: 2.5rem; font-weight: 900; line-height: 1; margin-bottom: 0.25rem; display: block; }
        .exp-badge .text { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.8; }

        /* ── STATS SECTION ────────────────────────────────────── */
        .stats-grid {
            padding: 6rem 0;
            background: var(--primary-accent);
            color: #fff;
            border-radius: 40px;
            margin-bottom: 10rem;
        }

        .stat-item { text-align: center; }
        .stat-item .num { font-size: 3.5rem; font-weight: 900; margin-bottom: 0.5rem; display: block; color: var(--secondary-accent); }
        .stat-item .lbl { font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; opacity: 0.8; }

        /* ── VALUES SECTION ────────────────────────────────────── */
        .values-section {
            padding: 10rem 0;
            background: var(--surface-alt);
        }

        .value-card {
            background: var(--surface);
            padding: 3.5rem 2.5rem;
            border-radius: 30px;
            height: 100%;
            border: 1px solid var(--border);
            transition: all 0.3s ease;
        }

        .value-card:hover {
            transform: translateY(-10px);
            border-color: var(--secondary-accent);
            box-shadow: var(--shadow-premium);
        }

        .value-icon {
            font-size: 2.5rem;
            color: var(--secondary-accent);
            margin-bottom: 2rem;
            display: inline-block;
        }

        .value-card h4 { color: var(--text-heading); font-weight: 800; margin-bottom: 1.25rem; }

        /* ── TEAM SECTION ─────────────────────────────────────── */
        .team-section { padding: 10rem 0; background: var(--surface); }

        .team-card {
            background: var(--surface);
            border-radius: 30px;
            overflow: hidden;
            border: 1px solid var(--border);
            height: 100%;
            transition: all 0.3s ease;
        }

        .team-card:hover {
            border-color: var(--secondary-accent);
            box-shadow: var(--shadow-premium);
        }

        .team-img { width: 100%; height: 300px; object-fit: cover; }
        .team-body { padding: 2.5rem; text-align: center; }
        .team-role { font-size: 0.7rem; font-weight: 800; color: var(--secondary-accent); text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 0.75rem; display: block; }
        .team-name { font-size: 1.4rem; color: var(--text-heading); font-weight: 800; margin-bottom: 1rem; }

        /* ── GALLERY ──────────────────────────────────────────── */
        .gallery-section { padding-bottom: 10rem; }
        .gallery-item {
            border-radius: 20px;
            overflow: hidden;
            height: 350px;
            margin-bottom: 1.5rem;
        }
        .gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
        .gallery-item:hover img { transform: scale(1.1); }

        /* ── CTA ─────────────────────────────────────────────── */
        .cta-wrap {
            background: linear-gradient(135deg, #0d2b13 0%, #155e2f 100%);
            border-radius: 40px;
            padding: 6rem 3rem;
            color: #fff;
            text-align: center;
        }

        /* ── RESPONSIVE ────────────────────────────────────────── */
        @media (max-width: 991px) {
            .story-img-container { margin-bottom: 4rem; }
            .stats-grid { border-radius: 0; }
            .about-hero { min-height: 60vh; }
        }
    </style>
</head>

<body>
    <%- include('partials/header') %>

    <main>
        <!-- ── HERO ─────────────────────────────────────────────── -->
        <section class="about-hero">
            <img src="/images/hero-aerial.jpg" alt="Sri Lalitamba Aerial View" class="hero-bg-img">
            <div class="hero-overlay"></div>
            <div class="about-hero-content" data-aos="fade-up">
                <span class="section-label" style="background: rgba(255,255,255,0.1); color: #fff; border: 1px solid rgba(255,255,255,0.2);">Our Journey</span>
                <h1 class="heading-xl text-white">Nurturing Nature<br>Since 2007</h1>
                <p>From a local small-scale plot to Andhra Pradesh's premier botanical landmark. Experience the legacy of green excellence at Sri Lalitamba Nursery & Gardens.</p>
                <a href="#story" class="btn btn-success btn-lg rounded-pill px-5 py-3 fw-bold shadow-lg">Discover More</a>
            </div>
        </section>

        <!-- ── STORY SECTION ────────────────────────────────────── -->
        <section id="story" class="story-section">
            <div class="container">
                <div class="row align-items-center g-5">
                    <div class="col-lg-6" data-aos="fade-right">
                        <div class="story-img-container">
                            <div class="exp-badge">
                                <span class="num">19+</span>
                                <span class="text">Years of Excellence</span>
                            </div>
                            <img src="/images/hero-nursery.jpg" alt="Heritage Site" class="img-main">
                            <img src="/images/hero-flowers.jpg" alt="Exotic Blooms" class="img-accent">
                        </div>
                    </div>
                    <div class="col-lg-6" data-aos="fade-left">
                        <span class="section-label">The Heritage</span>
                        <h2 class="heading-xl mb-4">A Botanical Legacy Built on Integrity</h2>
                        <p class="mb-4">Founded in 2007 by <strong>A V V Satyanarayana</strong>, Sri Lalitamba Nursery was born from a deep-rooted passion for sustainable horticulture and exotic species.</p>
                        <p class="text-muted mb-5">Today, located in Chemudulanka, we stand as a testament to nearly two decades of organic cultivation. We specialize in over 500 varieties of premium plants, serving thousands of green enthusiasts across the region with expert advice and authentic greenery.</p>
                        
                        <div class="row g-4">
                            <div class="col-6">
                                <div class="d-flex align-items-center gap-3">
                                    <i class="fas fa-certificate text-success fs-3"></i>
                                    <h6 class="fw-bold mb-0">Premium Quality</h6>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="d-flex align-items-center gap-3">
                                    <i class="fas fa-leaf text-success fs-3"></i>
                                    <h6 class="fw-bold mb-0">100% Organic</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── STATS SECTION ────────────────────────────────────── -->
        <div class="container">
            <section class="stats-grid" data-aos="zoom-in">
                <div class="row g-4">
                    <div class="col-6 col-lg-3">
                        <div class="stat-item">
                            <span class="num">500+</span>
                            <span class="lbl">Plant Species</span>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="stat-item">
                            <span class="num">15K+</span>
                            <span class="lbl">Satisfied Clients</span>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="stat-item">
                            <span class="num">20+</span>
                            <span class="lbl">Staff Members</span>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="stat-item">
                            <span class="num">100%</span>
                            <span class="lbl">Organic Policy</span>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <!-- ── VALUES SECTION ────────────────────────────────────── -->
        <section class="values-section">
            <div class="container">
                <div class="text-center mb-5" data-aos="fade-up">
                    <span class="section-label">Our Principles</span>
                    <h2 class="heading-xl">The Roots of Our Growth</h2>
                </div>
                <div class="row g-4">
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="0">
                        <div class="value-card">
                            <i class="fas fa-heart value-icon"></i>
                            <h4>Deep Passion</h4>
                            <p class="text-muted">We raise every sapling with the care and dedication it deserves, ensuring it brings life to your home.</p>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                        <div class="value-card">
                            <i class="fas fa-shield-check value-icon"></i>
                            <h4>Solid Integrity</h4>
                            <p class="text-muted">Honest guidance and transparent pricing are at the core of every customer interaction we have.</p>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
                        <div class="value-card">
                            <i class="fas fa-earth-asia value-icon"></i>
                            <h4>Eco-Responsibility</h4>
                            <p class="text-muted">We use sustainable methods to ensure that while we green your home, we also protect the planet.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── GALLERY SECTION ───────────────────────────────────── -->
        <section class="gallery-section mt-5">
            <div class="container">
                <div class="text-center mb-5" data-aos="fade-up">
                    <span class="section-label">A Glimpse of Green</span>
                    <h2 class="heading-xl">Life at Sri Lalitamba</h2>
                </div>
                <div class="row g-4">
                    <div class="col-lg-3 col-md-6" data-aos="fade-up">
                        <div class="gallery-item">
                            <img src="/images/flower-1.jpg" alt="Botanical Asset 1">
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                        <div class="gallery-item">
                            <img src="/images/path-thu.jpg" alt="Botanical Asset 2">
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                        <div class="gallery-item">
                            <img src="/images/flower-wed.jpg" alt="Botanical Asset 3">
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                        <div class="gallery-item">
                            <img src="/images/sunlight.jpg" alt="Botanical Asset 4">
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── TEAM SECTION ─────────────────────────────────────── -->
        <section class="team-section">
            <div class="container">
                <div class="text-center mb-5" data-aos="fade-up">
                    <span class="section-label">Our Green Team</span>
                    <h2 class="heading-xl">The Experts Behind</h2>
                </div>
                <div class="row g-4">
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="0">
                        <div class="team-card">
                            <div class="team-body">
                                <span class="team-role">Founder & Chief</span>
                                <h4 class="team-name">A V V Satyanarayana</h4>
                                <p class="text-muted small mb-0">The visionary behind Sri Lalitamba, with 19+ years of horticultural mastery.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                        <div class="team-card">
                            <div class="team-body">
                                <span class="team-role">Assistant</span>
                                <h4 class="team-name">Srinivasrao</h4>
                                <p class="text-muted small mb-0">Expert in large-scale cultivation and plant maintenance strategies.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                        <div class="team-card">
                            <div class="team-body">
                                <span class="team-role">Worker</span>
                                <h4 class="team-name">Suryanarayana</h4>
                                <p class="text-muted small mb-0">Dedicated to the daily care and nurturing of our exotic varieties.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                        <div class="team-card">
                            <div class="team-body">
                                <span class="team-role">Technical Support</span>
                                <h4 class="team-name">Venkata Thrinadh</h4>
                                <p class="text-muted small mb-0">Driving our digital innovation and technical excellence.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── CTA SECTION ─────────────────────────────────────── -->
        <section class="container mb-5 pb-5">
            <div class="cta-wrap" data-aos="zoom-in">
                <h2 class="heading-xl text-white mb-4">Start Your Green Journey Today</h2>
                <p class="text-white opacity-80 mb-5 max-w-600 mx-auto">Visit our farm in Chemudulanka or browse our collection online.</p>
                <div class="d-flex gap-3 justify-content-center flex-wrap">
                    <a href="/gallery" class="btn btn-light btn-lg rounded-pill px-5 py-3 fw-bold">Shop Plants</a>
                    <a href="/contact" class="btn btn-outline-light btn-lg rounded-pill px-5 py-3 fw-bold">Contact Us</a>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        AOS.init({ duration: 1000, once: true, offset: 100 });
    </script>
</body>

</html>
