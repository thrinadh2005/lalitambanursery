<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Learn about Sri Lalitamba Nursery & Gardens — a family-run nursery in Chemudulanka, Andhra Pradesh, dedicated to bringing premium plants and green beauty to your home since 2007.">
    <title><%= title %></title>

    <!-- CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;800;900&family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        :root {
            --about-accent: #2d8a4e;
            --about-accent-light: rgba(45, 138, 78, 0.1);
        }

        body {
            font-family: 'Outfit', 'Inter', sans-serif;
            color: var(--text-body);
            background: var(--background);
            overflow-x: hidden;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Playfair Display', serif;
        }

        /* ── HERO ─────────────────────────────────────────────── */
        .about-hero {
            min-height: 85vh;
            background-image:
                linear-gradient(170deg, rgba(5, 18, 8, 0.35) 0%, rgba(5, 18, 8, 0.65) 55%, rgba(5, 18, 8, 0.85) 100%),
                url('/images/hero-aerial.jpg');
            background-size: cover;
            background-position: center 40%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .about-hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='20' cy='20' r='1' fill='%23ffffff' fill-opacity='0.05'/%3E%3C/svg%3E");
            z-index: 1;
        }

        .about-hero-content {
            position: relative;
            z-index: 2;
            color: #fff;
            padding: 0 1.5rem;
            max-width: 900px;
        }

        .hero-tag {
            display: inline-block;
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.3);
            backdrop-filter: blur(12px);
            color: #fff;
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            padding: 0.6rem 1.8rem;
            border-radius: 100px;
            margin-bottom: 2rem;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        }

        .about-hero h1 {
            font-size: clamp(2.8rem, 8vw, 5.5rem);
            font-weight: 900;
            line-height: 1.05;
            color: #fff;
            text-shadow: 0 4px 30px rgba(0, 0, 0, 0.6);
            margin-bottom: 1.5rem;
            letter-spacing: -0.03em;
        }

        .about-hero p.lead {
            font-size: clamp(1.1rem, 2.5vw, 1.3rem);
            color: rgba(255, 255, 255, 0.95);
            max-width: 650px;
            margin: 0 auto;
            line-height: 1.8;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.4);
        }

        /* ── SECTION LABEL ────────────────────────────────────── */
        .section-label {
            font-size: 0.85rem;
            font-weight: 800;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--about-accent);
            margin-bottom: 1rem;
            display: block;
        }

        /* ── GLASS CARDS ───────────────────────────────────────── */
        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            -webkit-backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: 28px;
            padding: 3rem;
            box-shadow: var(--glass-shadow);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .glass-card:hover {
            transform: translateY(-8px);
            border-color: var(--about-accent);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        }

        /* ── STORY SECTION ────────────────────────────────────── */
        .story-section {
            padding: 10rem 0;
            background: var(--background);
            position: relative;
        }

        .story-img-wrap {
            position: relative;
            border-radius: 32px;
            overflow: hidden;
            box-shadow: 0 40px 100px rgba(0, 0, 0, 0.12);
        }

        .story-img-wrap img {
            width: 100%;
            height: 600px;
            object-fit: cover;
            transition: transform 1s ease;
        }

        .story-img-wrap:hover img {
            transform: scale(1.05);
        }

        .story-badge {
            position: absolute;
            bottom: 2.5rem;
            left: 2.5rem;
            background: linear-gradient(135deg, #1b5e2f, #2d8a4e);
            color: #fff;
            border-radius: 24px;
            padding: 1.8rem 2.5rem;
            text-align: center;
            box-shadow: 0 15px 45px rgba(27, 94, 47, 0.4);
            z-index: 2;
        }

        .story-badge .num {
            font-family: 'Outfit', sans-serif;
            font-size: 3.5rem;
            font-weight: 800;
            line-height: 1;
        }

        .story-badge .lbl {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.85);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            display: block;
            margin-top: 0.4rem;
        }

        /* ── STATS SECTION ────────────────────────────────────── */
        .stats-banner {
            padding: 8rem 0;
            background: var(--about-accent);
            color: #fff;
            position: relative;
            overflow: hidden;
        }

        .stats-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -10%;
            width: 60%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            transform: rotate(-15deg);
        }

        .stat-item {
            text-align: center;
            position: relative;
            z-index: 2;
        }

        .stat-item .num {
            font-family: 'Outfit', sans-serif;
            font-size: clamp(3rem, 6vw, 5rem);
            font-weight: 800;
            margin-bottom: 0.5rem;
            display: block;
        }

        .stat-item .lbl {
            font-size: 0.9rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: rgba(255, 255, 255, 0.8);
        }

        /* ── VALUES SECTION ────────────────────────────────────── */
        .values-section {
            padding: 10rem 0;
            background: var(--background-alt);
        }

        .value-box {
            text-align: center;
            padding: 3rem 2rem;
            height: 100%;
        }

        .value-icon-wrap {
            width: 80px;
            height: 80px;
            background: var(--surface);
            border-radius: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
            font-size: 2rem;
            color: var(--about-accent);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }

        .value-box:hover .value-icon-wrap {
            background: var(--about-accent);
            color: #fff;
            transform: rotate(10deg) scale(1.1);
        }

        /* ── TEAM SECTION ─────────────────────────────────────── */
        .team-section {
            padding: 10rem 0;
            background: var(--background);
        }

        .team-member {
            text-align: center;
            height: 100%;
        }

        .member-avatar {
            width: 120px;
            height: 120px;
            border-radius: 35% 65% 70% 30% / 30% 30% 70% 70%;
            background: linear-gradient(135deg, #1b5e2f, #4caf6e);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            font-weight: 800;
            color: #fff;
            box-shadow: 0 15px 40px rgba(45, 138, 78, 0.3);
            transition: all 0.5s ease;
        }

        .team-member:hover .member-avatar {
            border-radius: 50%;
            transform: scale(1.1) rotate(5deg);
        }

        /* ── WHY US ───────────────────────────────────────────── */
        .why-us-section {
            padding: 10rem 0;
            background: var(--background-alt);
        }

        .why-feature {
            display: flex;
            gap: 2rem;
            margin-bottom: 3rem;
            align-items: flex-start;
        }

        .why-icon {
            width: 60px;
            height: 60px;
            flex-shrink: 0;
            background: var(--about-accent-light);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: var(--about-accent);
        }

        /* ── CTA ─────────────────────────────────────────────── */
        .about-cta {
            background: linear-gradient(135deg, #0d2b13 0%, #1b5e2f 100%);
            padding: 8rem 0;
            text-align: center;
            border-radius: 40px;
            margin: 4rem;
            position: relative;
            overflow: hidden;
            color: #fff;
        }

        .about-cta::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url('/images/hero-bg.jpg');
            background-size: cover;
            background-position: center;
            opacity: 0.15;
            mix-blend-mode: overlay;
        }

        .cta-btn {
            background: #fff;
            color: #0d2b13;
            padding: 1.2rem 3.5rem;
            border-radius: 100px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            display: inline-flex;
            align-items: center;
            gap: 0.8rem;
            transition: all 0.3s ease;
            box-shadow: 0 15px 45px rgba(0, 0, 0, 0.2);
        }

        .cta-btn:hover {
            background: var(--about-accent);
            color: #fff;
            transform: translateY(-5px);
        }

        @media (max-width: 991px) {
            .about-cta { margin: 2rem 1rem; padding: 6rem 1.5rem; }
            .story-img-wrap img { height: 450px; }
        }
    </style>
</head>

<body>
    <%- include('partials/header') %>

    <main>
        <!-- ── HERO ─────────────────────────────────────────────── -->
        <section class="about-hero">
            <div class="about-hero-content" data-aos="zoom-out">
                <span class="hero-tag">Cultivating Life Since 2007</span>
                <h1>Crafting Green Sanctuaries<br>for Your Home</h1>
                <p class="lead">More than just a nursery, we are a family-run heritage dedicated to bringing the finest exotic flora and botanical expertise to your doorstep.</p>
            </div>
        </section>

        <!-- ── STORY SECTION ────────────────────────────────────── -->
        <section class="story-section">
            <div class="container">
                <div class="row g-5 align-items-center">
                    <div class="col-lg-6" data-aos="fade-right">
                        <div class="story-img-wrap">
                            <img src="/images/hero-aerial.jpg" alt="Our Heritage">
                            <div class="story-badge">
                                <div class="num">19+</div>
                                <div class="lbl">Years of<br>Excellence</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6" data-aos="fade-left">
                        <span class="section-label">Our Legacy</span>
                        <h2 class="display-4 fw-900 text-dark mb-4">A Tradition of Botanical Mastery</h2>
                        <p class="text-muted fs-5 mb-4">Founded in 2007, Sri Lalitamba Nursery & Gardens began with a simple mission: to preserve and propagate the highest quality plants while fostering a deeper connection between people and nature.</p>
                        <p class="text-muted mb-5">Today, our Chemudulanka farm spans across lush acres, housing over 500 varieties of exotic flowers, fruit-bearing trees, and ornamental wonders. Every plant we grow is a testament to our commitment to sustainable, organic horticulture.</p>
                        
                        <div class="row g-4 mt-2">
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="why-icon"><i class="fas fa-leaf"></i></div>
                                    <div class="fw-bold">100% Organic Cultivation</div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="why-icon"><i class="fas fa-certificate"></i></div>
                                    <div class="fw-bold">Premium Quality Seeds</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── STATS SECTION ────────────────────────────────────── -->
        <section class="stats-banner">
            <div class="container">
                <div class="row g-4">
                    <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="0">
                        <div class="stat-item">
                            <span class="num" data-count="500">500+</span>
                            <span class="lbl">Plant Varieties</span>
                        </div>
                    </div>
                    <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="100">
                        <div class="stat-item">
                            <span class="num" data-count="15">15K+</span>
                            <span class="lbl">Happy Clients</span>
                        </div>
                    </div>
                    <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="200">
                        <div class="stat-item">
                            <span class="num" data-count="20">20+</span>
                            <span class="lbl">Expert Gardeners</span>
                        </div>
                    </div>
                    <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="300">
                        <div class="stat-item">
                            <span class="num" data-count="100">100%</span>
                            <span class="lbl">Sustainability</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── WHY US ───────────────────────────────────────────── -->
        <section class="why-us-section">
            <div class="container">
                <div class="row g-5 align-items-center">
                    <div class="col-lg-6" data-aos="fade-right">
                        <span class="section-label">Why Choose Us</span>
                        <h2 class="display-5 fw-900 text-dark mb-4">Excellence in Every Leaf</h2>
                        <p class="text-muted mb-5">We go beyond just selling plants. We provide a complete botanical experience backed by nearly two decades of expertise.</p>
                        
                        <div class="why-feature">
                            <div class="why-icon"><i class="fas fa-truck-moving"></i></div>
                            <div>
                                <h5 class="fw-bold mb-2">Safe & Fast Delivery</h5>
                                <p class="text-muted mb-0">Specially designed packaging to ensure your plants arrive in pristine, nursery-fresh condition.</p>
                            </div>
                        </div>
                        
                        <div class="why-feature">
                            <div class="why-icon"><i class="fas fa-user-graduate"></i></div>
                            <div>
                                <h5 class="fw-bold mb-2">Expert Guidance</h5>
                                <p class="text-muted mb-0">Our horticulturists are always available to help you with plant selection and care tips.</p>
                            </div>
                        </div>
                        
                        <div class="why-feature">
                            <div class="why-icon"><i class="fas fa-sync-alt"></i></div>
                            <div>
                                <h5 class="fw-bold mb-2">Plant Replacement</h5>
                                <p class="text-muted mb-0">Your satisfaction is our priority. We offer a replacement guarantee for transit-damaged plants.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6" data-aos="fade-left">
                        <div class="glass-card p-0 overflow-hidden">
                            <img src="/images/hero-nursery.jpg" alt="Nursery Farm" class="img-fluid">
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── VALUES SECTION ────────────────────────────────────── -->
        <section class="values-section">
            <div class="container text-center mb-5">
                <span class="section-label" data-aos="fade-up">Our Core Values</span>
                <h2 class="display-5 fw-900 text-dark" data-aos="fade-up">What We Stand For</h2>
            </div>
            <div class="container">
                <div class="row g-4">
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="0">
                        <div class="glass-card value-box">
                            <div class="value-icon-wrap"><i class="fas fa-heart"></i></div>
                            <h4 class="fw-bold mb-3">Passion</h4>
                            <p class="text-muted mb-0">We don't just sell plants; we share our love for life and nature with every sapling we deliver.</p>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                        <div class="glass-card value-box">
                            <div class="value-icon-wrap"><i class="fas fa-shield-alt"></i></div>
                            <h4 class="fw-bold mb-3">Integrity</h4>
                            <p class="text-muted mb-0">Honest advice, fair pricing, and premium quality are the foundations of our long-term client relationships.</p>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
                        <div class="glass-card value-box">
                            <div class="value-icon-wrap"><i class="fas fa-seedling"></i></div>
                            <h4 class="fw-bold mb-3">Sustainability</h4>
                            <p class="text-muted mb-0">We employ eco-friendly practices and organic fertilizers to ensure a healthy future for the planet.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── TEAM SECTION ─────────────────────────────────────── -->
        <section class="team-section">
            <div class="container text-center mb-5">
                <span class="section-label" data-aos="fade-up">The Experts Behind</span>
                <h2 class="display-5 fw-900 text-dark" data-aos="fade-up">Meet Our Green Team</h2>
            </div>
            <div class="container">
                <div class="row g-4">
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="0">
                        <div class="team-member">
                            <div class="member-avatar">ST</div>
                            <h4 class="fw-bold mb-2">Sri Thrinadh</h4>
                            <p class="text-muted mb-3">Founder & Chief Horticulturist</p>
                            <p class="small text-muted">With 19+ years of experience, he leads our mission of green excellence.</p>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                        <div class="team-member">
                            <div class="member-avatar">VL</div>
                            <h4 class="fw-bold mb-2">Venkata Lakshmi</h4>
                            <p class="text-muted mb-3">Head of Plant Care</p>
                            <p class="small text-muted">Expert in exotic flora and organic cultivation techniques.</p>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
                        <div class="team-member">
                            <div class="member-avatar">AK</div>
                            <h4 class="fw-bold mb-2">Anil Kumar</h4>
                            <p class="text-muted mb-3">Landscape Designer</p>
                            <p class="small text-muted">Transforming spaces into lush, sustainable green sanctuaries.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── ABOUT CTA ────────────────────────────────────────── -->
        <section class="about-cta" data-aos="zoom-in">
            <div class="container position-relative z-2">
                <h2 class="display-4 fw-900 mb-4">Start Your Green Journey Today</h2>
                <p class="fs-5 opacity-90 mb-5 max-w-600 mx-auto">Visit our nursery in Chemudulanka or browse our collection online to find the perfect addition to your home.</p>
                <div class="d-flex gap-4 justify-content-center flex-wrap">
                    <a href="/gallery" class="cta-btn text-decoration-none">
                        <i class="fas fa-shopping-basket"></i> Shop Now
                    </a>
                    <a href="/contact" class="cta-btn text-decoration-none bg-transparent border border-white text-white">
                        <i class="fas fa-comment-dots"></i> Get Advice
                    </a>
                </div>
            </div>
        </section>
    </main>
        <%- include('partials/footer') %>

            <!-- Scripts -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
            <script src="/js/utils.js"></script>
            <script>
                // Init AOS
                AOS.init({ duration: 900, once: true, offset: 80 });

                // Smooth scroll for scroll arrow
                document.querySelector('.scroll-arrow')?.addEventListener('click', function (e) {
                    e.preventDefault();
                    document.querySelector(this.getAttribute('href')).scrollIntoView({ behavior: 'smooth' });
                });

                // Counter animation
                const counters = document.querySelectorAll('.stat-box .num[data-count]');
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            const el = entry.target;
                            const target = parseInt(el.dataset.count);
                            const duration = 1800;
                            const step = Math.ceil(target / (duration / 16));
                            let current = 0;
                            const timer = setInterval(() => {
                                current += step;
                                if (current >= target) {
                                    current = target;
                                    clearInterval(timer);
                                }
                                const suffix = el.textContent.includes('+') || el.textContent.includes('K') ? '+' : '';
                                if (target >= 1000) {
                                    el.textContent = (current / 1000).toFixed(0) + 'K+';
                                } else {
                                    el.textContent = current + suffix;
                                }
                            }, 16);
                            observer.unobserve(el);
                        }
                    });
                }, { threshold: 0.5 });
                counters.forEach(c => observer.observe(c));

                // Navbar active state
                document.querySelectorAll('.nav-link').forEach(link => {
                    if (link.href === window.location.href) link.classList.add('active');
                });
            </script>
</body>

</html>
