<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Discover the heritage of Sri Lalitamba Nursery & Gardens. From our humble beginnings in 2007 to becoming a botanical landmark in Chemudulanka, explore our journey of green excellence.">
    <title><%= title %></title>

    <!-- External Assets -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        :root {
            --primary-accent: #1b5e2f;
            --primary-glow: rgba(27, 94, 47, 0.15);
            --secondary-accent: #2d8a4e;
            --text-heading: #0a1a0e;
            --font-main: 'Plus Jakarta Sans', sans-serif;
            --font-heading: 'Playfair Display', serif;
            --font-accent: 'Outfit', sans-serif;
        }

        [data-theme="dark"] {
            --text-heading: #f8fcf9;
        }

        body {
            font-family: var(--font-main);
            color: var(--text-body);
            background: var(--background);
            overflow-x: hidden;
            line-height: 1.7;
        }

        /* ── UTILITIES ────────────────────────────────────────── */
        .premium-text-gradient {
            background: linear-gradient(135deg, var(--primary-accent) 0%, var(--secondary-accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
        }

        .section-label {
            font-family: var(--font-accent);
            font-size: 0.85rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.3em;
            color: var(--secondary-accent);
            display: inline-block;
            margin-bottom: 1.2rem;
            padding: 0.5rem 1.2rem;
            background: var(--primary-glow);
            border-radius: 100px;
        }

        /* ── HERO SECTION ─────────────────────────────────────── */
        .about-hero {
            position: relative;
            height: 100vh;
            min-height: 700px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: #051208;
        }

        .hero-video-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.4;
            filter: saturate(1.2);
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at center, transparent 0%, rgba(5, 18, 8, 0.8) 100%);
            z-index: 1;
        }

        .about-hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            color: #fff;
            max-width: 1000px;
            padding: 0 2rem;
        }

        .about-hero h1 {
            font-family: var(--font-heading);
            font-size: clamp(3.5rem, 10vw, 7rem);
            font-weight: 900;
            line-height: 0.95;
            margin-bottom: 1.5rem;
            text-shadow: 0 10px 40px rgba(0,0,0,0.5);
        }

        .about-hero p {
            font-size: clamp(1.1rem, 2.5vw, 1.4rem);
            font-weight: 400;
            opacity: 0.9;
            max-width: 700px;
            margin: 0 auto 3rem;
            line-height: 1.6;
        }

        .scroll-down-indicator {
            position: absolute;
            bottom: 3rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 2;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
            color: #fff;
            text-decoration: none;
            opacity: 0.7;
            transition: opacity 0.3s;
        }

        .scroll-down-indicator:hover { opacity: 1; color: #fff; }

        .mouse-icon {
            width: 26px;
            height: 42px;
            border: 2px solid #fff;
            border-radius: 20px;
            position: relative;
        }

        .mouse-wheel {
            width: 4px;
            height: 8px;
            background: #fff;
            border-radius: 2px;
            position: absolute;
            top: 8px;
            left: 50%;
            transform: translateX(-50%);
            animation: mouseScroll 1.5s infinite;
        }

        @keyframes mouseScroll {
            0% { transform: translate(-50%, 0); opacity: 1; }
            100% { transform: translate(-50%, 15px); opacity: 0; }
        }

        /* ── STORY SECTION ────────────────────────────────────── */
        .story-section {
            padding: 12rem 0;
            background: var(--background);
            position: relative;
        }

        .story-grid {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 6rem;
            align-items: center;
        }

        .story-visual {
            position: relative;
        }

        .story-img-main {
            width: 100%;
            height: 700px;
            object-fit: cover;
            border-radius: 40px;
            box-shadow: 0 50px 100px rgba(0,0,0,0.15);
        }

        .story-img-sub {
            position: absolute;
            bottom: -50px;
            right: -50px;
            width: 300px;
            height: 350px;
            object-fit: cover;
            border-radius: 30px;
            border: 10px solid var(--background);
            box-shadow: 0 30px 60px rgba(0,0,0,0.2);
        }

        .experience-badge {
            position: absolute;
            top: 40px;
            left: -40px;
            background: #fff;
            padding: 2.5rem;
            border-radius: 30px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.1);
            text-align: center;
            z-index: 2;
        }

        .experience-badge h2 {
            font-size: 3.5rem;
            font-weight: 900;
            color: var(--primary-accent);
            line-height: 1;
            margin-bottom: 0.2rem;
        }

        .experience-badge span {
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: var(--text-muted);
        }

        /* ── STATS SECTION ────────────────────────────────────── */
        .stats-ticker {
            background: #0d2b13;
            padding: 6rem 0;
            color: #fff;
            position: relative;
            overflow: hidden;
        }

        .stats-ticker::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='20' height='20' viewBox='0 0 20 20' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='2' cy='2' r='1' fill='rgba(255,255,255,0.05)'/%3E%3C/svg%3E");
        }

        .stat-card {
            text-align: center;
            position: relative;
            z-index: 2;
        }

        .stat-card .num {
            font-family: var(--font-accent);
            font-size: 4.5rem;
            font-weight: 900;
            line-height: 1;
            margin-bottom: 0.5rem;
            background: linear-gradient(to bottom, #fff, rgba(255,255,255,0.5));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .stat-card .label {
            font-size: 0.9rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: #4caf6e;
        }

        /* ── VALUES SECTION ────────────────────────────────────── */
        .values-section {
            padding: 12rem 0;
            background: var(--background-alt);
        }

        .value-card {
            background: var(--surface);
            padding: 4rem 3rem;
            border-radius: 40px;
            height: 100%;
            transition: all 0.4s ease;
            border: 1px solid var(--border);
            position: relative;
            overflow: hidden;
        }

        .value-card::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 100px;
            height: 100px;
            background: var(--primary-glow);
            border-radius: 0 0 0 100%;
            transition: all 0.4s ease;
        }

        .value-card:hover {
            transform: translateY(-15px);
            border-color: var(--secondary-accent);
            box-shadow: 0 30px 60px rgba(0,0,0,0.08);
        }

        .value-card:hover::after {
            width: 100%;
            height: 100%;
            border-radius: 0;
            opacity: 0.05;
        }

        .value-icon {
            width: 70px;
            height: 70px;
            background: var(--primary-glow);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: var(--primary-accent);
            margin-bottom: 2.5rem;
            transition: all 0.4s ease;
        }

        .value-card:hover .value-icon {
            background: var(--primary-accent);
            color: #fff;
            transform: rotate(10deg);
        }

        /* ── TIMELINE ─────────────────────────────────────────── */
        .timeline-section {
            padding: 12rem 0;
            background: var(--background);
        }

        .timeline-container {
            max-width: 1000px;
            margin: 0 auto;
            position: relative;
        }

        .timeline-line {
            position: absolute;
            left: 50%;
            top: 0;
            bottom: 0;
            width: 2px;
            background: var(--border);
            transform: translateX(-50%);
        }

        .timeline-item {
            display: flex;
            justify-content: flex-end;
            padding-right: 50%;
            margin-bottom: 6rem;
            position: relative;
        }

        .timeline-item:nth-child(even) {
            justify-content: flex-start;
            padding-right: 0;
            padding-left: 50%;
        }

        .timeline-dot {
            width: 20px;
            height: 20px;
            background: var(--secondary-accent);
            border: 4px solid var(--background);
            border-radius: 50%;
            position: absolute;
            left: 50%;
            top: 30px;
            transform: translateX(-50%);
            z-index: 2;
            box-shadow: 0 0 0 10px var(--primary-glow);
        }

        .timeline-content {
            width: 85%;
            padding: 3rem;
            background: var(--surface);
            border-radius: 30px;
            border: 1px solid var(--border);
            position: relative;
            margin: 0 3rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        }

        .timeline-year {
            font-family: var(--font-accent);
            font-size: 2rem;
            font-weight: 900;
            color: var(--primary-accent);
            margin-bottom: 1rem;
            display: block;
        }

        /* ── TEAM SECTION ─────────────────────────────────────── */
        .team-section {
            padding: 12rem 0;
            background: var(--background-alt);
        }

        .team-card {
            background: var(--surface);
            border-radius: 40px;
            padding: 1.5rem;
            transition: all 0.4s ease;
            height: 100%;
            border: 1px solid var(--border);
        }

        .team-img-wrap {
            width: 100%;
            height: 350px;
            border-radius: 30px;
            overflow: hidden;
            margin-bottom: 2rem;
            position: relative;
        }

        .team-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
        }

        .team-card:hover .team-img-wrap img {
            transform: scale(1.1);
        }

        .team-info {
            padding: 0 1rem 1rem;
            text-align: center;
        }

        .team-role {
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--secondary-accent);
            margin-bottom: 0.5rem;
            display: block;
        }

        /* ── RESPONSIVE ────────────────────────────────────────── */
        @media (max-width: 991px) {
            .story-grid { grid-template-columns: 1fr; gap: 4rem; }
            .story-visual { order: 2; max-width: 500px; margin: 0 auto; }
            .timeline-line { left: 30px; }
            .timeline-item, .timeline-item:nth-child(even) { justify-content: flex-start; padding-left: 60px; padding-right: 0; }
            .timeline-dot { left: 30px; }
            .timeline-content { width: 100%; margin: 0; }
            .about-hero h1 { font-size: 4rem; }
        }
    </style>
</head>

<body>
    <%- include('partials/header') %>

    <main>
        <!-- ── HERO ─────────────────────────────────────────────── -->
        <section class="about-hero">
            <img src="/images/hero-aerial.jpg" alt="Nature Background" class="hero-video-bg">
            <div class="hero-overlay"></div>
            <div class="about-hero-content" data-aos="fade-up">
                <span class="hero-tag">Welcome to Sri Lalitamba</span>
                <h1>Growing Legacies<br>Since 2007</h1>
                <p>We don't just cultivate plants; we nurture the connection between nature and your soul. Explore the story of Andhra's premier botanical destination.</p>
                <div class="d-flex gap-4 justify-content-center flex-wrap">
                    <a href="#our-story" class="btn btn-success btn-lg rounded-pill px-5 py-3 fw-bold">
                        Our Story <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
            <a href="#our-story" class="scroll-down-indicator">
                <span>Explore</span>
                <div class="mouse-icon">
                    <div class="mouse-wheel"></div>
                </div>
            </a>
        </section>

        <!-- ── STORY SECTION ────────────────────────────────────── -->
        <section id="our-story" class="story-section">
            <div class="container">
                <div class="story-grid">
                    <div class="story-visual" data-aos="fade-right">
                        <div class="experience-badge">
                            <h2 class="premium-text-gradient">19+</h2>
                            <span>Years of<br>Excellence</span>
                        </div>
                        <img src="/images/hero-nursery.jpg" alt="Our Nursery" class="story-img-main">
                        <img src="/images/hero-flowers.jpg" alt="Exotic Flowers" class="story-img-sub">
                    </div>
                    <div class="story-details" data-aos="fade-left">
                        <span class="section-label">Our Heritage</span>
                        <h2 class="display-3 fw-900 mb-4" style="font-family: var(--font-heading);">A Botanical Journey Rooted in Passion</h2>
                        <p class="fs-5 mb-4">Founded in 2007 in the lush landscapes of Chemudulanka, Sri Lalitamba Nursery & Gardens began as a small family project with a giant vision: to bring the beauty of exotic flora to every home.</p>
                        <p class="text-muted mb-5">Our founder, Sri Thrinadh, combined traditional horticultural wisdom with modern sustainable practices. Over the decades, what started as a few acres of local saplings has blossomed into a 500+ variety sanctuary, serving thousands of green enthusiasts across the region.</p>
                        
                        <div class="row g-4">
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="why-icon" style="width: 50px; height: 50px; background: var(--primary-glow); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--primary-accent);">
                                        <i class="fas fa-seedling"></i>
                                    </div>
                                    <h6 class="fw-bold mb-0">Organic First</h6>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="why-icon" style="width: 50px; height: 50px; background: var(--primary-glow); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--primary-accent);">
                                        <i class="fas fa-certificate"></i>
                                    </div>
                                    <h6 class="fw-bold mb-0">Verified Species</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── STATS TICKER ────────────────────────────────────── -->
        <section class="stats-ticker">
            <div class="container">
                <div class="row g-5">
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="0">
                        <div class="stat-card">
                            <div class="num" data-count="500">500+</div>
                            <div class="label">Plant Varieties</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="100">
                        <div class="stat-card">
                            <div class="num" data-count="15">15K+</div>
                            <div class="label">Happy Clients</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="200">
                        <div class="stat-card">
                            <div class="num" data-count="20">20+</div>
                            <div class="label">Expert Staff</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6" data-aos="zoom-in" data-aos-delay="300">
                        <div class="stat-card">
                            <div class="num" data-count="100">100%</div>
                            <div class="label">Sustainable</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── TIMELINE ─────────────────────────────────────────── -->
        <section class="timeline-section">
            <div class="container text-center mb-5">
                <span class="section-label" data-aos="fade-up">Our Journey</span>
                <h2 class="display-5 fw-900 mb-5" style="font-family: var(--font-heading);">Key Milestones</h2>
            </div>
            <div class="timeline-container">
                <div class="timeline-line"></div>
                
                <div class="timeline-item" data-aos="fade-right">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <span class="timeline-year">2007</span>
                        <h4 class="fw-bold">The Seed is Sown</h4>
                        <p class="text-muted mb-0">Sri Lalitamba Nursery is founded in Chemudulanka with a focus on local fruit trees and traditional flowers.</p>
                    </div>
                </div>

                <div class="timeline-item" data-aos="fade-left">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <span class="timeline-year">2012</span>
                        <h4 class="fw-bold">Expansion & Innovation</h4>
                        <p class="text-muted mb-0">Introduced exotic indoor varieties and modernized our irrigation systems for organic efficiency.</p>
                    </div>
                </div>

                <div class="timeline-item" data-aos="fade-right">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <span class="timeline-year">2018</span>
                        <h4 class="fw-bold">Digital Transformation</h4>
                        <p class="text-muted mb-0">Launched our first online catalog and delivery service, reaching plant lovers across Andhra Pradesh.</p>
                    </div>
                </div>

                <div class="timeline-item" data-aos="fade-left">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <span class="timeline-year">Today</span>
                        <h4 class="fw-bold">Andhra's Green Landmark</h4>
                        <p class="text-muted mb-0">Now housing 500+ species and serving as a hub for horticultural education and premium gardening.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── VALUES SECTION ────────────────────────────────────── -->
        <section class="values-section">
            <div class="container">
                <div class="text-center mb-5">
                    <span class="section-label" data-aos="fade-up">Our Core Values</span>
                    <h2 class="display-5 fw-900 mb-5" style="font-family: var(--font-heading);">What We Stand For</h2>
                </div>
                <div class="row g-4">
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="0">
                        <div class="value-card">
                            <div class="value-icon"><i class="fas fa-heart"></i></div>
                            <h4 class="fw-bold mb-3">Authentic Passion</h4>
                            <p class="text-muted mb-0">Every sapling is nurtured with genuine care, ensuring it thrives in its new home just as it did in ours.</p>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                        <div class="value-card">
                            <div class="value-icon"><i class="fas fa-shield-halved"></i></div>
                            <h4 class="fw-bold mb-3">Unwavering Integrity</h4>
                            <p class="text-muted mb-0">Transparent pricing, honest advice, and only the healthiest plants. No exceptions.</p>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
                        <div class="value-card">
                            <div class="value-icon"><i class="fas fa-leaf"></i></div>
                            <h4 class="fw-bold mb-3">Eco-Commitment</h4>
                            <p class="text-muted mb-0">We use 100% organic fertilizers and sustainable methods to protect the earth while decorating your home.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── TEAM SECTION ─────────────────────────────────────── -->
        <section class="team-section">
            <div class="container">
                <div class="text-center mb-5">
                    <span class="section-label" data-aos="fade-up">Our Green Team</span>
                    <h2 class="display-5 fw-900 mb-5" style="font-family: var(--font-heading);">The Minds Behind the Magic</h2>
                </div>
                <div class="row g-4">
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="0">
                        <div class="team-card shadow-sm">
                            <div class="team-img-wrap">
                                <img src="/images/hero-sunset.jpg" alt="Sri Thrinadh">
                            </div>
                            <div class="team-info">
                                <span class="team-role">Founder & Chief</span>
                                <h4 class="fw-bold mb-2">Sri Thrinadh</h4>
                                <p class="text-muted small">Leading our vision of green excellence with 19+ years of horticultural mastery.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                        <div class="team-card shadow-sm">
                            <div class="team-img-wrap">
                                <img src="/images/hero-nursery.jpg" alt="Venkata Lakshmi">
                            </div>
                            <div class="team-info">
                                <span class="team-role">Head of Cultivation</span>
                                <h4 class="fw-bold mb-2">Venkata Lakshmi</h4>
                                <p class="text-muted small">The heart of our farm, ensuring every plant meets our rigorous health standards.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
                        <div class="team-card shadow-sm">
                            <div class="team-img-wrap">
                                <img src="/images/hero-flowers.jpg" alt="The Support Team">
                            </div>
                            <div class="team-info">
                                <span class="team-role">Our Specialists</span>
                                <h4 class="fw-bold mb-2">Expert Horticulturists</h4>
                                <p class="text-muted small">A dedicated team of 20+ professionals passionate about your garden's success.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── CTA ─────────────────────────────────────────────── -->
        <section class="py-5" style="background: var(--background);">
            <div class="container">
                <div class="glass-card text-center py-5 px-4" style="background: linear-gradient(135deg, #0d2b13 0%, #1b5e2f 100%); border-radius: 50px; color: #fff; position: relative; overflow: hidden;" data-aos="zoom-in">
                    <div style="position: relative; z-index: 2;">
                        <h2 class="display-4 fw-900 mb-4" style="font-family: var(--font-heading);">Ready to Grow Your Legacy?</h2>
                        <p class="fs-5 opacity-90 mb-5 max-w-600 mx-auto">Visit our farm in Chemudulanka or explore our online gallery today.</p>
                        <div class="d-flex gap-3 justify-content-center flex-wrap">
                            <a href="/gallery" class="btn btn-light btn-lg rounded-pill px-5 py-3 fw-bold">
                                <i class="fas fa-shopping-basket me-2"></i> Shop Plants
                            </a>
                            <a href="/contact" class="btn btn-outline-light btn-lg rounded-pill px-5 py-3 fw-bold">
                                <i class="fas fa-phone me-2"></i> Get in Touch
                            </a>
                        </div>
                    </div>
                    <!-- decorative leaves -->
                    <i class="fas fa-leaf" style="position: absolute; bottom: -20px; right: -20px; font-size: 15rem; opacity: 0.1; transform: rotate(-15deg);"></i>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        // Init AOS
        AOS.init({ duration: 1000, once: true, offset: 100 });

        // Mouse Scroll Effect
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });

        // Counter Animation
        const counters = document.querySelectorAll('.stat-card .num');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const el = entry.target;
                    const target = parseInt(el.dataset.count) || parseInt(el.innerText);
                    const duration = 2000;
                    const step = target / (duration / 16);
                    let current = 0;
                    
                    const timer = setInterval(() => {
                        current += step;
                        if (current >= target) {
                            el.innerText = el.innerText.includes('K') ? (target/1000).toFixed(0) + 'K+' : target + (el.innerText.includes('+') ? '+' : (el.innerText.includes('%') ? '%' : ''));
                            clearInterval(timer);
                        } else {
                            el.innerText = Math.floor(current) + (el.innerText.includes('+') ? '+' : (el.innerText.includes('%') ? '%' : ''));
                        }
                    }, 16);
                    observer.unobserve(el);
                }
            });
        }, { threshold: 0.5 });
        counters.forEach(c => observer.observe(c));
    </script>
</body>

</html>
