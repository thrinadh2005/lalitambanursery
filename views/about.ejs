<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Learn about Sri Lalitamba Nursery & Gardens — a family-run nursery in Chemudulanka, Andhra Pradesh, dedicated to bringing premium plants and green beauty to your home since 2010.">
    <title>
        <%= title %>
    </title>

    <!-- CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        /* ── BASE ─────────────────────────────────────────────── */
        body {
            font-family: 'Inter', sans-serif;
            color: var(--text-muted);
            background: var(--surface);
            overflow-x: hidden;
        }

        h1,
        h2,
        h3,
        h4,
        h5,
        h6 {
            font-family: 'Playfair Display', serif;
        }

        /* ── HERO ─────────────────────────────────────────────── */
        .about-hero {
            min-height: 70vh;
            background-image:
                linear-gradient(170deg, rgba(5, 18, 8, 0.30) 0%, rgba(5, 18, 8, 0.60) 55%, rgba(5, 18, 8, 0.82) 100%),
                url('/images/hero-aerial.jpg');
            background-size: cover;
            background-position: center 40%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .about-hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='20' cy='20' r='1' fill='%23ffffff' fill-opacity='0.04'/%3E%3C/svg%3E");
        }

        .about-hero-content {
            position: relative;
            z-index: 2;
            color: #fff;
            padding: 0 1.5rem;
            max-width: 820px;
        }

        .hero-tag {
            display: inline-block;
            background: rgba(255, 255, 255, 0.12);
            border: 1.5px solid rgba(255, 255, 255, 0.40);
            backdrop-filter: blur(10px);
            color: #e8fff0;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            padding: 0.42rem 1.4rem;
            border-radius: 50px;
            margin-bottom: 1.5rem;
        }

        .about-hero h1 {
            font-size: clamp(2.6rem, 6vw, 4.8rem);
            font-weight: 900;
            line-height: 1.08;
            color: #fff;
            text-shadow: 0 3px 24px rgba(0, 0, 0, 0.5);
            margin-bottom: 1.25rem;
        }

        .about-hero p.lead {
            font-size: clamp(1rem, 2vw, 1.18rem);
            color: rgba(255, 255, 255, 0.90);
            max-width: 600px;
            margin: 0 auto;
            line-height: 1.75;
            text-shadow: 0 1px 8px rgba(0, 0, 0, 0.35);
        }

        /* scroll arrow */
        .scroll-arrow {
            position: absolute;
            bottom: 2rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10;
            color: rgba(255, 255, 255, 0.7);
            font-size: 1.55rem;
            animation: bounceDown 2s infinite;
            cursor: pointer;
            text-decoration: none;
        }

        @keyframes bounceDown {

            0%,
            100% {
                transform: translateX(-50%) translateY(0);
            }

            50% {
                transform: translateX(-50%) translateY(10px);
            }
        }

        /* ── SECTION LABEL ────────────────────────────────────── */
        .section-label {
            font-size: 0.76rem;
            font-weight: 800;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #2d8a4e;
            margin-bottom: 0.7rem;
            display: block;
        }

        /* ── OUR STORY ────────────────────────────────────────── */
        .story-section {
            padding: 6rem 0;
            background: var(--surface);
        }

        .story-img-wrap {
            position: relative;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 32px 80px rgba(13, 43, 19, 0.16);
        }

        .story-img-wrap img {
            width: 100%;
            height: 500px;
            object-fit: cover;
            display: block;
        }

        .story-float-badge {
            position: absolute;
            bottom: 2rem;
            left: 2rem;
            background: linear-gradient(135deg, #1b5e2f, #2d8a4e);
            color: #fff;
            border-radius: 18px;
            padding: 1.3rem 2rem;
            text-align: center;
            box-shadow: 0 14px 40px rgba(27, 94, 47, 0.42);
        }

        .story-float-badge .num {
            font-family: 'Playfair Display', serif;
            font-size: 2.8rem;
            font-weight: 900;
            line-height: 1;
        }

        .story-float-badge .lbl {
            font-size: 0.78rem;
            color: #c8f0d8;
            font-weight: 600;
            display: block;
            margin-top: 0.2rem;
        }

        .story-heading {
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 900;
            color: var(--text-main);
            line-height: 1.15;
            margin-bottom: 1.25rem;
        }

        .story-body {
            color: var(--text-muted);
            line-height: 1.85;
            font-size: 0.97rem;
        }

        .check-list {
            list-style: none;
            padding: 0;
            margin: 1.5rem 0 0;
        }

        .check-list li {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            margin-bottom: 0.9rem;
            font-size: 0.96rem;
            color: var(--text-muted);
        }

        .check-list li i {
            color: #2d8a4e;
            margin-top: 3px;
            flex-shrink: 0;
        }

        /* ── STATS DARK ───────────────────────────────────────── */
        .stats-dark {
            background-image:
                linear-gradient(rgba(10, 26, 14, 0.84), rgba(10, 26, 14, 0.84)),
                url('/images/hero-nursery.jpg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            padding: 5.5rem 0;
        }

        @media (max-width: 768px) {
            .stats-dark {
                background-attachment: scroll;
            }
        }

        .stat-box {
            text-align: center;
            padding: 1.5rem;
        }

        .stat-box .num {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 800;
            color: #7de0a4;
            line-height: 1;
            text-shadow: 0 0 30px rgba(125, 224, 164, 0.35);
        }

        .stat-box .lbl {
            font-weight: 500;
            color: #c5e8d0;
            margin-top: 0.55rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-size: 0.82rem;
        }

        .stat-divider {
            width: 1px;
            background: rgba(125, 224, 164, 0.2);
        }

        /* ── VALUES ───────────────────────────────────────────── */
        .values-section {
            padding: 6rem 0;
            background: var(--background-alt);
        }

        .values-heading {
            color: var(--text-main);
        }

        .value-card {
            background: var(--surface);
            border: 1.5px solid #cce8d6;
            border-radius: 22px;
            padding: 2.5rem 2rem;
            text-align: center;
            transition: all 0.35s ease;
            height: 100%;
        }

        .value-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 30px 65px rgba(27, 94, 47, 0.13);
            border-color: #2d8a4e;
        }

        .value-icon {
            width: 74px;
            height: 74px;
            background: linear-gradient(135deg, #1b5e2f, #4caf6e);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 1.75rem;
            color: #fff;
            transition: transform 0.3s;
        }

        .value-card:hover .value-icon {
            transform: rotate(6deg) scale(1.12);
        }

        .value-card h5 {
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 0.6rem;
            color: var(--text-main);
        }

        .value-card p {
            color: #3d5c47;
            font-size: 0.9rem;
            line-height: 1.65;
            margin: 0;
        }

        /* ── TEAM ─────────────────────────────────────────────── */
        .team-section {
            padding: 6rem 0;
            background: var(--background);
        }

        .team-card {
            background: var(--surface);
            border: 1.5px solid #cce8d6;
            border-radius: 22px;
            padding: 2.5rem 2rem;
            text-align: center;
            transition: all 0.35s ease;
            height: 100%;
        }

        .team-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 28px 60px rgba(27, 94, 47, 0.13);
            border-color: #2d8a4e;
        }

        .team-avatar {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            background: linear-gradient(135deg, #1b5e2f, #4caf6e);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.3rem;
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: 900;
            color: #fff;
            box-shadow: 0 8px 30px rgba(27, 94, 47, 0.22);
            transition: transform 0.3s;
        }

        .team-card:hover .team-avatar {
            transform: scale(1.08) rotate(-4deg);
        }

        .team-card h5 {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 0.25rem;
        }

        .team-role {
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: #2d8a4e;
            font-weight: 700;
            margin-bottom: 0.9rem;
        }

        .team-bio {
            color: #3d5c47;
            font-size: 0.9rem;
            line-height: 1.65;
            margin: 0;
        }

        /* ── WHY US ───────────────────────────────────────────── */
        .why-section {
            padding: 6rem 0;
            background: var(--background-alt);
        }

        .why-item {
            display: flex;
            gap: 1.5rem;
            align-items: flex-start;
            margin-bottom: 2.5rem;
        }

        .why-num {
            flex-shrink: 0;
            width: 54px;
            height: 54px;
            border-radius: 14px;
            background: linear-gradient(135deg, #1b5e2f, #4caf6e);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Playfair Display', serif;
            font-size: 1.3rem;
            font-weight: 900;
            color: #fff;
        }

        .why-text h5 {
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 0.4rem;
        }

        .why-text p {
            color: #3d5c47;
            font-size: 0.9rem;
            line-height: 1.65;
            margin: 0;
        }

        .why-img-wrap {
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 32px 80px rgba(13, 43, 19, 0.14);
        }

        .why-img-wrap img {
            width: 100%;
            height: 520px;
            object-fit: cover;
            display: block;
        }

        /* ── CTA BANNER ───────────────────────────────────────── */
        .cta-section {
            background: linear-gradient(135deg, #0d2b13 0%, #1b5e2f 50%, #2d8a4e 100%);
            padding: 5.5rem 0;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .cta-section::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='20' cy='20' r='1.5' fill='%23ffffff' fill-opacity='0.05'/%3E%3C/svg%3E");
        }

        .cta-section .container {
            position: relative;
            z-index: 1;
        }

        .cta-heading {
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 900;
            color: #fff;
            margin-bottom: 1rem;
            text-shadow: 0 2px 16px rgba(0, 0, 0, 0.3);
        }

        .cta-sub {
            font-size: 1.07rem;
            color: #c8f0d8;
            max-width: 540px;
            margin: 0 auto 2.2rem;
            line-height: 1.75;
        }

        .btn-cta-white {
            background: var(--surface);
            color: var(--text-main);
            border: 2px solid #fff;
            padding: 0.9rem 2.5rem;
            border-radius: 50px;
            font-weight: 800;
            font-size: 0.95rem;
            text-decoration: none;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-cta-white:hover {
            background: transparent;
            color: #fff;
            transform: translateY(-3px);
            box-shadow: 0 14px 36px rgba(0, 0, 0, 0.25);
        }

        .btn-cta-outline {
            background: transparent;
            color: #fff;
            border: 2px solid rgba(255, 255, 255, 0.55);
            padding: 0.9rem 2.5rem;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.95rem;
            text-decoration: none;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-cta-outline:hover {
            background: rgba(255, 255, 255, 0.12);
            border-color: #fff;
            color: #fff;
            transform: translateY(-3px);
        }

        /* trust strip */
        .trust-strip {
            background: #132218;
            padding: 1rem 0;
            border-bottom: 2px solid #1b5e2f;
        }

        .trust-item {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            font-size: 0.87rem;
            font-weight: 600;
            color: #d4f0df;
        }

        .trust-item i {
            color: #4caf6e;
            font-size: 1.05rem;
        }
    </style>
</head>

<body>
    <%- include('partials/header') %>

        <!-- ═══ HERO ═══════════════════════════════════════════════ -->
        <section class="about-hero">
            <div class="about-hero-content">
                <span class="hero-tag" data-aos="fade-down">Our Story</span>
                <h1 data-aos="fade-up" data-aos-delay="100">Rooted in Passion,<br>Growing with Purpose</h1>
                <p class="lead" data-aos="fade-up" data-aos-delay="200">
                    For over a decade, Sri Lalitamba Nursery &amp; Gardens has been nurturing green dreams across Andhra
                    Pradesh — one plant at a time.
                </p>
            </div>
            <a href="#our-story" class="scroll-arrow">
                <i class="fas fa-chevron-down"></i>
            </a>
        </section>

        <!-- ═══ TRUST STRIP ═════════════════════════════════════════ -->
        <div class="trust-strip">
            <div class="container">
                <div class="row g-3 justify-content-center text-center">
                    <div class="col-6 col-md-3">
                        <div class="trust-item justify-content-center">
                            <i class="fas fa-seedling"></i><span>Est. 2010</span>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="trust-item justify-content-center">
                            <i class="fas fa-leaf"></i><span>500+ Plant Varieties</span>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="trust-item justify-content-center">
                            <i class="fas fa-users"></i><span>10,000+ Happy Customers</span>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="trust-item justify-content-center">
                            <i class="fas fa-map-marker-alt"></i><span>East Godavari, AP</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══ OUR STORY ════════════════════════════════════════════ -->
        <section class="story-section" id="our-story">
            <div class="container">
                <div class="row g-5 align-items-center">
                    <div class="col-lg-6" data-aos="fade-right">
                        <div class="story-img-wrap">
                            <img src="/images/hero-nursery.jpg" alt="Sri Lalitamba Nursery — lush rows of plants">
                            <div class="story-float-badge">
                                <div class="num">15+</div>
                                <span class="lbl">Years of Excellence</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6" data-aos="fade-left">
                        <span class="section-label">Who We Are</span>
                        <h2 class="story-heading">A Family Legacy Born From the Love of Nature</h2>
                        <p class="story-body">
                            Sri Lalitamba Nursery &amp; Gardens was founded in 2010 by A V V Satyanarayana in the lush delta
                            region of East Godavari District, Andhra Pradesh. What started as a small plot of flowering
                            plants on the banks of the Godavari has grown into one of the region's most trusted
                            nurseries — spanning over 3 acres of carefully cultivated greenery.
                        </p>
                        <p class="story-body mt-3">
                            Our name "Lalitamba" — a form of the goddess Parvati representing grace, beauty, and
                            abundance — reflects our philosophy: every plant we nurture is a gift of nature, offered
                            with reverence and care.
                        </p>
                        <ul class="check-list mt-4">
                            <li><i class="fas fa-circle-check"></i> Hand-selected premium plant varieties</li>
                            <li><i class="fas fa-circle-check"></i> Organic & eco-friendly growing practices</li>
                            <li><i class="fas fa-circle-check"></i> Expert plant care guidance with every purchase</li>
                            <li><i class="fas fa-circle-check"></i> Doorstep delivery across East Godavari</li>
                            <li><i class="fas fa-circle-check"></i> Wholesale supply to hotels, offices &amp;
                                landscapers</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- ═══ STATS ════════════════════════════════════════════════ -->
        <section class="stats-dark">
            <div class="container">
                <div class="row g-4 text-center align-items-center">
                    <div class="col-6 col-lg-4" data-aos="fade-up" data-aos-delay="0">
                        <div class="stat-box">
                            <div class="num" data-count="25000">25K+</div>
                            <div class="lbl">Orders Delivered</div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-4" data-aos="fade-up" data-aos-delay="100">
                        <div class="stat-box">
                            <div class="num" data-count="18">18</div>
                            <div class="lbl">Plant Categories</div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-4" data-aos="fade-up" data-aos-delay="300">
                        <div class="stat-box">
                            <div class="num" data-count="98">98%</div>
                            <div class="lbl">5-Star Satisfaction</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ═══ VALUES ═══════════════════════════════════════════════ -->
        <section class="values-section">
            <div class="container">
                <div class="text-center mb-5" data-aos="fade-up">
                    <span class="section-label">What We Stand For</span>
                    <h2 class="values-heading" style="font-size:clamp(1.9rem,4vw,2.9rem); font-weight:900;">Our Core
                        Values</h2>
                    <p style="color:#3d5c47; max-width:540px; margin:0 auto; font-size:0.97rem;">
                        Every decision we make is guided by these principles — from how we grow our plants to how we
                        serve our customers.
                    </p>
                </div>
                <div class="row g-4">
                    <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="0">
                        <div class="value-card">
                            <div class="value-icon"><i class="fas fa-heart"></i></div>
                            <h5>Passion for Plants</h5>
                            <p>We are plant people first. Every variety we stock is something we genuinely love and have
                                grown ourselves.</p>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="100">
                        <div class="value-card">
                            <div class="value-icon"><i class="fas fa-recycle"></i></div>
                            <h5>Eco Responsibility</h5>
                            <p>From compost-rich soil to water-efficient drip irrigation, sustainability is not an
                                afterthought — it's our foundation.</p>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="200">
                        <div class="value-card">
                            <div class="value-icon"><i class="fas fa-shield-halved"></i></div>
                            <h5>Quality Assurance</h5>
                            <p>Every plant is inspected before it leaves our nursery. We don't ship unhealthy plants —
                                period.</p>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
                        <div class="value-card">
                            <div class="value-icon"><i class="fas fa-handshake"></i></div>
                            <h5>Community First</h5>
                            <p>We support local farmers, employ local people, and give back through various green-space
                                initiatives.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ═══ TEAM ══════════════════════════════════════════════════ -->
        <section class="team-section">
            <div class="container">
                <div class="text-center mb-5" data-aos="fade-up">
                    <span class="section-label">The People Behind the Plants</span>
                    <h2 style="font-size:clamp(1.9rem,4vw,2.9rem); font-weight:900; color:#0d2b13;">Meet Our Team</h2>
                    <p style="color:#3d5c47; max-width:520px; margin:0 auto; font-size:0.97rem;">
                        A passionate family and a dedicated crew who pour their hearts into every plant they grow.
                    </p>
                </div>
                <div class="row g-4 justify-content-center">
                    <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="0">
                        <div class="team-card">
                            <div class="team-avatar">AVVS</div>
                            <h5>A V V Satyanarayana</h5>
                            <div class="team-role">Founder & Owner</div>
                            <p class="team-bio">With decades of experience in horticulture, A V V Satyanarayana leads
