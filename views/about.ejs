<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Discover the heritage of Sri Lalitamba Nursery & Gardens. From our humble beginnings in 2007 to becoming a botanical landmark in Chemudulanka, explore our journey of green excellence.">
    <title><%= title %></title>

    <!-- External Assets -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        :root {
            --primary-accent: #1b5e2f;
            --primary-glow: rgba(27, 94, 47, 0.15);
            --secondary-accent: #2d8a4e;
            --text-heading: #0a1a0e;
            --font-main: 'Plus Jakarta Sans', sans-serif;
            --font-heading: 'Playfair Display', serif;
            --font-accent: 'Outfit', sans-serif;
        }

        [data-theme="dark"] {
            --text-heading: #f8fcf9;
        }

        body {
            font-family: var(--font-main);
            color: var(--text-body);
            background: var(--background);
            overflow-x: hidden;
            line-height: 1.7;
        }

        /* ── UTILITIES ────────────────────────────────────────── */
        .premium-text-gradient {
            background: linear-gradient(135deg, var(--primary-accent) 0%, var(--secondary-accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
        }

        .section-label {
            font-family: var(--font-accent);
            font-size: 0.85rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.3em;
            color: var(--secondary-accent);
            display: inline-block;
            margin-bottom: 1.2rem;
            padding: 0.5rem 1.2rem;
            background: var(--primary-glow);
            border-radius: 100px;
        }

        /* ── HERO SECTION ─────────────────────────────────────── */
        .about-hero {
            position: relative;
            height: 100vh;
            min-height: 700px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: #051208;
        }

        .hero-video-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.5;
            filter: saturate(1.2);
            transition: transform 0.5s ease-out;
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(5, 18, 8, 0.4) 0%, rgba(5, 18, 8, 0.9) 100%);
            z-index: 1;
        }

        .about-hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            color: #fff;
            max-width: 1000px;
            padding: 0 2rem;
        }

        .about-hero h1 {
            font-family: var(--font-heading);
            font-size: clamp(3.5rem, 10vw, 7rem);
            font-weight: 900;
            line-height: 0.95;
            margin-bottom: 1.5rem;
            text-shadow: 0 10px 40px rgba(0,0,0,0.5);
        }

        .about-hero p {
            font-size: clamp(1.1rem, 2.5vw, 1.4rem);
            font-weight: 400;
            opacity: 0.9;
            max-width: 700px;
            margin: 0 auto 3rem;
            line-height: 1.6;
        }

        /* ── STORY SECTION ────────────────────────────────────── */
        .story-section {
            padding: 12rem 0;
            background: var(--background);
            position: relative;
        }

        .story-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6rem;
            align-items: center;
        }

        .story-visual {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .story-img-main {
            width: 85%;
            height: 600px;
            object-fit: cover;
            border-radius: 40px;
            box-shadow: 0 50px 100px rgba(0,0,0,0.15);
            transition: all 0.5s ease;
        }

        .story-img-sub {
            position: absolute;
            bottom: -40px;
            right: 0;
            width: 280px;
            height: 320px;
            object-fit: cover;
            border-radius: 30px;
            border: 10px solid var(--background);
            box-shadow: 0 30px 60px rgba(0,0,0,0.2);
            transition: all 0.5s ease;
        }

        .story-visual:hover .story-img-main { transform: scale(1.02); }
        .story-visual:hover .story-img-sub { transform: translateY(-20px); }

        .experience-badge {
            position: absolute;
            top: -30px;
            left: 0;
            background: #fff;
            padding: 2rem;
            border-radius: 30px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.1);
            text-align: center;
            z-index: 2;
            border: 1px solid var(--border-light);
        }

        .experience-badge h2 {
            font-size: 3rem;
            font-weight: 900;
            color: var(--primary-accent);
            line-height: 1;
            margin-bottom: 0;
        }

        .experience-badge span {
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--text-muted);
        }

        /* ── STATS SECTION ────────────────────────────────────── */
        .stats-ticker {
            background: #0d2b13;
            padding: 8rem 0;
            color: #fff;
            position: relative;
            overflow: hidden;
            margin: 4rem 0;
            border-radius: 60px;
        }

        .stats-ticker::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='20' height='20' viewBox='0 0 20 20' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='2' cy='2' r='1' fill='rgba(255,255,255,0.05)'/%3E%3C/svg%3E");
        }

        .stat-card {
            text-align: center;
            position: relative;
            z-index: 2;
        }

        .stat-card .num {
            font-family: var(--font-accent);
            font-size: 4.5rem;
            font-weight: 900;
            line-height: 1;
            margin-bottom: 0.5rem;
            background: linear-gradient(to bottom, #fff, rgba(255,255,255,0.5));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .stat-card .label {
            font-size: 0.9rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: #4caf6e;
        }

        /* ── VALUES SECTION ────────────────────────────────────── */
        .values-section {
            padding: 10rem 0;
            background: var(--background-alt);
        }

        .value-card {
            background: var(--surface);
            padding: 4rem 3rem;
            border-radius: 40px;
            height: 100%;
            transition: all 0.4s ease;
            border: 1px solid var(--border);
            position: relative;
            overflow: hidden;
        }

        .value-icon {
            width: 70px;
            height: 70px;
            background: var(--primary-glow);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: var(--primary-accent);
            margin-bottom: 2.5rem;
            transition: all 0.4s ease;
        }

        .value-card:hover {
            transform: translateY(-15px);
            border-color: var(--secondary-accent);
            box-shadow: 0 30px 60px rgba(0,0,0,0.08);
        }

        /* ── TEAM SECTION ─────────────────────────────────────── */
        .team-section {
            padding: 12rem 0;
            background: var(--background);
        }

        .team-card {
            background: var(--surface);
            border-radius: 40px;
            padding: 1.5rem;
            transition: all 0.4s ease;
            height: 100%;
            border: 1px solid var(--border);
            text-align: center;
        }

        .team-img-wrap {
            width: 100%;
            height: 320px;
            border-radius: 30px;
            overflow: hidden;
            margin-bottom: 2rem;
            position: relative;
        }

        .team-img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
        }

        .team-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
            border-color: var(--secondary-accent);
        }

        .team-card:hover .team-img-wrap img {
            transform: scale(1.1);
        }

        .team-role {
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            color: var(--secondary-accent);
            margin-bottom: 0.5rem;
            display: block;
        }

        /* ── GALLERY SECTION ───────────────────────────────────── */
        .gallery-strip {
            padding: 6rem 0;
            background: var(--background);
        }

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
        }

        .gallery-item {
            height: 400px;
            border-radius: 30px;
            overflow: hidden;
            position: relative;
        }

        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.8s ease;
        }

        .gallery-item:hover img { transform: scale(1.15); }

        .gallery-item:nth-child(even) { margin-top: 4rem; }
        .gallery-item:nth-child(odd) { margin-bottom: 4rem; }

        /* ── RESPONSIVE ────────────────────────────────────────── */
        @media (max-width: 991px) {
            .story-grid { grid-template-columns: 1fr; gap: 4rem; }
            .gallery-grid { grid-template-columns: 1fr 1fr; }
            .gallery-item:nth-child(even), .gallery-item:nth-child(odd) { margin: 0; }
            .about-hero h1 { font-size: 4rem; }
            .story-img-main { width: 100%; }
        }
    </style>
</head>

<body>
    <%- include('partials/header') %>

    <main>
        <!-- ── HERO ─────────────────────────────────────────────── -->
        <section class="about-hero">
            <img src="/images/hero-aerial.jpg" alt="Aerial Nursery View" class="hero-video-bg">
            <div class="hero-overlay"></div>
            <div class="about-hero-content" data-aos="fade-up">
                <span class="hero-tag">Nature's Legacy</span>
                <h1>Crafting Green<br>Sanctuaries</h1>
                <p>Welcome to Sri Lalitamba Nursery & Gardens. Since 2007, we've been dedicated to bringing premium quality exotic flora and expert botanical solutions to your doorstep.</p>
                <div class="d-flex gap-4 justify-content-center flex-wrap">
                    <a href="#our-story" class="btn btn-success btn-lg rounded-pill px-5 py-3 fw-bold">
                        Our Story <i class="fas fa-arrow-down ms-2"></i>
                    </a>
                </div>
            </div>
        </section>

        <!-- ── STORY SECTION ────────────────────────────────────── -->
        <section id="our-story" class="story-section">
            <div class="container">
                <div class="story-grid">
                    <div class="story-visual" data-aos="fade-right">
                        <div class="experience-badge">
                            <h2>19+</h2>
                            <span>Years of Excellence</span>
                        </div>
                        <img src="/images/hero-nursery.jpg" alt="Nursery Heritage" class="story-img-main">
                        <img src="/images/hero-flowers.jpg" alt="Exotic Varieties" class="story-img-sub">
                    </div>
                    <div class="story-details" data-aos="fade-left">
                        <span class="section-label">Our Heritage</span>
                        <h2 class="display-3 fw-900 mb-4" style="font-family: var(--font-heading);">A Journey Rooted<br>in Passion</h2>
                        <p class="fs-5 mb-4">Founded in 2007 by A V V Satyanarayana, Sri Lalitamba Nursery & Gardens has grown from a humble local plot into one of Andhra Pradesh's most respected botanical landmarks.</p>
                        <p class="text-muted mb-5">Located in the heart of Chemudulanka, our nursery spans across lush acres dedicated to the sustainable cultivation of over 500 plant varieties. Every sapling we grow is a testament to our commitment to quality and environmental stewardship.</p>
                        
                        <div class="row g-4">
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="why-icon" style="width: 50px; height: 50px; background: var(--primary-glow); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--primary-accent);">
                                        <i class="fas fa-certificate"></i>
                                    </div>
                                    <h6 class="fw-bold mb-0">Premium Quality</h6>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="why-icon" style="width: 50px; height: 50px; background: var(--primary-glow); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--primary-accent);">
                                        <i class="fas fa-leaf"></i>
                                    </div>
                                    <h6 class="fw-bold mb-0">Organic Methods</h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── GALLERY STRIP ────────────────────────────────────── -->
        <section class="gallery-strip">
            <div class="container">
                <div class="gallery-grid">
                    <div class="gallery-item" data-aos="fade-up" data-aos-delay="0">
                        <img src="/images/flower-1.jpg" alt="Exotic Bloom">
                    </div>
                    <div class="gallery-item" data-aos="fade-up" data-aos-delay="100">
                        <img src="/images/path-thu.jpg" alt="Nursery Walkway">
                    </div>
                    <div class="gallery-item" data-aos="fade-up" data-aos-delay="200">
                        <img src="/images/flower-wed.jpg" alt="Wedding Plants">
                    </div>
                    <div class="gallery-item" data-aos="fade-up" data-aos-delay="300">
                        <img src="/images/sunlight.jpg" alt="Golden Hour at Nursery">
                    </div>
                </div>
            </div>
        </section>

        <!-- ── STATS TICKER ────────────────────────────────────── -->
        <section class="container" style="padding: 0 2rem;">
            <div class="stats-ticker" data-aos="zoom-in">
                <div class="row g-5">
                    <div class="col-md-3 col-6">
                        <div class="stat-card">
                            <div class="num">500+</div>
                            <div class="label">Plant Varieties</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="stat-card">
                            <div class="num">15K+</div>
                            <div class="label">Happy Clients</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="stat-card">
                            <div class="num">20+</div>
                            <div class="label">Expert Staff</div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="stat-card">
                            <div class="num">100%</div>
                            <div class="label">Sustainable</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── VALUES SECTION ────────────────────────────────────── -->
        <section class="values-section">
            <div class="container">
                <div class="text-center mb-5">
                    <span class="section-label" data-aos="fade-up">Our Principles</span>
                    <h2 class="display-5 fw-900 mb-5" style="font-family: var(--font-heading);">The Roots of Our Excellence</h2>
                </div>
                <div class="row g-4">
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="0">
                        <div class="value-card">
                            <div class="value-icon"><i class="fas fa-heart"></i></div>
                            <h4 class="fw-bold mb-3">Authentic Passion</h4>
                            <p class="text-muted mb-0">Every plant is raised with genuine love, ensuring it brings the same joy to your home as it did to our farm.</p>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                        <div class="value-card">
                            <div class="value-icon"><i class="fas fa-shield-check"></i></div>
                            <h4 class="fw-bold mb-3">Guaranteed Health</h4>
                            <p class="text-muted mb-0">We only ship the healthiest, most vibrant specimens. Our rigorous quality checks never compromise.</p>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
                        <div class="value-card">
                            <div class="value-icon"><i class="fas fa-earth-asia"></i></div>
                            <h4 class="fw-bold mb-3">Eco-Friendly</h4>
                            <p class="text-muted mb-0">Sustainability is at our core. We use organic methods to ensure a healthy future for the planet.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── TEAM SECTION ─────────────────────────────────────── -->
        <section class="team-section">
            <div class="container text-center mb-5">
                <span class="section-label" data-aos="fade-up">The Experts</span>
                <h2 class="display-5 fw-900 mb-5" style="font-family: var(--font-heading);">Meet Our Green Team</h2>
            </div>
            <div class="container">
                <div class="row g-4">
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="0">
                        <div class="team-card">
                            <div class="team-img-wrap">
                                <img src="/images/hero-sunset.jpg" alt="A V V Satyanarayana">
                            </div>
                            <div class="team-info">
                                <span class="team-role">Founder & Chief</span>
                                <h4 class="fw-bold mb-2">A V V Satyanarayana</h4>
                                <p class="text-muted small">The visionary behind Sri Lalitamba, with 19+ years of horticultural mastery.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                        <div class="team-card">
                            <div class="team-img-wrap">
                                <img src="/images/foggy-trees.jpg" alt="Srinivasrao">
                            </div>
                            <div class="team-info">
                                <span class="team-role">Assistant</span>
                                <h4 class="fw-bold mb-2">Srinivasrao</h4>
                                <p class="text-muted small">Expert in large-scale cultivation and plant maintenance strategies.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                        <div class="team-card">
                            <div class="team-img-wrap">
                                <img src="/images/sunlight.jpg" alt="Suryanarayana">
                            </div>
                            <div class="team-info">
                                <span class="team-role">Worker</span>
                                <h4 class="fw-bold mb-2">Suryanarayana</h4>
                                <p class="text-muted small">Dedicated to the daily care and nurturing of our exotic varieties.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                        <div class="team-card">
                            <div class="team-img-wrap">
                                <img src="/images/admin_bg.png" alt="Venkata Thrinadh">
                            </div>
                            <div class="team-info">
                                <span class="team-role">Technical Support</span>
                                <h4 class="fw-bold mb-2">Venkata Thrinadh</h4>
                                <p class="text-muted small">Driving our digital innovation and technical excellence.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── CTA ─────────────────────────────────────────────── -->
        <section class="py-5" style="background: var(--background);">
            <div class="container">
                <div class="glass-card text-center py-5 px-4" style="background: linear-gradient(135deg, #0d2b13 0%, #1b5e2f 100%); border-radius: 50px; color: #fff; position: relative; overflow: hidden;" data-aos="zoom-in">
                    <div style="position: relative; z-index: 2;">
                        <h2 class="display-4 fw-900 mb-4" style="font-family: var(--font-heading);">Ready to Grow Your Legacy?</h2>
                        <p class="fs-5 opacity-90 mb-5 max-w-600 mx-auto">Visit our farm in Chemudulanka or explore our online gallery today.</p>
                        <div class="d-flex gap-3 justify-content-center flex-wrap">
                            <a href="/gallery" class="btn btn-light btn-lg rounded-pill px-5 py-3 fw-bold">
                                <i class="fas fa-shopping-basket me-2"></i> Shop Plants
                            </a>
                            <a href="/contact" class="btn btn-outline-light btn-lg rounded-pill px-5 py-3 fw-bold">
                                <i class="fas fa-phone me-2"></i> Get in Touch
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        AOS.init({ duration: 1000, once: true, offset: 100 });
    </script>
</body>

</html>
