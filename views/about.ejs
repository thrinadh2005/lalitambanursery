<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Discover the heritage of Sri Lalitamba Nursery & Gardens. From our humble beginnings in 2007 to becoming a botanical landmark in Chemudulanka, explore our journey of green excellence.">
    <title><%= title %></title>

    <!-- External Assets -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        :root {
            /* Professional Green Palette */
            --primary-accent: #155e2f;
            --primary-glow: rgba(21, 94, 47, 0.08);
            --secondary-accent: #10b981;
            --hero-bg: #051208;
            --text-heading: #111827;
            --text-body: #4b5563;
            --text-muted: #6b7280;
            --surface: #ffffff;
            --surface-alt: #f9fafb;
            --border: #e5e7eb;
            --font-main: 'Plus Jakarta Sans', sans-serif;
            --font-heading: 'Playfair Display', serif;
            --font-accent: 'Outfit', sans-serif;
            --shadow-premium: 0 20px 40px -10px rgba(0, 0, 0, 0.05);
            --transition-smooth: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        [data-theme="dark"] {
            --surface: #111827;
            --surface-alt: #1f2937;
            --text-heading: #f9fafb;
            --text-body: #d1d5db;
            --text-muted: #9ca3af;
            --border: #374151;
            --shadow-premium: 0 20px 40px -10px rgba(0, 0, 0, 0.3);
        }

        /* ── CUSTOM SCROLLBAR ────────────────────────────────── */
        ::-webkit-scrollbar { width: 10px; }
        ::-webkit-scrollbar-track { background: var(--surface); }
        ::-webkit-scrollbar-thumb { 
            background: var(--primary-accent); 
            border-radius: 10px; 
            border: 3px solid var(--surface); 
        }

        body {
            font-family: var(--font-main);
            color: var(--text-body);
            background: var(--surface);
            overflow-x: hidden;
            line-height: 1.8;
            -webkit-font-smoothing: antialiased;
        }

        /* ── SCROLL PROGRESS ─────────────────────────────────── */
        #scroll-progress {
            position: fixed;
            top: 0;
            left: 0;
            width: 0%;
            height: 4px;
            background: linear-gradient(to right, var(--primary-accent), var(--secondary-accent));
            z-index: 9999;
            transition: width 0.1s ease-out;
        }

        /* ── UTILITIES ────────────────────────────────────────── */
        .section-label {
            font-family: var(--font-accent);
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.25em;
            color: var(--secondary-accent);
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.5rem;
            padding: 0.6rem 1.25rem;
            background: var(--primary-glow);
            border-radius: 100px;
        }

        .heading-xl {
            font-family: var(--font-heading);
            color: var(--text-heading);
            font-weight: 900;
            line-height: 1.1;
        }

        .text-gradient {
            background: linear-gradient(135deg, var(--primary-accent) 0%, var(--secondary-accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* ── HERO SECTION ─────────────────────────────────────── */
        .about-hero {
            position: relative;
            min-height: 90vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: var(--hero-bg);
            padding: 100px 0;
        }

        .hero-bg-img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.5;
            filter: saturate(1.2) brightness(0.8);
            transform: scale(1.1);
            animation: zoom-out 20s infinite alternate;
        }

        @keyframes zoom-out {
            from { transform: scale(1.1); }
            to { transform: scale(1.2); }
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at center, rgba(0,0,0,0.2) 0%, var(--hero-bg) 80%);
            z-index: 1;
        }

        .about-hero-content {
            position: relative;
            z-index: 2;
            text-align: center;
            color: #fff;
            max-width: 900px;
            padding: 0 1.5rem;
        }

        .about-hero h1 {
            font-size: clamp(3.5rem, 10vw, 6.5rem);
            margin-bottom: 1.5rem;
            text-shadow: 0 10px 40px rgba(0,0,0,0.5);
        }

        .hero-btn {
            background: #fff;
            color: var(--primary-accent);
            padding: 1.2rem 3rem;
            border-radius: 100px;
            font-weight: 800;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 1rem;
            transition: var(--transition-smooth);
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        .hero-btn:hover {
            transform: translateY(-5px);
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
            color: var(--secondary-accent);
        }

        /* ── STORY SECTION ────────────────────────────────────── */
        .story-section {
            padding: 12rem 0;
            background: var(--surface);
        }

        .story-img-wrap {
            position: relative;
            border-radius: 40px;
            overflow: hidden;
            box-shadow: var(--shadow-premium);
        }

        .story-img-wrap img {
            width: 100%;
            transition: transform 0.8s ease;
        }

        .story-img-wrap:hover img { transform: scale(1.05); }

        .floating-badge {
            position: absolute;
            bottom: 30px;
            right: 30px;
            background: #fff;
            padding: 1.5rem;
            border-radius: 25px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            gap: 1rem;
            z-index: 10;
        }

        /* ── STATS SECTION ────────────────────────────────────── */
        .stats-grid {
            padding: 8rem 0;
            background: #0a1f10;
            border-radius: 60px;
            margin-bottom: 12rem;
            box-shadow: 0 60px 100px rgba(0,0,0,0.25);
        }

        .stat-item {
            text-align: center;
            padding: 2.5rem;
            border-radius: 40px;
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.05);
            transition: var(--transition-smooth);
        }

        .stat-item:hover {
            background: rgba(255,255,255,0.06);
            transform: translateY(-15px);
            border-color: var(--secondary-accent);
        }

        .stat-num {
            font-size: 4.5rem;
            font-weight: 900;
            font-family: var(--font-accent);
            color: #fff;
            display: block;
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        .stat-lbl {
            font-size: 0.85rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.25em;
            color: var(--secondary-accent);
        }

        /* ── VALUES SECTION ────────────────────────────────────── */
        .values-section {
            padding: 12rem 0;
            background: var(--surface-alt);
            position: relative;
        }

        .value-card {
            background: var(--surface);
            padding: 4rem 3rem;
            border-radius: 50px;
            border: 1px solid var(--border);
            transition: var(--transition-smooth);
            height: 100%;
        }

        .value-card:hover {
            transform: translateY(-20px);
            box-shadow: var(--shadow-premium);
            border-color: var(--secondary-accent);
        }

        .value-icon-box {
            width: 80px;
            height: 80px;
            background: var(--primary-glow);
            border-radius: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            color: var(--primary-accent);
            margin-bottom: 2.5rem;
        }

        /* ── TEAM SECTION ─────────────────────────────────────── */
        .team-section { padding: 12rem 0; }

        .team-card {
            background: var(--surface);
            padding: 3rem;
            border-radius: 50px;
            text-align: center;
            border: 1px solid var(--border);
            transition: var(--transition-smooth);
            height: 100%;
        }

        .team-card:hover {
            transform: translateY(-15px);
            box-shadow: var(--shadow-premium);
            border-color: var(--secondary-accent);
        }

        .team-initial {
            width: 100px;
            height: 100px;
            background: var(--primary-accent);
            color: #fff;
            font-size: 2.5rem;
            font-weight: 900;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 35px;
            margin: 0 auto 2.5rem;
            font-family: var(--font-heading);
            box-shadow: 0 15px 30px rgba(21, 94, 47, 0.2);
        }

        .team-role {
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: var(--secondary-accent);
            margin-bottom: 0.5rem;
            display: block;
        }

        /* ── GALLERY SECTION ───────────────────────────────────── */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
        }

        .gallery-card {
            position: relative;
            border-radius: 40px;
            overflow: hidden;
            height: 450px;
            box-shadow: var(--shadow-premium);
        }

        .gallery-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .gallery-card:hover img { transform: scale(1.15); }

        .gallery-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 50%);
            opacity: 0;
            transition: var(--transition-smooth);
            display: flex;
            align-items: flex-end;
            padding: 2.5rem;
        }

        .gallery-card:hover .gallery-overlay { opacity: 1; }

        /* ── CTA SECTION ─────────────────────────────────────── */
        .final-cta {
            padding: 100px 0;
        }

        .cta-box {
            background: linear-gradient(135deg, #0d2b13 0%, #155e2f 100%);
            border-radius: 60px;
            padding: 8rem 4rem;
            text-align: center;
            color: #fff;
            position: relative;
            overflow: hidden;
        }

        .cta-box::after {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 500px;
            height: 500px;
            background: rgba(255,255,255,0.03);
            border-radius: 50%;
            z-index: 1;
        }

        /* ── RESPONSIVE ────────────────────────────────────────── */
        @media (max-width: 991px) {
            .story-details { text-align: center; padding-top: 4rem; }
            .section-label { margin-left: auto; margin-right: auto; }
            .cta-box { border-radius: 0; padding: 6rem 1.5rem; }
        }
    </style>
</head>

<body>
    <div id="scroll-progress"></div>

    <%- include('partials/header') %>

    <main>
        <!-- ── HERO ─────────────────────────────────────────────── -->
        <section class="about-hero">
            <img src="/images/hero-aerial.jpg" alt="Aerial Nursery View" class="hero-bg-img">
            <div class="hero-overlay"></div>
            <div class="about-hero-content" data-aos="fade-up" data-aos-duration="1500">
                <span class="section-label" style="background: rgba(255,255,255,0.1); color: #fff; border: 1px solid rgba(255,255,255,0.2);">Est. 2007</span>
                <h1 class="heading-xl">The Essence<br>of Horticulture</h1>
                <p>Welcome to Sri Lalitamba Nursery & Gardens. Discover nearly two decades of commitment to bringing premium quality botanical excellence to your garden.</p>
                <a href="#story" class="hero-btn">
                    Explore Our Legacy <i class="fas fa-chevron-right"></i>
                </a>
            </div>
        </section>

        <!-- ── STORY SECTION ────────────────────────────────────── -->
        <section id="story" class="story-section">
            <div class="container">
                <div class="row align-items-center g-5">
                    <div class="col-lg-6" data-aos="fade-right">
                        <div class="story-img-wrap">
                            <img src="/images/hero-nursery.jpg" alt="Our Legacy Farm">
                            <div class="floating-badge" data-aos="zoom-in" data-aos-delay="500">
                                <div class="badge-icon" style="font-size: 2.5rem; color: var(--secondary-accent);">
                                    <i class="fas fa-seedling"></i>
                                </div>
                                <div>
                                    <h4 class="fw-900 mb-0" id="years-counter">19+</h4>
                                    <span class="text-muted small fw-bold">Years of Trust</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6 story-details" data-aos="fade-left">
                        <span class="section-label">Our Heritage</span>
                        <h2 class="heading-xl mb-4">A Vision Rooted in<br><span class="text-gradient">Integrity & Nature</span></h2>
                        <p class="fs-5 mb-4 text-heading fw-500">Founded in 2007 by A V V Satyanarayana, we've spent the last 19 years mastering the art of cultivation in Chemudulanka.</p>
                        <p class="text-muted mb-5">What began as a small family project has blossomed into one of Andhra Pradesh's most trusted nurseries. We specialize in over 500 varieties of premium plants, each nurtured with 100% organic methods and a deep respect for the environment.</p>
                        
                        <div class="row g-4 pt-3">
                            <div class="col-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="p-3 rounded-circle bg-light text-success shadow-sm">
                                        <i class="fas fa-check-circle"></i>
                                    </div>
                                    <span class="fw-bold text-heading">Verified Quality</span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="p-3 rounded-circle bg-light text-success shadow-sm">
                                        <i class="fas fa-leaf"></i>
                                    </div>
                                    <span class="fw-bold text-heading">Eco-Cultivated</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── STATS SECTION ────────────────────────────────────── -->
        <div class="container">
            <section class="stats-grid" data-aos="zoom-in">
                <div class="row g-4">
                    <div class="col-6 col-lg-3">
                        <div class="stat-item">
                            <span class="stat-num">500+</span>
                            <span class="stat-lbl">Species</span>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="stat-item">
                            <span class="stat-num">15K+</span>
                            <span class="stat-lbl">Clients</span>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="stat-item">
                            <span class="stat-num">20+</span>
                            <span class="stat-lbl">Experts</span>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="stat-item">
                            <span class="stat-num">100%</span>
                            <span class="stat-lbl">Organic</span>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <!-- ── VALUES SECTION ────────────────────────────────────── -->
        <section class="values-section">
            <div class="container">
                <div class="text-center mb-5" data-aos="fade-up">
                    <span class="section-label">Core Values</span>
                    <h2 class="heading-xl">The Pillars of Excellence</h2>
                </div>
                <div class="row g-4">
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="0">
                        <div class="value-card">
                            <div class="value-icon-box"><i class="fas fa-heart"></i></div>
                            <h4>Absolute Passion</h4>
                            <p class="text-muted">We don't just sell plants; we nurture lives. Every sapling reflects our deep-seated love for the green world.</p>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                        <div class="value-card">
                            <div class="value-icon-box"><i class="fas fa-shield-halved"></i></div>
                            <h4>Unfailing Trust</h4>
                            <p class="text-muted">Honesty in pricing and integrity in quality. We build lasting relationships through transparent service.</p>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
                        <div class="value-card">
                            <div class="value-icon-box"><i class="fas fa-earth-leaf"></i></div>
                            <h4>Future Focused</h4>
                            <p class="text-muted">Sustainable practices are not a choice but a responsibility. We protect the earth for generations to come.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── GALLERY SECTION ───────────────────────────────────── -->
        <section class="py-5 mt-5">
            <div class="container">
                <div class="text-center mb-5" data-aos="fade-up">
                    <span class="section-label">Our Sanctuary</span>
                    <h2 class="heading-xl">Nature Captured</h2>
                </div>
                <div class="gallery-grid">
                    <div class="gallery-card" data-aos="fade-up">
                        <img src="/images/flower-1.jpg" alt="Exotic Bloom">
                        <div class="gallery-overlay">
                            <h5 class="text-white fw-bold">Tropical Varieties</h5>
                        </div>
                    </div>
                    <div class="gallery-card" data-aos="fade-up" data-aos-delay="100">
                        <img src="/images/path-thu.jpg" alt="Nursery Path">
                        <div class="gallery-overlay">
                            <h5 class="text-white fw-bold">Serene Walkways</h5>
                        </div>
                    </div>
                    <div class="gallery-card" data-aos="fade-up" data-aos-delay="200">
                        <img src="/images/IMG_20250630_110836.jpg" alt="Plant Collection">
                        <div class="gallery-overlay">
                            <h5 class="text-white fw-bold">Rare Finds</h5>
                        </div>
                    </div>
                    <div class="gallery-card" data-aos="fade-up" data-aos-delay="300">
                        <img src="/images/sunlight.jpg" alt="Golden Hour">
                        <div class="gallery-overlay">
                            <h5 class="text-white fw-bold">Golden Hour Care</h5>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── TEAM SECTION ─────────────────────────────────────── -->
        <section class="team-section bg-light">
            <div class="container">
                <div class="text-center mb-5" data-aos="fade-up">
                    <span class="section-label">The Specialists</span>
                    <h2 class="heading-xl">The Hands Behind the Green</h2>
                </div>
                <div class="row g-4">
                    <div class="col-lg-3 col-md-6" data-aos="fade-up">
                        <div class="team-card">
                            <div class="team-initial">A</div>
                            <span class="team-role">Founder & Chief</span>
                            <h4 class="fw-900 mb-3 text-heading">A V V Satyanarayana</h4>
                            <p class="text-muted small">The visionary behind Sri Lalitamba, with 19+ years of mastery.</p>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                        <div class="team-card">
                            <div class="team-initial" style="background: var(--secondary-accent);">S</div>
                            <span class="team-role">Assistant</span>
                            <h4 class="fw-900 mb-3 text-heading">Srinivasrao</h4>
                            <p class="text-muted small">Expert in large-scale cultivation and maintenance strategies.</p>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                        <div class="team-card">
                            <div class="team-initial" style="background: #fbbf24;">S</div>
                            <span class="team-role">Worker</span>
                            <h4 class="fw-900 mb-3 text-heading">Suryanarayana</h4>
                            <p class="text-muted small">Dedicated to the daily care and nurturing of exotic varieties.</p>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                        <div class="team-card">
                            <div class="team-initial" style="background: #3b82f6;">V</div>
                            <span class="team-role">Technical Support</span>
                            <h4 class="fw-900 mb-3 text-heading">Venkata Thrinadh</h4>
                            <p class="text-muted small">Driving our digital innovation and technical excellence.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── CTA SECTION ─────────────────────────────────────── -->
        <section class="final-cta">
            <div class="container">
                <div class="cta-box" data-aos="zoom-in">
                    <h2 class="display-3 fw-900 mb-4">Start Your Legacy Today</h2>
                    <p class="fs-5 opacity-90 mb-5 max-w-600 mx-auto">Join the Sri Lalitamba family and bring the timeless beauty of nature into your sanctuary.</p>
                    <div class="d-flex gap-3 justify-content-center flex-wrap">
                        <a href="/gallery" class="btn btn-light btn-lg rounded-pill px-5 py-3 fw-bold shadow-lg">Shop Collection</a>
                        <a href="/contact" class="btn btn-outline-light btn-lg rounded-pill px-5 py-3 fw-bold">Visit Our Farm</a>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        // Init AOS
        AOS.init({ duration: 1000, once: true, offset: 100 });

        // Scroll Progress Bar
        window.onscroll = function() {
            let winScroll = document.body.scrollTop || document.documentElement.scrollTop;
            let height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            let scrolled = (winScroll / height) * 100;
            document.getElementById("scroll-progress").style.width = scrolled + "%";
        };

        // Auto-updating Experience Counter
        const startYear = 2007;
        const currentYear = new Date().getFullYear();
        const experience = currentYear - startYear;
        const counterEl = document.getElementById('years-counter');
        if(counterEl) counterEl.innerText = experience + '+';
    </script>
</body>

</html>
