<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Learn about Sri Lalitamba Nursery & Gardens — a family-run nursery in Chemudulanka, Andhra Pradesh, dedicated to bringing premium plants and green beauty to your home since 2010.">
    <title><%= title %></title>

    <!-- CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;800;900&family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization (Prevent FOUC) -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        :root {
            --about-accent: #2d8a4e;
            --about-accent-light: rgba(45, 138, 78, 0.1);
        }

        body {
            font-family: 'Outfit', 'Inter', sans-serif;
            color: var(--text-body);
            background: var(--background);
            overflow-x: hidden;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Playfair Display', serif;
        }

        /* ── HERO ─────────────────────────────────────────────── */
        .about-hero {
            min-height: 85vh;
            background-image:
                linear-gradient(170deg, rgba(5, 18, 8, 0.35) 0%, rgba(5, 18, 8, 0.65) 55%, rgba(5, 18, 8, 0.85) 100%),
                url('/images/hero-aerial.jpg');
            background-size: cover;
            background-position: center 40%;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .about-hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='20' cy='20' r='1' fill='%23ffffff' fill-opacity='0.05'/%3E%3C/svg%3E");
            z-index: 1;
        }

        .about-hero-content {
            position: relative;
            z-index: 2;
            color: #fff;
            padding: 0 1.5rem;
            max-width: 900px;
        }

        .hero-tag {
            display: inline-block;
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.3);
            backdrop-filter: blur(12px);
            color: #fff;
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            padding: 0.6rem 1.8rem;
            border-radius: 100px;
            margin-bottom: 2rem;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        }

        .about-hero h1 {
            font-size: clamp(2.8rem, 8vw, 5.5rem);
            font-weight: 900;
            line-height: 1.05;
            color: #fff;
            text-shadow: 0 4px 30px rgba(0, 0, 0, 0.6);
            margin-bottom: 1.5rem;
            letter-spacing: -0.03em;
        }

        .about-hero p.lead {
            font-size: clamp(1.1rem, 2.5vw, 1.3rem);
            color: rgba(255, 255, 255, 0.95);
            max-width: 650px;
            margin: 0 auto;
            line-height: 1.8;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.4);
        }

        /* ── SECTION LABEL ────────────────────────────────────── */
        .section-label {
            font-size: 0.85rem;
            font-weight: 800;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--about-accent);
            margin-bottom: 1rem;
            display: block;
        }

        /* ── GLASS CARDS ───────────────────────────────────────── */
        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(var(--glass-blur));
            -webkit-backdrop-filter: blur(var(--glass-blur));
            border: 1px solid var(--glass-border);
            border-radius: 28px;
            padding: 3rem;
            box-shadow: var(--glass-shadow);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .glass-card:hover {
            transform: translateY(-8px);
            border-color: var(--about-accent);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        }

        /* ── STORY SECTION ────────────────────────────────────── */
        .story-section {
            padding: 10rem 0;
            background: var(--background);
            position: relative;
        }

        .story-img-wrap {
            position: relative;
            border-radius: 32px;
            overflow: hidden;
            box-shadow: 0 40px 100px rgba(0, 0, 0, 0.12);
        }

        .story-img-wrap img {
            width: 100%;
            height: 600px;
            object-fit: cover;
            transition: transform 1s ease;
        }

        .story-img-wrap:hover img {
            transform: scale(1.05);
        }

        .story-badge {
            position: absolute;
            bottom: 2.5rem;
            left: 2.5rem;
            background: linear-gradient(135deg, #1b5e2f, #2d8a4e);
            color: #fff;
            border-radius: 24px;
            padding: 1.8rem 2.5rem;
            text-align: center;
            box-shadow: 0 15px 45px rgba(27, 94, 47, 0.4);
            z-index: 2;
        }

        .story-badge .num {
            font-family: 'Outfit', sans-serif;
            font-size: 3.5rem;
            font-weight: 800;
            line-height: 1;
        }

        .story-badge .lbl {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.85);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            display: block;
            margin-top: 0.4rem;
        }

        /* ── STATS SECTION ────────────────────────────────────── */
        .stats-banner {
            padding: 8rem 0;
            background: var(--about-accent);
            color: #fff;
            position: relative;
            overflow: hidden;
        }

        .stats-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -10%;
            width: 60%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            transform: rotate(-15deg);
        }

        .stat-item {
            text-align: center;
            position: relative;
            z-index: 2;
        }

        .stat-item .num {
            font-family: 'Outfit', sans-serif;
            font-size: clamp(3rem, 6vw, 5rem);
            font-weight: 800;
            margin-bottom: 0.5rem;
            display: block;
        }

        .stat-item .lbl {
            font-size: 0.9rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            color: rgba(255, 255, 255, 0.8);
        }

        /* ── VALUES SECTION ────────────────────────────────────── */
        .values-section {
            padding: 10rem 0;
            background: var(--background-alt);
        }

        .value-box {
            text-align: center;
            padding: 3rem 2rem;
            height: 100%;
        }

        .value-icon-wrap {
            width: 80px;
            height: 80px;
            background: var(--surface);
            border-radius: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
            font-size: 2rem;
            color: var(--about-accent);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }

        .value-box:hover .value-icon-wrap {
            background: var(--about-accent);
            color: #fff;
            transform: rotate(10deg) scale(1.1);
        }

        /* ── TEAM SECTION ─────────────────────────────────────── */
        .team-section {
            padding: 10rem 0;
            background: var(--background);
        }

        .team-member {
            text-align: center;
            height: 100%;
        }

        .member-avatar {
            width: 120px;
            height: 120px;
            border-radius: 35% 65% 70% 30% / 30% 30% 70% 70%;
            background: linear-gradient(135deg, #1b5e2f, #4caf6e);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            font-weight: 800;
            color: #fff;
            box-shadow: 0 15px 40px rgba(45, 138, 78, 0.3);
            transition: all 0.5s ease;
        }

        .team-member:hover .member-avatar {
            border-radius: 50%;
            transform: scale(1.1) rotate(5deg);
        }

        /* ── WHY US ───────────────────────────────────────────── */
        .why-us-section {
            padding: 10rem 0;
            background: var(--background-alt);
        }

        .why-feature {
            display: flex;
            gap: 2rem;
            margin-bottom: 3rem;
            align-items: flex-start;
        }

        .why-icon {
            width: 60px;
            height: 60px;
            flex-shrink: 0;
            background: var(--about-accent-light);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: var(--about-accent);
        }

        /* ── CTA ─────────────────────────────────────────────── */
        .about-cta {
            background: linear-gradient(135deg, #0d2b13 0%, #1b5e2f 100%);
            padding: 8rem 0;
            text-align: center;
            border-radius: 40px;
            margin: 4rem;
            position: relative;
            overflow: hidden;
            color: #fff;
        }

        .about-cta::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url('/images/hero-bg.jpg');
            background-size: cover;
            background-position: center;
            opacity: 0.15;
            mix-blend-mode: overlay;
        }

        .cta-btn {
            background: #fff;
            color: #0d2b13;
            padding: 1.2rem 3.5rem;
            border-radius: 100px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            display: inline-flex;
            align-items: center;
            gap: 0.8rem;
            transition: all 0.3s ease;
            box-shadow: 0 15px 45px rgba(0, 0, 0, 0.2);
        }

        .cta-btn:hover {
            background: var(--about-accent);
            color: #fff;
            transform: translateY(-5px);
        }

        @media (max-width: 991px) {
            .about-cta { margin: 2rem 1rem; padding: 6rem 1.5rem; }
            .story-img-wrap img { height: 450px; }
        }
    </style>
</head>

<body>
    <%- include('partials/header') %>


        <!-- ═══ CTA ══════════════════════════════════════════════════ -->
        <section class="cta-section">
            <div class="container">
                <div data-aos="fade-up">
                    <h2 class="cta-heading">Ready to Bring Green Home?</h2>
                    <p class="cta-sub">Browse our curated collection of 500+ plants or visit us in Chemudulanka. We'd
                        love to help you find the perfect plant.</p>
                    <div class="d-flex gap-3 justify-content-center flex-wrap">
                        <a href="/gallery" class="btn-cta-white">
                            <i class="fas fa-leaf"></i> Shop Plants
                        </a>
                        <a href="/contact" class="btn-cta-outline">
                            <i class="fas fa-phone"></i> Get in Touch
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <%- include('partials/footer') %>

            <!-- Scripts -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
            <script src="/js/utils.js"></script>
            <script>
                // Init AOS
                AOS.init({ duration: 900, once: true, offset: 80 });

                // Smooth scroll for scroll arrow
                document.querySelector('.scroll-arrow')?.addEventListener('click', function (e) {
                    e.preventDefault();
                    document.querySelector(this.getAttribute('href')).scrollIntoView({ behavior: 'smooth' });
                });

                // Counter animation
                const counters = document.querySelectorAll('.stat-box .num[data-count]');
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            const el = entry.target;
                            const target = parseInt(el.dataset.count);
                            const duration = 1800;
                            const step = Math.ceil(target / (duration / 16));
                            let current = 0;
                            const timer = setInterval(() => {
                                current += step;
                                if (current >= target) {
                                    current = target;
                                    clearInterval(timer);
                                }
                                const suffix = el.textContent.includes('+') || el.textContent.includes('K') ? '+' : '';
                                if (target >= 1000) {
                                    el.textContent = (current / 1000).toFixed(0) + 'K+';
                                } else {
                                    el.textContent = current + suffix;
                                }
                            }, 16);
                            observer.unobserve(el);
                        }
                    });
                }, { threshold: 0.5 });
                counters.forEach(c => observer.observe(c));

                // Navbar active state
                document.querySelectorAll('.nav-link').forEach(link => {
                    if (link.href === window.location.href) link.classList.add('active');
                });
            </script>
</body>

</html>
