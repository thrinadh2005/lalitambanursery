<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Discover the heritage of Sri Lalitamba Nursery & Gardens. From our humble beginnings in 2007 to becoming a botanical landmark in Chemudulanka, explore our journey of green excellence.">
    <title><%= title %></title>

    <!-- External Assets -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ui-fixes.css">

    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>

    <style>
        :root {
            /* ── PREMIER BOTANICAL PALETTE ───────────────────────── */
            --primary-accent: #1b4332;   /* Deep Forest Green */
            --secondary-accent: #2d6a4f; /* Medium Emerald */
            --highlight: #b7e4c7;        /* Soft Mint */
            --accent-gold: #c8860a;      /* Muted Gold */
            
            /* Backgrounds */
            --bg-page: #f8faf9;          /* Very light sage-white */
            --bg-card: #ffffff;
            --bg-dark: #081c15;          /* Deepest Green-Black */
            
            /* Typography */
            --text-main: #1b2621;        /* Forest Charcoal */
            --text-heading: #081c15;
            --text-muted: #52635c;
            
            /* Utilities */
            --shadow-sm: 0 4px 20px rgba(0,0,0,0.03);
            --shadow-lg: 0 30px 60px rgba(0,0,0,0.08);
            --radius-lg: 40px;
            --radius-md: 20px;
        }

        [data-theme="dark"] {
            --bg-page: #050d0a;
            --bg-card: #0c1a14;
            --text-main: #d8e2dc;
            --text-heading: #f8fcf9;
            --text-muted: #8ea59b;
            --border: #1a2e26;
        }

        /* ── GLOBAL DEFAULTS ─────────────────────────────────── */
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-page);
            color: var(--text-main);
            overflow-x: hidden;
            line-height: 1.8;
        }

        h1, h2, h3, h4, .font-heading {
            font-family: 'Playfair Display', serif;
            color: var(--text-heading);
            font-weight: 900;
        }

        /* ── CUSTOM SCROLLBAR ────────────────────────────────── */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--bg-page); }
        ::-webkit-scrollbar-thumb { background: var(--secondary-accent); border-radius: 10px; }

        /* ── HERO SECTION ─────────────────────────────────────── */
        .about-hero {
            position: relative;
            height: 85vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-dark);
            overflow: hidden;
        }

        .hero-img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.5;
            filter: grayscale(20%) contrast(1.1);
        }

        .hero-gradient {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(8,28,21,0.2) 0%, rgba(8,28,21,0.9) 100%);
        }

        .hero-content {
            position: relative;
            z-index: 5;
            text-align: center;
            color: #fff;
            max-width: 900px;
            padding: 2rem;
        }

        .hero-tag {
            font-family: 'Outfit', sans-serif;
            font-size: 0.9rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.3em;
            color: var(--secondary-accent);
            margin-bottom: 1.5rem;
            display: block;
        }

        /* ── STORY SECTION ────────────────────────────────────── */
        .story-section { padding: 120px 0; }

        .story-card {
            background: var(--bg-card);
            border-radius: var(--radius-lg);
            padding: 4rem;
            box-shadow: var(--shadow-lg);
            border: 1px solid rgba(0,0,0,0.02);
        }

        .accent-line {
            width: 60px;
            height: 4px;
            background: var(--accent-gold);
            margin-bottom: 2rem;
        }

        /* ── STATS SECTION ────────────────────────────────────── */
        .stats-wrap {
            background: var(--bg-dark);
            padding: 80px 0;
            border-radius: var(--radius-lg);
            margin: 100px 0;
            color: #fff;
        }

        .stat-box { text-align: center; padding: 2rem; }
        .stat-num { font-size: 4rem; font-weight: 900; color: var(--highlight); font-family: 'Outfit', sans-serif; }
        .stat-lbl { font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2em; opacity: 0.7; }



        /* ── TEAM CARDS ──────────────────────────────────────── */
        .team-section { padding: 120px 0; }
        .team-item {
            background: var(--bg-card);
            padding: 3rem;
            border-radius: var(--radius-md);
            text-align: center;
            border: 1px solid rgba(0,0,0,0.05);
            height: 100%;
        }

        .team-initial {
            width: 70px; height: 70px; background: var(--highlight); color: var(--primary-accent);
            border-radius: 20px; display: flex; align-items: center; justify-content: center;
            font-size: 1.8rem; font-weight: 900; margin: 0 auto 2rem;
        }

        /* ── VALUES SECTION ───────────────────────────────────── */
        .values-section { padding: 120px 0; background: var(--bg-card); }
        .value-card {
            text-align: center;
            padding: 3rem;
            border-radius: var(--radius-md);
            transition: all 0.4s ease;
            background: var(--bg-page);
            height: 100%;
        }
        .value-card:hover { transform: translateY(-10px); box-shadow: var(--shadow-lg); }
        .value-icon { 
            font-size: 3rem; 
            color: var(--secondary-accent); 
            margin-bottom: 1.5rem;
            display: inline-block;
        }

        /* ── SPECIALIZATION ───────────────────────────────────── */
        .spec-section { padding: 120px 0; background: var(--bg-dark); color: #fff; }
        .spec-card {
            position: relative;
            border-radius: var(--radius-md);
            overflow: hidden;
            height: 400px;
            cursor: pointer;
        }
        .spec-card img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
        .spec-card:hover img { transform: scale(1.1); }
        .spec-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 2rem;
        }

        /* ── MISSION & VISION ─────────────────────────────────── */
        .mission-section { padding: 80px 0; background: var(--bg-page); border-top: 1px solid rgba(0,0,0,0.03); }
        .vision-card {
            background: linear-gradient(135deg, var(--bg-card) 0%, #f1f8f4 100%);
            padding: 3rem;
            border-radius: var(--radius-md);
            border: 1px solid rgba(45, 138, 78, 0.1);
            height: 100%;
        }

        /* ── BUSINESS HOURS ──────────────────────────────────── */
        .hours-section { padding: 120px 0; background: var(--bg-page); }
        .hours-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 1.5rem;
            background: var(--bg-card);
            border-radius: 12px;
            margin-bottom: 0.75rem;
            border: 1px solid rgba(0,0,0,0.03);
            transition: transform 0.3s ease;
        }
        .hours-item:hover { transform: translateX(10px); border-color: var(--secondary-accent); }
        .hours-item.today { background: var(--highlight); border-color: var(--secondary-accent); }

        /* ── LOCATION MAP ────────────────────────────────────── */
        .map-section { padding: 120px 0; background: var(--bg-dark); color: #fff; }
        .map-frame {
            width: 100%;
            height: 450px;
            border-radius: var(--radius-lg);
            overflow: hidden;
            border: 5px solid rgba(255,255,255,0.05);
            box-shadow: var(--shadow-lg);
        }

        /* ── RESPONSIVE ────────────────────────────────────────── */
        @media (max-width: 991px) {
            .story-card { padding: 2rem; }
            .cta-premium { border-radius: 0; padding: 4rem 1.5rem; }
            
            .stats-wrap, .team-section, .values-section, .spec-section, .hours-section, .map-section {
                padding: 60px 0;
                margin: 40px 0;
            }
            
            .stat-num { font-size: 3rem; }
            .display-1 { font-size: 3.5rem; }
            .display-4 { font-size: 2.25rem; }
        }

        @media (max-width: 767px) {
            .about-hero { height: 500px; padding-top: 100px; }
            .display-1 { font-size: 2.75rem !important; }
            .display-4 { font-size: 2rem !important; }
            
            .stat-box { padding: 1rem; }
            .stat-num { font-size: 2.5rem; }
            
            .team-item, .value-card, .vision-card { padding: 2rem; }
            
            .spec-card { height: 300px; }
            
            .map-frame { height: 350px; }
            
            .hours-item { padding: 0.75rem 1rem; }
        }
    </style>
</head>

<body>
    <%- include('partials/header') %>

    <main>
        <!-- ── HERO ─────────────────────────────────────────────── -->
        <section class="about-hero">
            <img src="/images/hero-aerial.jpg" alt="Sri Lalitamba Nursery" class="hero-img">
            <div class="hero-gradient"></div>
            <div class="hero-content" data-aos="fade-up">
                <span class="hero-tag">Botanical Excellence</span>
                <h1 class="display-1 text-white mb-4">Nurturing Life<br>Since 2007</h1>
                <p class="fs-5 opacity-90 mb-5">Experience the legacy of Andhra's premier nursery in Chemudulanka. Where passion meets horticulture.</p>
                <a href="#story" class="btn btn-outline-light btn-lg rounded-pill px-5">Explore Our Journey</a>
            </div>
        </section>

        <!-- ── STORY SECTION ────────────────────────────────────── -->
        <section id="story" class="story-section">
            <div class="container">
                <div class="story-card" data-aos="fade-up">
                    <div class="row g-5 align-items-center">
                        <div class="col-lg-6">
                            <img src="/images/hero-nursery.jpg" alt="Our Heritage" class="img-fluid rounded-4 shadow-sm">
                        </div>
                        <div class="col-lg-6">
                            <div class="accent-line"></div>
                            <h2 class="display-4 mb-4">Our Roots in<br>Chemudulanka</h2>
                            <p class="fs-5 text-main mb-4">Founded in 2007 by <strong>A V V Satyanarayana</strong>, Sri Lalitamba Nursery was established with a singular vision: to make rare and exotic flora accessible to every garden enthusiast.</p>
                            <p class="text-muted">Over the last 19 years, we have evolved from a local plot into a sanctuary for over 500 plant varieties. Our commitment remains firm—100% organic methods, unwavering integrity, and the healthiest plants in the region.</p>
                        </div>
                    </div>
                </div>
            </div>
        <!-- ── MISSION & VISION ─────────────────────────────────── -->
        <section class="mission-section">
            <div class="container">
                <div class="row g-4">
                    <div class="col-lg-6" data-aos="fade-right">
                        <div class="vision-card glass" style="border: 1px solid rgba(45, 138, 78, 0.1);">
                            <h3 class="mb-4">Our Mission</h3>
                            <p class="text-muted">To inspire a deeper connection with nature by providing high-quality, sustainably grown plants and expert guidance to every gardener, fostering a greener and healthier planet.</p>
                        </div>
                    </div>
                    <div class="col-lg-6" data-aos="fade-left">
                        <div class="vision-card" style="background: linear-gradient(135deg, var(--bg-dark) 0%, var(--primary-accent) 100%); color: #fff; border: 1px solid rgba(255,255,255,0.05);">
                            <h3 class="mb-4 text-white">Our Vision</h3>
                            <p class="opacity-75 text-white">To be the most trusted botanical sanctuary in Andhra Pradesh, recognized for our commitment to organic mastery, rare species preservation, and horticultural excellence.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── STATS SECTION ────────────────────────────────────── -->
        <div class="container">
            <section class="stats-wrap" data-aos="zoom-in">
                <div class="row">
                    <div class="col-6 col-md-3">
                        <div class="stat-box">
                            <div class="stat-num">500+</div>
                            <div class="stat-lbl">Varieties</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-box">
                            <div class="stat-num">15K+</div>
                            <div class="stat-lbl">Happy Clients</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-box">
                            <div class="stat-num">20+</div>
                            <div class="stat-lbl">Expert Staff</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-box">
                            <div class="stat-num">100%</div>
                            <div class="stat-lbl">Sustainable</div>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <!-- ── VALUES SECTION ───────────────────────────────────── -->
        <section class="values-section">
            <div class="container">
                <div class="text-center mb-5" data-aos="fade-up">
                    <span class="hero-tag">Our Philosophy</span>
                    <h2 class="display-5">Core Values that Drive Us</h2>
                </div>
                <div class="row g-4">
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="0">
                        <div class="value-card">
                            <i class="fas fa-leaf value-icon"></i>
                            <h4 class="mb-3">Premium Quality</h4>
                            <p class="text-muted">Every plant is nurtured with personalized care, ensuring only the healthiest specimens reach your garden.</p>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                        <div class="value-card">
                            <i class="fas fa-hand-holding-heart value-icon"></i>
                            <h4 class="mb-3">Sustainable Growth</h4>
                            <p class="text-muted">We use 100% organic fertilizers and traditional Vedic farming techniques to maintain ecological balance.</p>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
                        <div class="value-card">
                            <i class="fas fa-users value-icon"></i>
                            <h4 class="mb-3">Community First</h4>
                            <p class="text-muted">Beyond selling plants, we aim to build a greener community through education and botanical support.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── SPECIALIZATION SECTION ───────────────────────────── -->
        <section class="spec-section">
            <div class="container">
                <div class="row align-items-center mb-5">
                    <div class="col-lg-6" data-aos="fade-right">
                        <span class="hero-tag" style="color: var(--highlight);">Our Specialization</span>
                        <h2 class="display-4 text-white">Botanical Mastery in Every Category</h2>
                    </div>
                    <div class="col-lg-6" data-aos="fade-left">
                        <p class="opacity-75">From the rarest tropical fruits to the most elegant ornamental flowers, our nursery is a treasure trove for collectors and hobbyists alike.</p>
                    </div>
                </div>
                <div class="row g-4">
                    <div class="col-lg-4" data-aos="zoom-in" data-aos-delay="0">
                        <div class="spec-card">
                            <img src="/images/hero-fruits.png" alt="Tropical Fruits">
                            <div class="spec-overlay">
                                <h3 class="text-white">Tropical Fruits</h3>
                                <p class="text-white-50 small">Mangoes, Guavas, and Rare Exotic Fruits.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="zoom-in" data-aos-delay="100">
                        <div class="spec-card">
                            <img src="/images/hero-flowers.jpg" alt="Exotic Flowers">
                            <div class="spec-overlay">
                                <h3 class="text-white">Exotic Flowers</h3>
                                <p class="text-white-50 small">Adeniums, Orchids, and Seasonal Blooms.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4" data-aos="zoom-in" data-aos-delay="200">
                        <div class="spec-card">
                            <img src="/images/hero-aerial.jpg" alt="Landscaping">
                            <div class="spec-overlay">
                                <h3 class="text-white">Garden Design</h3>
                                <p class="text-white-50 small">Complete landscaping and consultancy services.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>



        <!-- ── TEAM SECTION ─────────────────────────────────────── -->
        <section class="team-section">
            <div class="container">
                <div class="text-center mb-5" data-aos="fade-up">
                    <h2 class="display-5">The Green Team</h2>
                    <p class="text-muted">The Experts Behind the Beauty</p>
                </div>
                <div class="row g-4">
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="0">
                        <div class="team-item">
                            <div class="team-initial">A</div>
                            <h5 class="fw-bold mb-1">A V V Satyanarayana</h5>
                            <small class="text-success fw-bold text-uppercase">Founder & Chief</small>
                            <p class="text-muted small mt-3">The visionary behind Sri Lalitamba, with 19+ years of mastery.</p>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                        <div class="team-item">
                            <div class="team-initial" style="background: #e9edc9;">S</div>
                            <h5 class="fw-bold mb-1">Srinivasrao</h5>
                            <small class="text-success fw-bold text-uppercase">Assistant</small>
                            <p class="text-muted small mt-3">Expert in large-scale cultivation and maintenance strategies.</p>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                        <div class="team-item">
                            <div class="team-initial" style="background: #faedcd;">S</div>
                            <h5 class="fw-bold mb-1">Suryanarayana</h5>
                            <small class="text-success fw-bold text-uppercase">Worker</small>
                            <p class="text-muted small mt-3">Dedicated to the daily care and health of every sapling.</p>
                        </div>
                    </div>
                    <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                        <div class="team-item">
                            <div class="team-initial" style="background: #d8e2dc;">V</div>
                            <h5 class="fw-bold mb-1">Venkata Thrinadh</h5>
                            <small class="text-success fw-bold text-uppercase">Technical Support</small>
                            <p class="text-muted small mt-3">Driving our digital innovation and technical excellence.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── CTA SECTION ─────────────────────────────────────── -->
        <div class="container mb-5 pb-5 mt-5">
            <div class="text-center mb-5" data-aos="fade-up">
                <div class="accent-line mx-auto"></div>
                <h2 class="display-5">Grow With Us</h2>
            </div>
            <section class="cta-premium" data-aos="zoom-in" style="background: linear-gradient(135deg, var(--bg-dark) 0%, var(--primary-accent) 100%); border-radius: var(--radius-lg); padding: 6rem 2rem; position: relative; overflow: hidden; box-shadow: var(--shadow-lg);">
                <div style="position: absolute; inset: 0; opacity: 0.15; background-image: url('https://www.transparenttextures.com/patterns/leaf.png'); pointer-events: none;"></div>
                <div class="position-relative z-1 text-center">
                    <h2 class="display-3 text-white mb-4">Ready to Grow Together?</h2>
                    <p class="fs-5 opacity-90 mb-5 max-w-600 mx-auto text-white">Visit us in Chemudulanka or browse our collection online. Experience the Sri Lalitamba difference.</p>
                    <div class="d-flex gap-3 justify-content-center flex-wrap">
                        <a href="/gallery" class="btn btn-light btn-lg rounded-pill px-5 fw-bold shadow-sm">Shop Collection</a>
                        <a href="/contact" class="btn btn-outline-light btn-lg rounded-pill px-5">Visit Our Farm</a>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <%- include('partials/footer') %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script src="/js/utils.js"></script>
    <script>
        AOS.init({ duration: 1000, once: true, offset: 100 });
    </script>
</body>

</html>
