                    <div class="d-flex align-items-center justify-content-between gap-2">
                        <button class="btn btn-outline-success theme-toggle-btn shadow-none rounded-pill flex-grow-1 py-2" id="themeToggleMobile">
                            <i class="fas fa-moon me-2 theme-icon-dark"></i>
                            <i class="fas fa-sun me-2 theme-icon-light d-none"></i>
                            <span class="small fw-bold">THEME</span>
                        </button>
                        
                        <% if (user) { %>
                            <div class="dropdown flex-grow-1">
                                <button class="btn btn-success rounded-pill w-100 py-2 fw-bold d-flex align-items-center justify-content-center gap-2" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle"></i>
                                    <span>ACCOUNT</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 w-100 mt-2 p-2">
                                    <li><a class="dropdown-item rounded-3 py-2" href="/profile"><i class="fas fa-user-circle me-2"></i>Profile</a></li>
                                    <li><a class="dropdown-item rounded-3 py-2" href="/orders"><i class="fas fa-shopping-bag me-2"></i>Orders</a></li>
                                    <% if (user.role === 'admin') { %>
                                        <li><a class="dropdown-item rounded-3 py-2" href="/admin/dashboard"><i class="fas fa-tachometer-alt me-2"></i>Admin Dashboard</a></li>
                                    <% } %>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item rounded-3 py-2 text-danger" href="/logout"><i class="fas fa-sign-out-alt me-2"></i>Sign Out</a></li>
                                </ul>
                            </div>
                        <% } else { %>
                            <a class="btn btn-success rounded-pill flex-grow-1 py-2 fw-bold text-uppercase" href="/login">
                                <i class="fas fa-sign-in-alt me-2"></i>LOGIN
                            </a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</nav>

<!-- Enhanced Global Message Center -->
<div class="message-container">
    <% if (messages && messages.success_msg && messages.success_msg.length> 0) { %>
        <% if (typeof messages.success_msg==='string' ) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <div class="alert-content">
                    <i class="fas fa-check-circle alert-icon"></i>
                    <div class="alert-text">
                        <strong>Success!</strong>
                        <span>
                            <%= messages.success_msg %>
                        </span>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } else if (Array.isArray(messages.success_msg)) { %>
                <% messages.success_msg.forEach(function(msg) { %>
                    <% if (msg && msg.length> 0) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <div class="alert-content">
                                <i class="fas fa-check-circle alert-icon"></i>
                                <div class="alert-text">
                                    <strong>Success!</strong>
                                    <span>
                                        <%= msg %>
                                    </span>
                                </div>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>
                            <% }); %>
                                <% } %>
                                    <% } %>

                                        <% if (messages && messages.error_msg && messages.error_msg.length> 0) { %>
                                            <% if (typeof messages.error_msg==='string' ) { %>
                                                <div class="alert alert-danger alert-dismissible fade show"
                                                    role="alert">
                                                    <div class="alert-content">
                                                        <i class="fas fa-exclamation-triangle alert-icon"></i>
                                                        <div class="alert-text">
                                                            <strong>Error!</strong>
                                                            <span>
                                                                <%= messages.error_msg %>
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <button type="button" class="btn-close"
                                                        data-bs-dismiss="alert"></button>
                                                </div>
                                                <% } else if (Array.isArray(messages.error_msg)) { %>
                                                    <% messages.error_msg.forEach(function(msg) { %>
                                                        <% if (msg && msg.length> 0) { %>
                                                            <div class="alert alert-danger alert-dismissible fade show"
                                                                role="alert">
                                                                <div class="alert-content">
                                                                    <i
                                                                        class="fas fa-exclamation-triangle alert-icon"></i>
                                                                    <div class="alert-text">
                                                                        <strong>Error!</strong>
                                                                        <span>
                                                                            <%= msg %>
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                                <button type="button" class="btn-close"
                                                                    data-bs-dismiss="alert"></button>
                                                            </div>
                                                            <% } %>
                                                                <% }); %>
                                                                    <% } %>
                                                                        <% } %>
</div>

