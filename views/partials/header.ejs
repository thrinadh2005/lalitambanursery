        <div class="d-flex align-items-center">
            <img src="/images/logo.png" alt="Logo" class="me-2" style="width: 32px; height: 32px; border-radius: 6px;">
            <span class="fw-bold text-primary" id="mobileMenuLabel">SRI LALITAMBA</span>
        </div>
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body p-0">
        <ul class="list-group list-group-flush border-0">
            <a href="/" class="list-group-item list-group-item-action py-3 px-4 border-0 <%= typeof page !== 'undefined' && page === 'home' ? 'bg-primary-light text-primary fw-bold' : '' %>">
                <i class="fas fa-home me-3 opacity-50"></i>HOME
            </a>
            <a href="/gallery" class="list-group-item list-group-item-action py-3 px-4 border-0 <%= typeof page !== 'undefined' && page === 'gallery' ? 'bg-primary-light text-primary fw-bold' : '' %>">
                <i class="fas fa-images me-3 opacity-50"></i>GALLERY
            </a>
            <a href="/contact" class="list-group-item list-group-item-action py-3 px-4 border-0 <%= typeof page !== 'undefined' && page === 'contact' ? 'bg-primary-light text-primary fw-bold' : '' %>">
                <i class="fas fa-envelope me-3 opacity-50"></i>CONTACT
            </a>
            <a href="/about" class="list-group-item list-group-item-action py-3 px-4 border-0 <%= typeof page !== 'undefined' && page === 'about' ? 'bg-primary-light text-primary fw-bold' : '' %>">
                <i class="fas fa-info-circle me-3 opacity-50"></i>ABOUT
            </a>
        </ul>
        
        <div class="p-4 mt-2">
            <div class="d-grid gap-3">
                <button class="btn btn-outline-success theme-toggle-btn w-100 d-flex align-items-center justify-content-center gap-2 py-3" id="themeToggleMobile">
                    <i class="fas fa-moon theme-icon-dark"></i>
                    <i class="fas fa-sun theme-icon-light d-none"></i>
                    <span>Toggle Theme</span>
                </button>
                
                <% if (user) { %>
                    <a href="/profile" class="btn btn-success py-3 fw-bold rounded-3">
                        <i class="fas fa-user-circle me-2"></i>My Profile
                    </a>
                    <a href="/logout" class="btn btn-outline-danger py-3 fw-bold rounded-3">
                        <i class="fas fa-sign-out-alt me-2"></i>Sign Out
                    </a>
                <% } else { %>
                    <a href="/login" class="btn btn-success py-3 fw-bold rounded-3">
                        <i class="fas fa-sign-in-alt me-2"></i>LOGIN
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</div>

<style>
    .offcanvas-body .nav-link.active {
        background-color: #e8f5e9;
        color: #1b5e20 !important;
    }
    .offcanvas-body .nav-link:hover {
        background-color: #f1f8e9;
    }
</style>

<!-- Enhanced Global Message Center -->
<div class="message-container">
    <% if (messages && messages.success_msg && messages.success_msg.length> 0) { %>
        <% if (typeof messages.success_msg==='string' ) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <div class="alert-content">
                    <i class="fas fa-check-circle alert-icon"></i>
                    <div class="alert-text">
                        <strong>Success!</strong>
                        <span>
                            <%= messages.success_msg %>
                        </span>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } else if (Array.isArray(messages.success_msg)) { %>
                <% messages.success_msg.forEach(function(msg) { %>
                    <% if (msg && msg.length> 0) { %>
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <div class="alert-content">
                                <i class="fas fa-check-circle alert-icon"></i>
                                <div class="alert-text">
                                    <strong>Success!</strong>
                                    <span>
                                        <%= msg %>
                                    </span>
                                </div>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>
                            <% }); %>
                                <% } %>
                                    <% } %>

                                        <% if (messages && messages.error_msg && messages.error_msg.length> 0) { %>
                                            <% if (typeof messages.error_msg==='string' ) { %>
                                                <div class="alert alert-danger alert-dismissible fade show"
                                                    role="alert">
                                                    <div class="alert-content">
                                                        <i class="fas fa-exclamation-triangle alert-icon"></i>
                                                        <div class="alert-text">
                                                            <strong>Error!</strong>
                                                            <span>
                                                                <%= messages.error_msg %>
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <button type="button" class="btn-close"
                                                        data-bs-dismiss="alert"></button>
                                                </div>
                                                <% } else if (Array.isArray(messages.error_msg)) { %>
                                                    <% messages.error_msg.forEach(function(msg) { %>
                                                        <% if (msg && msg.length> 0) { %>
                                                            <div class="alert alert-danger alert-dismissible fade show"
                                                                role="alert">
                                                                <div class="alert-content">
                                                                    <i
                                                                        class="fas fa-exclamation-triangle alert-icon"></i>
                                                                    <div class="alert-text">
                                                                        <strong>Error!</strong>
                                                                        <span>
                                                                            <%= msg %>
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                                <button type="button" class="btn-close"
                                                                    data-bs-dismiss="alert"></button>
                                                            </div>
                                                            <% } %>
                                                                <% }); %>
                                                                    <% } %>
                                                                        <% } %>
</div>

