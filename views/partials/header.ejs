    }

    /* Offcanvas Menu Dark Mode Support */
    .offcanvas {
        background-color: var(--surface) !important;
        color: var(--text-main) !important;
    }
    
    .offcanvas-header {
        border-bottom: 1px solid var(--border-light) !important;
    }

    .btn-close {
        filter: invert(var(--icon-invert, 0));
    }

    [data-theme="dark"] {
        --icon-invert: 1;
    }

    /* WhatsApp FAB */
